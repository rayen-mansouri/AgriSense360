{# templates/api/commodity.html.twig #}
{% extends 'layout/base.html.twig' %}

{% block title %}Prix des matières premières - Agrisens 360{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">🌾 Prix des matières premières</h1>
        <p class="page-subtitle">Suivi des cours internationaux (Source: Banque Mondiale)</p>
    </div>
</div>

<div class="card">
    <div class="form-card-header">
        <div class="form-card-icon" style="background:#ff9800;color:white">
            <i class="fa-solid fa-chart-line"></i>
        </div>
        <div>
            <h2 class="form-card-title">Cotations en temps réel</h2>
        </div>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; padding: 20px;">
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-wheat-awn" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Blé (WHEAT)</h3>
            <div id="wheat-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="wheat-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-corn" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Maïs (CORN)</h3>
            <div id="corn-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="corn-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-seedling" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Soja (SOYBEAN)</h3>
            <div id="soybean-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="soybean-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-cube" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Sucre (SUGAR)</h3>
            <div id="sugar-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="sugar-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-mug-hot" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Café (COFFEE)</h3>
            <div id="coffee-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="coffee-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
        <div class="commodity-card" style="background: #f5f5f5; border-radius: 12px; padding: 15px; text-align: center;">
            <i class="fa-solid fa-oil-can" style="font-size: 32px; color: #ff9800;"></i>
            <h3>Pétrole (OIL)</h3>
            <div id="oil-price" class="price" style="font-size: 24px; font-weight: bold; color: #5a9814;">Chargement...</div>
            <div id="oil-year" style="font-size: 12px; color: #666;"></div>
        </div>
        
    </div>
    
    <div style="text-align: center; padding: 20px; border-top: 1px solid #eee;">
        <p class="text-muted">* Prix en USD, source: Banque Mondiale (données annuelles)</p>
        <button onclick="refreshPrices()" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-refresh"></i> Actualiser
        </button>
    </div>
</div>

<script>
function refreshPrices() {
    const commodities = ['WHEAT', 'CORN', 'SOYBEAN', 'SUGAR', 'COFFEE', 'OIL'];
    
    commodities.forEach(commodity => {
        fetch(`/api/commodity/price?commodity=${commodity}`)
            .then(res => res.json())
            .then(data => {
                if (data.price) {
                    document.getElementById(`${commodity.toLowerCase()}-price`).innerHTML = `${data.price} $`;
                    document.getElementById(`${commodity.toLowerCase()}-year`).innerHTML = `Données: ${data.year}`;
                } else {
                    document.getElementById(`${commodity.toLowerCase()}-price`).innerHTML = 'Non disponible';
                }
            })
            .catch(() => {
                document.getElementById(`${commodity.toLowerCase()}-price`).innerHTML = 'Erreur';
            });
    });
}

refreshPrices();
</script>
{% endblock %}