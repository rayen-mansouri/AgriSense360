{# templates/api/exchange.html.twig #}
{% extends 'layout/base.html.twig' %}

{% block title %}Taux de Change - Agrisens 360{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">💱 Taux de Change</h1>
        <p class="page-subtitle">Conversion des prix en devises étrangères</p>
    </div>
</div>

<div class="card">
    <div class="form-card-header">
        <div class="form-card-icon" style="background:#2196f3;color:white">
            <i class="fa-solid fa-money-bill-wave"></i>
        </div>
        <div>
            <h2 class="form-card-title">Convertisseur de devises</h2>
        </div>
    </div>
    
    <div style="padding: 20px;">
        <div style="display: flex; gap: 20px; flex-wrap: wrap; align-items: flex-end;">
            <div>
                <label>Montant (TND)</label>
                <input type="number" id="amount" class="form-control" value="100" step="10" style="width: 150px;">
            </div>
            <div>
                <label>Devise cible</label>
                <select id="currency" class="form-control" style="width: 120px;">
                    <option value="EUR">EUR</option>
                    <option value="USD">USD</option>
                    <option value="GBP">GBP</option>
                    <option value="CAD">CAD</option>
                    <option value="JPY">JPY</option>
                </select>
            </div>
            <div>
                <button id="convertBtn" class="btn btn-primary">Convertir</button>
            </div>
        </div>
        
        <div id="result" style="margin-top: 30px; padding: 20px; background: #e8f5e9; border-radius: 12px; text-align: center;">
            <h2 id="convertedAmount">-</h2>
            <p id="rateInfo"></p>
        </div>
        
        <div style="margin-top: 30px;">
            <h3>📊 Taux du jour</h3>
            <div id="ratesList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; margin-top: 15px;"></div>
        </div>
    </div>
</div>

<script>
fetch('/api/exchange/rates')
    .then(res => res.json())
    .then(data => {
        let html = '';
        for (const [currency, rate] of Object.entries(data.rates)) {
            if (['EUR', 'USD', 'GBP', 'CAD', 'JPY'].includes(currency)) {
                html += `<div style="background: #f5f5f5; padding: 10px; border-radius: 8px; text-align: center;">
                            <strong>${currency}</strong><br>1 TND = ${rate.toFixed(4)} ${currency}
                         </div>`;
            }
        }
        document.getElementById('ratesList').innerHTML = html;
        document.getElementById('rateInfo').innerHTML = `Taux mis à jour le ${data.date}`;
    });

document.getElementById('convertBtn').addEventListener('click', function() {
    const amount = document.getElementById('amount').value;
    const currency = document.getElementById('currency').value;
    
    fetch(`/api/exchange/convert?amount=${amount}&currency=${currency}`)
        .then(res => res.json())
        .then(data => {
            document.getElementById('convertedAmount').innerHTML = `${data.converted} ${currency}`;
        });
});
</script>
{% endblock %}