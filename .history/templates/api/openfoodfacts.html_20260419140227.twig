{# templates/api/openfoodfacts.html.twig #}
{% extends 'layout/base.html.twig' %}

{% block title %}OpenFoodFacts - Scanner produit{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">📷 Scanner produit (OpenFoodFacts)</h1>
        <p class="page-subtitle">Scannez un code-barres pour obtenir les informations produit</p>
    </div>
</div>

<div class="card">
    <div class="form-card-header">
        <div class="form-card-icon" style="background:#4caf50;color:white">
            <i class="fa-solid fa-camera"></i>
        </div>
        <div>
            <h2 class="form-card-title">Scanner un code-barres</h2>
        </div>
    </div>
    
    <div style="text-align: center; padding: 20px;">
        <div id="scanner-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
            <video id="scanner-video" style="width: 100%; border-radius: 12px;"></video>
        </div>
        
        <div style="margin-top: 20px;">
            <button id="start-scanner" class="btn btn-primary"><i class="fa-solid fa-play"></i> Démarrer</button>
            <button id="stop-scanner" class="btn btn-secondary" style="display:none;"><i class="fa-solid fa-stop"></i> Arrêter</button>
        </div>
        
        <div id="scan-result" style="margin-top: 20px; display: none;">
            <div class="card" style="background: #f5f5f5;">
                <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                    <img id="product-image" src="" style="max-width: 150px; border-radius: 8px;">
                    <div>
                        <h3 id="product-name"></h3>
                        <p id="product-category"></p>
                        <p id="product-brand"></p>
                        <p id="product-desc"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/quagga@0.12.1/dist/quagga.min.js"></script>
<script>
const startBtn = document.getElementById('start-scanner');
const stopBtn = document.getElementById('stop-scanner');
const scanResult = document.getElementById('scan-result');

startBtn.addEventListener('click', function() {
    Quagga.init({
        inputStream: { name: "Live", type: "LiveStream", target: document.querySelector('#scanner-container'), constraints: { width: 640, height: 480, facingMode: "environment" } },
        decoder: { readers: ["code_128_reader", "ean_reader"] }
    }, function(err) {
        if (err) { alert("Erreur caméra"); return; }
        Quagga.start();
        startBtn.style.display = 'none';
        stopBtn.style.display = 'inline-block';
    });
    
    Quagga.onDetected(function(data) {
        var code = data.codeResult.code;
        fetch('/api/openfoodfacts/' + code)
            .then(res => res.json())
            .then(product => {
                scanResult.style.display = 'block';
                document.getElementById('product-name').innerText = product.nom || 'Nom non trouvé';
                document.getElementById('product-category').innerHTML = '<strong>Catégorie:</strong> ' + (product.categorie || '-');
                document.getElementById('product-brand').innerHTML = '<strong>Marque:</strong> ' + (product.marque || '-');
                document.getElementById('product-desc').innerHTML = '<strong>Description:</strong> ' + (product.description || '-');
                if (product.image_url) {
                    document.getElementById('product-image').src = product.image_url;
                }
            });
    });
});

stopBtn.addEventListener('click', function() {
    Quagga.stop();
    startBtn.style.display = 'inline-block';
    stopBtn.style.display = 'none';
});
</script>
{% endblock %}