{% extends 'layout/front_base.html.twig' %}

{% block title %}Ajouter un produit - Agrisens 360{% endblock %}

{% block content %}
<div class="front-produit-container">
    <div class="front-produit-header">
        <h1><i class="fa-solid fa-leaf"></i> Nouveau produit agricole</h1>
        <p>Ajoutez un produit à votre catalogue</p>
    </div>

    {{ form_start(form, {'attr': {'class': 'front-produit-form', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}

    <!-- Section produit -->
    <div class="form-section">
        <div class="section-title">
            <i class="fa-solid fa-box"></i>
            <h2>Informations produit</h2>
        </div>

        <div class="form-group">
            {{ form_label(form.categorie, 'Catégorie *') }}
            {{ form_widget(form.categorie, {'attr': {'class': 'form-control', 'id': 'categorie'}}) }}
            <div class="error-msg" id="error-categorie"></div>
        </div>

        <div class="form-group">
            {{ form_label(form.nom, 'Nom du produit *') }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'id': 'nom'}}) }}
            <div class="error-msg" id="error-nom"></div>
        </div>

        <div class="form-group">
            {{ form_label(form.description, 'Description') }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'id': 'description', 'rows': 4}}) }}
            <div class="error-msg" id="error-description"></div>
        </div>

        <div class="form-row">
            <div class="form-col">
                <div class="form-group">
                    {{ form_label(form.prixUnitaire, 'Prix unitaire (DT) *') }}
                    {{ form_widget(form.prixUnitaire, {'attr': {'class': 'form-control', 'id': 'prix', 'step': '0.01', 'min': '0.01'}}) }}
                    <div class="error-msg" id="error-prix"></div>
                </div>
            </div>

            <div class="form-col">
                <div class="form-group">
                    {{ form_label(form.photoFile, 'Photo du produit *') }}
                    <div class="upload-area" id="uploadArea">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <p>Cliquez pour choisir une image</p>
                        <span class="upload-hint">JPG, PNG, WebP (max 5MB)</span>
                        {{ form_widget(form.photoFile, {'attr': {'class': 'file-input', 'id': 'photo_input', 'accept': 'image/*'}}) }}
                    </div>
                    <div id="image_preview" class="image-preview" style="display:none;">
                        <img id="preview_img" src="" alt="Aperçu">
                        <button type="button" class="remove-image" onclick="removeImage()">🗑️ Supprimer</button>
                    </div>
                    <div class="error-msg" id="error-photo"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Section stock -->
    <div class="form-section">
        <div class="section-title">
            <i class="fa-solid fa-warehouse"></i>
            <h2>Stock initial</h2>
            <span class="badge-info">Optionnel</span>
        </div>

        <div class="form-row">
            <div class="form-col">
                <div class="form-group">
                    <label>Quantité initiale</label>
                    <input type="number" name="stock_quantite" class="form-control" id="stock_quantite" step="0.01" min="0" value="0">
                    <div class="error-msg" id="error-stock"></div>
                </div>
            </div>
            <div class="form-col">
                <div class="form-group">
                    <label>Unité de mesure</label>
                    <select name="stock_unite" class="form-control" id="stock_unite">
                        <option value="">Sélectionner...</option>
                        <option>kg</option>
                        <option>g</option>
                        <option>L</option>
                        <option>mL</option>
                        <option>unité</option>
                        <option>sac</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="info-box">
            <i class="fa-solid fa-info-circle"></i>
            <span>Vous pourrez gérer le stock plus tard dans l'espace d'administration.</span>
            <a href="{{ path('admin') }}">Aller au backoffice →</a>
        </div>
    </div>

    <!-- Boutons -->
    <div class="form-actions">
        <a href="{{ path('catalogue') }}" class="btn-secondary">Annuler</a>
        <button type="submit" class="btn-primary">Publier le produit</button>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ====================== UPLOAD IMAGE ======================
const uploadArea = document.getElementById('uploadArea');
const photoInput = document.getElementById('photo_input');
const imagePreview = document.getElementById('image_preview');
const previewImg = document.getElementById('preview_img');

// Clic sur la zone d'upload
if (uploadArea) {
    uploadArea.addEventListener('click', function(e) {
        e.preventDefault();
        if (photoInput) {
            photoInput.click();
        }
    });
}

// Changement de fichier
if (photoInput) {
    photoInput.addEventListener('change', function() {
        if (this.files && this.files[0]) {
            const file = this.files[0];
            if (file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    uploadArea.style.display = 'none';
                    imagePreview.style.display = 'flex';
                    clearError('photo');
                };
                reader.readAsDataURL(file);
            } else {
                showError('photo', 'Veuillez sélectionner une image');
            }
        }
    });
}

// Supprimer l'image
window.removeImage = function() {
    if (photoInput) photoInput.value = '';
    uploadArea.style.display = 'flex';
    imagePreview.style.display = 'none';
    showError('photo', 'La photo est obligatoire');
};

// ====================== VALIDATION ======================
function showError(fieldId, message) {
    const errorDiv = document.getElementById('error-' + fieldId);
    if (errorDiv) {
        errorDiv.innerHTML = message;
        errorDiv.style.display = 'block';
    }
    const input = document.getElementById(fieldId);
    if (input) {
        input.classList.add('error');
    }
}

function clearError(fieldId) {
    const errorDiv = document.getElementById('error-' + fieldId);
    if (errorDiv) {
        errorDiv.innerHTML = '';
        errorDiv.style.display = 'none';
    }
    const input = document.getElementById(fieldId);
    if (input) {
        input.classList.remove('error');
    }
}

function validateForm() {
    let isValid = true;
    
    // Catégorie
    const categorie = document.getElementById('categorie');
    if (!categorie.value) {
        showError('categorie', 'Veuillez sélectionner une catégorie');
        isValid = false;
    } else {
        clearError('categorie');
    }
    
    // Nom
    const nom = document.getElementById('nom');
    if (!nom.value.trim()) {
        showError('nom', 'Le nom est obligatoire');
        isValid = false;
    } else if (nom.value.trim().length < 3) {
        showError('nom', 'Minimum 3 caractères');
        isValid = false;
    } else {
        clearError('nom');
    }
    
    // Prix
    const prix = document.getElementById('prix');
    const prixVal = parseFloat(prix.value);
    if (!prix.value) {
        showError('prix', 'Le prix est obligatoire');
        isValid = false;
    } else if (prixVal <= 0) {
        showError('prix', 'Le prix doit être > 0');
        isValid = false;
    } else {
        clearError('prix');
    }
    
    // Photo
    const hasFile = photoInput && photoInput.files && photoInput.files.length > 0;
    const hasPreview = imagePreview.style.display === 'flex';
    if (!hasFile && !hasPreview) {
        showError('photo', 'La photo est obligatoire');
        isValid = false;
    } else {
        clearError('photo');
    }
    
    return isValid;
}

// Soumission
const form = document.querySelector('.front-produit-form');
form.addEventListener('submit', function(e) {
    if (!validateForm()) {
        e.preventDefault();
        const firstError = document.querySelector('.error');
        if (firstError) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
});

// Validation temps réel
document.getElementById('nom')?.addEventListener('input', function() {
    if (this.value.trim().length >= 3) clearError('nom');
});
document.getElementById('prix')?.addEventListener('input', function() {
    if (parseFloat(this.value) > 0) clearError('prix');
});
</script>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.front-produit-container {
    max-width: 800px;
    margin: 40px auto;
    padding: 0 20px;
}

.front-produit-header {
    background: linear-gradient(135deg, #5a9814 0%, #3a6b0a 100%);
    border-radius: 20px 20px 0 0;
    padding: 30px;
    color: white;
    text-align: center;
}

.front-produit-header h1 {
    font-size: 28px;
    margin-bottom: 8px;
}

.front-produit-form {
    background: white;
    border-radius: 0 0 20px 20px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.form-section {
    margin-bottom: 30px;
}

.section-title {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 2px solid #e8f5e9;
}

.section-title i {
    font-size: 24px;
    color: #5a9814;
}

.section-title h2 {
    font-size: 20px;
    margin: 0;
}

.badge-info {
    background: #e8f5e9;
    color: #5a9814;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
    color: #333;
}

.form-control {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 12px;
    font-size: 14px;
    transition: all 0.2s;
}

.form-control:focus {
    outline: none;
    border-color: #5a9814;
    box-shadow: 0 0 0 3px rgba(90,152,20,0.1);
}

.form-control.error {
    border-color: #dc3545;
    background: #fff8f8;
}

.form-hint {
    font-size: 11px;
    color: #999;
    margin-top: 6px;
    display: block;
}

.error-msg {
    color: #dc3545;
    font-size: 12px;
    margin-top: 6px;
    display: none;
}

.error-msg:not(:empty) {
    display: block;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

/* Upload */
.upload-area {
    border: 2px dashed #ddd;
    border-radius: 16px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: #fafafa;
}

.upload-area:hover {
    border-color: #5a9814;
    background: #f8fff4;
}

.upload-area i {
    font-size: 40px;
    color: #9aaa8a;
    margin-bottom: 12px;
}

.file-input {
    display: none;
}

.image-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
}

.image-preview img {
    max-width: 200px;
    border-radius: 12px;
}

.remove-image {
    background: #fee;
    border: none;
    color: #dc3545;
    padding: 6px 16px;
    border-radius: 20px;
    cursor: pointer;
}

.info-box {
    background: #e3f2fd;
    border-radius: 12px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 20px;
}

.info-box a {
    color: #2196f3;
    text-decoration: none;
    margin-left: auto;
}

.form-actions {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid #eee;
}

.btn-primary, .btn-secondary {
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
}

.btn-primary {
    background: #5a9814;
    color: white;
}

.btn-primary:hover {
    background: #4a7a10;
    transform: translateY(-2px);
}

.btn-secondary {
    background: #f0f2f5;
    color: #4a5568;
}

@media (max-width: 640px) {
    .form-row {
        grid-template-columns: 1fr;
    }
    .form-actions {
        flex-direction: column;
    }
    .btn-primary, .btn-secondary {
        text-align: center;
        justify-content: center;
    }
}
</style>
{% endblock %}