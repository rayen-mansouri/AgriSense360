{# templates/front/produit/show.html.twig #}
{% extends 'layout/front_base.html.twig' %}
{% block title %}{{ produit.nom }} — Agrisens 360{% endblock %}

{% block content %}
<div style="max-width: 900px; margin: 0 auto; padding: 20px;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <a href="{{ path('front_catalogue') }}" style="padding: 8px 16px; background: #f0f2f5; border-radius: 8px; text-decoration: none; color: #333;">← Catalogue</a>
        <div style="display: flex; gap: 10px;">
            <a href="{{ path('front_produit_edit', {id: produit.id}) }}" style="padding: 8px 16px; background: #e3f2fd; color: #2196f3; border-radius: 8px; text-decoration: none; font-weight: 600;">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
            {% if stock %}
            <a href="{{ path('front_stock_edit', {id: stock.id}) }}" style="padding: 8px 16px; background: #e8f5e9; color: #5a9814; border-radius: 8px; text-decoration: none; font-weight: 600;">
                <i class="fa-solid fa-warehouse"></i> Modifier le stock
            </a>
            {% else %}
            <a href="{{ path('front_stock_new', {id: produit.id}) }}" style="padding: 8px 16px; background: #5a9814; color: white; border-radius: 8px; text-decoration: none; font-weight: 600;">
                <i class="fa-solid fa-plus"></i> Ajouter un stock
            </a>
            {% endif %}
        </div>
    </div>

    {% for message in app.flashes('success') %}
    <div style="background: #dcfce7; color: #16a34a; padding: 14px 20px; border-radius: 10px; margin-bottom: 20px; border-left: 4px solid #16a34a; font-weight: 600;">
        {{ message }}
    </div>
    {% endfor %}

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

        {# Image #}
        <div style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
            {% if produit.photoUrl %}
            <img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}" style="width: 100%; height: 300px; object-fit: cover;">
            {% else %}
            <div style="width: 100%; height: 300px; background: #e8f5e9; display: flex; align-items: center; justify-content: center; font-size: 80px; color: #5a9814;">
                <i class="fa-solid fa-seedling"></i>
            </div>
            {% endif %}
        </div>

        {# Infos produit #}
        <div style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
            <span style="background: #e8f5e9; color: #5a9814; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">{{ produit.categorie }}</span>
            <h1 style="font-size: 24px; margin: 12px 0 8px;">{{ produit.nom }}</h1>
            {% if produit.description %}
            <p style="color: #666; font-size: 14px; line-height: 1.6; margin-bottom: 16px;">{{ produit.description }}</p>
            {% endif %}
            <div style="font-size: 28px; font-weight: 700; color: #5a9814; margin-bottom: 20px;">{{ produit.prixUnitaire }} DT <span style="font-size: 14px; font-weight: normal; color: #999;">/ unité</span></div>
            {% if produit.barcodeUrl %}
                <div style="text-align: center; margin-bottom: 15px;">
                    <img src="{{ produit.barcodeUrl }}" alt="Code-barres" style="background: white; padding: 10px; border-radius: 8px; max-width: 200px;">
                    <div style="font-size: 11px; color: #999; margin-top: 5px;">SKU: {{ produit.sku }}</div>
                </div>
                {% else %}
                <p style="color: #999; text-align: center;">Aucun code-barres généré</p>
                {% endif %}

            {# Stock info #}
            <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
                <div style="font-weight: 600; margin-bottom: 10px; font-size: 14px; color: #333;">📦 Informations de stock</div>
                {% if stock %}
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; font-size: 13px;">
                    <div>
                        <span style="color: #999;">Quantité :</span>
                        <strong style="display: block; font-size: 18px; color: #333;">{{ stock.quantiteActuelle }} {{ stock.uniteMesure }}</strong>
                    </div>
                    <div>
                        <span style="color: #999;">Seuil d'alerte :</span>
                        <strong style="display: block; font-size: 18px; color: #333;">{{ stock.seuilAlerte ?: '—' }}</strong>
                    </div>
                    {% if stock.emplacement %}
                    <div>
                        <span style="color: #999;">Emplacement :</span>
                        <strong style="display: block;">{{ stock.emplacement }}</strong>
                    </div>
                    {% endif %}
                    {% if stock.dateExpiration %}
                    <div>
                        <span style="color: #999;">Expiration :</span>
                        <strong style="display: block; color: #f44336;">{{ stock.dateExpiration|date('d/m/Y') }}</strong>
                    </div>
                    {% endif %}
                </div>
                <div style="margin-top: 12px;">
                    {% if stock.quantiteActuelle == 0 %}
                        <span style="background: #fee2e2; color: #dc2626; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;">🔴 Rupture de stock</span>
                    {% elseif stock.isEnAlerte %}
                        <span style="background: #fff3cd; color: #d97706; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;">⚠️ Stock limité</span>
                    {% else %}
                        <span style="background: #dcfce7; color: #16a34a; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 600;">✅ En stock</span>
                    {% endif %}
                </div>
                {% else %}
                <div style="text-align: center; padding: 20px; color: #999;">
                    <i class="fa-solid fa-box-open" style="font-size: 32px; margin-bottom: 8px; display: block;"></i>
                    <p style="margin: 0 0 12px;">Aucun stock enregistré</p>
                    <a href="{{ path('front_stock_new', {id: produit.id}) }}" style="padding: 8px 20px; background: #5a9814; color: white; border-radius: 20px; text-decoration: none; font-size: 13px; font-weight: 600;">
                        <i class="fa-solid fa-plus"></i> Ajouter un stock
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}