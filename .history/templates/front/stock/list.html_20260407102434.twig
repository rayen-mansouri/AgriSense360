{# templates/front/stock/list.html.twig #}
{% extends 'layout/front_base.html.twig' %}
{% block title %}Mes Stocks — Agrisens 360{% endblock %}

{% block content %}
<div style="max-width: 1100px; margin: 0 auto; padding: 20px;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
        <div>
            <h1 style="font-size:24px; margin:0;">📊 Gestion des Stocks</h1>
            <p style="color:#666; margin:5px 0 0;">{{ stocks|length }} référence(s) en stock</p>
        </div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a href="{{ path('front_catalogue') }}" style="padding:8px 16px; background:#f0f2f5; border-radius:8px; text-decoration:none; color:#333;">
                ← Catalogue
            </a>
            {% if produitsSansStock is not empty %}
            <button type="button" onclick="ouvrirModalChoixProduit()"
                style="padding:8px 16px; background:#5a9814; color:white; border:none; border-radius:8px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:8px;">
                <i class="fa-solid fa-plus"></i> Ajouter un stock
            </button>
            {% else %}
            <button type="button" disabled
                style="padding:8px 16px; background:#d1d5db; color:#9ca3af; border:none; border-radius:8px; font-weight:600; cursor:not-allowed; display:flex; align-items:center; gap:8px;"
                title="Tous les produits ont déjà un stock">
                <i class="fa-solid fa-check"></i> Tous les produits ont un stock
            </button>
            {% endif %}
        </div>
    </div>

    {% for message in app.flashes('success') %}
    <div style="background:#dcfce7;color:#16a34a;padding:14px 20px;border-radius:10px;margin-bottom:20px;border-left:4px solid #16a34a;font-weight:600;">
        {{ message }}
    </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div style="background:#fee2e2;color:#dc2626;padding:14px 20px;border-radius:10px;margin-bottom:20px;border-left:4px solid #dc2626;font-weight:600;">
        {{ message }}
    </div>
    {% endfor %}

    {% if stocks is empty %}
    <div style="text-align:center; padding:60px; background:white; border-radius:16px; box-shadow:0 2px 8px rgba(0,0,0,0.05);">
        <i class="fa-solid fa-warehouse" style="font-size:48px; color:#ccc; margin-bottom:16px; display:block;"></i>
        <p style="color:#666; font-size:16px;">Aucun stock enregistré.</p>
        {% if produitsSansStock is not empty %}
        <button type="button" onclick="ouvrirModalChoixProduit()"
            style="padding:10px 24px; background:#5a9814; color:white; border:none; border-radius:30px; font-weight:600; cursor:pointer; margin-top:16px;">
            <i class="fa-solid fa-plus"></i> Ajouter un stock
        </button>
        {% endif %}
    </div>
    {% else %}

    {# Résumé #}
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px;">
        {% set enAlerte = stocks|filter(s => s.isEnAlerte and s.quantiteActuelle > 0)|length %}
        {% set enRupture = stocks|filter(s => s.quantiteActuelle == 0)|length %}
        {% set ok = stocks|length - enAlerte - enRupture %}
        <div style="background:white; border-radius:12px; padding:20px; box-shadow:0 2px 8px rgba(0,0,0,0.05); border-left:4px solid #4caf50; text-align:center;">
            <div style="font-size:28px; font-weight:700; color:#4caf50;">{{ ok }}</div>
            <div style="color:#666; font-size:13px; margin-top:4px;">En stock</div>
        </div>
        <div style="background:white; border-radius:12px; padding:20px; box-shadow:0 2px 8px rgba(0,0,0,0.05); border-left:4px solid #ff9800; text-align:center;">
            <div style="font-size:28px; font-weight:700; color:#ff9800;">{{ enAlerte }}</div>
            <div style="color:#666; font-size:13px; margin-top:4px;">En alerte</div>
        </div>
        <div style="background:white; border-radius:12px; padding:20px; box-shadow:0 2px 8px rgba(0,0,0,0.05); border-left:4px solid #f44336; text-align:center;">
            <div style="font-size:28px; font-weight:700; color:#f44336;">{{ enRupture }}</div>
            <div style="color:#666; font-size:13px; margin-top:4px;">En rupture</div>
        </div>
    </div>

    {# Bandeau info produits sans stock #}
    {% if produitsSansStock is not empty %}
    <div style="background:#fff3cd; border:1px solid #fbbf24; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:10px;">
            <i class="fa-solid fa-triangle-exclamation" style="color:#d97706; font-size:18px;"></i>
            <span style="color:#92400e; font-size:14px;">
                <strong>{{ produitsSansStock|length }} produit(s)</strong> sans stock enregistré.
            </span>
        </div>
        <button type="button" onclick="ouvrirModalChoixProduit()"
            style="padding:6px 16px; background:#d97706; color:white; border:none; border-radius:20px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap;">
            <i class="fa-solid fa-plus"></i> Ajouter maintenant
        </button>
    </div>
    {% endif %}

    {# Liste des stocks #}
    <div style="background:white; border-radius:16px; box-shadow:0 2px 8px rgba(0,0,0,0.05); overflow:hidden;">
        {% for stock in stocks %}
        {% set produit = stock.produit %}
        <div style="display:flex; align-items:center; gap:16px; padding:16px 24px; border-bottom:1px solid #f0f2f5; {% if loop.last %}border-bottom:none;{% endif %}">

            {# Image #}
            <div style="flex-shrink:0;">
                {% if produit.photoUrl %}
                <img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}" style="width:52px; height:52px; object-fit:cover; border-radius:10px; border:2px solid #e8f5e9;">
                {% else %}
                <div style="width:52px; height:52px; background:#e8f5e9; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#5a9814; font-size:22px;">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                {% endif %}
            </div>

            {# Produit #}
            <div style="flex:1; min-width:0;">
                <div style="font-weight:700; font-size:15px; margin-bottom:3px;">{{ produit.nom }}</div>
                <div style="font-size:12px; color:#999;">{{ produit.categorie }} — {{ produit.prixUnitaire }} DT</div>
            </div>

            {# Quantité #}
            <div style="text-align:center; min-width:90px;">
                <div style="font-size:18px; font-weight:700; color:#333;">{{ stock.quantiteActuelle }}</div>
                <div style="font-size:11px; color:#999;">{{ stock.uniteMesure }}</div>
            </div>

            {# Seuil #}
            <div style="text-align:center; min-width:70px;">
                <div style="font-size:11px; color:#999;">Seuil</div>
                <div style="font-size:15px; font-weight:600;">{{ stock.seuilAlerte ?: '—' }}</div>
            </div>

            {# Statut #}
            <div style="min-width:100px; text-align:center;">
                {% if stock.quantiteActuelle == 0 %}
                    <span style="background:#fee2e2; color:#dc2626; padding:5px 10px; border-radius:20px; font-size:11px; font-weight:600;">Rupture</span>
                {% elseif stock.isEnAlerte %}
                    <span style="background:#fff3cd; color:#d97706; padding:5px 10px; border-radius:20px; font-size:11px; font-weight:600;">⚠️ Alerte</span>
                {% else %}
                    <span style="background:#dcfce7; color:#16a34a; padding:5px 10px; border-radius:20px; font-size:11px; font-weight:600;">✓ OK</span>
                {% endif %}
            </div>

            {# Dates #}
            <div style="text-align:center; min-width:100px; font-size:11px; color:#999;">
                {% if stock.dateExpiration %}
                <div>Exp :</div>
                <div style="color:#f44336; font-weight:600;">{{ stock.dateExpiration|date('d/m/Y') }}</div>
                {% endif %}
            </div>

            {# Actions #}
            <div style="display:flex; gap:8px; flex-shrink:0;">
                <a href="{{ path('front_stock_edit', {id: stock.id}) }}"
                   style="padding:6px 12px; background:#e3f2fd; color:#2196f3; border-radius:20px; text-decoration:none; font-size:12px; font-weight:600;"
                   title="Modifier le stock">
                    <i class="fa-solid fa-pen"></i>
                </a>
                <a href="{{ path('front_produit_show', {id: produit.id}) }}"
                   style="padding:6px 12px; background:#f3f4f6; color:#4b5563; border-radius:20px; text-decoration:none; font-size:12px; font-weight:600;"
                   title="Voir le produit">
                    <i class="fa-solid fa-eye"></i>
                </a>
                <button type="button"
                    onclick="confirmerSuppStock('{{ stock.id }}', '{{ produit.nom|e('js') }}', {{ stock.quantiteActuelle }}, '{{ stock.uniteMesure }}')"
                    style="padding:6px 12px; background:#fee2e2; color:#dc2626; border:none; border-radius:20px; font-size:12px; font-weight:600; cursor:pointer;"
                    title="Supprimer le stock">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </div>

            {# Formulaire suppression #}
            <form id="form-del-stock-{{ stock.id }}" action="{{ path('front_stock_delete', {id: stock.id}) }}" method="POST" style="display:none;">
                <input type="hidden" name="_token" value="{{ csrf_token('/stock/{id}/edit' ~ stock.id) }}">
            </form>
        </div>
        {% endfor %}
    </div>

    {% endif %}
</div>

{# ===== MODAL CHOIX PRODUIT SANS STOCK ===== #}
{% if produitsSansStock is not empty %}
<div id="modalChoixProduit" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:32px; max-width:500px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,0.3); max-height:80vh; overflow-y:auto;">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
            <h3 style="margin:0; font-size:20px;">
                <i class="fa-solid fa-plus" style="color:#5a9814;"></i> Ajouter un stock
            </h3>
            <button onclick="fermerModalChoix()" style="background:none; border:none; font-size:20px; cursor:pointer; color:#999; padding:4px;">✕</button>
        </div>

        <p style="color:#666; font-size:13px; margin-bottom:16px;">
            {{ produitsSansStock|length }} produit(s) sans stock. Choisissez le produit :
        </p>

        {# Barre de recherche #}
        <div style="position:relative; margin-bottom:16px;">
            <i class="fa-solid fa-magnifying-glass" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#999;"></i>
            <input type="text" id="rechercherProduit" placeholder="Rechercher un produit..."
                style="width:100%; padding:10px 12px 10px 36px; border:1px solid #ddd; border-radius:10px; font-size:14px; box-sizing:border-box;"
                onkeyup="filtrerProduits()">
        </div>

        {# Liste des produits SANS stock uniquement #}
        <div id="listeProduits" style="display:flex; flex-direction:column; gap:8px; max-height:360px; overflow-y:auto;">
            {% for produit in produitsSansStock %}
            <a href="{{ path('front_stock_new', {id: produit.id}) }}"
               class="produit-item"
               data-nom="{{ produit.nom|lower }}"
               style="display:flex; align-items:center; gap:12px; padding:12px 16px; border:1px solid #eee; border-radius:10px; text-decoration:none; color:inherit;">

                {# Image #}
                {% if produit.photoUrl %}
                <img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}" style="width:44px; height:44px; object-fit:cover; border-radius:8px; flex-shrink:0;">
                {% else %}
                <div style="width:44px; height:44px; background:#e8f5e9; border-radius:8px; display:flex; align-items:center; justify-content:center; color:#5a9814; font-size:20px; flex-shrink:0;">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                {% endif %}

                {# Infos #}
                <div style="flex:1; min-width:0;">
                    <div style="font-weight:600; font-size:14px; margin-bottom:2px;">{{ produit.nom }}</div>
                    <div style="font-size:12px; color:#999;">{{ produit.categorie }} — {{ produit.prixUnitaire }} DT</div>
                </div>

                {# Badge aucun stock #}
                <span style="background:#f3f4f6; color:#6b7280; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; flex-shrink:0; white-space:nowrap;">
                    Aucun stock
                </span>

                <i class="fa-solid fa-arrow-right" style="color:#5a9814; flex-shrink:0;"></i>
            </a>
            {% endfor %}

            {# Aucun résultat #}
            <div id="aucunResultat" style="display:none; text-align:center; padding:24px; color:#999; font-size:14px;">
                <i class="fa-solid fa-magnifying-glass" style="font-size:24px; margin-bottom:8px; display:block;"></i>
                Aucun produit trouvé
            </div>
        </div>

        <div style="margin-top:16px; padding-top:16px; border-top:1px solid #eee; text-align:center;">
            <p style="color:#999; font-size:12px; margin-bottom:10px;">Vous ne trouvez pas votre produit ?</p>
            <a href="{{ path('front_produit_new') }}"
               style="padding:8px 20px; background:#e8f5e9; color:#5a9814; border-radius:20px; text-decoration:none; font-size:13px; font-weight:600;">
                <i class="fa-solid fa-plus"></i> Créer un nouveau produit
            </a>
        </div>
    </div>
</div>
{% endif %}

{# Modal suppression stock #}
<div id="modalSuppStock" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:16px; padding:32px; max-width:420px; width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <div style="width:60px; height:60px; background:#fff3cd; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:28px; color:#d97706;">
            <i class="fa-solid fa-warehouse"></i>
        </div>
        <h3 style="margin:0 0 8px; font-size:20px;">Supprimer ce stock ?</h3>
        <p id="modalStockInfo" style="color:#666; margin-bottom:12px; font-size:14px;"></p>
        <p style="background:#fff3cd; color:#d97706; padding:10px; border-radius:8px; font-size:13px; margin-bottom:24px;">
            ⚠️ Cette action supprimera uniquement le stock, pas le produit.
        </p>
        <div style="display:flex; gap:12px; justify-content:center;">
            <button onclick="fermerModalSupp()" style="padding:10px 24px; background:#f0f2f5; border:none; border-radius:30px; font-weight:600; cursor:pointer; color:#4a5568;">
                Annuler
            </button>
            <button id="btnConfirmerSuppStock" style="padding:10px 24px; background:#dc2626; color:white; border:none; border-radius:30px; font-weight:600; cursor:pointer;">
                Oui, supprimer
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="text/javascript">
var stockIdASupprimer = null;

// ===== MODAL CHOIX PRODUIT =====
function ouvrirModalChoixProduit() {
    var modal = document.getElementById('modalChoixProduit');
    if (modal) {
        modal.style.display = 'flex';
        var input = document.getElementById('rechercherProduit');
        if (input) {
            input.value = '';
            filtrerProduits();
            input.focus();
        }
    }
}

function fermerModalChoix() {
    var modal = document.getElementById('modalChoixProduit');
    if (modal) modal.style.display = 'none';
}

function filtrerProduits() {
    var input = document.getElementById('rechercherProduit');
    var filtre = input ? input.value.toLowerCase() : '';
    var items = document.getElementsByClassName('produit-item');
    var nbVisible = 0;

    for (var i = 0; i < items.length; i++) {
        var nom = items[i].getAttribute('data-nom') || '';
        if (nom.indexOf(filtre) !== -1) {
            items[i].style.display = 'flex';
            nbVisible++;
        } else {
            items[i].style.display = 'none';
        }
    }

    var aucun = document.getElementById('aucunResultat');
    if (aucun) {
        aucun.style.display = nbVisible === 0 ? 'block' : 'none';
    }
}

// Hover sur les items
var items = document.getElementsByClassName('produit-item');
for (var i = 0; i < items.length; i++) {
    (function(item) {
        item.onmouseover = function() {
            item.style.background = '#f8fff4';
            item.style.borderColor = '#5a9814';
        };
        item.onmouseout = function() {
            item.style.background = '';
            item.style.borderColor = '#eee';
        };
    })(items[i]);
}

// Fermer en cliquant dehors
var modalChoix = document.getElementById('modalChoixProduit');
if (modalChoix) {
    modalChoix.onclick = function(e) {
        if (e.target === modalChoix) fermerModalChoix();
    };
}

// ===== MODAL SUPPRESSION =====
function confirmerSuppStock(id, nomProduit, quantite, unite) {
    stockIdASupprimer = id;
    var info = document.getElementById('modalStockInfo');
    if (info) {
        info.innerHTML = 'Produit : <strong>' + nomProduit + '</strong><br>Quantité : <strong>' + quantite + ' ' + unite + '</strong>';
    }
    var modal = document.getElementById('modalSuppStock');
    if (modal) modal.style.display = 'flex';
}

function fermerModalSupp() {
    var modal = document.getElementById('modalSuppStock');
    if (modal) modal.style.display = 'none';
    stockIdASupprimer = null;
}

var btnConfirmer = document.getElementById('btnConfirmerSuppStock');
if (btnConfirmer) {
    btnConfirmer.onclick = function() {
        if (stockIdASupprimer) {
            var form = document.getElementById('form-del-stock-' + stockIdASupprimer);
            if (form) form.submit();
        }
    };
}

var modalSupp = document.getElementById('modalSuppStock');
if (modalSupp) {
    modalSupp.onclick = function(e) {
        if (e.target === modalSupp) fermerModalSupp();
    };
}
</script>
{% endblock %}