<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Agrisens 360 — Monitoring Ferme{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="{{ asset('css/agrisens.css') }}">
</head>
<body>
<div class="app-wrapper">

<!-- ═══ SIDEBAR ══════════════════════════════════════════════════════════════ -->
<!-- ═══ SIDEBAR ══════════════════════════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="brand-logo"><i class="fa-solid fa-seedling"></i></div>
        <div>
            <div class="brand-name">Agrisens 360</div>
            <div class="brand-tagline">Monitoring Ferme</div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-title">TABLEAU DE BORD</div>
        <a href="{{ path('admin') }}" class="nav-item {{ app.request.attributes.get('_route') in ['home','admin'] ? 'active':'' }}">
            <i class="fa-solid fa-chart-pie"></i><span class="nav-label">Vue d'ensemble</span>
        </a>

        <div class="nav-section-title" style="margin-top:14px">PRODUITS</div>
    
        <a href="{{ path('export_produits_pdf') }}" class="nav-item" target="_blank">
            <i class="fa-solid fa-file-pdf" style="color:#ef9a9a"></i><span class="nav-label">Export PDF produits</span>
        </a>

        <div class="nav-section-title" style="margin-top:14px">STOCKS</div>
        
        <a href="{{ path('export_stocks_pdf') }}" class="nav-item" target="_blank">
            <i class="fa-solid fa-file-pdf" style="color:#ef9a9a"></i><span class="nav-label">Export PDF stocks</span>
        </a>

        <div class="nav-section-title" style="margin-top:14px">ALERTES</div>
        
        <a href="{{ path('export_alertes_pdf') }}" class="nav-item" target="_blank">
            <i class="fa-solid fa-file-pdf" style="color:#ef9a9a"></i><span class="nav-label">Rapport PDF alertes</span>
        </a>
        {# templates/layout/base.html.twig - Ajouter dans le sidebar #}

<div class="nav-section-title" style="margin-top:14px">ANALYSES</div>
<a href="{{ path('api_openfoodfacts_view') }}" class="nav-item">
    <i class="fa-solid fa-barcode"></i><span class="nav-label">Scan OpenFood</span>
</a>
<a href="{{ path('api_exchange_view') }}" class="nav-item">
    <i class="fa-solid fa-money-bill-wave"></i><span class="nav-label">Taux & Prix</span>
</a>
{# templates/layout/base.html.twig #}

<div class="nav-section-title" style="margin-top:14px">EXPORTS</div>
<a href="{{ path('export_excel_produits') }}" class="nav-item" target="_blank">
    <i class="fa-solid fa-file-excel" style="color:#4caf50"></i><span class="nav-label">Excel Produits</span>
</a>
<a href="{{ path('export_excel_stocks') }}" class="nav-item" target="_blank">
    <i class="fa-solid fa-file-excel" style="color:#2196f3"></i><span class="nav-label">Excel Stocks</span>
</a>

<a href="{{ path('api_commodity_view') }}" class="nav-item">
    <i class="fa-solid fa-chart-line"></i><span class="nav-label">Prix matières</span>
</a>
<a href="{{ path('analyse_complete') }}" class="nav-item">
    <i class="fa-solid fa-chart-line"></i><span class="nav-label">Analyse IA</span>
</a>
    </nav>

    <div class="sidebar-footer">
        <div class="pulse-dot"></div>
        <span>Système actif</span>
    </div>
</aside>
<!-- ═══ MAIN ═════════════════════════════════════════════════════════════════ -->
<div class="main-content" id="mainContent">

    <!-- HEADER -->
    <header class="top-header">
        <button class="sidebar-toggle" id="sidebarToggle" title="Réduire le menu">
            <i class="fa-solid fa-bars"></i>
        </button>

        <form action="{{ path('home') }}" method="GET" class="header-search">
            <i class="fa-solid fa-magnifying-glass" style="color:#9aaa8a;flex-shrink:0"></i>
            <input type="text" name="q" placeholder="Rechercher un produit, un stock..."
                   value="{{ app.request.query.get('q','') }}">
        </form>

        <div class="header-actions">
            <!-- Cloche Notifications -->
            <div class="notif-wrapper" id="notifWrapper">
                <button class="notif-btn" id="notifBtn" title="Alertes stock">
                    <i class="fa-solid fa-bell"></i>
                    <span class="notif-count" id="notifCount" style="display:none">0</span>
                </button>
                <div class="notif-dropdown" id="notifDropdown">
                    <div class="notif-header">
                        <span><i class="fa-solid fa-bell"></i> Alertes Stock</span>
                        <span class="notif-header-badge" id="notifBadge">0</span>
                    </div>
                    <div class="notif-list" id="notifList">
                        <div class="notif-empty">Chargement...</div>
                    </div>
                    <a href="{{ path('home') }}#alertes" class="notif-footer">
                        Voir toutes les alertes →
                    </a>
                </div>
            </div>

            <div class="user-avatar" title="Agriculteur"><i class="fa-solid fa-user"></i></div>
        </div>
    </header>

    <!-- FLASH MESSAGES -->
    <div class="flash-zone">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
            <div class="flash flash-{{ label }}">
                <i class="fa-solid {{ label=='success'?'fa-circle-check':'fa-circle-exclamation' }}"></i>
                {{ message }}
                <button class="flash-close" onclick="this.parentElement.remove()">×</button>
            </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- PAGE CONTENT -->
    <main class="page-content">
        {% block content %}{% endblock %}
    </main>

</div>
</div>

<!-- ═══ JS GLOBAL ════════════════════════════════════════════════════════════ -->
<script>
// Sidebar toggle
document.getElementById('sidebarToggle').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('collapsed');
    document.getElementById('mainContent').classList.toggle('expanded');
});

// Flash auto-dismiss
setTimeout(() => {
    document.querySelectorAll('.flash').forEach(el => {
        el.style.transition = 'opacity .5s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 500);
    });
}, 5000);

// ══ NOTIFICATION SYSTEM ═══════════════════════════════════════════════════════
const notifBtn = document.getElementById('notifBtn');
const notifDD  = document.getElementById('notifDropdown');
const notifCount = document.getElementById('notifCount');
const notifBadge = document.getElementById('notifBadge');
const notifList  = document.getElementById('notifList');

const ICON  = { danger: 'fa-circle-xmark', warning: 'fa-triangle-exclamation' };
const CLASS = { danger: 'danger', warning: 'warning' };

async function fetchNotif() {
    try {
        const d = await (await fetch('/api/notifications')).json();
        const n = d.notifications || [];
        const total = n.length;
        notifCount.textContent = total > 99 ? '99+' : total;
        notifCount.style.display = total > 0 ? 'flex' : 'none';
        notifBadge.textContent = total;

        if (!n.length) {
            notifList.innerHTML = `<div class="notif-empty">
                <i class="fa-solid fa-circle-check" style="color:#5a9814;font-size:28px;margin-bottom:8px;display:block"></i>
                Aucune alerte — tout va bien !
            </div>`;
            return;
        }
        notifList.innerHTML = n.map(x => `
            <a href="${x.url}" class="notif-item ${x.level === 'critical' ? 'critical' : 'unread'}">
                <div class="notif-icon ${CLASS[x.type] || 'warning'}">
                    <i class="fa-solid ${ICON[x.type] || 'fa-bell'}"></i>
                </div>
                <div class="notif-body">
                    <div class="notif-title">${x.title}</div>
                    <div class="notif-desc">${x.desc}</div>
                    <div class="notif-time">${x.time}</div>
                </div>
            </a>`).join('');
    } catch(e) { console.warn('Notif error', e); }
}

notifBtn.addEventListener('click', e => {
    e.stopPropagation();
    notifDD.classList.toggle('open');
    if (notifDD.classList.contains('open')) fetchNotif();
});
document.addEventListener('click', e => {
    if (!document.getElementById('notifWrapper').contains(e.target))
        notifDD.classList.remove('open');
});
fetchNotif();
setInterval(fetchNotif, 60000);
</script>
{% block javascripts %}{% endblock %}
</body>
</html>
