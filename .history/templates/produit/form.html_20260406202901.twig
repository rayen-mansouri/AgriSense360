{# templates/produit/form.html.twig #}
{% extends 'layout/base.html.twig' %}

{% block title %}{{ title }} — Agrisens 360{% endblock %}

{% block content %}
<div style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div>
            <h1 style="font-size: 24px; margin: 0;">{{ title }}</h1>
            <p style="color: #666; margin: 5px 0 0;">{{ subtitle }}</p>
        </div>
        <a href="{{ path('home') }}" style="padding: 8px 16px; background: #f0f2f5; border-radius: 8px; text-decoration: none; color: #333;">← Retour</a>
    </div>

    <form method="post" id="produitForm" enctype="multipart/form-data">
        {{ form_widget(form._token) }}

        <!-- Carte Produit -->
        <div style="background: white; border-radius: 16px; padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border: 1px solid #eef2f6;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #eee;">
                <div style="width: 40px; height: 40px; background: #e8f5e9; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #5a9814; font-size: 20px;">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div>
                    <h2 style="font-size: 18px; margin: 0;">📦 Informations Produit</h2>
                    <p style="font-size: 13px; color: #666; margin: 4px 0 0;">Renseignez les détails du produit agricole</p>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <!-- Catégorie -->
                <div class="field-container" data-field="categorie">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Catégorie *</label>
                    {{ form_widget(form.produit.categorie, {'attr': {'class': 'form-control field-categorie', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-categorie" style="margin-top: 6px;"></div>
                </div>

                <!-- Nom -->
                <div class="field-container" data-field="nom">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Nom du produit *</label>
                    {{ form_widget(form.produit.nom, {'attr': {'class': 'form-control field-nom', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-nom" style="margin-top: 6px;"></div>
                </div>

                <!-- Description -->
                <div style="grid-column: span 2;">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Description</label>
                    {{ form_widget(form.produit.description, {'attr': {'class': 'form-control', 'rows': 4, 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                </div>

                <!-- Prix -->
                <div class="field-container" data-field="prix">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Prix unitaire (DT) *</label>
                    {{ form_widget(form.produit.prixUnitaire, {'attr': {'class': 'form-control field-prix', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-prix" style="margin-top: 6px;"></div>
                </div>

                <!-- Photo -->
                <div class="field-container" data-field="photo">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Photo du produit *</label>
                    
                    <div id="uploadZone" style="border: 2px dashed #cbd5e1; border-radius: 12px; padding: 20px; text-align: center; cursor: pointer; background: #f8fafc;">
                        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 32px; color: #94a3b8; margin-bottom: 8px; display: block;"></i>
                        <p style="margin: 0; font-size: 13px; color: #475569;">Cliquez pour choisir une image</p>
                    </div>
                    
                    <div style="width: 0; height: 0; overflow: hidden;">
                        {{ form_widget(form.produit.photoFile, {'attr': {'class': 'field-photo'}}) }}
                    </div>
                    
                    <div id="previewZone" style="display: none; margin-top: 10px; text-align: center;">
                        <img id="previewImage" src="" alt="Aperçu" style="max-width: 150px; max-height: 150px; border-radius: 8px; border: 2px solid #5a9814;">
                        <br>
                        <span id="fileName" style="font-size: 12px; color: #666; display: block; margin-top: 5px;"></span>
                        <button type="button" id="btnSupprimer" style="background: #dc3545; color: white; border: none; padding: 6px 14px; border-radius: 20px; cursor: pointer; margin-top: 8px; font-size: 12px;">✖ Supprimer</button>
                    </div>
                    
                    <div class="error-container error-photo" style="margin-top: 6px;"></div>
                </div>
            </div>
        </div>

        <!-- Carte Stock -->
        <div style="background: white; border-radius: 16px; padding: 24px; margin-bottom: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border: 1px solid #eef2f6;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #eee;">
                <div style="width: 40px; height: 40px; background: #e3f2fd; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #2196f3; font-size: 20px;">
                    <i class="fa-solid fa-warehouse"></i>
                </div>
                <div>
                    <h2 style="font-size: 18px; margin: 0;">📊 Stock Initial</h2>
                    <p style="font-size: 13px; color: #666; margin: 4px 0 0;">Optionnel</p>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <!-- Quantité -->
                <div class="field-container" data-field="quantite">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Quantité actuelle</label>
                    {{ form_widget(form.stock.quantiteActuelle, {'attr': {'class': 'form-control field-quantite', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-quantite" style="margin-top: 6px;"></div>
                </div>

                <!-- Seuil -->
                <div class="field-container" data-field="seuil">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Seuil d'alerte</label>
                    {{ form_widget(form.stock.seuilAlerte, {'attr': {'class': 'form-control field-seuil', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-seuil" style="margin-top: 6px;"></div>
                </div>

                <!-- Unité -->
                <div class="field-container" data-field="unite">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Unité de mesure</label>
                    {{ form_widget(form.stock.uniteMesure, {'attr': {'class': 'form-control field-unite', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-unite" style="margin-top: 6px;"></div>
                </div>

                <!-- Emplacement -->
                <div class="field-container" data-field="emplacement">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Emplacement</label>
                    {{ form_widget(form.stock.emplacement, {'attr': {'class': 'form-control field-emplacement', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                </div>

                <!-- Date Réception -->
                <div class="field-container" data-field="dateReception">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Date de réception</label>
                    {{ form_widget(form.stock.dateReception, {'attr': {'class': 'form-control field-dateReception', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-dateReception" style="margin-top: 6px;"></div>
                </div>

                <!-- Date Expiration -->
                <div class="field-container" data-field="dateExpiration">
                    <label style="display: block; font-weight: 600; margin-bottom: 6px; font-size: 14px;">Date d'expiration</label>
                    {{ form_widget(form.stock.dateExpiration, {'attr': {'class': 'form-control field-dateExpiration', 'style': 'width:100%; padding:10px 14px; border:1px solid #ddd; border-radius:10px;'}}) }}
                    <div class="error-container error-dateExpiration" style="margin-top: 6px;"></div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div style="display: flex; justify-content: flex-end; gap: 15px; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
            <a href="{{ path('home') }}" style="padding: 10px 24px; background: #f0f2f5; border-radius: 30px; text-decoration: none; color: #4a5568; font-weight: 600;">Annuler</a>
            <button type="submit" id="btnSubmit" style="padding: 10px 24px; background: #5a9814; color: white; border: none; border-radius: 30px; font-weight: 600; cursor: pointer;">{{ btnLabel }}</button>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="text/javascript">
(function() {
    
    // =============================================
    // VARIABLES GLOBALES
    // =============================================
    var form = null;
    var uploadZone = null;
    var previewZone = null;
    var previewImage = null;
    var fileNameSpan = null;
    var btnSupprimer = null;
    var fileInput = null;
    var imageSelectionnee = false;
    
    // =============================================
    // TROUVER UN CHAMP PAR SA CLASSE
    // =============================================
    function trouverChamp(nomChamp) {
        var elements = document.getElementsByClassName('field-' + nomChamp);
        if (elements && elements.length > 0) {
            return elements[0];
        }
        return null;
    }
    
    // =============================================
    // TROUVER LE CONTENEUR D'ERREUR
    // =============================================
    function trouverErreurContainer(nomChamp) {
        var elements = document.getElementsByClassName('error-' + nomChamp);
        if (elements && elements.length > 0) {
            return elements[0];
        }
        return null;
    }
    
    // =============================================
    // AFFICHER UNE ERREUR
    // =============================================
    function afficherErreur(nomChamp, message) {
        var errorDiv = trouverErreurContainer(nomChamp);
        if (errorDiv) {
            var html = '<div style="';
            html += 'background-color: #fee2e2;';
            html += 'color: #b91c1c;';
            html += 'padding: 8px 12px;';
            html += 'border-radius: 6px;';
            html += 'font-size: 13px;';
            html += 'border-left: 4px solid #dc2626;';
            html += 'margin-top: 4px;';
            html += '">';
            html += '<strong>⚠️ ' + message + '</strong>';
            html += '</div>';
            errorDiv.innerHTML = html;
        }
        
        var champ = trouverChamp(nomChamp);
        if (champ) {
            champ.style.borderColor = '#dc2626';
            champ.style.backgroundColor = '#fef2f2';
        }
    }
    
    // =============================================
    // MASQUER UNE ERREUR
    // =============================================
    function masquerErreur(nomChamp) {
        var errorDiv = trouverErreurContainer(nomChamp);
        if (errorDiv) {
            errorDiv.innerHTML = '';
        }
        
        var champ = trouverChamp(nomChamp);
        if (champ) {
            champ.style.borderColor = '#ddd';
            champ.style.backgroundColor = '';
        }
    }
    
    // =============================================
    // MASQUER TOUTES LES ERREURS
    // =============================================
    function masquerToutesErreurs() {
        var champs = ['categorie', 'nom', 'prix', 'photo', 'quantite', 'seuil', 'unite', 'dateReception', 'dateExpiration'];
        for (var i = 0; i < champs.length; i++) {
            masquerErreur(champs[i]);
        }
    }
    
    // =============================================
    // OBTENIR LA VALEUR D'UN CHAMP
    // =============================================
    function getValeur(nomChamp) {
        var champ = trouverChamp(nomChamp);
        if (champ) {
            return champ.value;
        }
        return '';
    }
    
    // =============================================
    // TRIM MANUEL (compatible vieux navigateurs)
    // =============================================
    function trim(str) {
        if (!str) return '';
        var result = str;
        while (result.charAt(0) === ' ') {
            result = result.substring(1);
        }
        while (result.length > 0 && result.charAt(result.length - 1) === ' ') {
            result = result.substring(0, result.length - 1);
        }
        return result;
    }
    
    // =============================================
    // VERIFIER SI C'EST UNE IMAGE
    // =============================================
    function estUneImage(nomFichier) {
        if (!nomFichier) return false;
        var extensions = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.bmp'];
        var nomLower = nomFichier.toLowerCase();
        for (var i = 0; i < extensions.length; i++) {
            if (nomLower.indexOf(extensions[i]) !== -1) {
                return true;
            }
        }
        return false;
    }
    
    // =============================================
    // VALIDATION COMPLETE DU FORMULAIRE
    // =============================================
    function validerFormulaire() {
        var estValide = true;
        var erreurs = [];
        
        // Effacer toutes les erreurs
        masquerToutesErreurs();
        
        // ========== 1. CATEGORIE ==========
        var categorieVal = getValeur('categorie');
        if (!categorieVal || categorieVal === '') {
            afficherErreur('categorie', 'La catégorie est obligatoire');
            erreurs.push('categorie');
            estValide = false;
        }
        
        // ========== 2. NOM ==========
        var nomVal = trim(getValeur('nom'));
        if (!nomVal || nomVal === '') {
            afficherErreur('nom', 'Le nom du produit est obligatoire');
            erreurs.push('nom');
            estValide = false;
        } else if (nomVal.length < 3) {
            afficherErreur('nom', 'Le nom doit contenir au moins 3 caractères');
            erreurs.push('nom');
            estValide = false;
        } else if (nomVal.length > 100) {
            afficherErreur('nom', 'Le nom ne peut pas dépasser 100 caractères');
            erreurs.push('nom');
            estValide = false;
        }
        
        // ========== 3. PRIX ==========
        var prixVal = getValeur('prix');
        if (!prixVal || prixVal === '') {
            afficherErreur('prix', 'Le prix unitaire est obligatoire');
            erreurs.push('prix');
            estValide = false;
        } else {
            prixVal = prixVal.replace(',', '.');
            var prixNum = parseFloat(prixVal);
            if (isNaN(prixNum)) {
                afficherErreur('prix', 'Le prix doit être un nombre valide');
                erreurs.push('prix');
                estValide = false;
            } else if (prixNum <= 0) {
                afficherErreur('prix', 'Le prix doit être supérieur à 0');
                erreurs.push('prix');
                estValide = false;
            } else if (prixNum > 999999.99) {
                afficherErreur('prix', 'Le prix est trop élevé');
                erreurs.push('prix');
                estValide = false;
            }
        }
        
        // ========== 4. PHOTO ==========
        var photoValide = false;
        if (imageSelectionnee) {
            photoValide = true;
        } else if (fileInput) {
            if (fileInput.files && fileInput.files.length > 0) {
                photoValide = true;
            } else if (fileInput.value && fileInput.value !== '') {
                photoValide = true;
            }
        }
        
        if (!photoValide) {
            afficherErreur('photo', 'La photo du produit est obligatoire');
            erreurs.push('photo');
            estValide = false;
        }
        
        // ========== 5. QUANTITE ==========
        var quantiteVal = getValeur('quantite');
        var quantiteNum = 0;
        if (quantiteVal && quantiteVal !== '') {
            quantiteNum = parseFloat(quantiteVal);
            if (isNaN(quantiteNum)) {
                afficherErreur('quantite', 'La quantité doit être un nombre valide');
                erreurs.push('quantite');
                estValide = false;
            } else if (quantiteNum < 0) {
                afficherErreur('quantite', 'La quantité ne peut pas être négative');
                erreurs.push('quantite');
                estValide = false;
            }
        }
        
        // ========== 6. SEUIL ==========
        var seuilVal = getValeur('seuil');
        if (seuilVal && seuilVal !== '') {
            var seuilNum = parseFloat(seuilVal);
            if (isNaN(seuilNum)) {
                afficherErreur('seuil', 'Le seuil doit être un nombre valide');
                erreurs.push('seuil');
                estValide = false;
            } else if (seuilNum < 0) {
                afficherErreur('seuil', 'Le seuil ne peut pas être négatif');
                erreurs.push('seuil');
                estValide = false;
            }
        }
        
        // ========== 7. UNITE (si quantité > 0) ==========
        var uniteVal = getValeur('unite');
        if (quantiteVal && quantiteVal !== '' && !isNaN(quantiteNum) && quantiteNum > 0) {
            if (!uniteVal || uniteVal === '') {
                afficherErreur('unite', 'L\'unité est requise quand la quantité est supérieure à 0');
                erreurs.push('unite');
                estValide = false;
            }
        }
        
        // ========== 8. DATES ==========
        var dateReceptionVal = getValeur('dateReception');
        var dateExpirationVal = getValeur('dateExpiration');
        
        if (dateReceptionVal && dateReceptionVal !== '' && dateExpirationVal && dateExpirationVal !== '') {
            var dateR = new Date(dateReceptionVal);
            var dateE = new Date(dateExpirationVal);
            
            if (dateE.getTime() < dateR.getTime()) {
                afficherErreur('dateExpiration', 'La date d\'expiration doit être postérieure à la date de réception');
                erreurs.push('dateExpiration');
                estValide = false;
            }
        }
        
        // Scroll vers la première erreur
        if (erreurs.length > 0) {
            var premiereErreur = trouverErreurContainer(erreurs[0]);
            if (premiereErreur && premiereErreur.scrollIntoView) {
                premiereErreur.scrollIntoView();
            }
        }
        
        return estValide;
    }
    
    // =============================================
    // INITIALISATION
    // =============================================
    function initialiser() {
        form = document.getElementById('produitForm');
        uploadZone = document.getElementById('uploadZone');
        previewZone = document.getElementById('previewZone');
        previewImage = document.getElementById('previewImage');
        fileNameSpan = document.getElementById('fileName');
        btnSupprimer = document.getElementById('btnSupprimer');
        
        // Trouver l'input file
        fileInput = trouverChamp('photo');
        if (!fileInput) {
            var allInputs = document.getElementsByTagName('input');
            for (var i = 0; i < allInputs.length; i++) {
                if (allInputs[i].type === 'file') {
                    fileInput = allInputs[i];
                    break;
                }
            }
        }
        
        // ========== UPLOAD ZONE ==========
        if (uploadZone && fileInput) {
            uploadZone.onclick = function(e) {
                if (e.preventDefault) e.preventDefault();
                if (e.stopPropagation) e.stopPropagation();
                fileInput.click();
                return false;
            };
        }
        
        // ========== FILE INPUT CHANGE ==========
        if (fileInput) {
            fileInput.onchange = function() {
                var fichiers = this.files;
                if (fichiers && fichiers.length > 0) {
                    var fichier = fichiers[0];
                    var nom = fichier.name;
                    
                    if (!estUneImage(nom)) {
                        afficherErreur('photo', 'Veuillez sélectionner une image (JPG, PNG, GIF)');
                        this.value = '';
                        return;
                    }
                    
                    if (fichier.size > 5 * 1024 * 1024) {
                        afficherErreur('photo', 'L\'image ne doit pas dépasser 5 Mo');
                        this.value = '';
                        return;
                    }
                    
                    masquerErreur('photo');
                    
                    if (window.FileReader) {
                        var reader = new FileReader();
                        reader.onload = function(e) {
                            previewImage.src = e.target.result;
                            fileNameSpan.innerHTML = nom;
                            previewZone.style.display = 'block';
                            uploadZone.style.display = 'none';
                            imageSelectionnee = true;
                        };
                        reader.readAsDataURL(fichier);
                    } else {
                        fileNameSpan.innerHTML = nom;
                        previewZone.style.display = 'block';
                        uploadZone.style.display = 'none';
                        imageSelectionnee = true;
                    }
                }
            };
        }
        
        // ========== BOUTON SUPPRIMER ==========
        if (btnSupprimer) {
            btnSupprimer.onclick = function(e) {
                if (e.preventDefault) e.preventDefault();
                if (e.stopPropagation) e.stopPropagation();
                
                if (fileInput) fileInput.value = '';
                if (previewImage) previewImage.src = '';
                if (fileNameSpan) fileNameSpan.innerHTML = '';
                previewZone.style.display = 'none';
                uploadZone.style.display = 'block';
                imageSelectionnee = false;
                
                return false;
            };
        }
        
        // ========== SOUMISSION ==========
        if (form) {
            form.onsubmit = function(e) {
                var valide = validerFormulaire();
                
                if (!valide) {
                    if (e.preventDefault) {
                        e.preventDefault();
                    } else {
                        e.returnValue = false;
                    }
                    return false;
                }
                return true;
            };
        }
        
        // ========== VALIDATION TEMPS REEL ==========
        var champsAValider = ['categorie', 'nom', 'prix', 'quantite', 'seuil'];
        
        for (var i = 0; i < champsAValider.length; i++) {
            (function(nomChamp) {
                var champ = trouverChamp(nomChamp);
                if (champ) {
                    champ.onfocus = function() {
                        masquerErreur(nomChamp);
                    };
                    
                    champ.onblur = function() {
                        var val = trim(this.value);
                        
                        if (nomChamp === 'categorie') {
                            if (!val) {
                                afficherErreur('categorie', 'La catégorie est obligatoire');
                            }
                        }
                        
                        if (nomChamp === 'nom') {
                            if (!val) {
                                afficherErreur('nom', 'Le nom est obligatoire');
                            } else if (val.length < 3) {
                                afficherErreur('nom', 'Minimum 3 caractères');
                            }
                        }
                        
                        if (nomChamp === 'prix') {
                            if (!val) {
                                afficherErreur('prix', 'Le prix est obligatoire');
                            } else {
                                var num = parseFloat(val.replace(',', '.'));
                                if (isNaN(num)) {
                                    afficherErreur('prix', 'Nombre invalide');
                                } else if (num <= 0) {
                                    afficherErreur('prix', 'Le prix doit être > 0');
                                }
                            }
                        }
                        
                        if (nomChamp === 'quantite' && val) {
                            var num = parseFloat(val);
                            if (isNaN(num)) {
                                afficherErreur('quantite', 'Nombre invalide');
                            } else if (num < 0) {
                                afficherErreur('quantite', 'Quantité négative interdite');
                            }
                        }
                        
                        if (nomChamp === 'seuil' && val) {
                            var num = parseFloat(val);
                            if (isNaN(num)) {
                                afficherErreur('seuil', 'Nombre invalide');
                            } else if (num < 0) {
                                afficherErreur('seuil', 'Seuil négatif interdit');
                            }
                        }
                    };
                }
            })(champsAValider[i]);
        }
    }
    
    // =============================================
    // LANCEMENT AVEC POLLING
    // =============================================
    var tentatives = 0;
    var interval = setInterval(function() {
        tentatives++;
        var formTest = document.getElementById('produitForm');
        if (formTest || tentatives > 100) {
            clearInterval(interval);
            if (formTest) {
                initialiser();
            }
        }
    }, 50);
    
})();
</script>
{% endblock %}