{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit - Agrisens 360{% endblock %}

{% block content %}
<div class="form-container">
    <div class="form-header">
        <h1><i class="fa-solid fa-plus-circle"></i> Ajouter un Nouveau Produit</h1>
        <p>Remplissez les informations ci-dessous pour enregistrer un nouveau produit agricole</p>
    </div>

    {{ form_start(form, {'attr': {'class': 'beautiful-form'}}) }}

    <div class="form-grid">
        <div class="form-group">
            {{ form_label(form.nom, 'Nom du Produit') }}
            {{ form_widget(form.nom) }}
            {{ form_errors(form.nom) }}
        </div>

        <div class="form-group">
            {{ form_label(form.categorie, 'Catégorie') }}
            {{ form_widget(form.categorie) }}
            {{ form_errors(form.categorie) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.description, 'Description') }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="form-group">
            {{ form_label(form.prixUnitaire, 'Prix Unitaire (DT)') }}
            {{ form_widget(form.prixUnitaire) }}
            {{ form_errors(form.prixUnitaire) }}
        </div>

        <div class="form-group">
            {{ form_label(form.photoFile, 'Photo du Produit') }}
            {{ form_widget(form.photoFile) }}
            {{ form_errors(form.photoFile) }}
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-save"></i> Enregistrer le Produit
        </button>
        <a href="{{ path('produit_index') }}" class="btn btn-secondary btn-lg">Annuler</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}