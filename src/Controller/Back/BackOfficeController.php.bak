<?php
namespace App\Controller;

use App\Entity\Produit;
use App\Entity\Stock;
use App\Form\ProduitType;
use App\Form\StockType;
use App\Repository\ProduitRepository;
use App\Repository\StockRepository;
use Doctrine\ORM\EntityManagerInterface;
use Symfony\Bundle\FrameworkBundle\Controller\AbstractController;
use Symfony\Component\HttpFoundation\File\Exception\FileException;
use Symfony\Component\HttpFoundation\Request;
use Symfony\Component\HttpFoundation\Response;
use Symfony\Component\Routing\Attribute\Route;
use Symfony\Component\String\Slugger\SluggerInterface;

#[Route('/backoffice')]
class BackOfficeController extends AbstractController
{
    public function __construct(
        private ProduitRepository $produitRepo,
        private StockRepository $stockRepo,
        private EntityManagerInterface $em,
        private SluggerInterface $slugger,
    ) {}

    #[Route('/gestion', name: 'gestion_home')]           // ou garde '/admin' si tu préfères
#[Route('/admin', name: 'admin')]
public function index(ProduitRepository $produitRepository, StockRepository $stockRepository): Response
{
    $produits = $produitRepository->findAll();
    $stocks = $stockRepository->findAll();

    // Calcul des statistiques
    $totalProduits = count($produits);
    $totalStocks   = count($stocks);
    $totalAlertes  = 0;
    $valeurTotale  = 0;

    $categorieData = [];

    foreach ($produits as $produit) {
        $valeurTotale += $produit->getPrixUnitaire() * ($produit->getStockActuel()?->getQuantiteActuelle() ?? 0);

        $cat = $produit->getCategorie() ? $produit->getCategorie()->getNom() : 'Sans catégorie';
        $categorieData[$cat] = ($categorieData[$cat] ?? 0) + 1;

        // Compter les alertes
        if ($produit->getStockActuel() && $produit->getStockActuel()->isEnAlerte()) {
            $totalAlertes++;
        }
    }

    return $this->render('backoffice/index.html.twig', [
        'produits'      => $produits,
        'stocks'        => $stocks,
        'alertes'       => [],                    // tu peux remplir plus tard
        'totalProduits' => $totalProduits,
        'totalStocks'   => $totalStocks,
        'totalAlertes'  => $totalAlertes,
        'valeurTotale'  => number_format($valeurTotale, 2, ',', ' '),
        'categorieData' => $categorieData,
        'search'        => '',                    // pour la recherche future
    ]);

    }

    // ── PRODUIT ──────────────────────────────────────────────────────────────

    #[Route('/produit/nouveau', name: 'produit_new')]
    public function newProduit(Request $request): Response
    {
        $produit = new Produit();
        $stock   = new Stock();
        $formP   = $this->createForm(ProduitType::class, $produit);
        $formS   = $this->createForm(StockType::class, $stock, ['show_produit' => false]);

        $formP->handleRequest($request);
        $formS->handleRequest($request);

        if ($formP->isSubmitted() && $formP->isValid() && $formS->isSubmitted() && $formS->isValid()) {
            $this->handlePhoto($formP, $produit);
            $stock->setProduit($produit);
            $this->em->persist($produit);
            $this->em->persist($stock);
            $this->em->flush();
            $this->addFlash('success', '✅ Produit et stock créés avec succès !');
            return $this->redirectToRoute('admin');
        }

        return $this->render('produit/form.html.twig', [
            'formP'    => $formP,
            'formS'    => $formS,
            'produit'  => null,
            'title'    => '🌱 Ajouter Produit et Stock',
            'subtitle' => 'Créez un nouveau produit et configurez son stock initial',
            'btnLabel' => '✓ Enregistrer Produit',
        ]);
    }

    #[Route('/produit/{id}/modifier', name: 'produit_edit')]
    public function editProduit(Request $request, Produit $produit): Response
    {
        $stock = $produit->getStockActuel() ?? new Stock();
        $formP = $this->createForm(ProduitType::class, $produit);
        $formS = $this->createForm(StockType::class, $stock, ['show_produit' => false]);

        $formP->handleRequest($request);
        $formS->handleRequest($request);

        if ($formP->isSubmitted() && $formP->isValid() && $formS->isSubmitted() && $formS->isValid()) {
            $this->handlePhoto($formP, $produit);
            if ($stock->getProduit() === null) {
                $stock->setProduit($produit);
                $this->em->persist($stock);
            }
            $this->em->flush();
            $this->addFlash('success', '✅ Produit modifié avec succès !');
            return $this->redirectToRoute('admin');
        }

        return $this->render('produit/form.html.twig', [
            'formP'    => $formP,
            'formS'    => $formS,
            'produit'  => $produit,
            'title'    => '✏️ Modifier Produit et Stock',
            'subtitle' => 'Mettez à jour les informations du produit et de son stock',
            'btnLabel' => '✓ Enregistrer Modifications',
        ]);
    }

    #[Route('/produit/{id}/supprimer', name: 'produit_delete', methods: ['POST'])]
    public function deleteProduit(Request $request, Produit $produit): Response
    {
        if ($this->isCsrfTokenValid('delete'.$produit->getId(), $request->getPayload()->getString('_token'))) {
            $this->em->remove($produit);
            $this->em->flush();
            $this->addFlash('success', '🗑️ Produit supprimé.');
        }
        return $this->redirectToRoute('admin');
    }

    // ── STOCK ─────────────────────────────────────────────────────────────────

    #[Route('/stock/nouveau', name: 'stock_new')]
    public function newStock(Request $request): Response
    {
        $stock = new Stock();
        $form  = $this->createForm(StockType::class, $stock);
        $form->handleRequest($request);

        if ($form->isSubmitted() && $form->isValid()) {
            $this->em->persist($stock);
            $this->em->flush();
            $this->addFlash('success', '✅ Stock ajouté avec succès !');
            return $this->redirectToRoute('admin');
        }

        return $this->render('stock/form.html.twig', [
            'form'     => $form,
            'stock'    => null,
            'title'    => '➕ Ajouter Stock',
            'subtitle' => 'Ajoutez du stock pour un produit existant',
            'btnLabel' => '✓ Ajouter au Stock',
        ]);
    }

    #[Route('/stock/{id}/modifier', name: 'stock_edit')]
    public function editStock(Request $request, Stock $stock): Response
    {
        $form = $this->createForm(StockType::class, $stock, ['show_produit' => false]);
        $form->handleRequest($request);

        if ($form->isSubmitted() && $form->isValid()) {
            $this->em->flush();
            $this->addFlash('success', '✅ Stock modifié avec succès !');
            return $this->redirectToRoute('admin');
        }

        return $this->render('stock/form.html.twig', [
            'form'     => $form,
            'stock'    => $stock,
            'title'    => '✏️ Modifier Stock',
            'subtitle' => 'Mettez à jour les informations du stock',
            'btnLabel' => '✓ Enregistrer Modifications',
        ]);
    }

    #[Route('/stock/{id}/supprimer', name: 'stock_delete', methods: ['POST'])]
    public function deleteStock(Request $request, Stock $stock): Response
    {
        if ($this->isCsrfTokenValid('delete'.$stock->getId(), $request->getPayload()->getString('_token'))) {
            $this->em->remove($stock);
            $this->em->flush();
            $this->addFlash('success', '🗑️ Stock supprimé.');
        }
        return $this->redirectToRoute('admin');
    }

    // ── HELPER ───────────────────────────────────────────────────────────────

    private function handlePhoto($form, Produit $produit): void
    {
        $photoFile = $form->get('photoFile')->getData();
        if (!$photoFile) return;
        $safe = $this->slugger->slug(pathinfo($photoFile->getClientOriginalName(), PATHINFO_FILENAME));
        $filename = $safe.'-'.uniqid().'.'.$photoFile->guessExtension();
        try {
            $photoFile->move($this->getParameter('photos_directory'), $filename);
            $produit->setPhotoUrl('uploads/photos/'.$filename);
        } catch (FileException) {
            $this->addFlash('error', 'Erreur lors du téléchargement de la photo.');
        }
    }
}
