{% extends 'base.html.twig' %}

{% set activePage = 'cultures_admin' %}
{% set activeSection = 'main' %}

{% block title %}Analytique IA — Rendements (Admin) — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }

    /* KPI Cards */
    .analytics-kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 35px; }
    .analytics-kpi-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; padding: 25px; box-shadow: var(--sh-lg); display: flex; flex-direction: column; gap: 10px; }
    .kpi-icon { font-size: 2rem; margin-bottom: 5px; }
    .kpi-value { font-size: 1.8rem; font-weight: 900; color: var(--ch3); line-height: 1; }
    .kpi-label { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; color: var(--cp); letter-spacing: 0.5px; }

    .kpi-green { border-left: 5px solid #4CAF50; }
    .kpi-blue  { border-left: 5px solid #2196F3; }
    .kpi-amber { border-left: 5px solid #FF9800; }
    .kpi-teal  { border-left: 5px solid #009688; }

    /* Analytics Cards */
    .analytics-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; box-shadow: var(--sh-lg); overflow: hidden; margin-bottom: 35px; }
    .analytics-card-header { padding: 25px 30px; border-bottom: 1px solid var(--cbr); background: rgba(0,0,0,0.02); }
    .analytics-card-title { margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--ch3); display: flex; align-items: center; gap: 12px; }

    /* Tables */
    .analytics-table { width: 100%; border-collapse: collapse; }
    .analytics-table th { padding: 18px 25px; text-align: left; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--cp); border-bottom: 1px solid var(--cbr); background: rgba(0,0,0,0.05); }
    .analytics-table td { padding: 18px 25px; border-bottom: 1px solid var(--cbr); color: var(--ch3); font-weight: 600; }
    .analytics-table tr:last-child td { border-bottom: none; }
    .analytics-table tbody tr:hover td { background: rgba(90,181,90,0.03); }

    .empty-state { padding: 80px 40px; text-align: center; background: var(--cb); border-radius: 30px; border: 2px dashed var(--cbr); }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}
    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>
        <div class="content-wrapper" style="padding: 40px 60px;">

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('admin_culture_dashboard') }}">📊 Dashboard</a> /
            Analytique IA
        </p>
        <h1 class="page-title">🤖 Analytique IA — Rendements</h1>
        <p class="page-subtitle">Analyse des {{ harvests|length }} récolte(s) enregistrée(s) par le modèle IA</p>
    </div>
    <div>
        <a href="{{ path('admin_culture_dashboard') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour au Dashboard</a>
    </div>
</div>

{# ── Compute totals in twig ── #}
{% set totalKg   = 0 %}
{% set totalSurf = 0 %}
{% set byNom     = {} %}

{% for h in harvests %}
    {% set totalKg   = totalKg   + (h.quantiteRecolte ?? 0) %}
    {% set totalSurf = totalSurf + (h.surface ?? 0) %}
    {% set nom = h.cultureNom ?? 'Inconnu' %}
    {% if byNom[nom] is not defined %}
        {% set byNom = byNom|merge({(nom): {qty: 0, count: 0, surface: 0}}) %}
    {% endif %}
    {% set byNom = byNom|merge({(nom): {
        qty:     byNom[nom].qty     + (h.quantiteRecolte ?? 0),
        count:   byNom[nom].count   + 1,
        surface: byNom[nom].surface + (h.surface ?? 0)
    }}) %}
{% endfor %}

{% if harvests is empty %}
<div class="empty-state">
    <div class="empty-icon">🤖</div>
    <div class="empty-title">Aucune récolte IA enregistrée</div>
    <div class="empty-subtitle">
        Les données apparaîtront ici après les premières récoltes.
    </div>
</div>
{% else %}

<div class="analytics-kpi-grid">
    <div class="analytics-kpi-card kpi-green">
        <div class="kpi-icon">🌾</div>
        <div class="kpi-value">{{ totalKg|number_format(1,',',' ') }} kg</div>
        <div class="kpi-label">Production totale</div>
    </div>
    <div class="analytics-kpi-card kpi-blue">
        <div class="kpi-icon">📊</div>
        <div class="kpi-value">{{ harvests|length }}</div>
        <div class="kpi-label">Récoltes IA</div>
    </div>
    <div class="analytics-kpi-card kpi-amber">
        <div class="kpi-icon">📐</div>
        <div class="kpi-value">{{ totalSurf|number_format(0,',',' ') }} m²</div>
        <div class="kpi-label">Surface totale</div>
    </div>
    <div class="analytics-kpi-card kpi-teal">
        <div class="kpi-icon">⚡</div>
        <div class="kpi-value">
            {{ totalSurf > 0 ? (totalKg / totalSurf)|number_format(2,',',' ') : '—' }} <span style="font-size:1rem;opacity:0.6;">kg/m²</span>
        </div>
        <div class="kpi-label">Rendement moyen</div>
    </div>
</div>

<div class="analytics-card">
    <div class="analytics-card-header">
        <h3 class="analytics-card-title">📈 Production & Rendement par culture</h3>
    </div>
    <div style="padding:30px;">
        <canvas id="yieldChart" height="100"></canvas>
    </div>
</div>

<div class="analytics-card">
    <div class="analytics-card-header">
        <h3 class="analytics-card-title">🌱 Détail par type de culture</h3>
    </div>
    <div style="overflow-x:auto;">
        <table class="analytics-table">
            <thead>
                <tr>
                    <th>Culture</th>
                    <th>Récoltes</th>
                    <th>Qté (kg)</th>
                    <th>Surface (m²)</th>
                    <th>Rendement (kg/m²)</th>
                </tr>
            </thead>
            <tbody>
                {% for nom, data in byNom %}
                <tr>
                    <td style="color:var(--g);"><strong>{{ nom }}</strong></td>
                    <td>{{ data.count }}</td>
                    <td style="font-weight:800;">{{ data.qty|number_format(1,',',' ') }}</td>
                    <td>{{ data.surface|number_format(1,',',' ') }}</td>
                    <td>
                        {% if data.surface > 0 %}
                            <span style="padding:4px 10px; background:rgba(90,181,90,0.1); border-radius:8px; color:var(--g);">
                                {{ (data.qty / data.surface)|number_format(3,',',' ') }}
                            </span>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr style="background: rgba(0,0,0,0.1); font-weight:800;">
                    <td>Total</td>
                    <td>{{ harvests|length }}</td>
                    <td>{{ totalKg|number_format(1,',',' ') }}</td>
                    <td>{{ totalSurf|number_format(1,',',' ') }}</td>
                    <td>{{ totalSurf > 0 ? (totalKg / totalSurf)|number_format(3,',',' ') : '—' }}</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="analytics-card">
    <div class="analytics-card-header">
        <h3 class="analytics-card-title">🕐 Journal des récoltes</h3>
    </div>
    <div style="overflow-x:auto;">
        <table class="analytics-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Culture</th>
                    <th>Type</th>
                    <th>Quantité IA</th>
                    <th>Surface</th>
                    <th>Analyse IA</th>
                </tr>
            </thead>
            <tbody>
                {% for h in harvests %}
                <tr>
                    <td>{{ h.dateAction|date('d/m/Y') }}</td>
                    <td><strong style="color:var(--g)">{{ h.cultureNom ?? '—' }}</strong></td>
                    <td style="font-size:0.8rem;text-transform:uppercase;font-weight:800;opacity:0.7;">{{ h.typeCulture ?? '—' }}</td>
                    <td style="font-weight:800;">{{ h.quantiteRecolte|number_format(1,',',' ') }} kg</td>
                    <td>{{ h.surface|number_format(0,',',' ') }} m²</td>
                    <td style="font-size:0.85rem; color:var(--cp); max-width:300px; line-height:1.4;">
                        {{ h.description ?? '—' }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endif %}

        </div>
    </main>
</div>

{% if harvests is not empty %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
    (function() {
        const byNom = {{ byNom|json_encode|raw }};
        const labels = Object.keys(byNom);
        const qtys   = labels.map(n => byNom[n].qty);
        const yields = labels.map(n => byNom[n].surface > 0 ? byNom[n].qty / byNom[n].surface : 0);

        const ctx = document.getElementById('yieldChart');
        if (!ctx) return;

        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#a0a0a0' : '#666';

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    {
                        label: 'Production (kg)',
                        data: qtys,
                        backgroundColor: 'rgba(90, 181, 90, 0.6)',
                        borderColor: '#5ab55a',
                        borderWidth: 2,
                        borderRadius: 8,
                        yAxisID: 'y',
                    },
                    {
                        label: 'Rendement (kg/m²)',
                        data: yields,
                        type: 'line',
                        borderColor: '#ffa502',
                        backgroundColor: 'rgba(255, 165, 2, 0.1)',
                        borderWidth: 3,
                        pointRadius: 5,
                        pointBackgroundColor: '#ffa502',
                        tension: 0.4,
                        yAxisID: 'y2',
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { labels: { color: textColor, font: { weight: 'bold' } } }
                },
                scales: {
                    y: {
                        position: 'left',
                        title: { display: true, text: 'kg', color: textColor },
                        ticks: { color: textColor },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    },
                    y2: {
                        position: 'right',
                        title: { display: true, text: 'kg/m²', color: textColor },
                        ticks: { color: textColor },
                        grid: { display: false }
                    },
                    x: {
                        ticks: { color: textColor },
                        grid: { display: false }
                    }
                }
            }
        });
    })();

    /* ── SIDEBAR & THEME TOGGLES ── */
    const sidebarToggle = document.getElementById('sidebarToggle');
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle('open');
            } else {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');
            }
        });
    }
    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const html = document.documentElement;
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endif %}
{% endblock %}
