<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Accueil Admin — AgriSense 360</title>
    <link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}">
    <style>
        .stats-row { display: grid; grid-template-columns: repeat(5,1fr); gap: 14px; margin: 0 36px 24px; }
        .stat-card { background: var(--white); border-radius: var(--radius); padding: 20px 18px; box-shadow: var(--shadow-md); border-top: 4px solid var(--border); transition: transform .18s; }
        .stat-card:hover { transform: translateY(-3px); }
        .stat-card.green  { border-top-color: #4caf50; }
        .stat-card.blue   { border-top-color: #1976d2; }
        .stat-card.orange { border-top-color: #f57c00; }
        .stat-card.teal   { border-top-color: #00897b; }
        .stat-emoji { font-size: 1.5rem; margin-bottom: 8px; display: block; }
        .stat-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--text-mute); }
        .stat-value { font-family: 'Fraunces',serif; font-size: 2rem; font-weight: 700; color: var(--text-dark); margin: 4px 0 0; }
        .content-grid { display: grid; grid-template-columns: 1fr 320px; gap: 20px; margin: 0 36px 36px; }
        .recent-item { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #f0f8f0; }
        .recent-item:last-child { border-bottom: none; }
        .rec-av { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg,#1a4a2a,#4caf50); color: #fff; font-weight: 800; font-size: .85rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .rec-name { font-size: .86rem; font-weight: 700; }
        .rec-email { font-size: .74rem; color: var(--text-mute); }
        .quick-list { display: flex; flex-direction: column; gap: 10px; }
        .quick-btn { display: flex; align-items: center; gap: 12px; padding: 13px 16px; border-radius: var(--radius-sm); background: #fafcf8; border: 1.5px solid var(--border); text-decoration: none; color: var(--text-dark); font-size: .88rem; font-weight: 600; transition: border-color .18s, background .18s; }
        .quick-btn:hover { border-color: var(--green-400); background: var(--green-100); }
        .quick-icon { font-size: 1.2rem; }
    </style>
</head>
<body class="sidebar-collapsed">
{% set activePage = 'accueil' %}
{% set activeSection = 'main' %}

<div class="ambient" aria-hidden="true">
    <div class="ambient-leaf"><svg viewBox="0 0 64 64"><path d="M10 40C18 18 38 8 54 10c-2 18-12 36-34 44z" fill="currentColor"/></svg></div>
    <div class="ambient-leaf leaf-2"><svg viewBox="0 0 64 64"><path d="M12 46C18 22 36 10 54 12z" fill="currentColor"/></svg></div>
    <div class="ambient-leaf leaf-3"><svg viewBox="0 0 64 64"><path d="M10 40C18 18 38 8 54 10z" fill="currentColor"/></svg></div>
    <div class="ambient-leaf leaf-4"><svg viewBox="0 0 64 64"><path d="M12 46C18 22 36 10 54 12z" fill="currentColor"/></svg></div>
</div>

<div class="page">
    {% include 'partials/sidebar.html.twig' %}

    <main class="content">
        <header class="topbar">
            <div class="topbar-left">
                <button class="sidebar-toggle" type="button" onclick="_sbToggle()">
                    <span class="toggle-icon"><span></span></span>
                    <span class="toggle-text">Réduire le menu</span>
                </button>
                <h1>Bonjour, {{ app.user.name }} 👋</h1>
                <p class="topbar-sub">Bienvenue sur le tableau de bord administrateur d'AgriSense 360.</p>
            </div>
            <div class="topbar-right">
                <div class="top-stat"><span class="sv">{{ total }}</span><span class="sl">Utilisateurs</span></div>
                <div class="top-stat"><span class="sv">{{ actifs }}</span><span class="sl">Actifs</span></div>
            </div>
        </header>

        {% for msg in app.flashes('success') %}<div class="flash-success" style="margin:0 36px 16px;">✓ {{ msg }}</div>{% endfor %}

        <div class="stats-row">
            <div class="stat-card green"><span class="stat-emoji">👥</span><div class="stat-label">Total utilisateurs</div><div class="stat-value">{{ total }}</div></div>
            <div class="stat-card blue"><span class="stat-emoji">🛡️</span><div class="stat-label">Administrateurs</div><div class="stat-value">{{ admins }}</div></div>
            <div class="stat-card orange"><span class="stat-emoji">🧑‍💼</span><div class="stat-label">Gérants</div><div class="stat-value">{{ gerants }}</div></div>
            <div class="stat-card teal"><span class="stat-emoji">👷</span><div class="stat-label">Ouvriers</div><div class="stat-value">{{ ouvriers }}</div></div>
            <div class="stat-card green"><span class="stat-emoji">✅</span><div class="stat-label">Comptes actifs</div><div class="stat-value">{{ actifs }}</div></div>
        </div>

        <div class="content-grid">
            <div class="card">
                <div class="card-head">
                    <span class="card-title">🕐 Utilisateurs récents</span>
                    <a href="{{ path('admin_dashboard') }}" style="padding:6px 14px;border-radius:50px;background:var(--green-100);color:#1b5e20;border:1px solid #a5d6a7;font-size:.78rem;font-weight:700;text-decoration:none;">Voir tous</a>
                </div>
                <div class="card-body">
                    {% for u in recent %}
                    <div class="recent-item">
                        <div class="rec-av">{{ u.name|first|upper }}</div>
                        <div style="flex:1;"><div class="rec-name">{{ u.name }}</div><div class="rec-email">{{ u.email }}</div></div>
                        {% set r = u.getRoles() %}
                        {% if 'ROLE_ADMIN' in r %}<span class="badge badge-blue">Admin</span>
                        {% elseif 'ROLE_GERANT' in r %}<span class="badge badge-green">Gérant</span>
                        {% else %}<span class="badge badge-orange">Ouvrier</span>{% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
            <div class="card">
                <div class="card-head"><span class="card-title">⚡ Actions rapides</span></div>
                <div class="card-body">
                    <div class="quick-list">
                        <a href="{{ path('admin_user_add') }}" class="quick-btn"><span class="quick-icon">➕</span> Ajouter un utilisateur</a>
                        <a href="{{ path('admin_dashboard') }}" class="quick-btn"><span class="quick-icon">👥</span> Gérer les utilisateurs</a>
                        <a href="{{ path('profile_show') }}" class="quick-btn"><span class="quick-icon">⚙️</span> Mon profil</a>
                        <a href="{{ path('app_logout') }}" class="quick-btn" style="color:#c62828;border-color:#f5c6cb;">
                            <span class="quick-icon">🚪</span> Déconnexion
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
</body>
</html>
