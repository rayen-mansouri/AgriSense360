{% extends 'base.html.twig' %}

{% block title %}Accueil Admin — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 24px; }
    .stat-card { background: var(--cb); border-radius: 20px; padding: 24px; box-shadow: var(--shadow-sm); border: 1px solid var(--cbr); border-top: 4px solid var(--border); transition: transform .18s; }
    .stat-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); }
    .stat-card.green  { border-top-color: #4caf50; }
    .stat-card.blue   { border-top-color: #2196f3; }
    .stat-card.orange { border-top-color: #f59e0b; }
    .stat-card.teal   { border-top-color: #00897b; }
    .stat-emoji { font-size: 1.8rem; margin-bottom: 12px; display: block; }
    .stat-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--cp); }
    .stat-value { font-size: 2.2rem; font-weight: 800; color: var(--ch3); margin: 6px 0 0; }
    .content-grid { display: grid; grid-template-columns: 1fr 320px; gap: 24px; }
    @media (max-width: 992px) { .content-grid { grid-template-columns: 1fr; } }
    .recent-item { display: flex; align-items: center; gap: 14px; padding: 12px 0; border-bottom: 1px solid var(--cbr); }
    .recent-item:last-child { border-bottom: none; }
    .rec-av { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--g), var(--gm)); color: #fff; font-weight: 800; font-size: .95rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .rec-name { font-size: .9rem; font-weight: 700; color: var(--ch3); }
    .rec-email { font-size: .78rem; color: var(--cp); }
    .quick-list { display: flex; flex-direction: column; gap: 12px; }
    .quick-btn { display: flex; align-items: center; gap: 12px; padding: 14px 18px; border-radius: 12px; background: var(--surface2); border: 1px solid var(--cbr); text-decoration: none; color: var(--ch3); font-size: .9rem; font-weight: 600; transition: all .2s; }
    .quick-btn:hover { border-color: var(--g); background: rgba(90,181,90,0.08); color: var(--g); transform: translateX(5px); }
    .quick-icon { font-size: 1.3rem; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="content-wrapper">
            <div class="page-header" style="margin-bottom: 30px;">
                <div class="page-header-left">
                    <h1 class="page-title">Bonjour, {{ app.user.name }} 👋</h1>
                    <p class="page-subtitle">Bienvenue sur le tableau de bord administrateur d'AgriSense 360.</p>
                </div>
            </div>

            {% for msg in app.flashes('success') %}
                <div style="padding: 15px 20px; background: rgba(76,175,80,0.1); border-left: 4px solid #4caf50; color: #4caf50; border-radius: 8px; margin-bottom: 24px; font-weight: 600;">
                    ✓ {{ msg }}
                </div>
            {% endfor %}

            <div class="stats-row">
                <div class="stat-card green"><span class="stat-emoji">👥</span><div class="stat-label">Total utilisateurs</div><div class="stat-value">{{ total }}</div></div>
                <div class="stat-card blue"><span class="stat-emoji">🛡️</span><div class="stat-label">Administrateurs</div><div class="stat-value">{{ admins }}</div></div>
                <div class="stat-card orange"><span class="stat-emoji">🧑‍💼</span><div class="stat-label">Gérants</div><div class="stat-value">{{ gerants }}</div></div>
                <div class="stat-card teal"><span class="stat-emoji">👷</span><div class="stat-label">Ouvriers</div><div class="stat-value">{{ ouvriers }}</div></div>
                <div class="stat-card green"><span class="stat-emoji">✅</span><div class="stat-label">Comptes actifs</div><div class="stat-value">{{ actifs }}</div></div>
            </div>

            <div class="content-grid">
                <div class="card">
                    <div class="card-head">
                        <span class="card-title">🕐 Utilisateurs récents</span>
                        <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary btn-sm">Voir tous</a>
                    </div>
                    <div class="card-body">
                        {% for u in recent %}
                        <div class="recent-item">
                            <div class="rec-av">{{ u.name|first|upper }}</div>
                            <div style="flex:1;"><div class="rec-name">{{ u.name }}</div><div class="rec-email">{{ u.email }}</div></div>
                            {% set r = u.getRoles() %}
                            {% if 'ROLE_ADMIN' in r %}<span class="badge badge-blue">Admin</span>
                            {% elseif 'ROLE_GERANT' in r %}<span class="badge badge-green">Gérant</span>
                            {% else %}<span class="badge badge-orange">Ouvrier</span>{% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="card">
                    <div class="card-head"><span class="card-title">⚡ Actions rapides</span></div>
                    <div class="card-body">
                        <div class="quick-list">
                            <a href="{{ path('admin_user_add') }}" class="quick-btn"><span class="quick-icon">➕</span> Ajouter un utilisateur</a>
                            <a href="{{ path('admin_dashboard') }}" class="quick-btn"><span class="quick-icon">👥</span> Gérer les utilisateurs</a>
                            <a href="{{ path('profile_show') }}" class="quick-btn"><span class="quick-icon">⚙️</span> Mon profil</a>
                            <a href="{{ path('app_logout') }}" class="quick-btn" style="color:var(--danger);border-color:var(--danger);">
                                <span class="quick-icon">🚪</span> Déconnexion
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
