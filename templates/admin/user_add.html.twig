{% extends 'base.html.twig' %}

{% block title %}Ajouter un utilisateur — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .form-card { max-width: 800px; margin-top: 20px; }
    .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-label { font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--cp); }
    .form-input, .form-select { padding: 12px 16px; border: 1px solid var(--cbr); border-radius: 12px; background: var(--cb); color: var(--ch3); outline: none; transition: all .2s; width: 100%; }
    .form-input:focus, .form-select:focus { border-color: var(--g); box-shadow: 0 0 0 3px rgba(76,175,80,0.1); }
    
    .role-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-top: 10px; }
    .role-option input[type="radio"] { display: none; }
    .role-card { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 20px; border: 2px solid var(--cbr); border-radius: 16px; cursor: pointer; transition: all .2s; background: var(--surface2); text-align: center; }
    .role-card:hover { border-color: var(--g); background: rgba(90,181,90,0.05); }
    .role-option input:checked + .role-card { border-color: var(--g); background: rgba(90,181,90,0.08); transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .role-card-icon { font-size: 2rem; }
    .role-card-name { font-size: .95rem; font-weight: 700; color: var(--ch3); }
    .role-card-desc { font-size: .75rem; color: var(--cp); }

    .status-options { display: flex; gap: 12px; margin-top: 8px; }
    .status-opt input[type="radio"] { display: none; }
    .status-opt label { padding: 10px 24px; border: 2px solid var(--cbr); border-radius: 50px; cursor: pointer; font-size: .85rem; font-weight: 700; color: var(--cp); background: var(--surface2); transition: all .2s; }
    .status-opt input:checked + label { border-color: var(--g); background: rgba(90,181,90,0.1); color: var(--g); }

    .section-title { font-size: .85rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--cp); margin: 30px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--cbr); }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="content-wrapper">
            <div class="page-header" style="margin-bottom: 30px;">
                <div class="page-header-left">
                    <h1 class="page-title">Ajouter un utilisateur</h1>
                    <p class="page-subtitle">Créez un nouveau compte avec un rôle spécifique.</p>
                </div>
            </div>

            {% if error %}
                <div style="padding:15px 20px;background:rgba(244,67,54,0.1);border-left:4px solid #f44336;color:#f44336;border-radius:8px;margin-bottom:20px;font-weight:600;">⚠ {{ error }}</div>
            {% endif %}

            <div class="card form-card">
                <form method="post" enctype="multipart/form-data">
                    <div class="card-body">
                        <p class="section-title" style="margin-top:0;">Informations personnelles</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nom complet *</label>
                                <input type="text" name="name" class="form-input" placeholder="Ex: Ahmed Ben Ali" value="{{ app.request.request.get('name') }}" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Adresse email *</label>
                                <input type="email" name="email" class="form-input" placeholder="Ex: ahmed@agrisense.tn" value="{{ app.request.request.get('email') }}" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Téléphone</label>
                                <input type="tel" name="phone" class="form-input" placeholder="Ex: 55 123 456" value="{{ app.request.request.get('phone') }}">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Statut du compte</label>
                                <div class="status-options">
                                    <div class="status-opt">
                                        <input type="radio" name="status" id="status_active" value="active" checked>
                                        <label for="status_active">✓ Actif</label>
                                    </div>
                                    <div class="status-opt">
                                        <input type="radio" name="status" id="status_inactive" value="inactive">
                                        <label for="status_inactive">✗ Inactif</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <p class="section-title">Rôle de l'utilisateur</p>
                        <div class="role-grid">
                            <div class="role-option">
                                <input type="radio" name="role" id="role_admin" value="ROLE_ADMIN">
                                <label class="role-card" for="role_admin">
                                    <span class="role-card-icon">🛡️</span>
                                    <span class="role-card-name">Administrateur</span>
                                    <span class="role-card-desc">Accès complet</span>
                                </label>
                            </div>
                            <div class="role-option">
                                <input type="radio" name="role" id="role_gerant" value="ROLE_GERANT" checked>
                                <label class="role-card" for="role_gerant">
                                    <span class="role-card-icon">🧑‍💼</span>
                                    <span class="role-card-name">Gérant</span>
                                    <span class="role-card-desc">Opérations</span>
                                </label>
                            </div>
                            <div class="role-option">
                                <input type="radio" name="role" id="role_ouvrier" value="ROLE_OUVRIER">
                                <label class="role-card" for="role_ouvrier">
                                    <span class="role-card-icon">👷</span>
                                    <span class="role-card-name">Ouvrier</span>
                                    <span class="role-card-desc">Tâches limitées</span>
                                </label>
                            </div>
                        </div>

                        <p class="section-title">Sécurité et Documents</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Mot de passe *</label>
                                <input type="password" name="password" class="form-input" placeholder="Min. 6 caractères" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirmer le mot de passe *</label>
                                <input type="password" name="confirm_password" class="form-input" placeholder="Répéter le mot de passe" required>
                            </div>
                            <div class="form-group full">
                                <label class="form-label">Curriculum Vitae (CV) *</label>
                                <input type="file" name="cv" class="form-input" required>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer" style="padding: 20px 30px; background: var(--surface2); border-top: 1px solid var(--cbr); display: flex; gap: 12px; justify-content: flex-end;">
                        <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">✓ Créer l'utilisateur</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>
{% endblock %}
