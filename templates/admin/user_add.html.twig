{% extends 'base.html.twig' %}

{% block title %}Ajouter un utilisateur — AgriSense 360{% endblock %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
        --sidebar-bg: #1a3a1a; --green-dark: #1e5c1e; --green-mid: #2e7d32;
        --green-light: #4caf50; --green-pale: #e8f5e9; --bg: #f4f6f0;
        --white: #ffffff; --text-dark: #1a2e1a; --text-mid: #4a6741;
        --text-light: #8fa887; --border: #dde8d8;
        --shadow-md: 0 4px 16px rgba(0,0,0,.08); --radius: 16px; --radius-sm: 10px;
    }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text-dark); }
    .layout { display: flex; min-height: 100vh; }

    /* Sidebar */
    .sidebar { width: 260px; background: var(--sidebar-bg); display: flex; flex-direction: column; flex-shrink: 0; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; padding: 22px 20px 16px; border-bottom: 1px solid rgba(255,255,255,.08); }
    .brand-icon { width: 38px; height: 38px; background: var(--green-light); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .brand-name { font-size: 1rem; font-weight: 800; color: #fff; }
    .brand-sub  { font-size: .7rem; color: rgba(255,255,255,.45); }
    .nav-section-label { padding: 16px 20px 6px; font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.3); }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 11px 20px; color: rgba(255,255,255,.6); text-decoration: none; font-size: .88rem; font-weight: 500; margin: 1px 8px; border-radius: 8px; transition: background .15s, color .15s; }
    .nav-item:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.9); }
    .nav-item.active { background: #2d6e2d; color: #fff; font-weight: 600; }
    .nav-icon { width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: .95rem; }
    .nav-item.active .nav-icon { background: rgba(255,255,255,.12); }
    .sidebar-bottom { margin-top: auto; padding: 12px 8px; border-top: 1px solid rgba(255,255,255,.08); }

    /* Main */
    .main { margin-left: 260px; flex: 1; padding: 36px; }
    .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: var(--text-light); margin-bottom: 24px; }
    .breadcrumb a { color: var(--green-mid); text-decoration: none; font-weight: 600; }
    .breadcrumb a:hover { text-decoration: underline; }

    .flash-error   { background: #fde8e8; border: 1px solid #f5c6cb; color: #842029; padding: 12px 18px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: .9rem; }
    .flash-success { background: var(--green-pale); border: 1px solid #a5d6a7; color: var(--green-dark); padding: 12px 18px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: .9rem; font-weight: 600; }

    /* Form card */
    .form-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow-md); overflow: hidden; max-width: 720px; }

    .card-header { padding: 22px 28px; border-bottom: 1px solid var(--border); background: var(--green-pale); }
    .card-title { font-size: 1.1rem; font-weight: 800; color: var(--text-dark); }
    .card-sub { font-size: .82rem; color: var(--text-light); margin-top: 3px; }

    .card-body { padding: 32px 28px; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group.full { grid-column: 1 / -1; }

    .form-group label { font-size: .72rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-light); }

    .form-input, .form-select {
        padding: 11px 16px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: .9rem;
        color: var(--text-dark);
        background: #fafcf8;
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        width: 100%;
    }

    .form-input:focus, .form-select:focus { border-color: var(--green-light); box-shadow: 0 0 0 3px rgba(76,175,80,.1); }
    .form-input::placeholder { color: var(--text-light); }

    /* Role cards */
    .role-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .role-option input[type="radio"] { display: none; }

    .role-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 18px 12px;
        border: 2px solid var(--border);
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: all .2s;
        background: #fafcf8;
        text-align: center;
    }

    .role-card:hover { border-color: var(--green-mid); background: var(--green-pale); }
    .role-option input:checked + .role-card {
        border-color: var(--green-mid);
        background: var(--green-pale);
        box-shadow: 0 0 0 3px rgba(46,125,50,.1);
    }

    .role-card-icon { font-size: 1.8rem; }
    .role-card-name { font-size: .88rem; font-weight: 700; color: var(--text-dark); }
    .role-card-desc { font-size: .72rem; color: var(--text-light); }

    /* Status toggle */
    .status-options { display: flex; gap: 12px; }
    .status-opt input[type="radio"] { display: none; }
    .status-opt label {
        padding: 10px 20px;
        border: 2px solid var(--border);
        border-radius: 50px;
        cursor: pointer;
        font-size: .85rem;
        font-weight: 700;
        color: var(--text-mid);
        background: #fafcf8;
        transition: all .2s;
    }
    .status-opt input:checked + label { border-color: var(--green-mid); background: var(--green-pale); color: var(--green-dark); }

    /* Divider */
    .section-divider { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
    .section-title { font-size: .8rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--text-light); margin-bottom: 16px; }

    /* Actions */
    .action-bar { display: flex; align-items: center; gap: 12px; padding: 20px 28px; border-top: 1px solid var(--border); background: #fafcf8; }

    .btn { display: inline-flex; align-items: center; gap: 7px; padding: 11px 24px; border-radius: 50px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: .88rem; font-weight: 700; cursor: pointer; border: none; text-decoration: none; transition: filter .2s, transform .1s; }
    .btn:hover { filter: brightness(.92); transform: translateY(-1px); }
    .btn-save   { background: var(--green-mid); color: #fff; }
    .btn-cancel { background: var(--green-pale); color: var(--green-dark); border: 1.5px solid #a5d6a7; }
    .btn-cancel:hover { filter: none; background: #c8e6c9; }
</style>
{% endblock %}

{% block body %}
<div class="layout">

    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🌱</div>
            <div>
                <div class="brand-name">AgriSense 360</div>
                <div class="brand-sub">Smart AI Companion for Far...</div>
            </div>
        </div>
        <p class="nav-section-label">Managements</p>
        <a href="{{ path('admin_dashboard') }}" class="nav-item active">
            <div class="nav-icon">👥</div> User Management
        </a>
        <div class="sidebar-bottom">
            <a href="{{ path('app_logout') }}" class="nav-item" style="margin:0;">
                <div class="nav-icon">🚪</div> Logout
            </a>
        </div>
    </aside>

    <main class="main">
        <div class="breadcrumb">
            <a href="{{ path('admin_dashboard') }}">👥 Utilisateurs</a>
            <span>›</span>
            <span>Ajouter un utilisateur</span>
        </div>

        {% if error %}
            <div class="flash-error">⚠ {{ error }}</div>
        {% endif %}

        <div class="form-card">
            <div class="card-header">
                <div class="card-title">➕ Nouvel utilisateur</div>
                <div class="card-sub">Remplissez le formulaire pour créer un nouveau compte.</div>
            </div>

<form method="post" enctype="multipart/form-data">                <div class="card-body">

                    <!-- Personal info -->
                    <p class="section-title">Informations personnelles</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nom complet *</label>
                            <input type="text" name="name" class="form-input" placeholder="Ex: Ahmed Ben Ali" value="{{ app.request.request.get('name') }}" required>
                        </div>
                        <div class="form-group">
                            <label>Adresse email *</label>
                            <input type="email" name="email" class="form-input" placeholder="Ex: ahmed@agrisense.tn" value="{{ app.request.request.get('email') }}" required>
                        </div>
                        <div class="form-group">
                            <label>Téléphone</label>
                            <input type="tel" name="phone" class="form-input" placeholder="Ex: 55 123 456" value="{{ app.request.request.get('phone') }}">
                        </div>
                        <div class="form-group">
                            <label>Statut du compte</label>
                            <div class="status-options">
                                <div class="status-opt">
                                    <input type="radio" name="status" id="status_active" value="active" checked>
                                    <label for="status_active">✓ Actif</label>
                                </div>
                                <div class="status-opt">
                                    <input type="radio" name="status" id="status_inactive" value="inactive">
                                    <label for="status_inactive">✗ Inactif</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="section-divider">

                    <!-- Role -->
                    <p class="section-title">Rôle de l'utilisateur</p>
                    <div class="role-grid">
                        <div class="role-option">
                            <input type="radio" name="role" id="role_admin" value="ROLE_ADMIN">
                            <label class="role-card" for="role_admin">
                                <span class="role-card-icon">🛡️</span>
                                <span class="role-card-name">Administrateur</span>
                                <span class="role-card-desc">Accès complet au système</span>
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" name="role" id="role_gerant" value="ROLE_GERANT" checked>
                            <label class="role-card" for="role_gerant">
                                <span class="role-card-icon">🧑‍💼</span>
                                <span class="role-card-name">Gérant</span>
                                <span class="role-card-desc">Gestion des opérations</span>
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" name="role" id="role_ouvrier" value="ROLE_OUVRIER">
                            <label class="role-card" for="role_ouvrier">
                                <span class="role-card-icon">👷</span>
                                <span class="role-card-name">Ouvrier</span>
                                <span class="role-card-desc">Accès limité aux tâches</span>
                            </label>
                        </div>
                    </div>

                    <hr class="section-divider">

                    <!-- Password -->
                    <p class="section-title">Mot de passe</p>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Mot de passe *</label>
                            <input type="password" name="password" class="form-input" placeholder="Minimum 6 caractères" required>
                        </div>
                        <div class="form-group">
                            <label>Confirmer le mot de passe *</label>
                            <input type="password" name="confirm_password" class="form-input" placeholder="Répéter le mot de passe" required>
                        </div>
                    </div>

                </div>
                <div class="form-group full">
                 <label>CV *</label>
                 <input type="file" name="cv" class="form-input" required>
                </div>

                <div class="action-bar">
                    <button type="submit" class="btn btn-save">✓ Créer l'utilisateur</button>
                    <a href="{{ path('admin_dashboard') }}" class="btn btn-cancel">← Annuler</a>
                </div>
            </form>
        </div>
    </main>
</div>
{% endblock %}
