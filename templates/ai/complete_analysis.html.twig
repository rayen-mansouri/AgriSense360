{% extends 'base.html.twig' %}
{% set activePage = 'stockes' %}
{% set activeSection = 'main' %}

{% block title %}Analyse IA Complète — Agrisens 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    /* ── CUSTOM OVERRIDES ── */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    .page-title { font-size: 1.75rem; font-weight: 800; color: var(--ch3); margin-bottom: 4px; }
    .page-subtitle { color: var(--cp); font-size: 0.9rem; }

    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: var(--cb); border: 1px solid var(--cbr); padding: 24px; border-radius: 20px; display: flex; flex-direction: column; gap: 8px; transition: all 0.2s; box-shadow: var(--sh); }
    .stat-card:hover { transform: translateY(-4px); border-color: var(--g); box-shadow: var(--sh-lg); }
    .stat-icon { font-size: 1.5rem; color: var(--g); margin-bottom: 4px; }
    .stat-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--cp); letter-spacing: 0.05em; }
    .stat-value { font-size: 1.8rem; font-weight: 900; color: var(--ch3); }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; padding: 24px; margin-bottom: 24px; box-shadow: var(--sh); }
    .card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--cbr); }
    .card-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
    .card-title { font-size: 1.1rem; font-weight: 800; color: var(--ch3); margin: 0; }

    /* Tables */
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { text-align: left; padding: 12px; font-size: 0.75rem; color: var(--cp); text-transform: uppercase; border-bottom: 1px solid var(--cbr); }
    .data-table td { padding: 14px 12px; border-bottom: 1px solid var(--cbr); color: var(--pc); font-size: 0.9rem; }

    /* AI Classification Result */
    .ai-result-box { background: rgba(156,39,176,0.05); border: 1px solid rgba(156,39,176,0.2); border-radius: 20px; padding: 24px; margin-top: 20px; }
    
    .input-field { background: rgba(0,0,0,0.2); border: 1px solid var(--cbr); border-radius: 12px; padding: 12px 16px; color: var(--ch3); font-family: inherit; font-size: 0.95rem; outline: none; }

    /* Fix spacing */
    .content-wrapper { padding-top: 20px !important; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <a href="{{ path('homestock') }}" class="btn btn-pale btn-sm" style="border-radius: 50px; padding: 6px 16px;"><i class="fas fa-arrow-left"></i> Retour</a>
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>

        <div class="content-wrapper">
            
            <div class="page-header">
                <div>
                    <h1 class="page-title">🧠 Analyse IA Complète</h1>
                    <p class="page-subtitle">Monitoring intelligent de la qualité et des prix</p>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon" style="color:var(--g);"><i class="fas fa-microchip"></i></div>
                    <div class="stat-label">Produits Analysés</div>
                    <div class="stat-value">{{ produits|length }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="color:var(--indigo);"><i class="fas fa-tag"></i></div>
                    <div class="stat-label">Prix Moyen</div>
                    <div class="stat-value">{{ prixMoyen }} DT</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="color:var(--purple);"><i class="fas fa-layer-group"></i></div>
                    <div class="stat-label">Catégories</div>
                    <div class="stat-value">{{ categories|length }}</div>
                </div>
            </div>

            <!-- Anomalies -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon" style="background: rgba(239,68,68,0.1); color: #ef4444;"><i class="fas fa-exclamation-triangle"></i></div>
                    <h2 class="card-title">Détection d'Anomalies de Prix</h2>
                </div>
                <div id="anomaliesContainer">
                    <div style="text-align: center; padding: 40px; color: var(--cp);" id="loadingAnomalies">
                        <i class="fa-solid fa-spinner fa-spin"></i> Analyse en cours par l'IA...
                    </div>
                </div>
            </div>

            <!-- Classification IA -->
            <div class="card">
                <div class="card-header">
                    <div class="card-icon" style="background: rgba(156,39,176,0.1); color: #9c27b0;"><i class="fas fa-brain"></i></div>
                    <h2 class="card-title">Assistant de Classification IA (KNN)</h2>
                </div>
                <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <input type="text" id="produitNom" class="input-field" placeholder="Nom du produit..." style="flex: 2;">
                    <input type="number" id="produitPrix" class="input-field" placeholder="Prix (DT)" style="width: 150px;">
                    <button id="btnClassifier" class="btn btn-save" style="padding: 12px 24px; border-radius: 12px; background: #9c27b0;">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> Prédire la Catégorie
                    </button>
                </div>
                <div id="classificationResult" style="display: none;"></div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px;">
                <!-- Qualité -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon" style="background: rgba(16,185,129,0.1); color: #10b981;"><i class="fas fa-star"></i></div>
                        <h2 class="card-title">Score Qualité Fiches</h2>
                    </div>
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="data-table">
                            <thead><tr><th>Produit</th><th>Score</th><th>Niveau</th></tr></thead>
                            <tbody>
                                {% for qualite in qualites %}
                                <tr>
                                    <td><strong>{{ qualite.produit }}</strong></td>
                                    <td style="font-weight: 800; color: var(--g);">{{ qualite.score_global }}%</td>
                                    <td>{{ qualite.niveau }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Rentabilité -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon" style="background: rgba(245,158,11,0.1); color: #f59e0b;"><i class="fas fa-coins"></i></div>
                        <h2 class="card-title">Estimation Rentabilité</h2>
                    </div>
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="data-table">
                            <thead><tr><th>Produit</th><th>Marge Est.</th><th>Perf.</th></tr></thead>
                            <tbody>
                                {% for renta in rentabilite %}
                                <tr>
                                    <td><strong>{{ renta.produit }}</strong></td>
                                    <td style="font-weight: 800; color: #f59e0b;">{{ renta.marge_brute }} DT</td>
                                    <td>{{ renta.performance }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<script>
    // Sidebar & Theme logic
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) sidebar.classList.toggle('open');
        else { sidebar.classList.toggle('collapsed'); mainContent.classList.toggle('expanded'); }
    });
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);
    document.getElementById('themeToggle').addEventListener('click', () => {
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });

    // Anomalies IA
    fetch('/api/ai/anomalies')
        .then(res => res.json())
        .then(data => {
            const container = document.getElementById('anomaliesContainer');
            if (data.anomalies.length === 0) {
                container.innerHTML = '<div style="text-align:center; padding: 20px; color: var(--g);"><i class="fa-solid fa-circle-check"></i> Aucune anomalie détectée.</div>';
                return;
            }
            let htmlTable = '<table class="data-table"><thead><tr><th>Produit</th><th>Cat.</th><th>Prix</th><th>Écart</th><th>Recommandation</th></tr></thead><tbody>';
            data.anomalies.forEach(a => {
                const isHigh = a.type === 'Prix élevé';
                htmlTable += `<tr>
                    <td><strong>${a.produit}</strong></td>
                    <td>${a.categorie}</td>
                    <td style="color:${isHigh ? '#ef4444' : 'var(--g)'}">${a.prix} DT</td>
                    <td>${a.ecart > 0 ? '+' : ''}${a.ecart} DT</td>
                    <td style="font-size:0.8rem; font-style:italic; color:var(--cp);">${a.recommandation}</td>
                </tr>`;
            });
            htmlTable += '</tbody></table>';
            container.innerHTML = htmlTable;
        });

    // Classification KNN
    document.getElementById('btnClassifier').addEventListener('click', function() {
        const nom = document.getElementById('produitNom').value;
        const prix = document.getElementById('produitPrix').value;
        if (!nom) return alert('Nom requis');
        const resDiv = document.getElementById('classificationResult');
        resDiv.style.display = 'block';
        resDiv.innerHTML = '<div style="padding:20px; text-align:center;"><i class="fa-solid fa-spinner fa-spin"></i> L\'IA réfléchit...</div>';
        
        fetch('/api/ai/classify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nom, prix: prix || 50 })
        })
        .then(res => res.json())
        .then(data => {
            resDiv.innerHTML = `<div class="ai-result-box">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <div style="font-size:0.75rem; color:var(--cp);">CATÉGORIE PRÉDITE</div>
                        <div style="font-size:1.5rem; font-weight:900; color:#9c27b0;">${data.categorie_predite}</div>
                    </div>
                    <div style="text-align:right">
                        <div style="font-size:0.75rem; color:var(--cp);">CONFIANCE</div>
                        <div style="font-size:1.5rem; font-weight:900; color:var(--g);">${data.confiance}%</div>
                    </div>
                </div>
            </div>`;
        });
    });
</script>
{% endblock %}