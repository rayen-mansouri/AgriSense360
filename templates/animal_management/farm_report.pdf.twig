<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            margin: 30px;
        }

        body {
            color: #111111;
            font-family: Helvetica, Arial, sans-serif;
            font-size: 9px;
            margin: 0;
        }

        .brand {
            color: #2e7d32;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .title {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .meta {
            color: #555555;
            font-size: 9px;
            margin-bottom: 4px;
        }

        .divider {
            border-top: 2px solid #2e7d32;
            margin: 10px 0 14px;
        }

        .section {
            margin-bottom: 16px;
            page-break-inside: avoid;
        }

        .section-title {
            background: #2e7d32;
            color: #ffffff;
            font-size: 10px;
            font-weight: 700;
            padding: 5px 7px;
            margin-bottom: 8px;
        }

        .summary-line {
            font-size: 9px;
            margin-bottom: 6px;
            padding-left: 5px;
        }

        table {
            border-collapse: collapse;
            table-layout: fixed;
            width: 100%;
        }

        thead th {
            background: #43a047;
            color: #ffffff;
            font-size: 8.5px;
            font-weight: 700;
            padding: 6px 4px;
            text-align: left;
        }

        tbody td {
            border-bottom: 1px solid #dddddd;
            font-size: 8px;
            padding: 5px 4px;
            vertical-align: top;
            word-wrap: break-word;
        }

        tbody tr:nth-child(even) {
            background: #f3f8f3;
        }

        .bad {
            color: #c62828;
            font-weight: 700;
        }

        .empty {
            color: #555555;
            font-size: 9px;
            padding-left: 5px;
        }

        .footer {
            border-top: 1px solid #dddddd;
            color: #9e9e9e;
            font-size: 7.5px;
            margin-top: 18px;
            padding-top: 8px;
        }
    </style>
</head>
<body>
    <div class="brand">AgriSense 360</div>
    <div class="title">Rapport General de la Ferme</div>
    <div class="meta">Date : {{ generatedAt|date('Y-m-d') }} | Animaux : {{ animalRows|length }}</div>
    <div class="divider"></div>

    {% if includeSummary %}
        <div class="section">
            <div class="section-title">Resume de la Ferme</div>
            <div class="summary-line">Total animaux : {{ summary.totalAnimals }}</div>
            <div class="summary-line">Vaccines : {{ summary.vaccinated }} ({{ summary.vaccinatedPercent }}%)</div>
            <div class="summary-line">Animaux a risque : {{ summary.atRisk }}</div>
            <div class="summary-line">Sains : {{ summary.healthy }} | Malades : {{ summary.sick }} | Blesses : {{ summary.injured }} | Critiques : {{ summary.critical }}</div>
            <div class="summary-line">Dossiers de sante : {{ summary.recordsCount }}</div>
        </div>
    {% endif %}

    {% if includeAllAnimals %}
        <div class="section">
            <div class="section-title">Liste Complete des Animaux ({{ animalRows|length }})</div>
            <table>
                <thead>
                    <tr>
                        <th style="width: 14%;">#Boucle</th>
                        <th style="width: 18%;">Type</th>
                        <th style="width: 14%;">Poids(kg)</th>
                        <th style="width: 18%;">Sante</th>
                        <th style="width: 22%;">Emplacement</th>
                        <th style="width: 14%;">Vaccine</th>
                    </tr>
                </thead>
                <tbody>
                    {% for animal in animalRows %}
                        <tr>
                            <td>{{ animal.earTag }}</td>
                            <td>{{ animal.type }}</td>
                            <td>{{ animal.weight }}</td>
                            <td class="{{ animal.isAtRisk ? 'bad' : '' }}">{{ animal.healthStatus }}</td>
                            <td>{{ animal.location }}</td>
                            <td>{{ animal.vaccinated }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if includeAtRisk %}
        <div class="section">
            <div class="section-title">Animaux a Risque ({{ atRiskRows|length }})</div>
            {% if atRiskRows is empty %}
                <div class="empty">Aucun animal a risque detecte.</div>
            {% else %}
                <table>
                    <thead>
                        <tr>
                            <th style="width: 14%;">#Boucle</th>
                            <th style="width: 18%;">Type</th>
                            <th style="width: 14%;">Poids(kg)</th>
                            <th style="width: 18%;">Sante</th>
                            <th style="width: 22%;">Emplacement</th>
                            <th style="width: 14%;">Vaccine</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for animal in atRiskRows %}
                            <tr>
                                <td>{{ animal.earTag }}</td>
                                <td>{{ animal.type }}</td>
                                <td>{{ animal.weight }}</td>
                                <td class="bad">{{ animal.healthStatus }}</td>
                                <td>{{ animal.location }}</td>
                                <td>{{ animal.vaccinated }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    {% endif %}

    {% if includeRecentRecords %}
        <div class="section">
            <div class="section-title">Dossiers de Sante Recents ({{ recentRecordRows|length }})</div>
            {% if recentRecordRows is empty %}
                <div class="empty">Aucun dossier disponible.</div>
            {% else %}
                <table>
                    <thead>
                        <tr>
                            <th style="width: 11%;">#Boucle</th>
                            <th style="width: 11%;">Type</th>
                            <th style="width: 13%;">Date</th>
                            <th style="width: 11%;">Poids</th>
                            <th style="width: 13%;">Appetit</th>
                            <th style="width: 13%;">Condition</th>
                            <th style="width: 13%;">Production</th>
                            <th style="width: 15%;">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for record in recentRecordRows %}
                            <tr>
                                <td>{{ record.earTag }}</td>
                                <td>{{ record.type }}</td>
                                <td>{{ record.recordDate }}</td>
                                <td>{{ record.weight }}</td>
                                <td>{{ record.appetite }}</td>
                                <td>{{ record.condition }}</td>
                                <td>{{ record.production }}</td>
                                <td>{{ record.notes }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    {% endif %}

    <div class="footer">Genere par AgriSense 360 - {{ generatedAt|date('Y-m-d') }}</div>
</body>
</html>
