{% extends 'base.html.twig' %}

{% block title %}Animals Management{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/animals-management.css') }}">
{% endblock %}

{% block javascripts %}{{ parent() }}{% endblock %}

{% block body %}
<div class="mgmt-page">
    <div class="mgmt-tabs">
        <a class="mgmt-tab {{ currentTab == 'animaux' ? 'active' : '' }}" href="{{ path('animal_management_index', {tab: 'animaux'}) }}">Animaux</a>
        <a class="mgmt-tab {{ currentTab == 'dossiers' ? 'active' : '' }}" href="{{ path('animal_management_index', {tab: 'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0}|merge(visitLinkParams)) }}">Dossiers de Sante</a>
        <a class="mgmt-tab {{ currentTab == 'options' ? 'active' : '' }}" href="{{ path('animal_management_index', {tab: 'options'}) }}">Options</a>
        <a class="mgmt-tab {{ currentTab == 'predictor' ? 'active' : '' }}" href="{{ path('animal_management_index', {tab: 'predictor'}) }}">Condition Predictor</a>
        <a class="mgmt-tab {{ currentTab == 'analytics' ? 'active' : '' }}" href="{{ path('animal_management_index', {tab: 'analytics'}) }}">Analytiques</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    {% for errors in app.flashes('errors') %}
        {% for key, message in errors %}
            <div class="flash flash-error">{{ key }}: {{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if currentTab == 'animaux' %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Ajouter / Modifier un Animal</div>
                <div class="mgmt-form-subtitle">Les champs obligatoires sont marques avec *</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            {% set editAnimal = null %}
            {% for a in animals %}
                {% if a.id == editAnimalId %}{% set editAnimal = a %}{% endif %}
            {% endfor %}
            <form method="post" action="{{ editAnimal ? path('animal_update', {id: editAnimal.id}) : path('animal_add') }}" class="mgmt-grid">
                <label>Boucle d'Oreille *</label>
                <input class="mgmt-input" name="earTag" value="{{ editAnimal ? editAnimal.earTag : '' }}">
                <label>Type *</label>
                <select class="mgmt-input" name="type">
                    <option value="">Selectionner un type</option>
                    {% for type in types %}
                        <option value="{{ type }}" {% if editAnimal and editAnimal.type == type %}selected{% endif %}>{{ type }}</option>
                    {% endfor %}
                </select>
                <label>Poids (kg)</label>
                <input class="mgmt-input" name="weight" value="{{ editAnimal and editAnimal.weight is not null ? editAnimal.weight : '' }}">
                <label>Date de Naissance</label>
                <input class="mgmt-input" type="date" name="birthDate" value="{{ editAnimal and editAnimal.birthDate ? editAnimal.birthDate|date('Y-m-d') : '' }}">
                <label>Date d'Entree</label>
                <input class="mgmt-input" type="date" name="entryDate" value="{{ editAnimal and editAnimal.entryDate ? editAnimal.entryDate|date('Y-m-d') : '' }}">
                <label>Origine *</label>
                <select class="mgmt-input" name="origin">
                    <option value="">Selectionner une origine</option>
                    {% for origin in origins %}
                        <option value="{{ origin }}" {% if editAnimal and editAnimal.origin == origin %}selected{% endif %}>{{ origin }}</option>
                    {% endfor %}
                </select>
                <label>Emplacement *</label>
                <select class="mgmt-input" name="location">
                    <option value="">Selectionner un emplacement</option>
                    {% for location in locations %}
                        <option value="{{ location }}" {% if editAnimal and editAnimal.location == location %}selected{% endif %}>{{ location }}</option>
                    {% endfor %}
                </select>
                <label>Vaccine</label>
                <input type="checkbox" name="vaccinated" value="1" {% if editAnimal and editAnimal.vaccinated %}checked{% endif %}>
                <div class="mgmt-actions">
                    <button class="mgmt-btn-primary" type="submit">{{ editAnimal ? 'Modifier' : 'Ajouter' }}</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mgmt-table-card">
        <div class="mgmt-table-title">Tous les Animaux</div>
        <form method="get" class="inline-form" style="margin-bottom:10px;">
            <input type="hidden" name="tab" value="animaux">
            <select class="mgmt-input" name="animalSearchField">
                <option value="all" {{ animalSearchField == 'all' ? 'selected' : '' }}>All Fields</option>
                <option value="id" {{ animalSearchField == 'id' ? 'selected' : '' }}>ID</option>
                <option value="earTag" {{ animalSearchField == 'earTag' ? 'selected' : '' }}>Ear Tag</option>
                <option value="type" {{ animalSearchField == 'type' ? 'selected' : '' }}>Type</option>
                <option value="weight" {{ animalSearchField == 'weight' ? 'selected' : '' }}>Weight</option>
                <option value="healthStatus" {{ animalSearchField == 'healthStatus' ? 'selected' : '' }}>Health</option>
                <option value="birthDate" {{ animalSearchField == 'birthDate' ? 'selected' : '' }}>Birth Date</option>
                <option value="origin" {{ animalSearchField == 'origin' ? 'selected' : '' }}>Origin</option>
                <option value="location" {{ animalSearchField == 'location' ? 'selected' : '' }}>Location</option>
            </select>
            <input class="mgmt-input" type="text" name="animalSearch" value="{{ animalSearch }}" placeholder="Search...">
            <button class="mgmt-btn-primary" type="submit">Search</button>
        </form>
        <table class="mgmt-table">
            <thead>
            <tr>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'id', animalDir: (animalSort == 'id' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">ID</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'earTag', animalDir: (animalSort == 'earTag' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Ear Tag</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'type', animalDir: (animalSort == 'type' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Type</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'weight', animalDir: (animalSort == 'weight' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Weight</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'healthStatus', animalDir: (animalSort == 'healthStatus' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Health</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'birthDate', animalDir: (animalSort == 'birthDate' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Birth Date</a></th>
                <th>Age</th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'origin', animalDir: (animalSort == 'origin' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Origin</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'animaux', animalSort:'location', animalDir: (animalSort == 'location' and animalDir == 'ASC') ? 'DESC' : 'ASC', animalSearchField: animalSearchField, animalSearch: animalSearch, animalPage: animalPage}) }}">Location</a></th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for animal in animals %}
                <tr>
                    <td>{{ animal.id }}</td>
                    <td>{{ animal.earTag }}</td>
                    <td>{{ animal.type }}</td>
                    <td>{{ animal.weight is not null ? animal.weight ~ ' kg' : '-' }}</td>
                    <td>{{ animal.healthStatus ?: '-' }}</td>
                    <td>{{ animal.birthDate ? animal.birthDate|date('Y-m-d') : '-' }}</td>
                    <td>{{ animal.age is not null ? animal.age ~ ' yr' : '-' }}</td>
                    <td>{{ animal.origin ?: '-' }}</td>
                    <td>{{ animal.location ?: '-' }}</td>
                    <td class="row-actions">
                        <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab: 'animaux', editAnimalId: animal.id, animalId: animal.id, animalPage: animalPage}) }}">Modifier</a>
                        <form method="post" action="{{ path('animal_delete', {id: animal.id}) }}">
                            <button class="mgmt-btn-danger" type="submit">Supprimer</button>
                        </form>
                        <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab: 'dossiers', animalId: animal.id}) }}">+ Dossier</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="pagination">
            {% if animalPage > 1 %}
                <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab:'animaux', animalPage: animalPage - 1, animalSort: animalSort, animalDir: animalDir, animalSearchField: animalSearchField, animalSearch: animalSearch}) }}">Prev</a>
            {% endif %}
            <span>Page {{ animalPage }} / {{ animalTotalPages }}</span>
            {% if animalPage < animalTotalPages %}
                <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab:'animaux', animalPage: animalPage + 1, animalSort: animalSort, animalDir: animalDir, animalSearchField: animalSearchField, animalSearch: animalSearch}) }}">Next</a>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if currentTab == 'dossiers' %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Ajouter / Modifier un Dossier de Sante</div>
                <div class="mgmt-form-subtitle">Aucun champ n'est obligatoire sauf la date et la condition</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            {% set editRecord = null %}
            {% for r in records %}
                {% if r.id == editRecordId %}{% set editRecord = r %}{% endif %}
            {% endfor %}
            <form method="post" action="{{ editRecord ? path('record_update', {id: editRecord.id}) : path('record_add') }}" class="mgmt-grid">
                <label>Animal</label>
                <select class="mgmt-input" name="animalId" onchange="window.location.href='{{ path('animal_management_index', {tab: 'dossiers', recordSort: recordSort, recordDir: recordDir, recordSearchField: recordSearchField, recordSearch: recordSearch}|merge(visitLinkParams)) }}&animalId='+this.value;">
                    <option value="">Choisir un animal</option>
                    {% for animal in animals %}
                        <option value="{{ animal.id }}" {% if selectedAnimal and selectedAnimal.id == animal.id %}selected{% endif %}>ID {{ animal.id }} - Ear {{ animal.earTag }} ({{ animal.type }})</option>
                    {% endfor %}
                </select>
                <label>Date du Dossier</label>
                <input class="mgmt-input" type="date" name="recordDate" value="{{ editRecord and editRecord.recordDate ? editRecord.recordDate|date('Y-m-d') : 'now'|date('Y-m-d') }}">
                <label>Poids (kg)</label>
                <input class="mgmt-input" name="weight" value="{{ editRecord and editRecord.weight is not null ? editRecord.weight : '' }}">
                <label>Appetit</label>
                <select class="mgmt-input" name="appetite">
                    <option value="">Selectionner</option>
                    {% for appetite in appetites %}
                        <option value="{{ appetite }}" {% if editRecord and editRecord.appetite == appetite %}selected{% endif %}>{{ appetite }}</option>
                    {% endfor %}
                </select>
                <label>Condition</label>
                <select class="mgmt-input" name="conditionStatus">
                    <option value="">Selectionner</option>
                    {% for condition in conditions %}
                        <option value="{{ condition }}" {% if editRecord and editRecord.conditionStatus == condition %}selected{% endif %}>{{ condition }}</option>
                    {% endfor %}
                </select>
                <label>Production</label>
                <input class="mgmt-input" name="production" value="{{ editRecord ? (editRecord.milkYield ?? editRecord.eggCount ?? editRecord.woolLength ?? '') : '' }}">
                <label>Notes</label>
                <input class="mgmt-input" name="notes" value="{{ editRecord ? editRecord.notes : '' }}">
                <div class="mgmt-actions">
                    <button class="mgmt-btn-primary" type="submit">{{ editRecord ? 'Modifier' : 'Ajouter' }}</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Visite par Emplacement</div>
                <div class="mgmt-form-subtitle">Parcourez les animaux d'un emplacement un par un et enregistrez leurs dossiers</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            {% if visitWizard %}
                <div class="inline-form" style="margin-bottom:12px;align-items:center;flex-wrap:wrap;">
                    <span class="mgmt-form-title" style="margin:0;">Animal {{ visitIndex + 1 }} / {{ visitTotal }}</span>
                    <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab: 'dossiers'}) }}">Terminer</a>
                </div>
                <div class="mgmt-form-subtitle" style="margin-bottom:12px;">Boucle #{{ visitAnimal.earTag }} — {{ visitAnimal.type }}{% if visitAnimal.location %} [{{ visitAnimal.location }}]{% endif %}</div>
                <form method="post" action="{{ path('record_visit_save') }}" class="mgmt-grid">
                    <input type="hidden" name="animalId" value="{{ visitAnimal.id }}">
                    <input type="hidden" name="visitLocation" value="{{ visitLocationQuery }}">
                    <input type="hidden" name="visitIndex" value="{{ visitIndex }}">
                    <label>Date du Dossier</label>
                    <input class="mgmt-input" type="date" name="recordDate" value="{{ 'now'|date('Y-m-d') }}">
                    <label>Poids (kg)</label>
                    <input class="mgmt-input" name="weight" value="">
                    <label>Appetit</label>
                    <select class="mgmt-input" name="appetite">
                        <option value="">Selectionner</option>
                        {% for appetite in appetites %}
                            <option value="{{ appetite }}">{{ appetite }}</option>
                        {% endfor %}
                    </select>
                    <label>Condition</label>
                    <select class="mgmt-input" name="conditionStatus">
                        <option value="">Selectionner</option>
                        {% for condition in conditions %}
                            <option value="{{ condition }}">{{ condition }}</option>
                        {% endfor %}
                    </select>
                    {% set vt = visitAnimal.type|default('')|lower %}
                    <label>{% if vt in ['cow','goat'] %}Lait (L){% elseif vt == 'chicken' %}Nb Oeufs{% elseif vt == 'sheep' %}Laine (cm){% else %}Production{% endif %}</label>
                    <input class="mgmt-input" name="production" value="">
                    <label>Notes</label>
                    <input class="mgmt-input" name="notes" value="">
                    <div class="mgmt-actions">
                        <button class="mgmt-btn-primary" type="submit">Sauvegarder &amp; Suivant</button>
                        <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab: 'dossiers', visit: 1, visitLocation: visitLocationQuery, visitIndex: visitIndex + 1}) }}">Passer</a>
                    </div>
                </form>
            {% else %}
                {% if visitEmptyLocation %}
                    <div class="flash flash-error">Aucun animal trouvé à cet emplacement.</div>
                {% endif %}
                <form method="get" action="{{ path('animal_management_index') }}" class="inline-form">
                    <input type="hidden" name="tab" value="dossiers">
                    <input type="hidden" name="visit" value="1">
                    <input type="hidden" name="visitIndex" value="0">
                    <label>Emplacement :</label>
                    <select class="mgmt-input" name="visitLocation" required>
                        <option value="">Choisir un emplacement...</option>
                        {% for location in locations %}
                            <option value="{{ location }}" {% if visitLocationQuery == location %}selected{% endif %}>{{ location }}</option>
                        {% endfor %}
                    </select>
                    <button class="mgmt-btn-primary" type="submit">Démarrer la Visite</button>
                </form>
            {% endif %}
        </div>
    </div>

    <div class="mgmt-table-card">
        <div class="mgmt-table-title">Dossiers de Sante</div>
        <form method="get" class="inline-form" style="margin-bottom:10px;">
            <input type="hidden" name="tab" value="dossiers">
            <input type="hidden" name="animalId" value="{{ selectedAnimal ? selectedAnimal.id : 0 }}">
            {% if visitLinkParams is not empty %}
                <input type="hidden" name="visit" value="1">
                <input type="hidden" name="visitLocation" value="{{ visitLocationQuery }}">
                <input type="hidden" name="visitIndex" value="{{ visitIndex }}">
            {% endif %}
            <select class="mgmt-input" name="recordSearchField">
                <option value="all" {{ recordSearchField == 'all' ? 'selected' : '' }}>All Fields</option>
                <option value="id" {{ recordSearchField == 'id' ? 'selected' : '' }}>ID</option>
                <option value="recordDate" {{ recordSearchField == 'recordDate' ? 'selected' : '' }}>Date</option>
                <option value="weight" {{ recordSearchField == 'weight' ? 'selected' : '' }}>Weight</option>
                <option value="appetite" {{ recordSearchField == 'appetite' ? 'selected' : '' }}>Appetite</option>
                <option value="conditionStatus" {{ recordSearchField == 'conditionStatus' ? 'selected' : '' }}>Condition</option>
                <option value="production" {{ recordSearchField == 'production' ? 'selected' : '' }}>Production</option>
                <option value="notes" {{ recordSearchField == 'notes' ? 'selected' : '' }}>Notes</option>
            </select>
            <input class="mgmt-input" type="text" name="recordSearch" value="{{ recordSearch }}" placeholder="Search...">
            <button class="mgmt-btn-primary" type="submit">Search</button>
        </form>
        <table class="mgmt-table">
            <thead>
            <tr>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'id', recordDir: (recordSort == 'id' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">ID</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'recordDate', recordDir: (recordSort == 'recordDate' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Date</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'weight', recordDir: (recordSort == 'weight' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Weight</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'appetite', recordDir: (recordSort == 'appetite' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Appetite</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'conditionStatus', recordDir: (recordSort == 'conditionStatus' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Condition</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'production', recordDir: (recordSort == 'production' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Production</a></th>
                <th><a class="sort-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordSort:'notes', recordDir: (recordSort == 'notes' and recordDir == 'ASC') ? 'DESC' : 'ASC', recordSearchField: recordSearchField, recordSearch: recordSearch, recordPage: recordPage}|merge(visitLinkParams)) }}">Notes</a></th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for record in records %}
                <tr>
                    <td>{{ record.id }}</td>
                    <td>{{ record.recordDate ? record.recordDate|date('Y-m-d') : '-' }}</td>
                    <td>{{ record.weight is not null ? record.weight ~ ' kg' : '-' }}</td>
                    <td>{{ record.appetite ?: '-' }}</td>
                    <td>{{ record.conditionStatus ?: '-' }}</td>
                    <td>{{ record.milkYield ?? record.eggCount ?? record.woolLength ?? '-' }}</td>
                    <td>{{ record.notes ?: '-' }}</td>
                    <td class="row-actions">
                        <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab: 'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, editRecordId: record.id, recordPage: recordPage}|merge(visitLinkParams)) }}">Modifier</a>
                        <form method="post" action="{{ path('record_delete', {id: record.id}) }}">
                            <button class="mgmt-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="pagination">
            {% if recordPage > 1 %}
                <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordPage: recordPage - 1, recordSort: recordSort, recordDir: recordDir, recordSearchField: recordSearchField, recordSearch: recordSearch}|merge(visitLinkParams)) }}">Prev</a>
            {% endif %}
            <span>Page {{ recordPage }} / {{ recordTotalPages }}</span>
            {% if recordPage < recordTotalPages %}
                <a class="mgmt-btn-ghost-link" href="{{ path('animal_management_index', {tab:'dossiers', animalId: selectedAnimal ? selectedAnimal.id : 0, recordPage: recordPage + 1, recordSort: recordSort, recordDir: recordDir, recordSearchField: recordSearchField, recordSearch: recordSearch}|merge(visitLinkParams)) }}">Next</a>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if currentTab == 'options' %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div class="mgmt-form-title">Types et Emplacements</div>
        </div>
        <div class="mgmt-form-body options-grid">
            <div>
                <div class="mgmt-table-title">Animal Types</div>
                <ul class="mgmt-list">
                    {% for type in types %}
                        <li class="mgmt-list-row">
                            <span>{{ type }}</span>
                            <form method="post" action="{{ path('option_type_delete') }}">
                                <input type="hidden" name="value" value="{{ type }}">
                                <button class="mgmt-btn-danger" type="submit">Delete</button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('option_type_add') }}" class="inline-form">
                    <input class="mgmt-input" name="value" placeholder="New type name...">
                    <button class="mgmt-btn-primary" type="submit">Add</button>
                </form>
            </div>
            <div>
                <div class="mgmt-table-title">Pen Locations</div>
                <ul class="mgmt-list">
                    {% for location in locations %}
                        <li class="mgmt-list-row">
                            <span>{{ location }}</span>
                            <form method="post" action="{{ path('option_location_delete') }}">
                                <input type="hidden" name="value" value="{{ location }}">
                                <button class="mgmt-btn-danger" type="submit">Delete</button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('option_location_add') }}" class="inline-form">
                    <input class="mgmt-input" name="value" placeholder="New location name...">
                    <button class="mgmt-btn-primary" type="submit">Add</button>
                </form>
            </div>
        </div>
    </div>
    <div class="mgmt-form-card" style="margin-top:14px;">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Rapport email vétérinaire</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            <form method="post" action="{{ path('vet_report_send') }}" class="mgmt-grid">
                <label>Email du vétérinaire</label>
                <input class="mgmt-input" type="email" name="vetEmail" required placeholder="vet@example.com" autocomplete="email" value="{{ defaultVetEmail }}">
                <label>Notes additionnelles</label>
                <textarea class="mgmt-input" name="notes" rows="5" style="width:100%;min-height:100px;resize:vertical;" placeholder=""></textarea>
                <div class="mgmt-actions">
                    <button class="mgmt-btn-primary" type="submit">Envoyer le rapport</button>
                </div>
            </form>
        </div>
    </div>
    <div class="mgmt-form-card" style="margin-top:14px;">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Entrainement du Modele Personnalise</div>
                <div class="mgmt-form-subtitle">Utilisez vos propres donnees pour de meilleures predictions pour votre ferme</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            <div style="display:flex;flex-direction:column;gap:14px;">
                <div class="mgmt-list-row" style="justify-content:flex-start;">
                    <strong>Dossiers de sante en base :</strong>
                    <span>{{ healthRecordCount }}</span>
                </div>
                {% if canTrainCustomModel %}
                    <div class="flash flash-success" style="margin-bottom:0;">Vous avez assez de dossiers pour entrainer un modele personnalise.</div>
                {% else %}
                    <div class="flash flash-error" style="margin-bottom:0;">Vous avez besoin d'au moins {{ trainThreshold }} dossiers de sante. Il en manque {{ trainThreshold - healthRecordCount }}.</div>
                {% endif %}
                <div class="mgmt-form-subtitle">
                    Statut du modele personnalise :
                    <strong>{{ customModelAvailable ? 'disponible' : 'pas encore entraine' }}</strong>
                </div>
                <form method="post" action="{{ path('ai_model_train') }}">
                    <button class="mgmt-btn-primary" type="submit" {% if not canTrainCustomModel %}disabled{% endif %}>Exporter &amp; Reentrainer le Modele</button>
                </form>
            </div>
        </div>
    </div>
    <div class="mgmt-form-card" style="margin-top:14px;">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Exporter un Rapport PDF</div>
                <div class="mgmt-form-subtitle">Choisissez les sections a inclure dans le rapport de la ferme</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            <form method="post" action="{{ path('farm_report_pdf_export') }}">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <label class="mgmt-list-row" style="justify-content:flex-start;">
                        <input type="checkbox" name="includeSummary" value="1">
                        <span>Resume de la Ferme (totaux, vaccination, animaux a risque)</span>
                    </label>
                    <label class="mgmt-list-row" style="justify-content:flex-start;">
                        <input type="checkbox" name="includeAllAnimals" value="1">
                        <span>Liste complete des animaux</span>
                    </label>
                    <label class="mgmt-list-row" style="justify-content:flex-start;">
                        <input type="checkbox" name="includeAtRisk" value="1">
                        <span>Animaux a risque (malades, blesses, critiques)</span>
                    </label>
                    <label class="mgmt-list-row" style="justify-content:flex-start;">
                        <input type="checkbox" name="includeRecentRecords" value="1">
                        <span>Dossiers de sante recents (20 derniers)</span>
                    </label>
                </div>
                <div class="mgmt-actions">
                    <button class="mgmt-btn-primary" type="submit">Generer le Rapport PDF</button>
                </div>
            </form>
        </div>
    </div>
    {% endif %}
    {% if currentTab == 'predictor' %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Predicteur de Condition</div>
                <div class="mgmt-form-subtitle">Utilise jusqu'aux 10 derniers dossiers de sante</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            <form method="post" action="{{ path('analytics_predict') }}" style="display:flex;flex-direction:column;gap:14px;">
                <div class="inline-form" style="align-items:center;flex-wrap:wrap;margin-top:0;">
                    <label>Modele :</label>
                    <label class="mgmt-list-row" style="justify-content:flex-start;">
                        <input type="radio" name="model" value="general" {{ selectedAiModel != 'custom' ? 'checked' : '' }}>
                        <span>Modele General</span>
                    </label>
                    <label class="mgmt-list-row" style="justify-content:flex-start;opacity:{{ customModelAvailable ? '1' : '0.6' }};">
                        <input type="radio" name="model" value="custom" {{ selectedAiModel == 'custom' ? 'checked' : '' }} {% if not customModelAvailable %}disabled{% endif %}>
                        <span>Mon Modele Personnalise</span>
                    </label>
                    <span class="mgmt-form-subtitle">({{ customModelAvailable ? 'disponible' : 'pas encore entraine' }})</span>
                </div>
                <div class="inline-form" style="margin-top:0;align-items:center;">
                    <select class="mgmt-input" name="animalId" style="flex:1;">
                        <option value="">Selectionner un animal...</option>
                        {% for animal in analyticsAnimals %}
                            <option value="{{ animal.id }}" {{ selectedAiAnimalId == animal.id ? 'selected' : '' }}>#{{ animal.earTag }} - {{ animal.type }}</option>
                        {% endfor %}
                    </select>
                    <button class="mgmt-btn-primary" type="submit">Analyser</button>
                    <button class="mgmt-btn-ghost-link" type="submit" formaction="{{ path('analytics_predict_all') }}">Analyser tous</button>
                </div>
                {% if aiStatus %}
                    <div class="flash flash-error" style="margin-bottom:0;">{{ aiStatus }}</div>
                {% endif %}
                {% if batchStatus %}
                    <div class="{{ batchResults is empty ? 'flash flash-success' : 'mgmt-form-subtitle' }}" style="margin-bottom:0;">{{ batchStatus }}</div>
                {% endif %}
            </form>
        </div>
    </div>
    {% if predictionResult %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Resultat de Prediction</div>
                <div class="mgmt-form-subtitle">{{ predictionResult.animalInfo }}</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            <div style="display:flex;flex-direction:column;gap:18px;">
                <div style="display:flex;justify-content:center;">
                    <span class="ai-condition-badge ai-condition-badge-{{ predictionResult.condition|lower }}">{{ predictionResult.conditionLabel }}</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="mgmt-list-row" style="justify-content:flex-start;">
                        <strong>Fiabilite du Modele</strong>
                        <span class="ai-confidence-value">{{ (predictionResult.confidence * 100)|number_format(1, '.', '') }}%</span>
                    </div>
                    <div class="ai-progress-shell">
                        <div class="ai-progress-bar" style="width: {{ predictionResult.confidence * 100 }}%;"></div>
                    </div>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <div class="ai-section-label">DONNEES UTILISEES POUR LA PREDICTION</div>
                    <div class="ai-records-header">
                        <span>Date</span>
                        <span>Poids</span>
                        <span>Appetit</span>
                        <span>{{ predictionResult.productionLabel }}</span>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:4px;">
                        {% for record in predictionResult.records %}
                            <div class="ai-record-row">
                                <span>{{ record.recordDate }}</span>
                                <span>{{ record.weight }}</span>
                                <span>{{ record.appetite }}</span>
                                <span>{{ record.production }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
    {% if batchResults is not empty or batchStatus %}
    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Animaux a Surveiller</div>
                <div class="mgmt-form-subtitle">
                    {% if batchResults is not empty %}
                        {{ batchResults|length }} animal(s) necessitant attention - {{ selectedAiModel == 'custom' ? 'Modele Personnalise' : 'Modele General' }}
                    {% else %}
                        Aucun animal a surveiller
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="mgmt-form-body">
            {% if batchResults is not empty %}
                <div style="display:flex;flex-direction:column;gap:8px;max-height:280px;overflow:auto;">
                    {% for result in batchResults %}
                        <div class="ai-batch-row">
                            <span class="ai-condition-badge ai-condition-badge-{{ result.condition|lower }}">{{ result.conditionLabel }}</span>
                            <span style="flex:1;">#{{ result.earTag }} - {{ result.type|capitalize }}{% if result.location %} [{{ result.location }}]{% endif %}</span>
                            <strong class="ai-confidence-value">{{ (result.confidence * 100)|number_format(0, '.', '') }}%</strong>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
            <form method="post" action="{{ path('analytics_send_vet_report') }}" class="inline-form" style="align-items:center; margin-top:14px;">
                <input type="hidden" name="model" value="{{ selectedAiModel }}">
                <input class="mgmt-input" type="email" name="vetEmail" value="{{ batchVetEmail }}" placeholder="Email du veterinaire..." style="flex:1;">
                <button class="mgmt-btn-primary" type="submit">Envoyer au Veterinaire</button>
            </form>
            {% if batchEmailStatus %}
                <div class="{{ batchEmailSuccess is same as(true) ? 'flash flash-success' : batchEmailSuccess is same as(false) ? 'flash flash-error' : 'mgmt-form-subtitle' }}" style="margin-top:12px;margin-bottom:0;">{{ batchEmailStatus }}</div>
            {% endif %}
        </div>
    </div>
    {% endif %}
    {% endif %}
    {% if currentTab == 'analytics' %}
    <div class="analytics-kpi-grid">
        <div class="analytics-kpi-card">
            <div class="analytics-kpi-value">{{ analyticsSummary.totalAnimals }}</div>
            <div class="analytics-kpi-label">Animaux Total</div>
        </div>
        <div class="analytics-kpi-card">
            <div class="analytics-kpi-value">{{ analyticsSummary.totalRecords }}</div>
            <div class="analytics-kpi-label">Dossiers de Sante</div>
        </div>
        <div class="analytics-kpi-card">
            <div class="analytics-kpi-value">{{ analyticsSummary.vaccinationRate }}%</div>
            <div class="analytics-kpi-label">Taux de Vaccination</div>
        </div>
        <div class="analytics-kpi-card analytics-kpi-card-danger">
            <div class="analytics-kpi-value analytics-kpi-value-danger">{{ analyticsSummary.atRiskCount }}</div>
            <div class="analytics-kpi-label">Animaux a Risque</div>
        </div>
    </div>

    <div class="analytics-chart-grid">
        <div class="mgmt-form-card">
            <div class="mgmt-form-card-header">
                <div>
                    <div class="mgmt-form-title">Etat des Conditions</div>
                    <div class="mgmt-form-subtitle">Repartition des dossiers par condition de sante</div>
                </div>
            </div>
            <div class="mgmt-form-body">
                {% if analyticsConditionChart and analyticsHasConditionData %}
                    <div class="analytics-chart-shell">
                        {{ render_chart(analyticsConditionChart) }}
                    </div>
                {% else %}
                    <div class="mgmt-form-subtitle">Aucune donnee de condition disponible.</div>
                {% endif %}
            </div>
        </div>

        <div class="mgmt-form-card">
            <div class="mgmt-form-card-header">
                <div>
                    <div class="mgmt-form-title">Repartition par Type</div>
                    <div class="mgmt-form-subtitle">Nombre d animaux par type</div>
                </div>
            </div>
            <div class="mgmt-form-body">
                {% if analyticsTypeChart and analyticsHasTypeData %}
                    <div class="analytics-chart-shell">
                        {{ render_chart(analyticsTypeChart) }}
                    </div>
                {% else %}
                    <div class="mgmt-form-subtitle">Aucune donnee de type disponible.</div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="mgmt-form-card">
        <div class="mgmt-form-card-header">
            <div>
                <div class="mgmt-form-title">Animaux par Emplacement</div>
                <div class="mgmt-form-subtitle">Vue rapide des emplacements les plus charges</div>
            </div>
        </div>
        <div class="mgmt-form-body">
            {% if analyticsLocations is not empty %}
                <div class="analytics-location-grid">
                    {% for location in analyticsLocations %}
                        <div class="analytics-location-card">
                            <div class="analytics-location-count">{{ location.count }}</div>
                            <div class="analytics-location-name">{{ location.name }}</div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="mgmt-form-subtitle">Aucun emplacement disponible.</div>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
