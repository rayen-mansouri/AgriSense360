</div>

<div class="mgmt-form-card" style="margin-top:14px;">
    <div class="mgmt-form-card-header">
        <div>
            <div class="mgmt-form-title">Entrainement du Modele Personnalise</div>
            <div class="mgmt-form-subtitle">Utilisez vos propres donnees pour de meilleures predictions pour votre ferme</div>
        </div>
    </div>
    <div class="mgmt-form-body">
        <div style="display:flex;flex-direction:column;gap:14px;">
            <div class="mgmt-list-row" style="justify-content:flex-start;">
                <strong>Dossiers de sante en base :</strong>
                <span>{{ healthRecordCount }}</span>
            </div>
            {% if canTrainCustomModel %}
                <div class="flash flash-success" style="margin-bottom:0;">Vous avez assez de dossiers pour entrainer un modele personnalise.</div>
            {% else %}
                <div class="flash flash-error" style="margin-bottom:0;">Vous avez besoin d'au moins {{ trainThreshold }} dossiers de sante. Il en manque {{ trainThreshold - healthRecordCount }}.</div>
            {% endif %}
            <div class="mgmt-form-subtitle">
                Statut du modele personnalise :
                <strong>{{ customModelAvailable ? 'disponible' : 'pas encore entraine' }}</strong>
            </div>
            <form method="post" action="{{ path('ai_model_train') }}">
                <button class="mgmt-btn-primary" type="submit" {% if not canTrainCustomModel %}disabled{% endif %}>Exporter &amp; Reentrainer le Modele</button>
            </form>
        </div>
    </div>
</div>

<div class="mgmt-form-card" style="margin-top:14px;">
    <div class="mgmt-form-card-header">
        <div>
            <div class="mgmt-form-title">Exporter un Rapport PDF</div>
            <div class="mgmt-form-subtitle">Choisissez les sections a inclure dans le rapport de la ferme</div>
        </div>
    </div>
    <div class="mgmt-form-body">
        <form method="post" action="{{ path('farm_report_pdf_export') }}">
            <div style="display:flex;flex-direction:column;gap:10px;">
                <label class="mgmt-list-row" style="justify-content:flex-start;">
                    <input type="checkbox" name="includeSummary" value="1">
                    <span>Resume de la Ferme (totaux, vaccination, animaux a risque)</span>
                </label>
                <label class="mgmt-list-row" style="justify-content:flex-start;">
                    <input type="checkbox" name="includeAllAnimals" value="1">
                    <span>Liste complete des animaux</span>
                </label>
                <label class="mgmt-list-row" style="justify-content:flex-start;">
                    <input type="checkbox" name="includeAtRisk" value="1">
                    <span>Animaux a risque (malades, blesses, critiques)</span>
                </label>
                <label class="mgmt-list-row" style="justify-content:flex-start;">
                    <input type="checkbox" name="includeRecentRecords" value="1">
                    <span>Dossiers de sante recents (20 derniers)</span>
                </label>
            </div>
            <div class="mgmt-actions">
                <button class="mgmt-btn-primary" type="submit">Generer le Rapport PDF</button>
            </div>
        </form>
    </div>
</div>
