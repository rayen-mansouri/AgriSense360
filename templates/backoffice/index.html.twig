{% extends 'layout/base.html.twig' %}
{% block title %}Tableau de bord — Agrisens 360{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">🏢 Tableau de bord</h1>
        <p class="page-subtitle">Vue d'ensemble et gestion centralisée de votre inventaire</p>
    </div>
    <div class="page-header-actions">
        <a href="{{ path('produit_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouveau Produit</a>
        <a href="{{ path('stock_new') }}"   class="btn btn-secondary"><i class="fa-solid fa-plus"></i> Nouveau Stock</a>
    </div>
</div>

<!-- STATS -->
<div class="stats-grid">
    <div class="stat-card stat-green">
        <div class="stat-icon"><i class="fa-solid fa-box"></i></div>
        <div class="stat-label">Total Produits</div>
        <div class="stat-value">{{ totalProduits }}</div>
    </div>
    <div class="stat-card stat-blue">
        <div class="stat-icon"><i class="fa-solid fa-warehouse"></i></div>
        <div class="stat-label">Stocks Enregistrés</div>
        <div class="stat-value">{{ totalStocks }}</div>
    </div>
    <div class="stat-card stat-red">
        <div class="stat-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div class="stat-label">Alertes Critiques</div>
        <div class="stat-value">{{ totalAlertes }}</div>
    </div>
    <div class="stat-card stat-purple">
        <div class="stat-icon"><i class="fa-solid fa-coins"></i></div>
        <div class="stat-label">Valeur Totale</div>
        <div class="stat-value" style="font-size:24px">{{ valeurTotale }} DT</div>
    </div>
</div>

<!-- CHART -->
<div class="card">
    <h2 class="section-title"><i class="fa-solid fa-chart-column"></i> Répartition par catégorie</h2>
    <div class="chart-wrapper"><canvas id="chartCategories"></canvas></div>
</div>

<!-- PRODUITS -->
<div class="card" id="produits">
    <div class="section-header">
        <h2 class="section-title"><i class="fa-solid fa-leaf"></i> Liste des Produits</h2>
        <span class="badge-count">{{ totalProduits }} produit(s)</span>
    </div>
    {% if produits is empty %}
        <div class="empty-state"><i class="fa-solid fa-box-open"></i><p>Aucun produit{% if search %} pour « {{ search }} »{% endif %}.</p></div>
    {% else %}
    <div class="cards-grid">
        {% for produit in produits %}
        <div class="item-card">
            {% if produit.photoUrl %}
                <div class="item-card-img"><img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}"></div>
            {% else %}
                <div class="item-card-img item-card-img-placeholder"><i class="fa-solid fa-image"></i></div>
            {% endif %}
            <div class="item-card-body">
                <span class="item-badge">{{ produit.categorie ?: 'Autre' }}</span>
                <h3 class="item-card-title">{{ produit.nom }}</h3>
                {% if produit.description %}<p class="item-card-desc">{{ produit.description|slice(0,70) }}{% if produit.description|length>70 %}…{% endif %}</p>{% endif %}
                <div class="item-card-meta">
                    <span class="item-price"><i class="fa-solid fa-tag"></i> {{ produit.prixUnitaire }} DT</span>
                    {% set s = produit.stockActuel %}
                    {% if s %}
                        <span class="item-qty {{ s.isEnAlerte ? 'qty-danger':'qty-ok' }}">
                            <i class="fa-solid fa-boxes-stacked"></i> {{ s.quantiteActuelle }} {{ s.uniteMesure }}
                        </span>
                    {% else %}
                        <span class="item-qty qty-danger"><i class="fa-solid fa-circle-exclamation"></i> Aucun stock</span>
                    {% endif %}
                </div>
            </div>
            <div class="item-card-actions">
                <a href="{{ path('produit_show', {id: produit.id}) }}" class="btn btn-icon" style="background:rgba(90,152,20,.1);color:var(--primary)" title="Voir"><i class="fa-solid fa-eye"></i></a>
                <a href="{{ path('produit_edit', {id: produit.id}) }}" class="btn btn-icon btn-edit" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                <form method="POST" action="{{ path('produit_delete', {id: produit.id}) }}" onsubmit="return confirm('Supprimer ce produit et tous ses stocks ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete'~produit.id) }}">
                    <button type="submit" class="btn btn-icon btn-delete" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<!-- STOCKS -->
<div class="card" id="stocks">
    <div class="section-header">
        <h2 class="section-title"><i class="fa-solid fa-warehouse"></i> Liste des Stocks</h2>
        <span class="badge-count">{{ totalStocks }} stock(s)</span>
    </div>
    {% if stocks is empty %}
        <div class="empty-state"><i class="fa-solid fa-boxes-stacked"></i><p>Aucun stock enregistré.</p></div>
    {% else %}
    <div class="cards-grid">
        {% for stock in stocks %}
        <div class="item-card {{ stock.isEnAlerte ? 'card-alert':'' }}">
            <div class="item-card-body">
                <div class="stock-card-top">
                    <div>
                        <h3 class="item-card-title">{{ stock.produit.nom }}</h3>
                        <span class="item-badge">{{ stock.produit.categorie ?: 'Autre' }}</span>
                    </div>
                    <span class="statut-badge statut-{{ stock.statut|lower }}">{{ stock.statut }}</span>
                </div>
                <div class="stock-card-stats">
                    <div>
                        <span class="stock-stat-label"><i class="fa-solid fa-cubes"></i> Quantité</span>
                        <span class="stock-stat-value {{ stock.isEnAlerte ? 'text-danger':'text-success' }}">{{ stock.quantiteActuelle }} {{ stock.uniteMesure }}</span>
                    </div>
                    {% if stock.seuilAlerte %}<div><span class="stock-stat-label"><i class="fa-solid fa-bell"></i> Seuil</span><span class="stock-stat-value">{{ stock.seuilAlerte }} {{ stock.uniteMesure }}</span></div>{% endif %}
                    {% if stock.emplacement %}<div><span class="stock-stat-label"><i class="fa-solid fa-location-dot"></i> Emplacement</span><span class="stock-stat-value">{{ stock.emplacement }}</span></div>{% endif %}
                    {% if stock.dateExpiration %}<div><span class="stock-stat-label"><i class="fa-solid fa-calendar-xmark"></i> Expiration</span><span class="stock-stat-value">{{ stock.dateExpiration|date('d/m/Y') }}</span></div>{% endif %}
                </div>
                                {% if stock.seuilAlerte and stock.seuilAlerte > 0 %}
                    {% set ratio = (stock.quantiteActuelle / stock.seuilAlerte * 100)|round %}
                    {% set pct = ratio > 100 ? 100 : (ratio < 0 ? 0 : ratio) %}

                    <div class="progress-container">
                        <div class="progress-bar">
                            <div class="progress-fill {{ pct < 50 ? 'fill-danger' : (pct < 100 ? 'fill-warning' : 'fill-ok') }}" 
                                 style="width: {{ pct }}%"></div>
                        </div>
                        <span class="progress-label">{{ pct }}% du seuil d'alerte</span>
                    </div>
                {% endif %}
            </div>
            <div class="item-card-actions">
                <a href="{{ path('stock_edit', {id: stock.id}) }}" class="btn btn-icon btn-edit"><i class="fa-solid fa-pen"></i></a>
                <form method="POST" action="{{ path('stock_delete', {id: stock.id}) }}" onsubmit="return confirm('Supprimer ce stock ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete'~stock.id) }}">
                    <button type="submit" class="btn btn-icon btn-delete"><i class="fa-solid fa-trash"></i></button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

<!-- ALERTES -->
<div class="card" id="alertes">
    <div class="section-header">
        <h2 class="section-title"><i class="fa-solid fa-triangle-exclamation" style="color:#f44336"></i> Produits en alerte de stock</h2>
        <span class="badge-count {{ totalAlertes > 0 ? 'badge-danger':'' }}">{{ totalAlertes }} alerte(s)</span>
    </div>
    {% if alertes is empty %}
        <div class="empty-state">
            <i class="fa-solid fa-circle-check" style="color:#5a9814;opacity:.5"></i>
            <p>Aucune alerte de stock — tout va bien !</p>
        </div>
    {% else %}
    <div class="table-responsive">
        <table class="data-table">
            <thead><tr><th>Produit</th><th>Catégorie</th><th>Quantité</th><th>Seuil</th><th>Unité</th><th>Emplacement</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
                {% for a in alertes %}
                <tr>
                    <td><strong>{{ a.produit.nom }}</strong></td>
                    <td><span class="item-badge">{{ a.produit.categorie ?: 'Autre' }}</span></td>
                    <td class="text-danger"><strong>{{ a.quantiteActuelle }}</strong></td>
                    <td>{{ a.seuilAlerte }}</td>
                    <td>{{ a.uniteMesure }}</td>
                    <td>{{ a.emplacement ?? '—' }}</td>
                    <td><span class="statut-badge statut-{{ a.statut|lower }}">{{ a.statut }}</span></td>
                    <td><a href="{{ path('stock_edit', {id: a.id}) }}" class="btn btn-icon btn-edit btn-sm"><i class="fa-solid fa-pen"></i></a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script>
const data={{ categorieData|json_encode|raw }};
const ctx=document.getElementById('chartCategories');
if(ctx && Object.keys(data).length>0){
    new Chart(ctx,{type:'bar',
        data:{labels:Object.keys(data),datasets:[{label:'Produits',data:Object.values(data),
            backgroundColor:['rgba(90,152,20,.75)','rgba(33,150,243,.75)','rgba(156,39,176,.75)',
                'rgba(255,152,0,.75)','rgba(244,67,54,.75)','rgba(76,175,80,.75)','rgba(0,188,212,.75)','rgba(255,87,34,.75)'],
            borderRadius:8,borderWidth:0}]},
        options:{responsive:true,maintainAspectRatio:false,
            plugins:{legend:{display:false}},
            scales:{y:{beginAtZero:true,ticks:{stepSize:1},grid:{color:'rgba(90,152,20,.08)'}},x:{grid:{display:false}}}}
    });
}
</script>
{% endblock %}
