<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgriSense360 – {% block title %}Tableau de bord{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════
     SIDEBAR NAVIGATION
     Fixed left sidebar with all modules.
     Teammates' modules are shown as "coming soon" badges.
     ═══════════════════════════════════════════════════════════ -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <span class="brand-icon">🌿</span>
        <span class="brand-name">AgriSense<em>360</em></span>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Gestion</div>

        {# Gestion Culture - with submenu for Parcelle #}
        <div class="nav-item-group">
            <a href="{{ path('culture_index') }}"
               class="nav-link {% if app.request.attributes.get('_route') starts with 'culture' %}active{% endif %}">
                <span class="nav-icon">🌱</span>
                <span class="nav-label">Culture</span>
            </a>
            <a href="{{ path('parcelle_index') }}"
               class="nav-link nav-sub {% if app.request.attributes.get('_route') starts with 'parcelle' %}active{% endif %}">
                <span class="nav-icon">🗺️</span>
                <span class="nav-label">Parcelle</span>
            </a>
        </div>

        {# Gestion Animal - Coming Soon #}
        <div class="nav-link nav-coming-soon" title="Module en cours d'intégration">
            <span class="nav-icon">🐄</span>
            <span class="nav-label">Animal</span>
            <span class="coming-badge">Bientôt</span>
        </div>

        {# Gestion Équipement - Coming Soon #}
        <div class="nav-link nav-coming-soon" title="Module en cours d'intégration">
            <span class="nav-icon">🚜</span>
            <span class="nav-label">Équipement</span>
            <span class="coming-badge">Bientôt</span>
        </div>

        {# Gestion Stock - Coming Soon #}
        <div class="nav-link nav-coming-soon" title="Module en cours d'intégration">
            <span class="nav-icon">📦</span>
            <span class="nav-label">Stock</span>
            <span class="coming-badge">Bientôt</span>
        </div>

        {# Gestion Ouvrier - Coming Soon #}
        <div class="nav-link nav-coming-soon" title="Module en cours d'intégration">
            <span class="nav-icon">👥</span>
            <span class="nav-label">Ouvrier</span>
            <span class="coming-badge">Bientôt</span>
        </div>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-user">
            <span class="user-avatar">👤</span>
            <span class="user-name">Agriculteur</span>
        </div>
        <button class="btn-logout" title="Se déconnecter" onclick="alert('Logout will be linked by user later')">
            <span class="logout-icon">🚪</span>
            <span class="logout-text">Déconnexion</span>
        </button>
    </div>
</aside>

<!-- ═══════════════════════════════════════════════════════════
     MAIN CONTENT AREA
     ═══════════════════════════════════════════════════════════ -->
<main class="main-content">
    {# Flash messages - success / error from controllers #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash flash-{{ label }}">
                {{ message }}
                <button class="flash-close" onclick="this.parentElement.remove()">×</button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block content %}{% endblock %}
</main>

{% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
</body>
</html>
