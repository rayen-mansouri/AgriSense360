<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AgriSense 360{% endblock %}</title>

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green-dark:#2d6a2d;
            --green-mid:#3e8e3e;
            --green-light:#5ab55a;
            --green-pale:#d4edda;
            --bg:#e8f5e4;
            --white:#fff;
            --text-dark:#1e3a1e;
            --text-mid:#4a6741;
            --text-light:#7fa87a;
            --border:#c3ddbf;
            --shadow:0 4px 20px rgba(46,107,46,.12);
            --radius:14px;
        }

        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--bg);
            color: var(--text-dark);
        }

        /* NAVBAR */
/* NAVBAR */
.navbar {
    width: 100%;
    padding: 22px 40px; /* 🔥 taller header */
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--white);
    box-shadow: var(--shadow);
}

.logo {
    font-weight: 800;
    font-size: 1.6rem;
    color: var(--green-dark);
}

/* BUTTONS */
.nav-actions {
    display: flex;
    gap: 12px;
}

.btn-main {
    padding: 10px 22px;
    background: var(--green-mid);
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
}

.btn-main:hover {
    background: var(--green-dark);
}

.btn-outline {
    padding: 10px 20px;
    border: 2px solid var(--green-mid);
    border-radius: 50px;
    text-decoration: none;
    color: var(--green-mid);
    font-weight: 600;
}

.btn-outline:hover {
    background: var(--green-pale);
}

        .nav-links a:hover {
            color: var(--green-dark);
        }

        .container {
            padding: 40px 20px;
        }

        .btn-primary {
            display:block;
            width:100%;
            padding:14px;
            background:var(--green-mid);
            color:#fff;
            border-radius:50px;
            text-align:center;
            text-decoration:none;
            font-weight:700;
        }

        .btn-outline {
            display:block;
            width:100%;
            padding:13px;
            border:2px solid var(--green-mid);
            border-radius:50px;
            text-align:center;
            text-decoration:none;
            color:var(--green-mid);
        }

    </style>

    {% block styles %}{% endblock %}
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
    <div class="logo">🌱 AgriSense 360</div>

    <div class="nav-actions">
        {% if app.user %}
            <a href="{{ path('app_logout') }}" class="btn-outline">Déconnexion</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn-outline">Se connecter</a>
            <a href="{{ path('app_register') }}" class="btn-main">S'inscrire</a>
        {% endif %}
    </div>
</div>

{% block body %}{% endblock %}

</body>
</html>