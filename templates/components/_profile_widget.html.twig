{#
  Usage: {% set _navUser = app.user %}{% include 'components/_profile_widget.html.twig' %}
  Renders: avatar button + dropdown + edit modal
#}
{% set _u = app.user %}
{% if _u %}

{# ── Inline styles (injected once per page via this include) ── #}
<style>
.pw-wrap{position:relative;display:inline-block}
.pw-btn{width:40px;height:40px;border-radius:50%;border:2px solid rgba(62,142,62,.3);cursor:pointer;overflow:hidden;background:#3e8e3e;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.92rem;flex-shrink:0;transition:border-color .18s}
.pw-btn:hover{border-color:#3e8e3e}
.pw-btn img{width:100%;height:100%;object-fit:cover}
.pw-dropdown{position:absolute;top:calc(100% + 10px);right:0;width:220px;background:#fff;border:1.5px solid #dde8d8;border-radius:14px;box-shadow:0 8px 32px rgba(30,58,30,.12);z-index:500;padding:8px 0;display:none;animation:fadeIn .15s ease}
.pw-dropdown.open{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.pw-header{padding:12px 16px 10px;border-bottom:1px solid #f0f4f0}
.pw-name{font-weight:700;font-size:.88rem;color:#1e3a1e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pw-email{font-size:.72rem;color:#6b8f6b;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pw-item{display:flex;align-items:center;gap:9px;padding:9px 16px;font-size:.83rem;color:#1e3a1e;cursor:pointer;text-decoration:none;transition:background .15s;border:none;background:none;width:100%;text-align:left}
.pw-item:hover{background:#f4f9f1}
.pw-item.danger{color:#dc2626}
.pw-item.danger:hover{background:rgba(220,38,38,.06)}
.pw-lang-switcher{display:flex;padding:8px 16px;gap:8px;border-top:1px solid #f0f4f0;margin-top:4px}
.pw-lang-btn{font-size:.75rem;font-weight:700;color:#6b8f6b;text-decoration:none;padding:2px 6px;border-radius:4px;border:1px solid #dde8d8}
.pw-lang-btn.active{background:#3e8e3e;color:#fff;border-color:#3e8e3e}

/* Modal */
.pm-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center;padding:20px}
.pm-overlay.open{display:flex}
.pm-box{background:#fff;border-radius:20px;width:100%;max-width:440px;overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.2);animation:slideUp .22s ease}
@keyframes slideUp{from{transform:translateY(30px);opacity:0}to{transform:translateY(0);opacity:1}}
.pm-top{height:4px;background:linear-gradient(90deg,#2d6a2d,#3e8e3e,#81c784)}
.pm-inner{padding:24px 28px 28px}
.pm-title{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:700;color:#1e3a1e;margin-bottom:18px}
.pm-avatar-row{display:flex;align-items:center;gap:14px;margin-bottom:18px}
.pm-av{width:60px;height:60px;border-radius:50%;object-fit:cover;border:2px solid #dde8d8;background:#3e8e3e;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:1.3rem;flex-shrink:0;overflow:hidden}
.pm-av img{width:100%;height:100%;object-fit:cover}
.pm-av-label{font-size:.78rem;color:#6b8f6b;cursor:pointer;text-decoration:underline}
.pm-field{margin-bottom:13px}
.pm-label{display:block;font-size:.7rem;font-weight:700;color:#6b8f6b;margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em}
.pm-inp{width:100%;padding:10px 13px;background:#f4f9f1;border:1.5px solid #dde8d8;border-radius:9px;font-family:inherit;font-size:.87rem;color:#1e3a1e;outline:none;transition:border-color .18s}
.pm-inp:focus{border-color:#3e8e3e;box-shadow:0 0 0 3px rgba(76,175,80,.12);background:#fff}
.pm-divider{border:none;border-top:1px solid #f0f4f0;margin:16px 0}
.pm-actions{display:flex;gap:10px;margin-top:20px}
.pm-cancel{flex:1;padding:11px;background:transparent;color:#6b8f6b;border:1.5px solid #dde8d8;border-radius:9px;font-family:inherit;font-weight:700;font-size:.87rem;cursor:pointer}
.pm-save{flex:2;padding:11px;background:#3e8e3e;color:#fff;border:none;border-radius:9px;font-family:inherit;font-weight:700;font-size:.87rem;cursor:pointer;transition:background .18s}
.pm-save:hover{background:#2d6a2d}
.pm-save:disabled{opacity:.55;cursor:not-allowed}
.pm-msg{padding:9px 12px;border-radius:8px;font-size:.81rem;margin-bottom:12px;display:none}
.pm-msg.ok{background:rgba(62,142,62,.1);color:#2d6a2d;border:1px solid rgba(62,142,62,.25)}
.pm-msg.err{background:rgba(220,38,38,.07);color:#dc2626;border:1px solid rgba(220,38,38,.2)}
</style>

{# Build avatar src #}
{% set _pic = _u.profilePicture %}
{% if _pic starts with 'http' %}
    {% set _avatarSrc = _pic %}
{% elseif _pic %}
    {% set _avatarSrc = asset('uploads/profiles/' ~ _pic) %}
{% else %}
    {% set _avatarSrc = null %}
{% endif %}

<div class="pw-wrap" id="pwWrap">
    <div class="pw-btn" id="pwBtn" onclick="toggleProfileDropdown()">
        {% if _avatarSrc %}<img src="{{ _avatarSrc }}" alt="{{ _u.name }}">{% else %}{{ _u.name|slice(0,1)|upper }}{% endif %}
    </div>
    <div class="pw-dropdown" id="pwDropdown">
        <div class="pw-header">
            <div class="pw-name" id="pwName">{{ _u.name }}</div>
            <div class="pw-email">{{ _u.email }}</div>
        </div>
        <button class="pw-item" onclick="openProfileModal()">✏️ {{ 'profile.quick_edit'|trans }}</button>
        <a href="{{ path('profile_show') }}" class="pw-item">👤 {{ 'profile.full_profile'|trans }}</a>
        <a href="{{ path('app_logout') }}" class="pw-item danger">🚪 {{ 'nav.logout'|trans }}</a>
        
        <div class="pw-lang-switcher">
            <a href="{{ path('change_locale', {locale: 'fr'}) }}" class="pw-lang-btn {{ app.request.locale == 'fr' ? 'active' : '' }}">FR</a>
            <a href="{{ path('change_locale', {locale: 'en'}) }}" class="pw-lang-btn {{ app.request.locale == 'en' ? 'active' : '' }}">EN</a>
        </div>
    </div>
</div>

{# Edit Modal #}
<div class="pm-overlay" id="pmOverlay">
    <div class="pm-box">
        <div class="pm-top"></div>
        <div class="pm-inner">
            <div class="pm-title">✏️ {{ 'profile.quick_edit'|trans }}</div>
            <div class="pm-msg" id="pmMsg"></div>

            <div class="pm-avatar-row">
                <div class="pm-av" id="pmAv">
                    {% if _avatarSrc %}<img src="{{ _avatarSrc }}" id="pmAvImg" alt="">{% else %}<span id="pmAvInitial">{{ _u.name|slice(0,1)|upper }}</span>{% endif %}
                </div>
                <div>
                    <div style="font-size:.85rem;font-weight:600;color:#1e3a1e;margin-bottom:3px">{{ _u.name }}</div>
                    <label class="pm-av-label" for="pmPhotoInput">{{ 'profile.change_photo'|trans }}</label>
                    <input type="file" id="pmPhotoInput" accept="image/*" style="display:none">
                </div>
            </div>

            <div class="pm-field">
                <label class="pm-label" for="pmName">{{ 'common.name'|trans }}</label>
                <input class="pm-inp" type="text" id="pmName" value="{{ _u.name }}" placeholder="{{ 'common.name'|trans }}">
            </div>

            <hr class="pm-divider">
            <div style="font-size:.7rem;font-weight:700;color:#6b8f6b;text-transform:uppercase;letter-spacing:.04em;margin-bottom:10px">{{ 'profile.new_password'|trans }}</div>

            <div class="pm-field">
                <label class="pm-label" for="pmCurrent">{{ 'profile.current_password'|trans }}</label>
                <input class="pm-inp" type="password" id="pmCurrent" placeholder="{{ 'profile.current_password'|trans }}">
            </div>
            <div class="pm-field">
                <label class="pm-label" for="pmNew">{{ 'profile.new_password'|trans }} <span style="font-weight:400;text-transform:none">({{ 'farms.cv_hint'|trans|replace({'PDF': '', '5 Mo': ''})|trim }})</span></label>
                <input class="pm-inp" type="password" id="pmNew" placeholder="{{ 'profile.new_password'|trans }}">
            </div>
            <div class="pm-field">
                <label class="pm-label" for="pmConfirm">{{ 'profile.confirm_password'|trans }}</label>
                <input class="pm-inp" type="password" id="pmConfirm" placeholder="{{ 'profile.confirm_password'|trans }}">
            </div>

            <div class="pm-actions">
                <button class="pm-cancel" onclick="closeProfileModal()">{{ 'common.cancel'|trans }}</button>
                <button class="pm-save" id="pmSave" onclick="saveProfile()">💾 {{ 'common.save'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<script>
const _quickUpdateUrl = '{{ path('profile_quick_update') }}';
let _pmPhotoFile = null;

function toggleProfileDropdown() {
    document.getElementById('pwDropdown').classList.toggle('open');
}
document.addEventListener('click', function(e) {
    const wrap = document.getElementById('pwWrap');
    if (wrap && !wrap.contains(e.target)) {
        document.getElementById('pwDropdown').classList.remove('open');
    }
});

function openProfileModal() {
    document.getElementById('pwDropdown').classList.remove('open');
    document.getElementById('pmOverlay').classList.add('open');
    document.getElementById('pmMsg').style.display = 'none';
    document.getElementById('pmCurrent').value = '';
    document.getElementById('pmNew').value = '';
    document.getElementById('pmConfirm').value = '';
    _pmPhotoFile = null;
}
function closeProfileModal() {
    document.getElementById('pmOverlay').classList.remove('open');
}
document.getElementById('pmOverlay').addEventListener('click', function(e) {
    if (e.target === this) closeProfileModal();
});

document.getElementById('pmPhotoInput').addEventListener('change', function() {
    if (this.files && this.files[0]) {
        _pmPhotoFile = this.files[0];
        const reader = new FileReader();
        reader.onload = e => {
            const av = document.getElementById('pmAv');
            av.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover" alt="">';
        };
        reader.readAsDataURL(_pmPhotoFile);
    }
});

async function saveProfile() {
    const btn  = document.getElementById('pmSave');
    const msg  = document.getElementById('pmMsg');
    btn.disabled = true; btn.textContent = '{{ 'profile.saving'|trans }}';
    msg.style.display = 'none';

    const fd = new FormData();
    fd.append('name',             document.getElementById('pmName').value);
    fd.append('current_password', document.getElementById('pmCurrent').value);
    fd.append('new_password',     document.getElementById('pmNew').value);
    fd.append('confirm_password', document.getElementById('pmConfirm').value);
    if (_pmPhotoFile) fd.append('photo', _pmPhotoFile);

    try {
        const res  = await fetch(_quickUpdateUrl, { method: 'POST', body: fd });
        const data = await res.json();
        msg.className = 'pm-msg ' + (data.success ? 'ok' : 'err');
        msg.textContent = data.message;
        msg.style.display = 'block';
        if (data.success) {
            // Update nav avatar + name live
            document.getElementById('pwName').textContent = data.name;
            if (data.photoUrl) {
                document.getElementById('pwBtn').innerHTML = '<img src="' + data.photoUrl + '" style="width:100%;height:100%;object-fit:cover" alt="">';
            }
            setTimeout(closeProfileModal, 1500);
        }
    } catch(e) {
        msg.className = 'pm-msg err'; msg.textContent = '{{ 'profile.network_error'|trans }}'; msg.style.display = 'block';
    }
    btn.disabled = false; btn.textContent = '💾 {{ 'common.save'|trans }}';
}
</script>
{% endif %}
