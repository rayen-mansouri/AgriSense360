// ═══════════════════════════════════════
// CULTURE MAP
// ═══════════════════════════════════════
const CULTURE_MAP = {{ cultureMap|json_encode|raw }};

// ═══════════════════════════════════════
// VALIDATION HELPERS
// ═══════════════════════════════════════
function setError(inputEl, errEl, msg) { errEl.textContent = msg; inputEl.classList.add('is-invalid'); }
function clearError(inputEl, errEl)    { errEl.textContent = '';  inputEl.classList.remove('is-invalid'); }

function validateCultureForm(prefix) {
    let valid = true;
    const fields = [
        [prefix+'-type',            prefix+'-type-err',            '⚠️ Veuillez sélectionner un type de culture'],
        [prefix+'-nom',             prefix+'-nom-err',             '⚠️ Veuillez sélectionner une culture'],
        [prefix+'-parcelle',        prefix+'-parcelle-err',        '⚠️ Veuillez sélectionner une parcelle'],
        [prefix+'-date-plantation', prefix+'-date-plantation-err', '⚠️ La date de plantation est obligatoire'],
    ];
    fields.forEach(([id, errId, msg]) => {
        const el = document.getElementById(id);
        const err = document.getElementById(errId);
        if (!el.value) { setError(el, err, msg); valid = false; }
        else clearError(el, err);
    });

    const surfEl  = document.getElementById(prefix+'-surface');
    const surfErr = document.getElementById(prefix+'-surface-err');
    const surfVal = surfEl.value.trim();
    if (!surfVal)                        { setError(surfEl, surfErr, '⚠️ La surface est obligatoire'); valid = false; }
    else if (isNaN(surfVal))             { setError(surfEl, surfErr, '⚠️ Entrez un nombre valide');   valid = false; }
    else if (parseFloat(surfVal) <= 0)   { setError(surfEl, surfErr, '⚠️ La surface doit être > 0');  valid = false; }
    else clearError(surfEl, surfErr);

    return valid;
}

document.addEventListener('DOMContentLoaded', function () {
    ['add','edit'].forEach(function(prefix) {
        [['type','change'],['nom','change'],['parcelle','change'],['date-plantation','change'],['surface','input']]
        .forEach(function([field, evt]) {
            const el  = document.getElementById(prefix+'-'+field);
            const err = document.getElementById(prefix+'-'+field+'-err');
            if (el && err) el.addEventListener(evt, () => clearError(el, err));
        });
    });
});

// ═══════════════════════════════════════
// MODAL HELPERS
// ═══════════════════════════════════════
function openModal(id) { 
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.style.display = 'flex'; 
    // Don't lock body overflow - let modal handle scrolling internally
}
function closeModal(id) {
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.style.display = 'none';
    document.querySelectorAll('#'+id+' .field-error').forEach(el => el.textContent = '');
    document.querySelectorAll('#'+id+' .form-control.is-invalid').forEach(el => el.classList.remove('is-invalid'));
}

{% if app.request.query.get('modal') == 'add' %}
    window.addEventListener('DOMContentLoaded', () => openModal('modal-add'));
{% endif %}

// ═══════════════════════════════════════
// CROP LIST
// ═══════════════════════════════════════
function updateCropList(prefix) {
    const type = document.getElementById(prefix+'-type').value;
    const nomSelect = document.getElementById(prefix+'-nom');
    nomSelect.innerHTML = '<option value="">— Sélectionner —</option>';
    if (type && CULTURE_MAP[type]) {
        CULTURE_MAP[type].forEach(crop => {
            const opt = document.createElement('option');
            opt.value = opt.textContent = crop;
            nomSelect.appendChild(opt);
        });
    }
}

// ═══════════════════════════════════════
// HARVEST DATE AUTO-CALCULATE
// ═══════════════════════════════════════
async function fetchHarvestDate(prefix) {
    const nom = document.getElementById(prefix+'-nom').value;
    const dp  = document.getElementById(prefix+'-date-plantation').value;
    const recolteInput = document.getElementById(prefix+'-date-recolte');
    const previewDiv   = document.getElementById(prefix+'-harvest-preview');
    if (!nom || !dp) return;
    try {
        const res  = await fetch(`{{ path('culture_harvest_date') }}?nom=${encodeURIComponent(nom)}&date=${dp}`);
        const data = await res.json();
        if (data.date) {
            recolteInput.value = data.date;
            previewDiv.innerHTML = `🗓️ Récolte estimée : <strong>${formatDate(data.date)}</strong>
                — Durée totale : <strong>${data.duration} jours</strong>
                (Semis: ${data.phases.semis}j · Croissance: ${data.phases.croissance}j · Maturité: ${data.phases.maturite}j)`;
            previewDiv.classList.add('visible');
        }
    } catch(e) { console.warn('Harvest date fetch failed', e); }
}

function formatDate(iso) { const [y,m,d] = iso.split('-'); return `${d}/${m}/${y}`; }

// ═══════════════════════════════════════
// EDIT MODAL
// ═══════════════════════════════════════
function openEditModal(id, nom, type, dp, dr, surface, parcelleId) {
    document.getElementById('form-edit').action = `/culture/${id}/edit`;
    const typeEl = document.getElementById('edit-type');
    typeEl.value = type;
    updateCropList('edit');
    setTimeout(() => {
        document.getElementById('edit-nom').value            = nom;
        document.getElementById('edit-date-plantation').value= dp || '';
        document.getElementById('edit-date-recolte').value   = dr || '';
        document.getElementById('edit-surface').value        = surface;
        document.getElementById('edit-parcelle').value       = parcelleId;
    }, 10);
    openModal('modal-edit');
}

