        <div style="margin-top:16px;padding:14px 16px;background:#f0fdf4;
                    border:1px solid #86efac;border-radius:10px;">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;
                        color:#1e3c2c;margin-bottom:8px;letter-spacing:0.05em;">
                🤖 Résultat IA — Récolte confirmée
            </div>
            <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;">
                <div>
                    <div style="font-size:0.7rem;color:#6b7280;">Quantité récoltée</div>
                    <div style="font-size:1.5rem;font-weight:800;color:#1e3c2c;">${c.quantiteRecolte} kg</div>
