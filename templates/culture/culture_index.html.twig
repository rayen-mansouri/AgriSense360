{% extends 'base.html.twig' %}
{% set activePage = 'cultures' %}
{% set activeSection = 'main' %}

{% block title %}Cultures — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    /* Override page elements for dark theme */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    .page-title { font-size: 1.75rem; font-weight: 800; color: var(--ch3); margin-bottom: 4px; }
    .page-subtitle { color: var(--cp); font-size: 0.9rem; }
    
    /* Search and toolbar */
    .toolbar { background: var(--cb); padding: 16px; border-radius: 12px; margin-bottom: 24px; border: 1px solid var(--cbr); }
    .search-wrap { position: relative; flex: 1; min-width: 200px; }
    .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--cp); font-size: 1rem; pointer-events: none; }
    .search-input { width: 100%; padding: 10px 14px 10px 36px; border: 1px solid var(--cbr); border-radius: 8px; background: transparent; color: var(--ch3); font-size: 0.9rem; }
    .search-input::placeholder { color: var(--cp); }
    .search-input:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 2px rgba(90,181,90,0.15); }
    
    /* Card grid */
    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }
    
    /* Culture cards - main styling */
    .culture-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 16px; overflow: hidden; transition: all 0.3s ease; display: flex; flex-direction: column; }
    .culture-card:hover { transform: translateY(-5px); box-shadow: 0 12px 30px rgba(0,0,0,0.3); border-color: var(--g); }
    
    .culture-card-image { width: 100%; height: 180px; background: linear-gradient(135deg, rgba(90,181,90,0.1), rgba(90,181,90,0.05)); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .culture-card-image img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
    .img-fallback { font-size: 3rem; opacity: 0.7; }
    
    .culture-card-body { padding: 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .culture-card-type { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cp); }
    .culture-card-name { font-size: 1.05rem; font-weight: 700; color: var(--ch3); line-height: 1.3; }
    
    .culture-card-footer { padding: 12px 16px 16px; display: flex; gap: 8px; align-items: center; justify-content: center; flex-wrap: wrap; border-top: 1px solid var(--cbr); }
    
    /* État badges */
    .etat-badge { display: inline-block; padding: 4px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; text-align: center; }
    .etat-semis { background: rgba(76,175,80,0.2); color: #4CAF50; }
    .etat-croissance { background: rgba(255,152,0,0.2); color: #FF9800; }
    .etat-maturite { background: rgba(33,150,243,0.2); color: #2196F3; }
    .etat-recolte { background: rgba(244,67,54,0.2); color: #F44336; }
    .etat-recolte-prevue { background: rgba(255,193,7,0.2); color: #FFC107; }
    
    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; border: 1px solid transparent; font-family: inherit; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .btn:active { transform: scale(0.98); }
    .btn-primary { background: var(--g); color: #fff; border-color: var(--g); }
    .btn-primary:hover { background: var(--gm); border-color: var(--gm); }
    .btn-secondary { background: var(--cb); color: var(--cp); border-color: var(--cbr); }
    .btn-secondary:hover { background: rgba(90,181,90,0.1); border-color: var(--g); color: var(--g); }
    .btn-sm { padding: 6px 10px; font-size: 0.8rem; }
    
    /* Field errors */
    .field-error { display:block;color:var(--danger);font-size:12px;margin-top:4px;min-height:16px;font-weight:500; }
    .field-error:empty { margin-top:0; }
    .form-control.is-invalid { border-color:var(--danger) !important; box-shadow:0 0 0 2px rgba(248,113,113,.15); }
    
    /* Harvest button */
    .btn-harvest { background: var(--gd); color: #fff; border: none; font-weight: 700; transition: background 0.15s; }
    .btn-harvest:hover { background: var(--gm); }
    
    /* IA harvested badge */
    .ia-harvested-badge { position: absolute; bottom: 8px; left: 8px; background: rgba(0,0,0,0.6); color: #fff; font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; backdrop-filter: blur(4px); }
    
    /* Modal dark theme fixes */
    /* Modal premium pop-up styling */
    .modal-backdrop { 
        position: fixed; top: 0; left: 0; right: 0; bottom: 0; 
        background: rgba(0,0,0,0.75); 
        backdrop-filter: blur(8px);
        z-index: 10000 !important; 
        display: none; 
        align-items: center; justify-content: center; 
        padding: 20px; 
    }
    .modal { 
        background: var(--sidebar-bg); 
        box-shadow: 0 30px 70px rgba(0,0,0,0.6); 
        border-radius: 28px; 
        width: 100%; max-width: 540px; 
        max-height: 90vh; 
        overflow-y: auto; 
        border: 1px solid var(--sidebar-border);
        position: relative;
        animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalScale {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
    .modal-header { 
        padding: 24px 32px; 
        display: flex; align-items: center; justify-content: space-between; 
        border-bottom: 1px solid var(--sidebar-border); 
    }
    .modal-title { 
        color: var(--ch3); 
        font-weight: 800; font-size: 1.5rem; 
        display: flex; align-items: center; gap: 10px;
    }
    .modal-close { 
        background: none; border: none; color: var(--cp); 
        font-size: 1.8rem; cursor: pointer; padding: 4px; 
        transition: all 0.2s; line-height: 1;
    }
    .modal-close:hover { color: var(--danger); transform: rotate(90deg); }
    .modal-body { padding: 32px; }
    .modal-footer { 
        padding: 20px 32px; 
        background: rgba(0,0,0,0.05);
        border-top: 1px solid var(--sidebar-border); 
        display: flex; justify-content: flex-end; gap: 12px; 
    }
    
    /* Form refinement to match capture */
    .form-group { margin-bottom: 20px; }
    .form-group label { 
        font-size: 0.9rem; font-weight: 700; color: var(--ch3); 
        margin-bottom: 8px; display: block;
    }
    .form-control { 
        width: 100%;
        background: rgba(0,0,0,0.1); 
        border: 1.5px solid var(--sidebar-border);
        border-radius: 12px; padding: 12px 16px; 
        color: var(--ch3); font-weight: 500;
        transition: all 0.2s;
    }
    [data-theme="light"] .form-control { background: #f8fafc; border-color: rgba(0,0,0,0.1); color: #1a3a1a; }
    .form-control:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 4px rgba(90,181,90,0.1); }
    
    /* Orange button from capture */
    .btn-orange { 
        background: #ff8c00; color: #fff; border: none; 
        padding: 12px 28px; border-radius: 50px; 
        font-weight: 700; font-size: 1rem;
        box-shadow: 0 4px 15px rgba(255,140,0,0.3);
        cursor: pointer;
        display: inline-flex; align-items: center; gap: 8px;
        transition: all 0.2s;
    }
    .btn-orange:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,140,0,0.4); background: #ff9f1a; }
    .btn-orange:active { transform: scale(0.98); }
    
    /* Empty state */
    .empty-state { grid-column: 1 / -1; text-align: center; padding: 60px 20px; }
    .empty-icon { font-size: 4rem; margin-bottom: 16px; }
    .empty-title { font-size: 1.3rem; font-weight: 700; color: var(--ch3); margin-bottom: 8px; }
    .empty-subtitle { color: var(--cp); font-size: 0.95rem; }
    
    /* IA modal KPI cards */
    .ia-kpi { padding: 10px 12px; background: #f0fdf4; border: 1px solid #86efac; border-radius: 10px; text-align: center; }
    .ia-kpi-label { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; color: #6b7280; margin-bottom: 4px; }
    .ia-kpi-value { font-size: 1.05rem; font-weight: 800; color: #1e3c2c; }
    
    /* Breakdown items */
    .ia-bd-item { display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; border-radius: 8px; margin-bottom: 6px; font-size: 0.85rem; border-left: 3px solid transparent; }
    .ia-bd-item.danger  { background: #fff5f5; border-left-color: #dc2626; }
    .ia-bd-item.warning { background: #fffbeb; border-left-color: #d97706; }
    .ia-bd-item.info    { background: #eff6ff; border-left-color: #3b82f6; }
    .ia-bd-item.success { background: #f0fdf4; border-left-color: #16a34a; }
    .ia-bd-icon  { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
    .ia-bd-label { font-weight: 600; color: #1f2937; }
    .ia-bd-impact { font-size: 0.77rem; color: #6b7280; margin-top: 1px; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div style="padding: 30px;">

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('app_home') }}">🏠 Accueil</a> / Cultures
        </p>
        <h1 class="page-title">🌱 Cultures</h1>
        <p class="page-subtitle">{{ cultures|length }} culture(s) enregistrée(s)</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">🗺️ Voir les parcelles</a>
        <a href="{{ path('culture_analytics') }}" class="btn btn-secondary">🤖 Analytique IA</a>
        <button class="btn btn-secondary" onclick="openAgendaModal()">📅 Agenda</button>
        <button class="btn btn-primary" onclick="openModal('modal-add')">➕ Nouvelle culture</button>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   TOOLBAR
   ═══════════════════════════════════════════════════ #}
<div class="toolbar">
    <form method="get" action="{{ path('culture_index') }}" style="flex:1;display:flex;gap:10px;flex-wrap:wrap;">
        <div class="search-wrap" style="flex:1;min-width:200px;">
            <span class="search-icon">🔍</span>
            <input type="text"
                   name="search"
                   value="{{ search }}"
                   class="search-input"
                   placeholder="Rechercher une culture…"
                   autocomplete="off">
        </div>
        <div class="sort-group">
            <button type="submit" name="sort" value="type"
                    class="btn btn-secondary {% if sort == 'type' %}active{% endif %}">
                🏷️ Type
            </button>
            <button type="submit" name="sort" value="etat"
                    class="btn btn-secondary {% if sort == 'etat' %}active{% endif %}">
                📊 État
            </button>
            <button type="submit" name="sort" value="surface"
                    class="btn btn-secondary {% if sort == 'surface' %}active{% endif %}">
                📐 Surface
            </button>
            {% if sort or search %}
                <a href="{{ path('culture_index') }}" class="btn btn-secondary">↺ Reset</a>
            {% endif %}
        </div>
    </form>
</div>

{# ═══════════════════════════════════════════════════
   DONNÉES JS
   ═══════════════════════════════════════════════════ #}
<script>
const CULTURES_DATA = [
    {% for culture in cultures %}
    {
        id: {{ culture.id }},
        nom: {{ culture.nom|json_encode|raw }},
        typeCulture: {{ culture.typeCulture|json_encode|raw }},
        etat: {{ culture.etat|json_encode|raw }},
        surface: {{ culture.surface ?? 0 }},
        datePlantation: {{ culture.datePlantation ? culture.datePlantation|date('Y-m-d')|json_encode|raw : 'null' }},
        dateRecolte: {{ culture.dateRecolte ? culture.dateRecolte|date('Y-m-d')|json_encode|raw : 'null' }},
        img: {{ culture.img|json_encode|raw }},
        parcelleName: {{ (parcelleMap[culture.parcelle.id] ?? 'N/A')|json_encode|raw }},
        quantiteRecolte: {{ culture.quantiteRecolte is not null ? culture.quantiteRecolte : 'null' }},
        iaScore: {{ culture.iaScore is not null ? culture.iaScore : 'null' }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
];
</script>

{# ═══════════════════════════════════════════════════
   CULTURE CARDS GRID
   ═══════════════════════════════════════════════════ #}
<div class="card-grid">

    {% if cultures is empty %}
        <div class="empty-state">
            <div class="empty-icon">🌱</div>
            <div class="empty-title">Aucune culture trouvée</div>
            <div class="empty-subtitle">Ajoutez votre première culture pour commencer</div>
        </div>
    {% endif %}

    {% for culture in cultures %}
    <div class="culture-card"
         style="cursor:pointer;"
         title="Double-cliquez pour voir les détails"
         ondblclick="openCultureDetail({{ culture.id }})"
         data-culture-id="{{ culture.id }}">

        <div class="culture-card-image">
            {% if culture.img %}
                <img src="{{ asset('images/cultures/' ~ culture.img) }}"
                     alt="{{ culture.nom }}"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="img-fallback" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;background:var(--green-100);">
                    {{ cultureTypeEmoji(culture.typeCulture) }}
                </div>
            {% else %}
                <div class="img-fallback" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--green-100);">
                    {{ cultureTypeEmoji(culture.typeCulture) }}
                </div>
            {% endif %}

            {# ── IA Récolte badge — shown if already harvested ── #}
            {% if culture.etat == 'Récolte' and culture.quantiteRecolte is not null %}
            <div class="ia-harvested-badge">
                🌾 {{ culture.quantiteRecolte|number_format(1) }} kg
            </div>
            {% endif %}
        </div>

        <div class="culture-card-body">
            <span class="culture-card-type">{{ culture.typeCulture }}</span>
            <div class="culture-card-name">{{ culture.nom }}</div>
            {% set etatClass = etatToCssClass(culture.etat) %}
            <span class="etat-badge {{ etatClass }}">{{ culture.etat }}</span>

            <div class="culture-card-meta">
                <div class="meta-item">
                    <span class="meta-label">Surface</span>
                    <span class="meta-value">{{ culture.surface }} m²</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Parcelle</span>
                    <span class="meta-value">
                        <a href="{{ path('parcelle_index') }}" style="color:var(--green-600);text-decoration:none;">
                            {{ parcelleMap[culture.parcelle.id] ?? 'N/A' }}
                        </a>
                    </span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Plantation</span>
                    <span class="meta-value">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Récolte prévue</span>
                    <span class="meta-value">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</span>
                </div>
            </div>
        </div>

        <div class="culture-card-footer">
            {# ── Standard edit button (hidden when already harvested) ── #}
            {% if culture.etat != 'Récolte' %}
            <button class="btn btn-secondary btn-sm"
                    onclick="event.stopPropagation(); openEditModal({{ culture.id }},
                        '{{ culture.nom|e('js') }}',
                        '{{ culture.typeCulture|e('js') }}',
                        {{ culture.datePlantation ? "'" ~ culture.datePlantation|date('Y-m-d') ~ "'" : 'null' }},
                        {{ culture.dateRecolte ? "'" ~ culture.dateRecolte|date('Y-m-d') ~ "'" : 'null' }},
                        {{ culture.surface ?? 0 }},
                        {{ culture.parcelle.id }})">
                ✏️ Modifier
            </button>
            {% endif %}

            {# ── 🌾 RÉCOLTER button — only when close to or past harvest date ── #}
            {% if culture.isReadyToHarvest() and culture.etat != 'Récolte' %}
            <button class="btn btn-harvest btn-sm"
                    onclick="event.stopPropagation(); openHarvestModal(
                        {{ culture.id }},
                        {{ culture.nom|json_encode|raw }},
                        {{ culture.surface ?? 0 }},
                        {{ csrf_token('harvest-culture-' ~ culture.id)|json_encode|raw }}
                    )">
                🌾 Récolter
            </button>
            {% endif %}

            {# ── Delete button ── #}
            <form method="post" action="{{ path('culture_delete', {id: culture.id}) }}"
                  onsubmit="return confirm('Supprimer « {{ culture.nom|e('js') }} » ?')"
                  onclick="event.stopPropagation();">
                <input type="hidden" name="_token"
                       value="{{ csrf_token('del-culture-' ~ culture.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
            </form>
        </div>
    </div>
    {% endfor %}

</div>

{# ═══════════════════════════════════════════════════
   MODAL — ADD CULTURE
   ═══════════════════════════════════════════════════ #}
<div id="modal-add" class="modal-backdrop" style="display:none;"
     onclick="if(event.target===this)closeModal('modal-add')">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">+ Ajouter une Culture</span>
            <button class="modal-close" onclick="closeModal('modal-add')">×</button>
        </div>
        <form id="form-add" method="post" action="{{ path('culture_new') }}"
              onsubmit="return validateCultureForm('add')">
            <div class="modal-body">

                {% if app.request.query.has('error') %}
                <div style="background:#ffebee; border-left:4px solid #f44336; padding:12px; border-radius:5px; margin-bottom:15px; color:#c62828;">
                    ⚠️ Veuillez corriger les erreurs ci-dessous
                </div>
                {% endif %}

                <div class="form-group">
                    <label class="form-label">Type de culture <span class="required">*</span></label>
                    <select name="type_culture" id="add-type" class="form-control"
                            onchange="updateCropList('add')">
                        <option value="">— Sélectionner un type —</option>
                        {% for type, names in cultureMap %}
                            <option value="{{ type }}">{{ type }}</option>
                        {% endfor %}
                    </select>
                    <span class="field-error" id="add-type-err"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Culture <span class="required">*</span></label>
                    <select name="nom" id="add-nom" class="form-control"
                            onchange="fetchHarvestDate('add')">
                        <option value="">— Choisir d'abord le type —</option>
                    </select>
                    <span class="field-error" id="add-nom-err"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Parcelle <span class="required">*</span></label>
                    <select name="parcelle_id" id="add-parcelle" class="form-control">
                        <option value="">— Sélectionner une parcelle —</option>
                        {% for parcelle in parcelles %}
                            {% if parcelle.statut == 'Libre' and parcelle.surfaceRestant > 0.01 %}
                                <option value="{{ parcelle.id }}">
                                    {{ parcelle.nom }} — Restant: {{ parcelle.surfaceRestant|number_format(2,',') }} m²
                                </option>
                            {% endif %}
                        {% endfor %}
                    </select>
                    <span class="field-error" id="add-parcelle-err"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Date de plantation <span class="required">*</span></label>
                        <input type="date" name="date_plantation" id="add-date-plantation"
                               class="form-control"
                               onchange="fetchHarvestDate('add')">
                        <span class="field-error" id="add-date-plantation-err"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Surface (m²) <span class="required">*</span></label>
                        <input type="text" name="surface" id="add-surface" class="form-control"
                               placeholder="ex: 500">
                        <span class="field-error" id="add-surface-err"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Date de récolte <span style="font-size:0.75rem;color:#6b7280;font-weight:400;">(calculée automatiquement)</span></label>
                    <input type="date" name="date_recolte" id="add-date-recolte" class="form-control"
                           readonly tabindex="-1"
                           style="background:#f3f4f6;color:#6b7280;cursor:not-allowed;pointer-events:none;">
                    <div id="add-harvest-preview" class="harvest-preview">
                        🗓️ Date calculée automatiquement selon la durée de croissance
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-add')">Annuler</button>
                <button type="submit" class="btn-orange">✓ Enregistrer</button>
            </div>
        </form>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   MODAL — EDIT CULTURE
   ═══════════════════════════════════════════════════ #}
<div id="modal-edit" class="modal-backdrop" style="display:none;"
     onclick="if(event.target===this)closeModal('modal-edit')">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">✏️ Modifier la Culture</span>
            <button class="modal-close" onclick="closeModal('modal-edit')">×</button>
        </div>
        <form id="form-edit" method="post" action=""
              onsubmit="return validateCultureForm('edit')">
            <div class="modal-body">

                {% if app.request.query.get('edit_error') == '1' %}
                <div style="background:#ffebee; border-left:4px solid #f44336; padding:12px; border-radius:5px; margin-bottom:15px; color:#c62828;">
                    ⚠️ Erreur lors de la modification. Veuillez vérifier les informations.
                </div>
                {% endif %}

                <div class="form-group">
                    <label class="form-label">Type de culture <span class="required">*</span></label>
                    <select name="type_culture" id="edit-type" class="form-control"
                            onchange="updateCropList('edit')">
                        <option value="">— Sélectionner un type —</option>
                        {% for type, names in cultureMap %}
                            <option value="{{ type }}">{{ type }}</option>
                        {% endfor %}
                    </select>
                    <span class="field-error" id="edit-type-err"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Culture <span class="required">*</span></label>
                    <select name="nom" id="edit-nom" class="form-control"
                            onchange="fetchHarvestDate('edit')">
                        <option value="">— Sélectionner —</option>
