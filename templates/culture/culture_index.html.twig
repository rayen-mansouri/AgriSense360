// ═══════════════════════════════════════════════════════════════
// IA HARVEST MODAL
// ═══════════════════════════════════════════════════════════════

async function openHarvestModal(id, nom, surface, csrfToken) {
    // Reset modal state
    document.getElementById('harvest-loading').style.display = 'block';
    document.getElementById('harvest-result').style.display  = 'none';
    document.getElementById('harvest-error').style.display   = 'none';
    openModal('modal-harvest');

    try {
        const res  = await fetch(`/culture/${id}/ia-preview`);
        const data = await res.json();
        if (!res.ok || data.error) throw new Error(data.error || `HTTP ${res.status}`);
        _fillHarvestModal(id, nom, csrfToken, data);
        document.getElementById('harvest-loading').style.display = 'none';
        document.getElementById('harvest-result').style.display  = 'block';
    } catch (err) {
        console.error('IA preview error:', err);
        document.getElementById('harvest-loading').style.display = 'none';
        document.getElementById('harvest-error').style.display   = 'block';
        document.getElementById('harvest-error-msg').textContent = 'Erreur IA : ' + err.message;
    }
}

function _fillHarvestModal(id, nom, csrfToken, data) {
    // Form wiring
    document.getElementById('harvest-confirm-form').action = `/culture/${id}/harvest`;
    document.getElementById('harvest-csrf-token').value    = csrfToken;
    document.getElementById('harvest-qty-input').value     = data.quantite;
    document.getElementById('harvest-score-input').value   = data.iaScore;
    document.getElementById('harvest-source-input').value  = data.source || 'php_fallback';

    // Header
    document.getElementById('harvest-culture-name').textContent = `🌾 ${nom}`;
    document.getElementById('harvest-confidence').textContent   =
        `Confiance : ${data.confidence}  ·  ${data.logsCount} jour(s) météo enregistré(s)`;
    document.getElementById('harvest-source-label').textContent =
        data.source === 'ml' ? '🤖 Modèle ML Python (Random Forest)' : '🧮 Formule agronomique PHP';

    // Score ring
    _drawScoreRing(data.iaScore);
    document.getElementById('score-label').innerHTML =
        `<span>${Math.round(data.iaScore)}%</span><span style="font-size:0.55rem;font-weight:500;">qualité</span>`;

    // KPI cards
    document.getElementById('ia-quantite').textContent = `${data.quantite} kg`;

    const lEl = document.getElementById('ia-lateness');
    lEl.textContent = `${data.latenessScore}%`;
    lEl.style.color = data.latenessScore < 80 ? '#dc2626' : data.latenessScore < 95 ? '#d97706' : '#16a34a';

    const wEl = document.getElementById('ia-weather');
    wEl.textContent = `${data.weatherScore}%`;
    wEl.style.color = data.weatherScore < 60 ? '#dc2626' : data.weatherScore < 80 ? '#d97706' : '#16a34a';

    // Breakdown
    const container = document.getElementById('breakdown-list');
    container.innerHTML = '';
    if (!data.breakdown || data.breakdown.length === 0) {
        container.innerHTML = `<div class="ia-bd-item success">
            <span class="ia-bd-icon">✅</span>
            <div><div class="ia-bd-label">Aucun facteur négatif détecté</div>
                 <div class="ia-bd-impact">Conditions idéales pendant toute la croissance</div></div></div>`;
    } else {
        data.breakdown.forEach(item => {
            const div = document.createElement('div');
            div.className = `ia-bd-item ${item.type || 'info'}`;
            div.innerHTML = `<span class="ia-bd-icon">${item.icon}</span>
                <div><div class="ia-bd-label">${item.label}</div>
                     <div class="ia-bd-impact">${item.impact}</div></div>`;
            container.appendChild(div);
        });
    }

    // Style confirm button by score
    const btn = document.getElementById('harvest-confirm-btn');
    if (data.iaScore < 50) {
        btn.style.background = '#dc2626';
        btn.textContent = '⚠️ Confirmer malgré les pertes';
    } else {
        btn.style.background = '#1e3c2c';
        btn.textContent = '✅ Confirmer la récolte';
    }
}

function _drawScoreRing(score) {
    const canvas = document.getElementById('score-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const cx  = 50, cy = 50, r = 42;
    const pct = Math.min(100, Math.max(0, score)) / 100;
    ctx.clearRect(0, 0, 100, 100);

    // Background track
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, 2*Math.PI);
    ctx.strokeStyle = '#e5e7eb'; ctx.lineWidth = 8; ctx.stroke();

    // Progress arc
    ctx.beginPath();
    ctx.arc(cx, cy, r, -Math.PI/2, -Math.PI/2 + pct*2*Math.PI);
    ctx.strokeStyle = pct > 0.75 ? '#16a34a' : pct > 0.5 ? '#d97706' : '#dc2626';
    ctx.lineWidth = 8; ctx.lineCap = 'round'; ctx.stroke();
}

function _submitHarvest() {
    const btn = document.getElementById('harvest-confirm-btn');
    btn.disabled = true;
    btn.textContent = '⏳ Enregistrement…';
    return true;
}

// ═══════════════════════════════════════════════════════════════
