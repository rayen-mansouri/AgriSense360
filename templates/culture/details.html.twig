{% extends 'base.html.twig' %}

{% set activePage = 'cultures' %}
{% set activeSection = 'main' %}

{% block title %}Détails — {{ culture.nom }} — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }
    .page-breadcrumb { color: var(--cp); font-size: 0.9rem; margin-bottom: 5px; font-weight: 600; }
    .page-breadcrumb a { color: var(--g); text-decoration: none; }
    .page-breadcrumb a:hover { text-decoration: underline; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; border-radius: 14px; border: 1px solid transparent; font-family: inherit; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; border: none; box-shadow: 0 4px 15px rgba(90,181,90,0.3); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(90,181,90,0.4); }
    .btn-secondary { background: var(--cb); color: var(--cp); border: 1px solid var(--cbr); }
    .btn-secondary:hover { background: rgba(90,181,90,0.05); border-color: var(--g); color: var(--g); }

    /* Details Layout */
    .details-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 32px; box-shadow: var(--sh-lg); overflow: hidden; display: flex; flex-direction: row; gap: 0; min-height: 450px; }
    @media (max-width: 850px) { .details-card { flex-direction: column; } }

    .details-image-side { flex: 0 0 40%; background: #000; position: relative; overflow: hidden; border-right: 1px solid var(--cbr); display: flex; align-items: center; justify-content: center; }
    .details-image-side img { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }
    .details-image-side .img-fallback { font-size: 6rem; opacity: 0.5; }

    .details-content-side { flex: 1; padding: 40px; display: flex; flex-direction: column; }
    .details-section-title { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; color: var(--g); letter-spacing: 1.5px; margin-bottom: 15px; }

    .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 25px; margin-bottom: 30px; }
    .detail-item { display: flex; flex-direction: column; gap: 6px; }
    .detail-label { font-size: 0.75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; }
    .detail-value { font-size: 1.1rem; font-weight: 800; color: var(--ch3); }

    .etat-badge { padding: 5px 15px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; border: 1px solid transparent; }
    .etat-semis { background: rgba(76,175,80,0.1); color: #4CAF50; border-color: rgba(76,175,80,0.2); }
    .etat-croissance { background: rgba(255,152,0,0.1); color: #FF9800; border-color: rgba(255,152,0,0.2); }
    .etat-maturite { background: rgba(33,150,243,0.1); color: #2196F3; border-color: rgba(33,150,243,0.2); }
    .etat-recolte { background: rgba(244,67,54,0.1); color: #F44336; border-color: rgba(244,67,54,0.2); }
    .etat-recolte-prevue { background: rgba(255,193,7,0.1); color: #FFC107; border-color: rgba(255,193,7,0.2); }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('app_home') }}">🏠 Accueil</a> /
            <a href="{{ path('culture_index') }}">Cultures</a> /
            Détails
        </p>
        <h1 class="page-title">📋 Détails Culture</h1>
        <p class="page-subtitle">Consultez les informations détaillées de votre plantation</p>
    </div>
    <div style="display:flex;gap:15px;align-items:center;">
        <a href="{{ path('culture_index') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a>
        <form method="post" action="{{ path('culture_harvest', {id: culture.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('harvest-culture-' ~ culture.id) }}">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-wheat-awn"></i> Récolter</button>
        </form>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   DETAILS CARD
   ═══════════════════════════════════════════════════ #}
<div class="details-card">
    <div class="details-image-side">
        {% if culture.img %}
            <img src="{{ asset('images/cultures/' ~ culture.img) }}" alt="{{ culture.nom }}">
        {% else %}
            <div class="img-fallback">🌱</div>
        {% endif %}
    </div>

    <div class="details-content-side">
        <div class="details-section-title">Informations Générales</div>
        <h2 style="font-size: 2rem; font-weight: 900; color: var(--ch3); margin: 0 0 30px 0; letter-spacing: -0.5px;">{{ culture.nom }}</h2>

        <div class="details-grid">
            <div class="detail-item">
                <span class="detail-label">Type de culture</span>
                <span class="detail-value">{{ culture.typeCulture }}</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Statut actuel</span>
                <div>
                    <span class="etat-badge {{ etatToCssClass(culture.etat) }}">
                        {{ etatToEmoji(culture.etat) }} {{ culture.etat }}
                    </span>
                </div>
            </div>
            <div class="detail-item">
                <span class="detail-label">Surface exploitée</span>
                <span class="detail-value">{{ culture.surface|number_format(0,',',' ') }} <span style="font-size:0.8rem;opacity:0.6;">m²</span></span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Emplacement</span>
                <span class="detail-value">
                    <a href="{{ path('parcelle_index') }}" style="color:var(--g);text-decoration:none;">
                        📍 {{ parcelle ? parcelle.nom : 'Parcelle #' ~ culture.parcelle.id }}
                    </a>
                </span>
            </div>
        </div>

        <div style="margin-top:auto; background: rgba(0,0,0,0.1); border-radius:24px; padding:25px; border: 1px solid var(--cbr);">
            <div class="details-section-title" style="margin-bottom:15px;color:var(--cp);">Calendrier cultural</div>
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div style="text-align:center; flex:1;">
                    <div style="font-size:0.75rem; font-weight:800; color:var(--cp); margin-bottom:5px;">PLANTATION</div>
                    <div style="font-size:1.1rem; font-weight:800; color:var(--ch3);">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</div>
                </div>
                <div style="font-size:1.5rem; color:var(--g); opacity:0.5;"><i class="fa-solid fa-arrow-right-long"></i></div>
                <div style="text-align:center; flex:1;">
                    <div style="font-size:0.75rem; font-weight:800; color:var(--cp); margin-bottom:5px;">RÉCOLTE PRÉVUE</div>
                    <div style="font-size:1.1rem; font-weight:800; color:var(--g);">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

    </div>
</main>

<script>
    // Theme toggle
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endblock %}