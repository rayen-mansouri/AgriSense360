{% extends 'base.html.twig' %}

{% block title %}Tableau de bord Propriétaire — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
    :root {
        --pg: #0a0f0a; --pc: #e8f5e4;
        --s1: #0d1a0d; --s2: #0a0f0a;
        --cb: rgba(255,255,255,.04); --cbr: rgba(255,255,255,.08);
        --ch3: #fff; --cp: rgba(232,245,228,.55);
        --g: #5ab55a; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #060a06;
        --sidebar-border: rgba(255,255,255,.05);
        --danger: #f87171; --danger-bg: rgba(248,113,113,.1);
        --indigo: #818cf8; --indigo-bg: rgba(129,140,248,.1);
    }
    [data-theme="light"] {
        --pg: #f0f7ee; --pc: #1a3a1a;
        --s1: #e8f5e4; --s2: #f0f7ee;
        --cb: rgba(255,255,255,.85); --cbr: rgba(0,0,0,.07);
        --ch3: #1a3a1a; --cp: #4a6741;
        --g: #3e8e3e; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #ffffff;
        --sidebar-border: rgba(0,0,0,.08);
        --danger: #dc2626; --danger-bg: rgba(220,38,38,.1);
        --indigo: #4338ca; --indigo-bg: rgba(67,56,202,.1);
    }

    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* Sidebar */
    .sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); display: flex; flex-direction: column; transition: transform .3s ease, width .3s ease; position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; }
    .sidebar.collapsed { transform: translateX(-100%); }
    .sidebar-header { padding: 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--sidebar-border); }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ch3); font-weight: 800; font-size: 1.1rem; }
    .sidebar-brand img { width: 32px; height: 32px; object-fit: contain; }
    .sidebar-nav { padding: 20px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .sidebar-link { padding: 12px 16px; display: flex; align-items: center; gap: 12px; color: var(--cp); text-decoration: none; font-weight: 600; font-size: .95rem; border-radius: 10px; transition: all .2s; }
    .sidebar-link:hover, .sidebar-link.active { background: rgba(90,181,90,.1); color: var(--g); }
    .sidebar-footer { padding: 20px; border-top: 1px solid var(--sidebar-border); }

    .theme-toggle { background: none; border: none; color: var(--cp); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 8px; border-radius: 8px; transition: all .2s; }
    .theme-toggle:hover { background: rgba(255,255,255,.05); color: var(--ch3); }
    [data-theme="light"] .theme-toggle:hover { background: rgba(0,0,0,.05); }
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="light"] .icon-sun { display: none; }

    /* Main Content */
    .main-content { flex: 1; margin-left: 260px; transition: margin-left .3s ease; display: flex; flex-direction: column; min-height: 100vh; }
    .main-content.expanded { margin-left: 0; }

    .topbar { height: 70px; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(var(--sidebar-bg), .8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--sidebar-border); position: sticky; top: 0; z-index: 90; }
    .sidebar-toggle { background: none; border: none; color: var(--ch3); cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 8px; }
    .sidebar-toggle span { display: block; width: 24px; height: 2px; background: currentColor; border-radius: 2px; }

    .content-wrapper { padding: 32px; max-width: 1200px; margin: 0 auto; width: 100%; }

    /* Hero */
    .hero { position: relative; border-radius: 24px; overflow: hidden; padding: 48px; margin-bottom: 40px; display: flex; align-items: center; background: #1a2e1a; }
    .hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.4; mix-blend-mode: overlay; }
    .hero-content { position: relative; z-index: 2; }
    .hero h1 { font-family: 'Inter', sans-serif; font-size: clamp(2.4rem, 5.5vw, 4.2rem); font-weight: 900; line-height: 1.12; color: #fff; margin-bottom: 22px; }
    .hero p { font-size: 1.1rem; color: rgba(255,255,255,.75); max-width: 540px; line-height: 1.7; margin-bottom: 38px; }
    .hero-actions { margin-top: 24px; }
    .btn-primary { background: linear-gradient(135deg, #3e8e3e, #5ab55a); color: #fff; padding: 14px 32px; border-radius: 50px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all .25s; border: none; cursor: pointer; font-size: .95rem; box-shadow: 0 8px 30px rgba(62,142,62,.4); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(62,142,62,.55); }

    /* KPIs */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-bottom: 48px; }
    .kpi-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 20px; padding: 24px; display: flex; align-items: center; gap: 20px; transition: transform .2s; }
    .kpi-card:hover { transform: translateY(-4px); border-color: rgba(90,181,90,.3); }
    .kpi-icon { width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, rgba(90,181,90,.15), rgba(62,142,62,.05)); color: var(--g); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; }
    .kpi-info h3 { font-size: 2rem; font-weight: 800; color: var(--ch3); line-height: 1; margin-bottom: 6px; }
    .kpi-info p { font-size: .9rem; color: var(--cp); font-weight: 500; }

    /* Farm Section */
    .farm-section { margin-bottom: 48px; background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; overflow: hidden; }
    .farm-header { padding: 24px 32px; border-bottom: 1px solid var(--cbr); display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,.02); }
    [data-theme="light"] .farm-header { background: rgba(0,0,0,.01); }
    .farm-title { font-family: 'Inter', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--ch3); display: flex; align-items: center; gap: 12px; }
    .farm-title-badge { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 700; background: rgba(90,181,90,.1); color: var(--g); padding: 4px 10px; border-radius: 50px; }
    .btn-edit { color: var(--cp); text-decoration: none; font-size: .9rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 50px; border: 1px solid var(--cbr); transition: all .2s; }
    .btn-edit:hover { background: var(--cbr); color: var(--ch3); }

    .farm-body { padding: 32px; display: grid; grid-template-columns: 1fr; gap: 32px; }
    @media (min-width: 1024px) {
        .farm-body { grid-template-columns: 1fr 1fr; }
    }

    /* Lists */
    .list-header { font-size: 1.1rem; font-weight: 700; color: var(--ch3); margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
    .badge-count { background: var(--cbr); color: var(--ch3); font-size: .8rem; padding: 2px 8px; border-radius: 50px; }

    .card-list { display: flex; flex-direction: column; gap: 12px; }
    .applicant-card { background: var(--pg); border: 1px solid var(--cbr); border-radius: 16px; padding: 16px; display: flex; flex-direction: column; gap: 12px; }
    .applicant-header { display: flex; align-items: center; gap: 12px; }
    .avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; }
    .applicant-info { flex: 1; }
    .applicant-name { font-weight: 700; color: var(--ch3); font-size: .95rem; }
    .applicant-email { font-size: .8rem; color: var(--cp); }

    .actions-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .btn-action { padding: 6px 12px; border-radius: 8px; font-size: .8rem; font-weight: 600; cursor: pointer; border: none; transition: opacity .2s; display: inline-flex; align-items: center; gap: 4px; }
    .btn-action:hover { opacity: .8; }
    .btn-gerant { background: var(--indigo-bg); color: var(--indigo); }
    .btn-ouvrier { background: rgba(90,181,90,.15); color: var(--g); }
    .btn-reject { background: var(--danger-bg); color: var(--danger); }

    /* Table */
    .team-table-wrap { overflow-x: auto; background: var(--pg); border: 1px solid var(--cbr); border-radius: 16px; }
    .team-table { width: 100%; border-collapse: collapse; text-align: left; }
    .team-table th { padding: 12px 16px; font-size: .8rem; color: var(--cp); border-bottom: 1px solid var(--cbr); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .team-table td { padding: 16px; font-size: .9rem; color: var(--ch3); border-bottom: 1px solid var(--cbr); }
    .team-table tr:last-child td { border-bottom: none; }

    .role-badge { display: inline-flex; padding: 4px 10px; border-radius: 50px; font-size: .75rem; font-weight: 700; }
    .role-gerant { background: var(--indigo-bg); color: var(--indigo); }
    .role-ouvrier { background: rgba(90,181,90,.15); color: var(--g); }

    .empty-state { text-align: center; padding: 40px 20px; color: var(--cp); font-size: .95rem; border: 1px dashed var(--cbr); border-radius: 16px; }

    @media (max-width: 768px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .main-content { margin-left: 0; }
    }
</style>
{% endblock %}

{% block body %}

{% set totalFarms = farmData|length %}
{% set totalPending = 0 %}
{% set totalApproved = 0 %}
{% for entry in farmData %}
    {% set totalPending = totalPending + entry.pendingWorkers|length %}
    {% set totalApproved = totalApproved + entry.approvedWorkers|length %}
{% endfor %}

<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('app_index') }}" class="sidebar-brand">
            <img src="{{ asset('images/logo.png') }}" alt="Logo">
            AgriSense 360
        </a>
    </div>
    <div class="sidebar-nav">
        <a href="{{ path('farm_dashboard') }}" class="sidebar-link active">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Tableau de bord
        </a>
        <a href="{{ path('farm_create') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>
            Nouvelle Ferme
        </a>
    </div>
    <div class="sidebar-footer">
        <a href="{{ path('profile_show') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Mon Profil
        </a>
        <a href="{{ path('app_logout') }}" class="sidebar-link" style="color: var(--danger);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Déconnexion
        </a>
    </div>
</div>

<main class="main-content" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>

    <div class="content-wrapper">

        {# Flash Messages #}
        {% for msg in app.flashes('success') %}
            <div style="background: rgba(90,181,90,.1); border: 1px solid rgba(90,181,90,.3); color: var(--g); padding: 16px; border-radius: 12px; margin-bottom: 24px; font-weight: 500;">
                ✓ {{ msg }}
            </div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div style="background: var(--danger-bg); border: 1px solid rgba(248,113,113,.3); color: var(--danger); padding: 16px; border-radius: 12px; margin-bottom: 24px; font-weight: 500;">
                ⚠ {{ msg }}
            </div>
        {% endfor %}

        {# Hero #}
        <div class="hero">
            <img src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="Aerial Farm" class="hero-img">
            <div class="hero-content">
                <h1>Bonjour, {{ owner.name|default('Propriétaire') }}</h1>
                <p>Bienvenue sur votre tableau de bord. Gérez vos exploitations agricoles, vos candidatures et vos équipes en toute simplicité.</p>
                <div class="hero-actions">
                    <a href="{{ path('farm_create') }}" class="btn-primary">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>
                        Créer une nouvelle ferme
                    </a>
                </div>
            </div>
        </div>

        {# KPIs #}
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-icon">🌾</div>
                <div class="kpi-info">
                    <h3>{{ totalFarms }}</h3>
                    <p>Fermes enregistrées</p>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">⏳</div>
                <div class="kpi-info">
                    <h3>{{ totalPending }}</h3>
                    <p>Candidatures en attente</p>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">✅</div>
                <div class="kpi-info">
                    <h3>{{ totalApproved }}</h3>
                    <p>Ouvriers actifs</p>
                </div>
            </div>
        </div>

        {# Farms #}
        {% if totalFarms == 0 %}
            <div class="empty-state">
                <div style="font-size: 3rem; margin-bottom: 16px;">🏡</div>
                <h2 style="font-family: 'Inter', sans-serif; font-weight: 800; color: var(--ch3); margin-bottom: 8px;">Aucune ferme pour le moment</h2>
                <p>Commencez par ajouter votre première exploitation agricole.</p>
            </div>
        {% else %}
            {% for entry in farmData %}
                {% set farm = entry.farm %}
                {% set pending = entry.pendingWorkers %}
                {% set approved = entry.approvedWorkers %}

                <div class="farm-section">
                    <div class="farm-header">
                        <div class="farm-title">
                            {{ farm.name }}
                            <span class="farm-title-badge">ID: {{ farm.farmId }}</span>
                        </div>
                        <a href="{{ path('farm_edit', {id: farm.id}) }}" class="btn-edit">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            Modifier
                        </a>
                    </div>

                    <div class="farm-body">
                        {# Pending Applicants Column #}
                        <div>
                            <div class="list-header">
                                Candidatures en attente
                                <span class="badge-count">{{ pending|length }}</span>
                            </div>

                            {% if pending|length == 0 %}
                                <div class="empty-state" style="padding: 24px 16px;">
                                    Aucune candidature en attente
                                </div>
                            {% else %}
                                <div class="card-list">
                                    {% for worker in pending %}
                                        <div class="applicant-card">
                                            <div class="applicant-header">
                                                <div class="avatar">{{ worker.name|slice(0,1)|upper }}</div>
                                                <div class="applicant-info">
                                                    <div class="applicant-name">{{ worker.name }}</div>
                                                    <div class="applicant-email">{{ worker.email }}</div>
                                                </div>
                                            </div>
                                            <div class="actions-row">
                                                <form method="post" action="{{ path('farm_worker_assign', {id: worker.id}) }}" style="display:inline-block; margin:0;">
                                                    <input type="hidden" name="role" value="ROLE_GERANT">
                                                    <button class="btn-action btn-gerant" type="submit">👔 Gérant</button>
                                                </form>
                                                <form method="post" action="{{ path('farm_worker_assign', {id: worker.id}) }}" style="display:inline-block; margin:0;">
                                                    <input type="hidden" name="role" value="ROLE_OUVRIER">
                                                    <button class="btn-action btn-ouvrier" type="submit">🌾 Ouvrier</button>
                                                </form>
                                                <form method="post" action="{{ path('farm_worker_reject', {id: worker.id}) }}" style="display:inline-block; margin:0;" onsubmit="return confirm('Refuser cette candidature ?');">
                                                    <button class="btn-action btn-reject" type="submit">✕ Refuser</button>
                                                </form>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        {# Approved Team Column #}
                        <div>
                            <div class="list-header">
                                Équipe active
                                <span class="badge-count">{{ approved|length }}</span>
                            </div>

                            {% if approved|length == 0 %}
                                <div class="empty-state" style="padding: 24px 16px;">
                                    Aucun membre dans l'équipe
                                </div>
                            {% else %}
                                <div class="team-table-wrap">
                                    <table class="team-table">
                                        <thead>
                                            <tr>
                                                <th>Nom</th>
                                                <th>Rôle</th>
                                                <th style="text-align: right;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for worker in approved %}
                                                <tr>
                                                    <td>
                                                        <div style="font-weight: 600;">{{ worker.name }}</div>
                                                        <div style="font-size: .8rem; color: var(--cp);">{{ worker.email }}</div>
                                                    </td>
                                                    <td>
                                                        {% if 'ROLE_GERANT' in worker.roles %}
                                                            <span class="role-badge role-gerant">Gérant</span>
                                                        {% else %}
                                                            <span class="role-badge role-ouvrier">Ouvrier</span>
                                                        {% endif %}
                                                    </td>
                                                    <td style="text-align: right;">
                                                        <form method="post" action="{{ path('farm_worker_remove', {id: worker.id}) }}" onsubmit="return confirm('Retirer ce membre de la ferme ?');" style="margin:0;">
                                                            <button type="submit" class="btn-action btn-reject" style="padding: 4px 10px;">Retirer</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

    </div>
</main>

<script>
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('open');
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        }
    });

    // Theme toggle — persist preference
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);

    document.getElementById('themeToggle').addEventListener('click', function () {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
