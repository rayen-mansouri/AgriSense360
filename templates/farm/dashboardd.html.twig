<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
    <script>(function(){var t=localStorage.getItem('agri-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
    <title>Tableau de bord propriétaire — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{
            --g:#5ab55a;--gm:#3e8e3e;--gd:#2d6a2d;
            --pg:#0c140c;--pc:#d4e8d0;
            --surface:rgba(255,255,255,.05);--surface-b:rgba(255,255,255,.09);
            --h:#e8f5e4;--txt:rgba(212,232,208,.82);--muted:rgba(170,200,168,.5);
            --card:#0f1a0f;--card-b:rgba(255,255,255,.08);
            --inp-bg:rgba(255,255,255,.05);--inp-b:rgba(255,255,255,.1);--inp-c:#e8f5e4;
            --nav-bg:rgba(10,20,10,.96);--nav-b:rgba(255,255,255,.07);
            --hero-ov:linear-gradient(120deg,rgba(6,18,6,.9),rgba(6,24,6,.6));
            --danger:#f87171;--warn:#fbbf24;--indigo:#818cf8;
            --radius:14px;--radius-sm:9px;
            --sh:0 4px 20px rgba(0,0,0,.25);
        }
        [data-theme="light"]{
            --pg:#f0f7ee;--pc:#1a3a1a;
            --surface:rgba(255,255,255,.9);--surface-b:rgba(0,0,0,.08);
            --h:#1a3a1a;--txt:#3a5e3a;--muted:#7a9a7a;
            --card:#fff;--card-b:rgba(0,0,0,.08);
            --inp-bg:#fff;--inp-b:rgba(0,0,0,.12);--inp-c:#1a3a1a;
            --nav-bg:rgba(240,247,238,.96);--nav-b:rgba(0,0,0,.07);
            --hero-ov:linear-gradient(120deg,rgba(8,30,8,.82),rgba(8,30,8,.55));
            --danger:#dc2626;--warn:#d97706;--indigo:#4338ca;
            --sh:0 4px 20px rgba(0,0,0,.08);
        }
        body{min-height:100vh;font-family:'Inter',sans-serif;background:var(--pg);color:var(--pc);transition:background .3s,color .3s}

        /* Navbar */
        .nav{display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:64px;background:var(--nav-bg);border-bottom:1px solid var(--nav-b);position:sticky;top:0;z-index:50;backdrop-filter:blur(14px)}
        .nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none}
        .nav-logo{width:36px;height:36px;border-radius:9px;object-fit:contain}
        .nav-name{font-weight:800;font-size:1rem;color:var(--h)}
        .nav-name span{color:var(--g)}
        .nav-right{display:flex;align-items:center;gap:12px}
        .nav-btn{padding:8px 16px;border-radius:50px;font-family:'Inter',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;transition:all .18s;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
        .btn-new-farm{background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none}
        .btn-new-farm:hover{transform:translateY(-1px);box-shadow:0 6px 16px rgba(62,142,62,.4)}
        .nav-theme{background:var(--surface);border:1px solid var(--surface-b);border-radius:8px;padding:8px;cursor:pointer;color:var(--muted);display:flex;align-items:center;transition:all .2s}
        .nav-theme:hover{color:var(--h)}
        .nav-theme svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
        [data-theme="dark"] .icon-moon{display:none}
        [data-theme="light"] .icon-sun{display:none}

        .container{max-width:1200px;margin:0 auto;padding:36px 24px}

        /* Flash */
        .flash-success{background:rgba(62,142,62,.1);border:1px solid rgba(62,142,62,.25);color:var(--g7);padding:12px 18px;border-radius:10px;font-size:.86rem;margin-bottom:20px;font-weight:600}
        .flash-info{background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.2);color:#1d4ed8;padding:12px 18px;border-radius:10px;font-size:.86rem;margin-bottom:20px}
        .flash-error{background:rgba(220,38,38,.07);border:1px solid rgba(220,38,38,.2);color:var(--danger);padding:12px 18px;border-radius:10px;font-size:.86rem;margin-bottom:20px}

        /* Page header */
        .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;flex-wrap:wrap;gap:12px}
        .page-header h1{font-family:'Fraunces',serif;font-size:1.8rem;font-weight:700;color:var(--text)}
        .page-header p{font-size:.88rem;color:var(--muted);margin-top:4px}

        /* No farm state */
        .empty-owner{text-align:center;padding:60px 20px;background:var(--white);border-radius:20px;border:1px solid var(--border)}
        .empty-owner .eo-icon{font-size:3.5rem;margin-bottom:16px}
        .empty-owner h2{font-family:'Fraunces',serif;font-size:1.5rem;color:var(--text);margin-bottom:10px}
        .empty-owner p{font-size:.9rem;color:var(--muted);max-width:400px;margin:0 auto 24px;line-height:1.6}
        .btn-create{display:inline-flex;align-items:center;gap:8px;padding:13px 24px;background:var(--g5);color:#fff;border-radius:12px;font-weight:700;font-size:.95rem;text-decoration:none;transition:background .18s}
        .btn-create:hover{background:var(--g7)}

        /* Farm section */
        .farm-section{margin-bottom:40px}
        .farm-header-card{background:linear-gradient(135deg,var(--g7) 0%,var(--g5) 100%);border-radius:18px;padding:28px 36px;color:#fff;display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;position:relative;overflow:hidden}
        .farm-header-card::before{content:'🌾';position:absolute;right:30px;top:50%;transform:translateY(-50%);font-size:4.5rem;opacity:.12;pointer-events:none}
        .fh-title{font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;margin-bottom:8px}
        .fh-id{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.3);border-radius:50px;padding:5px 14px;font-family:monospace;font-size:.82rem;font-weight:700;letter-spacing:.06em}
        .fh-meta{display:flex;gap:18px;margin-top:12px}
        .fh-meta-item{font-size:.82rem;opacity:.85;display:flex;align-items:center;gap:5px}

        /* Section labels */
        .section-label{display:flex;align-items:center;gap:10px;margin-bottom:14px}
        .section-label-text{font-family:'Fraunces',serif;font-size:1rem;font-weight:700;color:var(--text)}
        .badge-count{background:var(--warn);color:#fff;border-radius:50px;padding:2px 10px;font-size:.72rem;font-weight:800}
        .badge-active{background:var(--g5);color:#fff;border-radius:50px;padding:2px 10px;font-size:.72rem;font-weight:800}

        /* Worker applicant cards */
        .applicants-grid{display:flex;flex-direction:column;gap:12px;margin-bottom:28px}
        .applicant-card{background:var(--white);border-radius:13px;border:1px solid var(--border);padding:18px 22px;display:flex;align-items:flex-start;gap:16px;transition:box-shadow .2s}
        .applicant-card:hover{box-shadow:0 4px 18px rgba(30,58,30,.08)}
        .ac-avatar{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--g5),var(--g7));display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0}
        .ac-info{flex:1;min-width:0}
        .ac-name{font-weight:700;font-size:.95rem;color:var(--text);margin-bottom:2px}
        .ac-email{font-size:.78rem;color:var(--muted);margin-bottom:8px}
        .ai-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(62,142,62,.07);border:1px solid rgba(62,142,62,.18);border-radius:8px;padding:5px 10px;font-size:.76rem;margin-bottom:8px;flex-wrap:wrap}
        .ai-role{font-weight:800;color:var(--g7)}
        .ai-reason{color:var(--muted);font-style:italic}
        .cv-link{font-size:.76rem;color:var(--g5);text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:4px}
        .cv-link:hover{text-decoration:underline}
        .ac-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
        .btn-action{padding:7px 14px;border-radius:8px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.78rem;font-weight:700;cursor:pointer;border:1.5px solid transparent;transition:all .18s}
        .btn-gerant{background:rgba(67,56,202,.08);color:var(--indigo);border-color:rgba(67,56,202,.25)}
        .btn-gerant:hover{background:var(--indigo);color:#fff;border-color:var(--indigo)}
        .btn-ouvrier{background:rgba(62,142,62,.08);color:var(--g7);border-color:rgba(62,142,62,.25)}
        .btn-ouvrier:hover{background:var(--g5);color:#fff;border-color:var(--g5)}
        .btn-reject{background:rgba(220,38,38,.06);color:var(--danger);border-color:rgba(220,38,38,.2)}
        .btn-reject:hover{background:var(--danger);color:#fff;border-color:var(--danger)}
        .btn-remove{background:rgba(107,114,128,.08);color:#4b5563;border-color:rgba(107,114,128,.25)}
        .btn-remove:hover{background:#6b7280;color:#fff;border-color:#6b7280}

        /* Active workers table */
        .workers-table-wrap{background:var(--white);border-radius:13px;border:1px solid var(--border);overflow:hidden;margin-bottom:8px}
        table{width:100%;border-collapse:collapse}
        th{padding:11px 16px;font-size:.7rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;text-align:left;border-bottom:1px solid var(--border);background:#fafdf9}
        td{padding:12px 16px;font-size:.86rem;color:var(--text);border-bottom:1px solid #f0f4f0}
        tr:last-child td{border-bottom:none}
        .role-pill{display:inline-flex;padding:3px 10px;border-radius:50px;font-size:.72rem;font-weight:800}
        .role-gerant{background:rgba(67,56,202,.1);color:var(--indigo)}
        .role-ouvrier{background:rgba(62,142,62,.1);color:var(--g7)}

        .empty-state-sm{text-align:center;padding:28px 20px;background:var(--white);border-radius:13px;border:1px dashed var(--border);color:var(--muted);font-size:.86rem;margin-bottom:10px}
        .empty-state-sm .esi-icon{font-size:1.8rem;margin-bottom:6px}

        .divider-farm{border:none;border-top:2px dashed var(--border);margin:36px 0}
    </style>
</head>
<body>

<nav class="nav">
    <div class="nav-brand">
        <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg></div>
        <div class="nav-name">AgriSense 360</div>
    </div>
    <div class="nav-right">
        <a href="{{ path('farm_create') }}" class="nav-btn btn-new-farm">+ Nouvelle ferme</a>
        {% include 'components/_profile_widget.html.twig' %}
    </div>
</nav>

<div class="container">

    {% for msg in app.flashes('success') %}<div class="flash-success">✓ {{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('info') %}<div class="flash-info">ℹ {{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="flash-error">⚠ {{ msg }}</div>{% endfor %}

    <div class="page-header">
        <div>
            <h1>Mes Fermes</h1>
            <p>{{ farmData|length }} ferme{{ farmData|length != 1 ? 's' : '' }} · Gérez vos équipes et candidatures</p>
        </div>
    </div>

    {# ── No farms yet ── #}
    {% if farmData|length == 0 %}
    <div class="empty-owner">
        <div class="eo-icon">🏡</div>
        <h2>Créez votre première ferme</h2>
        <p>Configurez votre exploitation et commencez à recevoir des candidatures de travailleurs.</p>
        <a href="{{ path('farm_create') }}" class="btn-create">🌾 Créer ma première ferme</a>
    </div>

    {% else %}
        {# ── Loop over each farm ── #}
        {% for entry in farmData %}
            {% set farm = entry.farm %}
            {% set pending  = entry.pendingWorkers %}
            {% set approved = entry.approvedWorkers %}

            <div class="farm-section">

                {# Farm header card with optional image #}
                <div class="farm-header-card" {% if farm.image %}style="background:linear-gradient(rgba(10,20,10,.6),rgba(10,20,10,.6)),url('{{ app.request.basePath }}/uploads/farms/{{ farm.image }}') center/cover;"{% endif %}>
                    <div>
                        <div class="fh-title">{{ farm.name }}</div>
                        <div class="fh-id">🔑 {{ farm.farmId }}</div>
                        <div class="fh-meta">
                            {% if farm.location %}<span class="fh-meta-item">📍 {{ farm.location }}</span>{% endif %}
                            {% if farm.surface %}<span class="fh-meta-item">📐 {{ farm.surface }} ha</span>{% endif %}
                            <span class="fh-meta-item">📅 {{ farm.createdAt ? farm.createdAt|date('d/m/Y') : '—' }}</span>
                            <span class="fh-meta-item">⏳ {{ pending|length }} en attente</span>
                            <span class="fh-meta-item">✅ {{ approved|length }} approuvé{{ approved|length != 1 ? 's' : '' }}</span>
                        </div>
                        {% if farm.description %}
                        <div style="margin-top:10px;font-size:.82rem;opacity:.85;max-width:580px;line-height:1.5">{{ farm.description }}</div>
                        {% endif %}
                    </div>
                    <a href="{{ path('farm_edit', {id: farm.id}) }}" style="background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.35);padding:9px 18px;border-radius:9px;font-size:.82rem;font-weight:700;text-decoration:none;flex-shrink:0;transition:background .18s" onmouseover="this.style.background='rgba(255,255,255,.3)'" onmouseout="this.style.background='rgba(255,255,255,.18)'">
                        ✏️ Modifier
                    </a>
                </div>

                {# ── Pending applicants ── #}
                <div class="section-label">
                    <span class="section-label-text">⏳ Candidatures en attente</span>
                    {% if pending|length > 0 %}<span class="badge-count">{{ pending|length }}</span>{% endif %}
                </div>

                {% if pending|length == 0 %}
                    <div class="empty-state-sm">
                        <div class="esi-icon">📭</div>
                        Aucune candidature en attente pour cette ferme.
                    </div>
                {% else %}
                    <div class="applicants-grid">
                    {% for worker in pending %}
                        <div class="applicant-card">
                            <div class="ac-avatar">{{ worker.name|slice(0,1)|upper }}</div>
                            <div class="ac-info">
                                <div class="ac-name">{{ worker.name }}</div>
                                <div class="ac-email">{{ worker.email }}</div>

                                {% if worker.aiSuggestedRole %}
                                <div class="ai-badge">
                                    🤖 Suggestion IA :
                                    <span class="ai-role">
                                        {{ worker.aiSuggestedRole == 'ROLE_GERANT' ? 'Gérant' : 'Ouvrier' }}
                                    </span>
                                    {% if worker.decisionReason %}
                                        <span class="ai-reason">— {{ worker.decisionReason }}</span>
                                    {% endif %}
                                </div>
                                {% endif %}

                                {% if worker.cvFile %}
                                    <a class="cv-link" href="{{ app.request.basePath }}/uploads/{{ worker.cvFile }}" target="_blank">📄 Voir le CV</a>
                                {% endif %}

                                <div class="ac-actions">
                                    <form method="post" action="{{ path('farm_worker_assign', {id: worker.id}) }}" style="display:inline">
                                        <input type="hidden" name="role" value="ROLE_GERANT">
                                        <button type="submit" class="btn-action btn-gerant">👔 Assigner Gérant</button>
                                    </form>
                                    <form method="post" action="{{ path('farm_worker_assign', {id: worker.id}) }}" style="display:inline">
                                        <input type="hidden" name="role" value="ROLE_OUVRIER">
                                        <button type="submit" class="btn-action btn-ouvrier">🌾 Assigner Ouvrier</button>
                                    </form>
                                    <form method="post" action="{{ path('farm_worker_reject', {id: worker.id}) }}" style="display:inline"
                                          onsubmit="return confirm('Refuser la candidature de {{ worker.name }} ?')">
                                        <button type="submit" class="btn-action btn-reject">✕ Refuser</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                    </div>
                {% endif %}

                {# ── Approved workers ── #}
                <div class="section-label" style="margin-top:6px">
                    <span class="section-label-text">✅ Équipe approuvée</span>
                    <span class="badge-active">{{ approved|length }}</span>
                </div>

                {% if approved|length == 0 %}
                    <div class="empty-state-sm">
                        <div class="esi-icon">👷</div>
                        Aucun travailleur approuvé pour l'instant. Approuvez des candidatures ci-dessus.
                    </div>
                {% else %}
                    <div class="workers-table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Nom</th><th>Email</th><th>Rôle</th><th>CV</th><th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for worker in approved %}
                                <tr>
                                    <td><strong>{{ worker.name }}</strong></td>
                                    <td style="color:var(--muted)">{{ worker.email }}</td>
                                    <td>
                                        {% if 'ROLE_GERANT' in worker.roles %}
                                            <span class="role-pill role-gerant">👔 Gérant</span>
                                        {% else %}
                                            <span class="role-pill role-ouvrier">🌾 Ouvrier</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if worker.cvFile %}
                                            <a class="cv-link" href="{{ app.request.basePath }}/uploads/{{ worker.cvFile }}" target="_blank">📄 CV</a>
                                        {% else %}—{% endif %}
                                    </td>
                                    <td>
                                        <form method="post" action="{{ path('farm_worker_remove', {id: worker.id}) }}"
                                              onsubmit="return confirm('Retirer {{ worker.name }} de la ferme ?')">
                                            <button type="submit" class="btn-action btn-remove">✕ Retirer</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

            </div>

            {% if not loop.last %}<hr class="divider-farm">{% endif %}
        {% endfor %}
    {% endif %}

</div>
</body>
</html>
