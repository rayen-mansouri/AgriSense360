<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Modifier la ferme — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--g5:#3e8e3e;--g7:#2d6a2d;--panel:#f4f9f1;--white:#fff;--border:#dde8d8;--text:#1e3a1e;--muted:#6b8f6b;--danger:#dc2626}
        body{min-height:100vh;font-family:'Plus Jakarta Sans',sans-serif;background:var(--panel);display:flex;align-items:flex-start;justify-content:center;padding:40px 16px}
        .card{background:var(--white);border-radius:24px;box-shadow:0 12px 60px rgba(30,58,30,.12);width:100%;max-width:560px;overflow:hidden}
        .card-top{height:5px;background:linear-gradient(90deg,var(--g7),var(--g5),#81c784)}
        .inner{padding:36px 44px 44px}
        .back{display:inline-flex;align-items:center;gap:7px;font-size:.82rem;color:var(--muted);text-decoration:none;margin-bottom:22px;transition:color .15s}
        .back:hover{color:var(--g7)}
        .brand{display:flex;align-items:center;gap:12px;margin-bottom:28px}
        .brand-icon{width:42px;height:42px;border-radius:11px;background:var(--g5);display:flex;align-items:center;justify-content:center}
        .brand-icon svg{width:22px;height:22px;fill:#fff}
        .brand-name{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:var(--text)}
        h1{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:700;color:var(--text);margin-bottom:6px}
        .farm-id{font-family:monospace;font-size:.8rem;color:var(--muted);background:rgba(62,142,62,.08);border:1px solid rgba(62,142,62,.2);border-radius:50px;padding:3px 12px;display:inline-block;margin-bottom:26px}
        .field{margin-bottom:16px}
        .label{display:block;font-size:.72rem;font-weight:700;color:var(--muted);margin-bottom:6px;letter-spacing:.04em;text-transform:uppercase}
        .inp-wrap{position:relative}
        .inp-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none}
        .inp-icon svg{width:16px;height:16px;stroke:var(--muted);fill:none;stroke-width:2;stroke-linecap:round}
        input[type=text],input[type=number]{width:100%;padding:12px 14px 12px 44px;background:var(--panel);border:1.5px solid var(--border);border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;color:var(--text);outline:none;transition:border-color .18s,box-shadow .18s}
        input:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.13);background:#fff}
        textarea{width:100%;padding:12px 14px;background:var(--panel);border:1.5px solid var(--border);border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;color:var(--text);outline:none;resize:vertical;min-height:100px;transition:border-color .18s}
        textarea:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.13);background:#fff}
        .row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
        /* Image zone */
        .img-current{width:100%;height:140px;object-fit:cover;border-radius:12px;margin-bottom:10px;display:block}
        .img-dz{border:2px dashed var(--border);border-radius:12px;padding:18px;cursor:pointer;text-align:center;transition:all .2s;background:var(--panel)}
        .img-dz:hover,.img-dz.has-file{border-color:var(--g5);background:rgba(62,142,62,.04)}
        .img-dz-title{font-size:.82rem;font-weight:600;color:var(--text);margin-bottom:2px}
        .img-dz-hint{font-size:.72rem;color:var(--muted)}
        .img-preview{width:100%;max-height:140px;object-fit:cover;border-radius:10px;margin-top:8px;display:none}
        .btn-submit{width:100%;padding:14px;background:var(--g5);color:#fff;border:none;border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:background .18s,transform .12s;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:8px}
        .btn-submit:hover{background:var(--g7);transform:translateY(-1px)}
        .flash-success{background:rgba(62,142,62,.1);border:1px solid rgba(62,142,62,.25);color:var(--g7);padding:10px 14px;border-radius:9px;font-size:.84rem;margin-bottom:18px}
    </style>
</head>
<body>
<div class="card">
    <div class="card-top"></div>
    <div class="inner">
        <a href="{{ path('farm_dashboard') }}" class="back">← Retour au tableau de bord</a>
        <div class="brand">
            <div class="brand-icon"><svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg></div>
            <div class="brand-name">AgriSense 360</div>
        </div>

        {% for msg in app.flashes('success') %}<div class="flash-success">✓ {{ msg }}</div>{% endfor %}

        <h1>Modifier la ferme</h1>
        <div class="farm-id">🔑 {{ farm.farmId }}</div>

        <form method="post" enctype="multipart/form-data">

            <div class="field">
                <label class="label" for="f-name">Nom de la ferme *</label>
                <div class="inp-wrap">
                    <span class="inp-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
                    <input type="text" id="f-name" name="name" value="{{ farm.name }}" required>
                </div>
            </div>

            <div class="row">
                <div class="field">
                    <label class="label" for="f-loc">Localisation</label>
                    <div class="inp-wrap">
                        <span class="inp-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                        <input type="text" id="f-loc" name="location" value="{{ farm.location }}">
                    </div>
                </div>
                <div class="field">
                    <label class="label" for="f-surf">Surface (ha)</label>
                    <div class="inp-wrap">
                        <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg></span>
                        <input type="number" id="f-surf" name="surface" value="{{ farm.surface }}" step="0.1" min="0">
                    </div>
                </div>
            </div>

            <div class="field">
                <label class="label" for="f-desc">Description & profils recherchés</label>
                <textarea id="f-desc" name="description" placeholder="Décrivez votre ferme et les profils de travailleurs recherchés...">{{ farm.description }}</textarea>
            </div>

            <div class="field">
                <label class="label">Photo de la ferme</label>
                {% if farm.image %}
                    <img src="{{ app.request.basePath }}/uploads/farms/{{ farm.image }}" class="img-current" alt="Photo actuelle">
                    <p style="font-size:.75rem;color:var(--muted);margin-bottom:8px">Sélectionnez une nouvelle image pour remplacer l'actuelle</p>
                {% endif %}
                <div class="img-dz" id="imgDz" onclick="document.getElementById('imgInput').click()">
                    <div class="img-dz-title">{{ farm.image ? 'Changer la photo' : 'Ajouter une photo' }}</div>
                    <div class="img-dz-hint">JPG, PNG · Max 5 Mo (optionnel)</div>
                    <input type="file" id="imgInput" name="image" accept="image/*" style="display:none">
                    <img id="imgPreview" class="img-preview" alt="Aperçu">
                </div>
            </div>

            <button type="submit" class="btn-submit">💾 Enregistrer les modifications</button>
        </form>
    </div>
</div>

<script>
document.getElementById('imgInput').addEventListener('change', function() {
    if (this.files && this.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            const p = document.getElementById('imgPreview');
            p.src = e.target.result; p.style.display = 'block';
            document.getElementById('imgDz').classList.add('has-file');
        };
        reader.readAsDataURL(this.files[0]);
    }
});
</script>
</body>
</html>
