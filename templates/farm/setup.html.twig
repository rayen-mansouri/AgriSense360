<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Configurer ma ferme — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--g5:#3e8e3e;--g7:#2d6a2d;--panel:#f4f9f1;--white:#fff;--border:#dde8d8;--text:#1e3a1e;--muted:#6b8f6b}
        body{min-height:100vh;font-family:'Plus Jakarta Sans',sans-serif;background:var(--panel);display:flex;align-items:center;justify-content:center;padding:24px 16px}
        .card{background:var(--white);border-radius:24px;box-shadow:0 12px 60px rgba(30,58,30,.12);width:100%;max-width:520px;overflow:hidden}
        .card-top{height:5px;background:linear-gradient(90deg,var(--g7),var(--g5),#81c784)}
        .inner{padding:40px 44px 48px}
        .brand{display:flex;align-items:center;gap:12px;margin-bottom:36px}
        .brand-icon{width:42px;height:42px;border-radius:11px;background:var(--g5);display:flex;align-items:center;justify-content:center}
        .brand-icon svg{width:22px;height:22px;fill:#fff}
        .brand-name{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:var(--text)}
        .brand-sub{font-size:.68rem;color:var(--muted)}
        .step-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(62,142,62,.1);color:var(--g7);border-radius:50px;padding:6px 14px;font-size:.78rem;font-weight:700;margin-bottom:16px}
        h1{font-family:'Fraunces',serif;font-size:1.7rem;font-weight:700;color:var(--text);margin-bottom:6px}
        .sub{font-size:.87rem;color:var(--muted);margin-bottom:28px;line-height:1.6}
        .field{margin-bottom:18px}
        .label{display:block;font-size:.72rem;font-weight:700;color:var(--muted);margin-bottom:8px;letter-spacing:.04em;text-transform:uppercase}
        .inp-wrap{position:relative}
        .inp-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none}
        .inp-icon svg{width:16px;height:16px;stroke:var(--muted);fill:none;stroke-width:2;stroke-linecap:round}
        input{width:100%;padding:13px 14px 13px 44px;background:var(--panel);border:1.5px solid var(--border);border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;color:var(--text);outline:none;transition:border-color .18s,box-shadow .18s}
        input:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.13);background:#fff}
        input::placeholder{color:#9bb79b}
        textarea{width:100%;padding:13px 14px;background:var(--panel);border:1.5px solid var(--border);border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;color:var(--text);outline:none;transition:border-color .18s;resize:vertical;min-height:90px}
        textarea:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.13);background:#fff}
        textarea::placeholder{color:#9bb79b}
        .row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
        .btn{width:100%;padding:14px;background:var(--g5);color:#fff;border:none;border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:background .18s,transform .12s;margin-top:6px;display:flex;align-items:center;justify-content:center;gap:8px}
        .btn:hover{background:var(--g7);transform:translateY(-1px)}
        .alert-error{background:rgba(220,38,38,.07);border:1px solid rgba(220,38,38,.2);color:#b91c1c;padding:12px 14px;border-radius:10px;font-size:.84rem;margin-bottom:20px}
        .id-preview{display:flex;align-items:center;justify-content:space-between;background:rgba(62,142,62,.06);border:1px dashed rgba(62,142,62,.3);border-radius:10px;padding:12px 16px;margin-bottom:20px}
        .id-label{font-size:.72rem;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.05em}
        .id-value{font-family:monospace;font-size:1rem;font-weight:700;color:var(--g5);letter-spacing:.08em}
        .id-note{font-size:.7rem;color:var(--muted);margin-top:2px}
        /* Image drop zone */
        .img-dz{border:2px dashed var(--border);border-radius:12px;padding:20px;cursor:pointer;text-align:center;transition:all .2s;background:var(--panel);margin-bottom:4px}
        .img-dz:hover,.img-dz.has-file{border-color:var(--g5);background:rgba(62,142,62,.04)}
        .img-dz-icon{font-size:1.8rem;margin-bottom:6px}
        .img-dz-title{font-size:.82rem;font-weight:600;color:var(--text)}
        .img-dz-hint{font-size:.72rem;color:var(--muted)}
        .img-preview{width:100%;max-height:160px;object-fit:cover;border-radius:10px;margin-top:10px;display:none}
    </style>
</head>
<body>
<div class="card">
    <div class="card-top"></div>
    <div class="inner">
        <div class="brand">
            <div class="brand-icon"><svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg></div>
            <div><div class="brand-name">AgriSense 360</div><div class="brand-sub">Agriculture Intelligente</div></div>
        </div>
        <div class="step-badge">🏡 Étape 1 · Configuration de la ferme</div>
        <h1>Créez votre ferme</h1>
        <p class="sub">Donnez un nom à votre exploitation. Un identifiant unique sera généré automatiquement.</p>
        {% if error %}<div class="alert-error">⚠ {{ error }}</div>{% endif %}
        <div class="id-preview">
            <div>
                <div class="id-label">Identifiant unique</div>
                <div class="id-value">FARM-??????</div>
                <div class="id-note">Généré automatiquement après enregistrement</div>
            </div>
            <span style="font-size:1.6rem">🔑</span>
        </div>
        <form method="post" enctype="multipart/form-data">
            <div class="field">
                <label class="label" for="f-name">Nom de la ferme *</label>
                <div class="inp-wrap">
                    <span class="inp-icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
                    <input id="f-name" type="text" name="name" placeholder="Ex: Ferme El Baraka" required value="{{ app.request.request.get('name') }}">
                </div>
            </div>
            <div class="row">
                <div class="field">
                    <label class="label" for="f-loc">Localisation</label>
                    <div class="inp-wrap">
                        <span class="inp-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                        <input id="f-loc" type="text" name="location" placeholder="Wilaya, région..." value="{{ app.request.request.get('location') }}">
                    </div>
                </div>
                <div class="field">
                    <label class="label" for="f-surf">Surface (ha)</label>
                    <div class="inp-wrap">
                        <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg></span>
                        <input id="f-surf" type="number" name="surface" placeholder="Ex: 25.5" step="0.1" min="0" value="{{ app.request.request.get('surface') }}">
                    </div>
                </div>
            </div>

            <div class="field">
                <label class="label" for="f-desc">Description & profils recherchés</label>
                <textarea id="f-desc" name="description" placeholder="Ex: Nous cherchons des ouvriers agricoles pour la récolte d'olives et un gérant expérimenté en irrigation. Saison : octobre-novembre.">{{ app.request.request.get('description') }}</textarea>
            </div>

            <div class="field">
                <label class="label">Photo de la ferme <span style="font-weight:400;color:var(--muted);text-transform:none">(optionnel)</span></label>
                <div class="img-dz" id="imgDz" onclick="document.getElementById('imgInput').click()">
                    <div class="img-dz-icon">🖼️</div>
                    <div class="img-dz-title">Cliquez ou glissez une photo</div>
                    <div class="img-dz-hint">JPG, PNG · Max 5 Mo</div>
                    <input type="file" id="imgInput" name="image" accept="image/*" style="display:none">
                    <img id="imgPreview" class="img-preview" alt="Aperçu">
                </div>
            </div>

            <button type="submit" class="btn">🌾 Créer ma ferme →</button>
        </form>
    </div>
</div>
<script>
const imgInput = document.getElementById('imgInput');
const imgPreview = document.getElementById('imgPreview');
const imgDz = document.getElementById('imgDz');
imgInput.addEventListener('change', function() {
    if (this.files && this.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            imgPreview.src = e.target.result;
            imgPreview.style.display = 'block';
            imgDz.classList.add('has-file');
        };
        reader.readAsDataURL(this.files[0]);
    }
});
</script>
</body>
</html>
