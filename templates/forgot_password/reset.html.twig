<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Nouveau mot de passe — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--g5:#3e8e3e;--g7:#2d6a2d;--panel:#f4f9f1;--white:#ffffff;--border:#dde8d8;--text:#1e3a1e;--muted:#6b8f6b}
        body{min-height:100vh;font-family:'Plus Jakarta Sans',sans-serif;background:var(--panel);display:flex;align-items:center;justify-content:center;padding:24px 16px}
        .card{background:var(--white);border-radius:20px;box-shadow:0 8px 40px rgba(30,58,30,.10);width:100%;max-width:440px;overflow:hidden}
        .card::before{content:'';display:block;height:4px;background:linear-gradient(90deg,var(--g7),var(--g5),#81c784)}
        .inner{padding:36px 40px 40px}
        .brand{display:flex;align-items:center;gap:12px;margin-bottom:32px}
        .brand-icon{width:40px;height:40px;border-radius:10px;background:var(--g5);display:flex;align-items:center;justify-content:center}
        .brand-icon svg{width:22px;height:22px;fill:#fff}
        .brand-name{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:var(--text)}
        .brand-sub{font-size:.68rem;color:var(--muted)}
        .icon-circle{width:68px;height:68px;border-radius:50%;background:rgba(62,142,62,.10);border:2px solid rgba(62,142,62,.20);display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
        .icon-circle svg{width:30px;height:30px;stroke:var(--g5);fill:none;stroke-width:1.8;stroke-linecap:round}
        h1{font-family:'Fraunces',serif;font-size:1.55rem;font-weight:700;color:var(--text);text-align:center;margin-bottom:8px}
        .sub{font-size:.86rem;color:var(--muted);text-align:center;line-height:1.6;margin-bottom:28px}
        .field{margin-bottom:18px}
        .label{display:block;font-size:.72rem;font-weight:700;color:var(--muted);margin-bottom:8px;letter-spacing:.05em;text-transform:uppercase}
        .inp-wrap{position:relative}
        .inp-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);pointer-events:none}
        .inp-icon svg{width:16px;height:16px;stroke:var(--muted);fill:none;stroke-width:2;stroke-linecap:round}
        .eye-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:4px;color:var(--muted);display:flex;align-items:center;transition:color .15s}
        .eye-btn:hover{color:var(--g5)}
        .eye-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round}
        input[type=password],input[type=text]{width:100%;padding:13px 44px;background:var(--panel);border:1.5px solid var(--border);border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;color:var(--text);outline:none;transition:border-color .18s,box-shadow .18s}
        input[type=password]:focus,input[type=text]:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.15);background:#fff}
        input::placeholder{color:#9bb79b}
        .strength-bars{display:flex;gap:4px;margin:10px 0 4px}
        .seg{flex:1;height:4px;border-radius:2px;background:var(--border);transition:background .25s}
        .strength-label{font-size:.7rem;color:var(--muted)}
        .btn{width:100%;padding:14px;background:var(--g5);color:#fff;border:none;border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:background .18s,transform .12s;margin-top:4px}
        .btn:hover{background:var(--g7);transform:translateY(-1px)}
        .alert-error{background:rgba(220,38,38,.08);border:1px solid rgba(220,38,38,.22);color:#b91c1c;padding:12px 14px;border-radius:10px;font-size:.84rem;margin-bottom:20px}
    </style>
</head>
<body>
<div class="card">
    <div class="inner">
        <div class="brand">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg>
            </div>
            <div>
                <div class="brand-name">AgriSense 360</div>
                <div class="brand-sub">Agriculture Intelligente</div>
            </div>
        </div>

        <div class="icon-circle">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>

        <h1>Nouveau mot de passe</h1>
        <p class="sub">Choisissez un mot de passe fort pour sécuriser votre compte.</p>

        {% if error %}<div class="alert-error">⚠ {{ error }}</div>{% endif %}

        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}">
            <div class="field">
                <label class="label">Nouveau mot de passe</label>
                <div class="inp-wrap">
                    <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                    <input type="password" name="password" id="pwd1" placeholder="Minimum 8 caractères" oninput="checkStr(this.value)" required>
                    <button type="button" class="eye-btn" onclick="toggle('pwd1')"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                </div>
                <div class="strength-bars"><div class="seg" id="s1"></div><div class="seg" id="s2"></div><div class="seg" id="s3"></div><div class="seg" id="s4"></div></div>
                <div class="strength-label" id="sl"></div>
            </div>
            <div class="field">
                <label class="label">Confirmer le mot de passe</label>
                <div class="inp-wrap">
                    <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                    <input type="password" name="confirm" id="pwd2" placeholder="Répéter le mot de passe" required>
                    <button type="button" class="eye-btn" onclick="toggle('pwd2')"><svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                </div>
            </div>
            <button type="submit" class="btn">Enregistrer →</button>
        </form>
    </div>
</div>
<script>
function toggle(id){const i=document.getElementById(id);i.type=i.type==='password'?'text':'password';}
const colors=['','#ef4444','#f97316','#eab308','#22c55e'];
const labels=['','Très faible','Faible','Moyen','Fort'];
function checkStr(v){
    const score=[v.length>=8,/[A-Z]/.test(v),/[a-z]/.test(v),/[0-9]/.test(v)].filter(Boolean).length;
    for(let i=1;i<=4;i++){document.getElementById('s'+i).style.background=i<=score?colors[score]:'var(--border)';}
    const el=document.getElementById('sl');el.textContent=v.length?labels[score]:'';el.style.color=colors[score];
}
</script>
</body>
</html>