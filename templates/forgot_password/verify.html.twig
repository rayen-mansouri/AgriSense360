<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Entrer le code — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        :root{--g5:#3e8e3e;--g7:#2d6a2d;--panel:#f4f9f1;--white:#ffffff;--border:#dde8d8;--text:#1e3a1e;--muted:#6b8f6b}
        body{min-height:100vh;font-family:'Plus Jakarta Sans',sans-serif;background:var(--panel);display:flex;align-items:center;justify-content:center;padding:24px 16px}
        .card{background:var(--white);border-radius:20px;box-shadow:0 8px 40px rgba(30,58,30,.10);width:100%;max-width:440px;overflow:hidden}
        .card::before{content:'';display:block;height:4px;background:linear-gradient(90deg,var(--g7),var(--g5),#81c784)}
        .inner{padding:36px 40px 40px}
        .brand{display:flex;align-items:center;gap:12px;margin-bottom:32px}
        .brand-icon{width:40px;height:40px;border-radius:10px;background:var(--g5);display:flex;align-items:center;justify-content:center}
        .brand-icon svg{width:22px;height:22px;fill:#fff}
        .brand-name{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:var(--text)}
        .brand-sub{font-size:.68rem;color:var(--muted)}
        .icon-circle{width:68px;height:68px;border-radius:50%;background:rgba(62,142,62,.10);border:2px solid rgba(62,142,62,.20);display:flex;align-items:center;justify-content:center;margin:0 auto 20px}
        .icon-circle svg{width:30px;height:30px;stroke:var(--g5);fill:none;stroke-width:1.8;stroke-linecap:round}
        h1{font-family:'Fraunces',serif;font-size:1.55rem;font-weight:700;color:var(--text);text-align:center;margin-bottom:8px}
        .sub{font-size:.86rem;color:var(--muted);text-align:center;line-height:1.6;margin-bottom:28px}
        .label{display:block;font-size:.72rem;font-weight:700;color:var(--muted);margin-bottom:12px;letter-spacing:.05em;text-transform:uppercase;text-align:center}
        /* Code boxes */
        .code-row{display:flex;gap:10px;justify-content:center;margin-bottom:24px}
        .code-box{width:52px;height:60px;border:2px solid var(--border);border-radius:12px;font-size:1.6rem;font-weight:700;text-align:center;color:var(--text);background:var(--panel);outline:none;transition:border-color .18s,box-shadow .18s;font-family:'Plus Jakarta Sans',sans-serif}
        .code-box:focus{border-color:var(--g5);box-shadow:0 0 0 3px rgba(76,175,80,.15);background:#fff}
        input[name=code]{display:none}
        .btn{width:100%;padding:14px;background:var(--g5);color:#fff;border:none;border-radius:11px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;transition:background .18s,transform .12s}
        .btn:hover{background:var(--g7);transform:translateY(-1px)}
        .alert-error{background:rgba(220,38,38,.08);border:1px solid rgba(220,38,38,.22);color:#b91c1c;padding:12px 14px;border-radius:10px;font-size:.84rem;margin-bottom:20px;text-align:center}
        .back{text-align:center;margin-top:20px;font-size:.82rem;color:var(--muted)}
        .back a{color:var(--g5);font-weight:600;text-decoration:none}
        .back a:hover{text-decoration:underline}
        .timer{text-align:center;font-size:.8rem;color:var(--muted);margin-bottom:16px}
        .timer span{font-weight:700;color:var(--g5)}
    </style>
</head>
<body>
<div class="card">
    <div class="inner">
        <div class="brand">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg>
            </div>
            <div>
                <div class="brand-name">AgriSense 360</div>
                <div class="brand-sub">Agriculture Intelligente</div>
            </div>
        </div>

        <div class="icon-circle">
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>

        <h1>Entrez votre code</h1>
        <p class="sub">Nous avons envoyé un code à 6 chiffres à votre email. Valable <strong>15 minutes</strong>.</p>

        {% if error %}<div class="alert-error">⚠ {{ error }}</div>{% endif %}

        <div class="timer">Expire dans : <span id="countdown">15:00</span></div>

        <form method="POST" id="codeForm">
            <input type="hidden" name="_token" value="{{ csrf_token('verify_code') }}">
            <label class="label">Code de vérification</label>
            <div class="code-row">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
                <input class="code-box" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
            </div>
            <input type="hidden" name="code" id="finalCode">
            <button type="submit" class="btn" id="submitBtn" disabled>Vérifier le code →</button>
        </form>

        <div class="back">
            <a href="{{ path('app_forgot_password') }}">← Renvoyer un nouveau code</a>
        </div>
    </div>
</div>

<script>
// Auto-advance between boxes
const boxes = document.querySelectorAll('.code-box');
const finalInput = document.getElementById('finalCode');
const submitBtn = document.getElementById('submitBtn');

boxes.forEach((box, i) => {
    box.addEventListener('input', () => {
        box.value = box.value.replace(/[^0-9]/g, '');
        if (box.value && i < 5) boxes[i + 1].focus();
        updateFinal();
    });
    box.addEventListener('keydown', e => {
        if (e.key === 'Backspace' && !box.value && i > 0) boxes[i - 1].focus();
    });
    box.addEventListener('paste', e => {
        e.preventDefault();
        const pasted = e.clipboardData.getData('text').replace(/\D/g, '').slice(0, 6);
        pasted.split('').forEach((ch, idx) => { if (boxes[idx]) boxes[idx].value = ch; });
        updateFinal();
        if (boxes[Math.min(pasted.length, 5)]) boxes[Math.min(pasted.length, 5)].focus();
    });
});

function updateFinal() {
    const code = [...boxes].map(b => b.value).join('');
    finalInput.value = code;
    submitBtn.disabled = code.length < 6;
}

// Countdown 15 min
let seconds = 15 * 60;
const el = document.getElementById('countdown');
const timer = setInterval(() => {
    seconds--;
    if (seconds <= 0) { clearInterval(timer); el.textContent = 'Expiré'; el.style.color = '#ef4444'; return; }
    const m = Math.floor(seconds / 60).toString().padStart(2, '0');
    const s = (seconds % 60).toString().padStart(2, '0');
    el.textContent = m + ':' + s;
}, 1000);
</script>
</body>
</html>