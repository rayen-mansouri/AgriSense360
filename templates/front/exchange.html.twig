{% extends 'base.html.twig' %}
{% set activePage = 'exchange' %}
{% block title %}Taux de change — Agrisens 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    /* ── BASE LAYOUT ── */
    body { background-color: var(--pg) !important; font-family: 'Inter', sans-serif !important; }
    .front-main { padding-top: 70px; width: 100%; }
    .front-main-container { max-width: 1200px; margin: 0 auto; padding: 60px 24px; }

    /* ── DASHBOARD CARDS ── */
    .exchange-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 32px;
        padding: 40px;
        margin-bottom: 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        position: relative;
        overflow: hidden;
    }
    .exchange-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--g), #a8d060);
    }

    .card-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--ch3);
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .card-title i { color: var(--g); }

    /* ── CONVERTER ── */
    .converter-row {
        display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-end;
    }
    .form-group { flex: 1; min-width: 200px; }
    .form-label {
        display: block; margin-bottom: 10px; font-weight: 700; color: var(--cp);
        font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .form-input {
        width: 100%; padding: 14px 20px; background: var(--fi);
        border: 1px solid var(--cbr); border-radius: 14px; color: var(--ch3);
        font-size: 1rem; outline: none; transition: border-color 0.2s;
    }
    .form-input:focus { border-color: var(--g); }

    #result {
        margin-top: 30px; padding: 30px; border-radius: 20px;
        background: var(--fi); border: 1px solid var(--cbr);
        text-align: center; display: none;
    }
    #convertedAmount { font-size: 3.5rem; font-weight: 900; color: var(--g); margin: 0; line-height: 1.2; }
    #rateInfo { margin-top: 10px; color: var(--cp); font-weight: 600; }

    /* ── RATES GRID ── */
    .rates-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;
    }
    .rate-item {
        background: var(--surface2); border: 1px solid var(--cbr);
        padding: 24px; border-radius: 20px; text-align: center;
        transition: transform 0.2s, background 0.2s;
    }
    .rate-item:hover { transform: translateY(-5px); background: var(--fb); border-color: var(--g); }
    .rate-flag { font-size: 2.5rem; margin-bottom: 12px; display: block; }
    .rate-code { font-weight: 800; color: var(--ch3); margin-bottom: 8px; font-size: 1.1rem; }
    .rate-val { font-size: 1.2rem; font-weight: 900; color: var(--g); }
</style>
{% endblock %}

{% block body %}
<!-- GLOBAL HEADER -->
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">
        
        <header style="margin-bottom: 50px; text-align: center;">
             <div style="display:inline-flex; align-items:center; gap:10px; background:rgba(90,181,90,0.1); padding:8px 16px; border-radius:50px; margin-bottom:15px; border:1px solid rgba(90,181,90,0.2);">
                 <i class="fa-solid fa-coins" style="color:var(--g);"></i>
                 <span style="color:var(--g); font-size:0.75rem; font-weight:800; text-transform:uppercase;">Intelligence Marché</span>
             </div>
             <h1 style="font-size: 3rem; font-weight: 900; color: var(--ch3); letter-spacing: -0.04em;">Taux de Change</h1>
             <p style="color: var(--cp); font-size: 1.2rem;">Suivez l'évolution des devises pour vos transactions internationales.</p>
        </header>

        <!-- CONVERTER -->
        <div class="exchange-card">
            <h2 class="card-title"><i class="fa-solid fa-rotate"></i> Convertisseur Direct</h2>
            <div class="converter-row">
                <div class="form-group">
                    <label class="form-label">Montant (TND)</label>
                    <input type="number" id="amount" class="form-input" value="100" step="10">
                </div>
                <div class="form-group">
                    <label class="form-label">Devise Cible</label>
                    <select id="currency" class="form-input">
                        <option value="EUR">🇪🇺 Euro (EUR)</option>
                        <option value="USD">🇺🇸 Dollar US (USD)</option>
                        <option value="GBP">🇬🇧 Livre Sterling (GBP)</option>
                        <option value="CAD">🇨🇦 Dollar Canadien (CAD)</option>
                        <option value="JPY">🇯🇵 Yen Japonais (JPY)</option>
                        <option value="CHF">🇨🇭 Franc Suisse (CHF)</option>
                    </select>
                </div>
                <button id="convertBtn" class="hn-btn hn-btn--solid" style="height: 52px; padding: 0 40px;">Convertir</button>
            </div>
            
            <div id="result">
                <h2 id="convertedAmount">-</h2>
                <p id="rateInfo"></p>
            </div>
        </div>

        <!-- DAILY RATES -->
        <div class="exchange-card">
            <h2 class="card-title"><i class="fa-solid fa-chart-line"></i> Taux du Jour (Base 1 TND)</h2>
            <div id="ratesList" class="rates-grid">
                <!-- Loaded via JS -->
            </div>
            <div style="margin-top: 30px; text-align: center; border-top: 1px solid var(--cbr); padding-top: 20px;">
                <p id="updateDate" style="font-size: 0.8rem; color: var(--cp); font-weight: 600;"></p>
            </div>
        </div>

    </div>
</main>

<script>
const flags = { EUR: '🇪🇺', USD: '🇺🇸', GBP: '🇬🇧', CAD: '🇨🇦', JPY: '🇯🇵', CHF: '🇨🇭' };
let currentRates = {};

function fetchRates() {
    fetch('/api/exchange/rates')
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                currentRates = data.rates;
                let html = '';
                const currencies = ['EUR', 'USD', 'GBP', 'CAD', 'JPY', 'CHF'];
                for (const currency of currencies) {
                    const rate = currentRates[currency];
                    if (rate) {
                        html += `
                            <div class="rate-item">
                                <span class="rate-flag">${flags[currency]}</span>
                                <div class="rate-code">${currency}</div>
                                <div class="rate-val">${rate.toFixed(4)}</div>
                            </div>`;
                    }
                }
                document.getElementById('ratesList').innerHTML = html;
                document.getElementById('updateDate').innerHTML = `<i class="fa-solid fa-clock"></i> Dernière mise à jour : ${data.date}`;
            }
        });
}

document.getElementById('convertBtn').addEventListener('click', function() {
    const amount = parseFloat(document.getElementById('amount').value);
    const currency = document.getElementById('currency').value;
    const rate = currentRates[currency];
    
    if (rate) {
        const converted = (amount * rate).toFixed(2);
        document.getElementById('convertedAmount').innerHTML = `${converted} ${currency}`;
        document.getElementById('rateInfo').innerHTML = `${amount} TND = ${converted} ${currency} (1 TND = ${rate.toFixed(4)} ${currency})`;
        document.getElementById('result').style.display = 'block';
    }
});

fetchRates();
setInterval(fetchRates, 3600000);

// Theme toggle
const html = document.documentElement;
const themeBtn = document.getElementById('themeToggleNav');
if (themeBtn) {
    themeBtn.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
}
</script>
{% endblock %}