{# templates/front/produit/form.html.twig #}
{% extends 'base.html.twig' %}
{% set activePage = 'catalogue' %}
{% block title %}Gestion Produit — Agrisens 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    /* ── BASE LAYOUT ── */
    body { background-color: var(--pg) !important; font-family: 'Inter', sans-serif !important; }
    .front-main { padding-top: 70px; width: 100%; }
    .front-main-container { max-width: 900px; margin: 0 auto; padding: 60px 24px; }

    /* ── FORM CONTAINER ── */
    .front-produit-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    }
    .front-produit-header {
        background: linear-gradient(135deg, var(--gd), var(--g));
        padding: 50px 40px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        position: relative;
    }
    .front-produit-header::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--g), #a8d060);
    }
    .front-produit-header h1 { font-size: 2.5rem; font-weight: 900; color: #fff; letter-spacing: -0.04em; margin-bottom: 10px; }
    .front-produit-header p { color: rgba(255,255,255,0.8); font-size: 1.1rem; }

    .front-produit-form { padding: 40px; }

    /* ── SECTIONS ── */
    .form-section { margin-bottom: 40px; }
    .section-title {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 24px; padding-bottom: 12px;
        border-bottom: 1px solid var(--cbr);
    }
    .section-title i { font-size: 1.5rem; color: var(--g); }
    .section-title h2 { font-size: 1.25rem; font-weight: 800; color: var(--ch3); margin: 0; }
    .badge-info { background: rgba(255,255,255,0.05); color: var(--cp); padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }

    /* ── FIELDS ── */
    .form-group { margin-bottom: 24px; }
    .form-label { display: block; font-weight: 700; margin-bottom: 10px; color: var(--cp); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .form-control {
        width: 100%; padding: 14px 20px; background: var(--fi);
        border: 1px solid var(--cbr); border-radius: 14px; color: var(--ch3);
        font-size: 1rem; outline: none; transition: border-color 0.2s;
    }
    .form-control:focus { border-color: var(--g); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

    .upload-area {
        border: 2px dashed var(--cbr); border-radius: 16px; padding: 40px;
        text-align: center; cursor: pointer; background: rgba(255,255,255,0.02);
        display: flex; flex-direction: column; align-items: center;
        transition: all 0.2s;
    }
    .upload-area:hover { border-color: var(--g); background: rgba(90,181,90,0.05); }
    .upload-area i { font-size: 40px; color: var(--cp); margin-bottom: 12px; }
    .upload-hint { font-size: 11px; color: var(--cp); opacity: 0.6; }

    .image-preview { flex-direction: column; align-items: center; gap: 16px; margin-top: 16px; }
    .image-preview img { max-width: 100%; border-radius: 16px; border: 1px solid var(--cbr); }
    .remove-image { background: rgba(244,67,54,0.1); border: none; color: #f44336; padding: 8px 20px; border-radius: 50px; cursor: pointer; font-weight: 700; font-size: 0.85rem; }

    .info-box {
        background: rgba(33,150,243,0.05); border: 1px solid rgba(33,150,243,0.2);
        border-radius: 16px; padding: 16px; display: flex; align-items: center; gap: 12px;
        margin-top: 24px; font-size: 0.9rem; color: var(--ch3);
    }
    .info-box a { color: #2196f3; text-decoration: none; font-weight: 700; margin-left: auto; }

    .form-actions {
        display: flex; justify-content: flex-end; gap: 16px;
        margin-top: 40px; padding-top: 30px; border-top: 1px solid var(--cbr);
    }

    @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}
<!-- GLOBAL HEADER -->
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

        <div class="front-produit-card">
            <div class="front-produit-header">
                <h1><i class="fa-solid fa-leaf" style="color:var(--g);"></i> Nouveau Produit</h1>
                <p>Propulsez votre exploitation avec des produits de haute qualité.</p>
            </div>

            <form method="post" id="produitForm" enctype="multipart/form-data" class="front-produit-form">
                {{ form_widget(form._token) }}

                <!-- Section produit -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fa-solid fa-box"></i>
                        <h2>Informations Générales</h2>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Catégorie *</label>
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-control field-categorie'}}) }}
                        <div class="error-container error-categorie" style="margin-top: 10px;"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Nom du Produit *</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control field-nom', 'placeholder': 'Ex: Engrais NPK 15-15-15'}}) }}
                        <div class="error-container error-nom" style="margin-top: 10px;"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Description Détaillée</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control field-description', 'rows': 4, 'placeholder': 'Décrivez les caractéristiques du produit...'}}) }}
                        <div class="error-container error-description" style="margin-top: 10px;"></div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Prix Unitaire (DT) *</label>
                            {{ form_widget(form.prixUnitaire, {'attr': {'class': 'form-control field-prix'}}) }}
                            <div class="error-container error-prix" style="margin-top: 10px;"></div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Visuel Produit *</label>
                            <div class="upload-area" id="uploadZone">
                                <i class="fa-solid fa-cloud-arrow-up"></i>
                                <p style="font-weight:700; color:var(--ch3); margin-bottom:5px;">Téléverser une image</p>
                                <span class="upload-hint">Format recommandé: 800x600 (Max 5MB)</span>
                            </div>
                            <div style="width: 0; height: 0; overflow: hidden;">
                                {{ form_widget(form.photoFile, {'attr': {'class': 'field-photo'}}) }}
                            </div>
                            <div id="previewZone" class="image-preview" style="display:none;">
                                <img id="previewImage" src="" alt="Aperçu">
                                <button type="button" id="btnSupprimer" class="remove-image"><i class="fa-solid fa-trash"></i> Supprimer</button>
                            </div>
                            <div class="error-container error-photo" style="margin-top: 10px;"></div>
                        </div>
                    </div>
                </div>

                <!-- Section stock -->
                <div class="form-section">
                    <div class="section-title">
                        <i class="fa-solid fa-warehouse"></i>
                        <h2>Configuration du Stock</h2>
                        <span class="badge-info">Optionnel</span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Quantité Initiale</label>
                            <input type="text" name="stock_quantite" class="form-control field-stockQuantite" value="0">
                            <div class="error-container error-stockQuantite" style="margin-top: 10px;"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Seuil d'Alerte</label>
                            <input type="text" name="stock_seuil" class="form-control field-stockSeuil" value="0">
                            <div class="error-container error-stockSeuil" style="margin-top: 10px;"></div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Unité de Mesure</label>
                            <select name="stock_unite" class="form-control field-stockUnite">
                                <option value="">Choisir...</option>
                                <option value="kg">Kilogrammes (kg)</option>
                                <option value="g">Grammes (g)</option>
                                <option value="L">Litres (L)</option>
                                <option value="mL">Millilitres (mL)</option>
                                <option value="unité">Unité(s)</option>
                                <option value="sac">Sac(s)</option>
                                <option value="tonne">Tonne(s)</option>
                            </select>
                            <div class="error-container error-stockUnite" style="margin-top: 10px;"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Emplacement Physique</label>
                            <input type="text" name="stock_emplacement" class="form-control field-stockEmplacement" placeholder="Ex: Hangar Sud, Rayon B">
                            <div class="error-container error-stockEmplacement" style="margin-top: 10px;"></div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Date de Réception</label>
                            <input type="date" name="stock_date_reception" class="form-control field-stockDateReception">
                            <div class="error-container error-stockDateReception" style="margin-top: 10px;"></div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Date d'Expiration</label>
                            <input type="date" name="stock_date_expiration" class="form-control field-stockDateExpiration">
                            <div class="error-container error-stockDateExpiration" style="margin-top: 10px;"></div>
                        </div>
                    </div>

                    <div class="info-box">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>Vous pourrez affiner ces paramètres plus tard dans le Hub Intelligence.</span>
                        <a href="{{ path('gerant_stockes') }}">Hub Stock →</a>
                    </div>
                </div>

                <!-- Boutons -->
                <div class="form-actions">
                    <a href="{{ path('front_catalogue') }}" class="hn-btn hn-btn--outline" style="border-radius:12px;">Annuler</a>
                    <button type="submit" class="hn-btn hn-btn--solid" style="border-radius:12px; padding:0 40px;">Publier le Produit</button>
                </div>
            </form>
        </div>

    </div>
</main>

<script>
(function() {
    var form = null, uploadZone = null, previewZone = null, previewImage = null, btnSupprimer = null, fileInput = null, imageSelectionnee = false;

    function trouverChamp(nomChamp) {
        var elements = document.getElementsByClassName('field-' + nomChamp);
        return (elements && elements.length > 0) ? elements[0] : null;
    }

    function trouverErreurContainer(nomChamp) {
        var elements = document.getElementsByClassName('error-' + nomChamp);
        return (elements && elements.length > 0) ? elements[0] : null;
    }

    function afficherErreur(nomChamp, message) {
        var errorDiv = trouverErreurContainer(nomChamp);
        if (errorDiv) {
            errorDiv.innerHTML = '<div style="background:rgba(244,67,54,0.1); color:#f44336; padding:10px 14px; border-radius:10px; font-size:12px; font-weight:700; border-left:4px solid #f44336;">⚠️ ' + message + '</div>';
        }
        var champ = trouverChamp(nomChamp);
        if (champ) champ.style.borderColor = '#f44336';
    }

    function masquerErreur(nomChamp) {
        var errorDiv = trouverErreurContainer(nomChamp);
        if (errorDiv) errorDiv.innerHTML = '';
        var champ = trouverChamp(nomChamp);
        if (champ) champ.style.borderColor = '';
    }

    function masquerToutesErreurs() {
        var champs = ['categorie', 'nom', 'description', 'prix', 'photo', 'stockQuantite', 'stockSeuil', 'stockUnite', 'stockEmplacement', 'stockDateReception', 'stockDateExpiration'];
        for (var i = 0; i < champs.length; i++) masquerErreur(champs[i]);
    }

    function getValeur(nomChamp) { var champ = trouverChamp(nomChamp); return champ ? champ.value : ''; }
    function trim(str) { return str ? str.replace(/^\s+|\s+$/g, '') : ''; }

    function validerFormulaire() {
        var estValide = true;
        var erreurs = [];
        masquerToutesErreurs();

        if (!getValeur('categorie')) { afficherErreur('categorie', 'La catégorie est obligatoire'); erreurs.push('categorie'); estValide = false; }
        var nomVal = trim(getValeur('nom'));
        if (!nomVal) { afficherErreur('nom', 'Le nom est obligatoire'); erreurs.push('nom'); estValide = false; }
        var prixVal = getValeur('prix');
        if (!prixVal || isNaN(parseFloat(prixVal))) { afficherErreur('prix', 'Prix invalide'); erreurs.push('prix'); estValide = false; }
        if (!imageSelectionnee) { afficherErreur('photo', 'Photo obligatoire'); erreurs.push('photo'); estValide = false; }

        if (erreurs.length > 0) {
            var el = trouverErreurContainer(erreurs[0]);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return estValide;
    }

    function initialiser() {
        form = document.getElementById('produitForm');
        uploadZone = document.getElementById('uploadZone');
        previewZone = document.getElementById('previewZone');
        previewImage = document.getElementById('previewImage');
        btnSupprimer = document.getElementById('btnSupprimer');
        fileInput = document.querySelector('input[type="file"]');

        if (!form) return;

        if (uploadZone && fileInput) {
            uploadZone.onclick = function() { fileInput.click(); };
        }

        if (fileInput) {
            fileInput.onchange = function() {
                var fichier = this.files[0];
                if (fichier) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        previewImage.src = e.target.result;
                        previewZone.style.display = 'flex';
                        uploadZone.style.display = 'none';
                        imageSelectionnee = true;
                    };
                    reader.readAsDataURL(fichier);
                    masquerErreur('photo');
                }
            };
        }

        if (btnSupprimer) {
            btnSupprimer.onclick = function() {
                fileInput.value = '';
                previewZone.style.display = 'none';
                uploadZone.style.display = 'flex';
                imageSelectionnee = false;
            };
        }

        form.onsubmit = function(e) { if (!validerFormulaire()) { e.preventDefault(); return false; } return true; };
    }

    initialiser();

    // Theme toggle
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
})();
</script>
{% endblock %}