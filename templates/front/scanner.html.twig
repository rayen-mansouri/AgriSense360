{% extends 'base.html.twig' %}
{% set activePage = 'scanner' %}
{% block title %}Scanner un code-barres — Agrisens 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    /* ── BASE LAYOUT ── */
    body { background-color: var(--pg) !important; font-family: 'Inter', sans-serif !important; }
    .front-main { padding-top: 70px; width: 100%; }
    .front-main-container { max-width: 1000px; margin: 0 auto; padding: 60px 24px; }

    /* ── SCANNER CARD ── */
    .scanner-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        position: relative;
    }
    .scanner-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--g), #a8d060);
    }
    .scanner-header {
        background: linear-gradient(135deg, rgba(90,181,90,0.1) 0%, rgba(10,20,10,0.4) 100%);
        padding: 50px 30px;
        text-align: center;
        border-bottom: 1px solid var(--cbr);
    }
    .scanner-header h1 {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--ch3);
        letter-spacing: -0.04em;
        margin-bottom: 10px;
    }
    .scanner-header p { color: var(--cp); font-size: 1.1rem; }

    .scanner-body { padding: 50px; text-align: center; }
    #scanner-container {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
        border-radius: 20px;
        overflow: hidden;
        border: 4px solid var(--cbr);
        position: relative;
        background: #000;
    }
    #scanner-video { width: 100%; display: block; }
    
    .scanner-controls { margin-top: 40px; display: flex; justify-content: center; gap: 16px; }

    #scan-result { margin-top: 40px; display: none; }
    .result-box {
        background: rgba(90,181,90,0.05);
        border: 1px solid rgba(90,181,90,0.2);
        border-radius: 20px;
        padding: 30px;
        animation: slideUp 0.4s ease;
    }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    
    #scan-message { color: var(--ch3); font-size: 1.1rem; font-weight: 600; margin-bottom: 15px; }
    #scan-link {
        display: inline-block;
        padding: 10px 24px;
        background: var(--g);
        color: #fff;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s;
        box-shadow: 0 10px 20px rgba(90,181,90,0.3);
    }
</style>
{% endblock %}

{% block body %}
<!-- GLOBAL HEADER -->
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">
        <div class="scanner-card">
            <div class="scanner-header">
                <div style="display:inline-flex; align-items:center; gap:10px; background:rgba(90,181,90,0.1); padding:8px 16px; border-radius:50px; margin-bottom:15px; border:1px solid rgba(90,181,90,0.2);">
                    <i class="fa-solid fa-camera" style="color:var(--g);"></i>
                    <span style="color:var(--g); font-size:0.75rem; font-weight:800; text-transform:uppercase;">Vision IA</span>
                </div>
                <h1>Scanner un code-barres</h1>
                <p>Identifiez instantanément vos produits agricoles par simple scan.</p>
            </div>
            
            <div class="scanner-body">
                <div id="scanner-container">
                    <video id="scanner-video"></video>
                </div>
                
                <div class="scanner-controls">
                    <button id="start-scanner" class="hn-btn hn-btn--solid">
                        <i class="fa-solid fa-play" style="margin-right:8px;"></i> Démarrer le scan
                    </button>
                    <button id="stop-scanner" class="hn-btn hn-btn--outline" style="display: none;">
                        <i class="fa-solid fa-stop" style="margin-right:8px;"></i> Arrêter
                    </button>
                </div>
                
                <div id="scan-result">
                    <div class="result-box">
                        <div id="scan-message"></div>
                        <a id="scan-link" href="#">Accéder au produit →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script src="https://unpkg.com/quagga@0.12.1/dist/quagga.min.js"></script>
<script>
const startBtn = document.getElementById('start-scanner');
const stopBtn = document.getElementById('stop-scanner');
const scanResult = document.getElementById('scan-result');
const scanMessage = document.getElementById('scan-message');
const scanLink = document.getElementById('scan-link');

startBtn.addEventListener('click', function() {
    Quagga.init({
        inputStream: { name: "Live", type: "LiveStream", target: document.querySelector('#scanner-container'), constraints: { width: 640, height: 480, facingMode: "environment" } },
        decoder: { readers: ["code_128_reader", "ean_reader", "ean_8_reader"] }
    }, function(err) {
        if (err) { alert("Erreur d'accès à la caméra"); return; }
        Quagga.start();
        startBtn.style.display = 'none';
        stopBtn.style.display = 'inline-block';
    });
    
    Quagga.onDetected(function(data) {
        var code = data.codeResult.code;
        scanMessage.innerHTML = '🔍 Code scanné : <strong>' + code + '</strong><br>Recherche en cours...';
        scanResult.style.display = 'block';
        
        fetch('/api/produit/recherche?code=' + encodeURIComponent(code))
            .then(res => res.json())
            .then(product => {
                if (product.id) {
                    scanMessage.innerHTML = '✅ Produit trouvé : <strong>' + product.nom + '</strong>';
                    scanLink.href = product.url;
                    scanLink.style.display = 'inline-block';
                    Quagga.stop();
                    stopBtn.style.display = 'none';
                    startBtn.style.display = 'inline-block';
                } else {
                    scanMessage.innerHTML = '❌ Produit non trouvé (Code: ' + code + ')';
                    scanLink.style.display = 'none';
                }
            })
            .catch(() => {
                scanMessage.innerHTML = '❌ Erreur lors de la recherche';
                scanLink.style.display = 'none';
            });
    });
});

stopBtn.addEventListener('click', function() {
    Quagga.stop();
    startBtn.style.display = 'inline-block';
    stopBtn.style.display = 'none';
});

// Theme toggle
const html = document.documentElement;
const themeBtn = document.getElementById('themeToggleNav');
if (themeBtn) {
    themeBtn.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
}
</script>
{% endblock %}