{% extends 'layout/front_base.html.twig' %}

{% block title %}Scanner un code-barres - Agrisens 360{% endblock %}

{% block content %}
<div style="max-width: 800px; margin: 40px auto; padding: 20px;">
    <div class="card" style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div style="background: linear-gradient(135deg, #5a9814 0%, #3a6b0a 100%); padding: 30px; color: white; text-align: center;">
            <h1 style="font-size: 28px; margin-bottom: 8px;">📷 Scanner un code-barres</h1>
            <p style="margin: 0;">Utilisez la caméra pour scanner un produit</p>
        </div>
        
        <div style="padding: 30px; text-align: center;">
            <div id="scanner-container" style="width: 100%; max-width: 500px; margin: 0 auto;">
                <video id="scanner-video" style="width: 100%; border-radius: 12px; border: 2px solid #ddd;"></video>
            </div>
            
            <div style="margin-top: 20px;">
                <button id="start-scanner" class="btn btn-primary" style="padding: 10px 24px; background: #5a9814; color: white; border: none; border-radius: 30px; cursor: pointer;">
                    <i class="fa-solid fa-play"></i> Démarrer le scan
                </button>
                <button id="stop-scanner" class="btn btn-secondary" style="display: none; padding: 10px 24px; background: #f0f2f5; color: #333; border: none; border-radius: 30px; cursor: pointer;">
                    <i class="fa-solid fa-stop"></i> Arrêter
                </button>
            </div>
            
            <div id="scan-result" style="margin-top: 20px; display: none;">
                <div style="background: #e8f5e9; border-radius: 12px; padding: 20px;">
                    <div id="scan-message"></div>
                    <a id="scan-link" href="#" style="display: inline-block; margin-top: 10px; color: #5a9814; font-weight: 600;">Voir le produit →</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/quagga@0.12.1/dist/quagga.min.js"></script>
<script>
const startBtn = document.getElementById('start-scanner');
const stopBtn = document.getElementById('stop-scanner');
const scanResult = document.getElementById('scan-result');
const scanMessage = document.getElementById('scan-message');
const scanLink = document.getElementById('scan-link');

startBtn.addEventListener('click', function() {
    Quagga.init({
        inputStream: { name: "Live", type: "LiveStream", target: document.querySelector('#scanner-container'), constraints: { width: 640, height: 480, facingMode: "environment" } },
        decoder: { readers: ["code_128_reader", "ean_reader", "ean_8_reader"] }
    }, function(err) {
        if (err) { alert("Erreur d'accès à la caméra"); return; }
        Quagga.start();
        startBtn.style.display = 'none';
        stopBtn.style.display = 'inline-block';
    });
    
    Quagga.onDetected(function(data) {
        var code = data.codeResult.code;
        scanMessage.innerHTML = '🔍 Code scanné : <strong>' + code + '</strong><br>Recherche en cours...';
        scanResult.style.display = 'block';
        
        fetch('/api/produit/recherche?code=' + encodeURIComponent(code))
            .then(res => res.json())
            .then(product => {
                if (product.id) {
                    scanMessage.innerHTML = '✅ Produit trouvé : <strong>' + product.nom + '</strong>';
                    scanLink.href = product.url;
                    scanLink.style.display = 'inline-block';
                } else {
                    scanMessage.innerHTML = '❌ Produit non trouvé (Code: ' + code + ')';
                    scanLink.style.display = 'none';
                }
            })
            .catch(() => {
                scanMessage.innerHTML = '❌ Erreur lors de la recherche';
                scanLink.style.display = 'none';
            });
    });
});

stopBtn.addEventListener('click', function() {
    Quagga.stop();
    startBtn.style.display = 'inline-block';
    stopBtn.style.display = 'none';
});
</script>
{% endblock %}