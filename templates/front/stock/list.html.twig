{# templates/front/stock/list.html.twig #}
{% extends 'base.html.twig' %}
{% set activePage = 'stock_list' %}
{% block title %}Mes Stocks — Agrisens 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    /* ── BASE LAYOUT ── */
    body {
        background-color: var(--pg) !important;
        font-family: 'Inter', sans-serif !important;
    }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1600px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* ── HEADER AREA ── */
    .stock-header-area {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 20px;
    }
    .page-title {
        font-size: 2.8rem !important;
        font-weight: 900 !important;
        color: var(--ch3) !important;
        letter-spacing: -0.04em;
        margin-bottom: 4px;
    }
    .page-subtitle { color: var(--cp) !important; font-size: 1.1rem; }

    /* ── SUMMARY CARDS ── */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 40px;
    }
    .summary-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 24px;
        padding: 24px;
        text-align: center;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    .summary-card::after {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
    }
    .summary-card.ok::after { background: #4caf50; }
    .summary-card.alerte::after { background: #ff9800; }
    .summary-card.rupture::after { background: #f44336; }
    
    .summary-val {
        font-size: 2.5rem;
        font-weight: 900;
        margin-bottom: 5px;
        line-height: 1;
    }
    .summary-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--cp);
        letter-spacing: 0.05em;
    }

    /* ── STOCK LIST ── */
    .stock-list-container {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 24px;
        overflow: hidden;
    }
    .stock-item {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px 32px;
        border-bottom: 1px solid var(--cbr);
        transition: background 0.2s;
    }
    .stock-item:hover { background: var(--fb); }
    .stock-item:last-child { border-bottom: none; }

    .stock-item-img {
        width: 56px; height: 56px;
        border-radius: 14px;
        overflow: hidden;
        background: var(--fi);
        border: 1px solid var(--cbr);
    }
    .stock-item-img img { width: 100%; height: 100%; object-fit: cover; }

    .stock-item-info { flex: 1; min-width: 0; }
    .stock-item-name { font-weight: 800; font-size: 1.1rem; color: var(--ch3); margin-bottom: 2px; }
    .stock-item-meta { font-size: 0.85rem; color: var(--cp); }

    .stock-item-qty { text-align: center; min-width: 100px; }
    .qty-val { font-size: 1.5rem; font-weight: 900; color: var(--ch3); line-height: 1; }
    .qty-unit { font-size: 0.75rem; color: var(--cp); font-weight: 600; }

    .stock-item-status { min-width: 120px; text-align: center; }
    .status-badge {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .status-ok { background: rgba(76,175,80,0.1); color: #4caf50; }
    .status-alerte { background: rgba(255,152,0,0.1); color: #ff9800; }
    .status-rupture { background: rgba(244,67,54,0.1); color: #f44336; }

    /* ── ACTION BUTTONS ── */
    .btn-action {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .btn-edit { background: rgba(33,150,243,0.1); color: #2196f3; }
    .btn-edit:hover { background: #2196f3; color: white; }
    .btn-view { background: var(--fi); color: var(--cp); }
    .btn-view:hover { background: var(--cp); color: var(--pg); }
    .btn-delete { background: rgba(244,67,54,0.1); color: #f44336; }
    .btn-delete:hover { background: #f44336; color: white; }

    /* ── MODALS ── */
    .modal-content {
        background: var(--cb); 
        backdrop-filter: blur(15px);
        border: 1px solid var(--cbr); border-radius: 32px;
        padding: 40px; max-width: 500px; width: 90%; color: var(--ch3);
        box-shadow: 0 30px 70px rgba(0,0,0,0.5);
        animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalScale {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal-overlay {
        display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); z-index: 9999;
        align-items: center; justify-content: center;
    }
    .modal-overlay.active { display: flex !important; }
</style>
{% endblock %}

{% block body %}
<!-- GLOBAL HEADER -->
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

        <!-- HEADER AREA -->
        <div class="stock-header-area">
            <div>
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                     <i class="fa-solid fa-warehouse" style="color:var(--g); font-size:1.2rem;"></i>
                     <span style="color:var(--g); font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.1em;">Inventaire Global</span>
                </div>
                <h1 class="page-title">Mes Stocks</h1>
                <p class="page-subtitle">{{ stocks|length }} référence(s) en stock</p>
            </div>
            <div style="display:flex; gap:12px;">
                <a href="{{ path('front_catalogue') }}" class="hn-btn hn-btn--outline">
                   <i class="fa-solid fa-arrow-left" style="margin-right:8px;"></i> Catalogue
                </a>
                {% if produitsSansStock is not empty %}
                <button type="button" onclick="ouvrirModalChoixProduit()" class="hn-btn hn-btn--solid">
                    <i class="fa-solid fa-plus" style="margin-right:8px;"></i> Ajouter un stock
                </button>
                {% endif %}
            </div>
        </div>

        <!-- FLASHES -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="background:var(--fi); color:{{ label == 'success' ? 'var(--g)' : 'var(--danger-c)' }}; padding:16px 24px; border-radius:16px; margin-bottom:24px; border-left:4px solid {{ label == 'success' ? 'var(--g)' : 'var(--danger-c)' }}; font-weight:600; display:flex; align-items:center; gap:12px;">
                    <i class="fa-solid {{ label == 'success' ? 'fa-circle-check' : 'fa-circle-exclamation' }}"></i>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if stocks is empty %}
            <div style="text-align:center; padding:100px 40px; background:var(--cb); border:1px solid var(--cbr); border-radius:32px;">
                <i class="fa-solid fa-warehouse" style="font-size:64px; color:var(--cbr); margin-bottom:24px; display:block;"></i>
                <p style="color:var(--cp); font-size:1.2rem; margin-bottom:30px;">Aucun stock enregistré.</p>
                {% if produitsSansStock is not empty %}
                <button type="button" onclick="ouvrirModalChoixProduit()" class="hn-btn hn-btn--solid">
                    <i class="fa-solid fa-plus" style="margin-right:8px;"></i> Ajouter mon premier stock
                </button>
                {% endif %}
            </div>
        {% else %}

            <!-- SUMMARY -->
            <div class="summary-grid">
                {% set enAlerte = stocks|filter(s => s.isEnAlerte and s.quantiteActuelle > 0)|length %}
                {% set enRupture = stocks|filter(s => s.quantiteActuelle == 0)|length %}
                {% set ok = stocks|length - enAlerte - enRupture %}
                <div class="summary-card ok">
                    <div class="summary-val" style="color:#4caf50;">{{ ok }}</div>
                    <div class="summary-label">En stock optimal</div>
                </div>
                <div class="summary-card alerte">
                    <div class="summary-val" style="color:#ff9800;">{{ enAlerte }}</div>
                    <div class="summary-label">Seuil d'alerte atteint</div>
                </div>
                <div class="summary-card rupture">
                    <div class="summary-val" style="color:#f44336;">{{ enRupture }}</div>
                    <div class="summary-label">Rupture de stock</div>
                </div>
            </div>

            <!-- INFO BANNER FOR UNREGISTERED STOCKS -->
            {% if produitsSansStock is not empty %}
            <div style="background:rgba(255,152,0,0.05); border:1px solid rgba(255,152,0,0.2); border-radius:16px; padding:16px 24px; margin-bottom:32px; display:flex; align-items:center; justify-content:space-between; gap:20px;">
                <div style="display:flex; align-items:center; gap:12px;">
                    <i class="fa-solid fa-triangle-exclamation" style="color:#ff9800; font-size:20px;"></i>
                    <span style="color:var(--ch3); font-weight:600;">
                        {{ produitsSansStock|length }} produit(s) n'ont pas encore de stock configuré.
                    </span>
                </div>
                <button type="button" onclick="ouvrirModalChoixProduit()" class="hn-btn hn-btn--outline" style="padding:6px 20px; font-size:0.8rem;">
                    Configurer
                </button>
            </div>
            {% endif %}

            <!-- LIST -->
            <div class="stock-list-container">
                {% for stock in stocks %}
                {% set produit = stock.produit %}
                <div class="stock-item">
                    <div class="stock-item-img">
                        {% if produit.photoUrl %}<img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}">
                        {% else %}<div style="display:flex; align-items:center; justify-content:center; height:100%; color:var(--g);"><i class="fa-solid fa-leaf"></i></div>{% endif %}
                    </div>
                    <div class="stock-item-info">
                        <div class="stock-item-name">{{ produit.nom }}</div>
                        <div class="stock-item-meta">{{ produit.categorie }} • {{ produit.prixUnitaire }} DT/u</div>
                    </div>
                    <div class="stock-item-qty">
                        <div class="qty-val">{{ stock.quantiteActuelle }}</div>
                        <div class="qty-unit">{{ stock.uniteMesure }}</div>
                    </div>
                    <div style="text-align:center; min-width:80px;">
                        <div style="font-size:0.7rem; color:var(--cp); font-weight:700; text-transform:uppercase;">Seuil</div>
                        <div style="font-weight:800; color:var(--ch3);">{{ stock.seuilAlerte ?: '—' }}</div>
                    </div>
                    <div class="stock-item-status">
                        {% if stock.quantiteActuelle == 0 %}
                            <span class="status-badge status-rupture">Rupture</span>
                        {% elseif stock.isEnAlerte %}
                            <span class="status-badge status-alerte">Alerte</span>
                        {% else %}
                            <span class="status-badge status-ok">Optimal</span>
                        {% endif %}
                    </div>
                    <div style="text-align:center; min-width:100px;">
                        {% if stock.dateExpiration %}
                            <div style="font-size:0.7rem; color:var(--cp); font-weight:700;">EXPIRATION</div>
                            <div style="font-size:0.85rem; font-weight:700; color:#f44336;">{{ stock.dateExpiration|date('d/m/Y') }}</div>
                        {% endif %}
                    </div>
                    <div style="display:flex; gap:10px;">
                        <a href="{{ path('front_stock_edit', {id: stock.id}) }}" class="btn-action btn-edit" title="Modifier le stock">
                            <i class="fa-solid fa-pen"></i>
                        </a>
                        <a href="{{ path('front_produit_show', {id: produit.id}) }}" class="btn-action btn-view" title="Voir le produit">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <button type="button" class="btn-action btn-delete" title="Supprimer le stock" 
                            onclick="confirmerSuppStock('{{ stock.id }}', '{{ produit.nom|e('js') }}', {{ stock.quantiteActuelle }}, '{{ stock.uniteMesure }}')">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</main>

<!-- MODALS -->
<div id="modalChoixProduit" class="modal-overlay">
    <div class="modal-content" style="max-height:85vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
            <h3 style="margin:0; font-size:1.5rem; font-weight:800; letter-spacing:-0.02em;">Nouveau Stock</h3>
            <button onclick="fermerModalChoix()" style="background:none; border:none; color:var(--cp); cursor:pointer; font-size:1.5rem;">&times;</button>
        </div>
        <div style="position:relative; margin-bottom:24px;">
            <i class="fa-solid fa-magnifying-glass" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:var(--cp);"></i>
            <input type="text" id="rechercherProduit" placeholder="Rechercher un produit..." 
                style="width:100%; padding:14px 14px 14px 44px; background:var(--fi); border:1px solid var(--cbr); border-radius:14px; color:var(--ch3); outline:none;"
                onkeyup="filtrerProduits()">
        </div>
        <div id="listeProduits" style="display:flex; flex-direction:column; gap:10px;">
            {% for produit in produitsSansStock %}
            <a href="{{ path('front_stock_new', {id: produit.id}) }}" class="produit-item" data-nom="{{ produit.nom|lower }}"
               style="display:flex; align-items:center; gap:16px; padding:14px; border:1px solid var(--cbr); border-radius:16px; text-decoration:none; color:inherit; transition:all 0.2s;">
                <div style="width:44px; height:44px; border-radius:10px; overflow:hidden; background:var(--fi);">
                    {% if produit.photoUrl %}<img src="{{ asset(produit.photoUrl) }}" style="width:100%; height:100%; object-fit:cover;">
                    {% else %}<div style="display:flex; align-items:center; justify-content:center; height:100%; color:var(--g);"><i class="fa-solid fa-leaf"></i></div>{% endif %}
                </div>
                <div style="flex:1;">
                    <div style="font-weight:700; color:var(--ch3);">{{ produit.nom }}</div>
                    <div style="font-size:0.75rem; color:var(--cp);">{{ produit.categorie }}</div>
                </div>
                <i class="fa-solid fa-plus" style="color:var(--g);"></i>
            </a>
            {% endfor %}
        </div>
    </div>
</div>

<div id="modalSuppStock" class="modal-overlay">
    <div class="modal-content" style="text-align:center;">
        <div style="width:70px; height:70px; background:rgba(244,67,54,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:32px; color:#f44336;">
            <i class="fa-solid fa-warehouse"></i>
        </div>
        <h3 style="margin:0 0 12px; font-size:24px; font-weight:800;">Supprimer ce stock ?</h3>
        <p id="modalStockInfo" style="color:var(--cp); margin-bottom:24px; font-size:1.1rem;"></p>
        <div style="display:flex; gap:16px; justify-content:center;">
            <button onclick="fermerModalSupp()" class="hn-btn hn-btn--outline" style="border-radius:12px;">Annuler</button>
            <button id="btnConfirmerSuppStock" class="hn-btn hn-btn--solid" style="background:#f44336; border-radius:12px;">Supprimer</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    var stockIdASupprimer = null;

    function ouvrirModalChoixProduit() { document.getElementById('modalChoixProduit').classList.add('active'); }
    function fermerModalChoix() { document.getElementById('modalChoixProduit').classList.remove('active'); }

    function filtrerProduits() {
        var input = document.getElementById('rechercherProduit');
        var filtre = input.value.toLowerCase();
        var items = document.getElementsByClassName('produit-item');
        for (var i = 0; i < items.length; i++) {
            var nom = items[i].getAttribute('data-nom');
            items[i].style.display = nom.includes(filtre) ? 'flex' : 'none';
        }
    }

    function confirmerSuppStock(id, nomProduit, quantite, unite) {
        stockIdASupprimer = id;
        document.getElementById('modalStockInfo').innerHTML = 'Stock : <strong>' + nomProduit + '</strong> (' + quantite + ' ' + unite + ')';
        document.getElementById('modalSuppStock').classList.add('active');
    }

    function fermerModalSupp() { document.getElementById('modalSuppStock').classList.remove('active'); }

    document.getElementById('btnConfirmerSuppStock').onclick = function() {
        if (stockIdASupprimer) {
            document.getElementById('form-del-stock-' + stockIdASupprimer).submit();
        }
    };

    // Close modals on overlay click
    window.onclick = function(e) {
        if (e.target.classList.contains('modal-overlay')) {
            fermerModalChoix();
            fermerModalSupp();
        }
        if (!e.target.closest('.gerant-profile')) {
            const drop = document.getElementById('gerant-dropdown-nav');
            if (drop) drop.classList.remove('show');
        }
    };

    // Theme toggle
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endblock %}