{% extends 'base.html.twig' %}

{% set activePage = 'affectations' %}
{% set activeSection = 'main' %}

{% block title %}Affectations — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }

    /* Table Styling */
    .table-container { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; box-shadow: var(--sh-lg); overflow: hidden; }
    .premium-table { width: 100%; border-collapse: collapse; }
    .premium-table th { padding: 20px 25px; text-align: left; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--cp); border-bottom: 1px solid var(--cbr); background: rgba(0,0,0,0.05); }
    .premium-table td { padding: 20px 25px; border-bottom: 1px solid var(--cbr); color: var(--ch3); font-weight: 600; font-size: 0.95rem; }
    .premium-table tr:last-child td { border-bottom: none; }
    .premium-table tbody tr:hover td { background: rgba(90,181,90,0.03); }

    .status-badge { padding: 6px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; display: inline-flex; align-items: center; gap: 6px; }
    .status-active { background: rgba(76,175,80,0.1); color: #4CAF50; border: 1px solid rgba(76,175,80,0.2); }

    .empty-state { padding: 100px 40px; text-align: center; color: var(--cp); }
    .empty-icon { font-size: 4rem; margin-bottom: 20px; opacity: 0.3; }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">🤝 Affectations des Ouvriers</h1>
        <p class="page-subtitle">Gérez l'affectation des ouvriers aux parcelles et tâches agricoles.</p>
    </div>
</div>

<div class="table-container">
    <table class="premium-table">
        <thead>
            <tr>
                <th>Ouvrier</th>
                <th>Parcelle</th>
                <th>Tâche</th>
                <th>Date Début</th>
                <th>Date Fin</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {# Mock data or loop if available in future #}
            <tr>
                <td colspan="6">
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <h3 style="margin:0; font-size:1.2rem; color:var(--ch3);">Aucune affectation enregistrée</h3>
                        <p style="margin:10px 0 0 0;">Les missions assignées apparaîtront ici.</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>

    </div>
</main>

<script>
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
</script>
{% endblock %}
