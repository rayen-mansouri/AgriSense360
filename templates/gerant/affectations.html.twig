{% extends 'base.html.twig' %}
{% set activePage = 'affectations' %}
{% set activeSection = 'main' %}

{% block title %}Affectations — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .affectations-container {
        padding: 2rem;
    }
    .affectations-header {
        margin-bottom: 2rem;
    }
    .affectations-header h1 {
        color: var(--ch3);
        font-size: 1.875rem;
        margin-bottom: 0.5rem;
    }
    .affectations-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 8px;
        overflow: hidden;
        color: var(--pc);
    }
    .affectations-table thead {
        background: var(--cbr);
        color: var(--ch3);
    }
    .affectations-table th {
        padding: 1rem;
        text-align: left;
        font-weight: 600;
        border-right: 1px solid var(--cbr);
    }
    .affectations-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--cbr);
        border-right: 1px solid var(--cbr);
    }
    .affectations-table tr:hover {
        background: var(--ch1);
    }
    .empty-state {
        padding: 2rem;
        text-align: center;
        color: var(--ch2);
    }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="affectations-container">
            <div class="affectations-header">
                <h1>Affectations des Ouvriers</h1>
                <p>Gérez l'affectation des ouvriers aux parcelles et tâches agricoles.</p>
            </div>

            <table class="affectations-table">
                <thead>
                    <tr>
                        <th>Ouvrier</th>
                        <th>Parcelle</th>
                        <th>Tâche</th>
                        <th>Date Début</th>
                        <th>Date Fin</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="empty-state">
                            Aucune affectation enregistrée
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</div>

<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.querySelector('.main');
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
    });
    const saved = localStorage.getItem('agri-theme') || 'dark';
    document.documentElement.setAttribute('data-theme', saved);
    document.getElementById('themeToggle')?.addEventListener('click', function() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
