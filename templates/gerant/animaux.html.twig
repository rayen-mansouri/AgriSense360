{% extends 'base.html.twig' %}
{% set activePage = 'animaux' %}
{% set activeSection = 'main' %}

{% block title %}Animaux — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .animaux-container {
        padding: 2rem;
    }
    .animaux-header {
        margin-bottom: 2rem;
    }
    .animaux-header h1 {
        color: var(--ch3);
        font-size: 1.875rem;
        margin-bottom: 0.5rem;
    }
    .animaux-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }
    .animal-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 8px;
        padding: 1.5rem;
        color: var(--pc);
    }
    .animal-card h3 {
        color: var(--ch3);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .animal-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 1rem;
    }
    .badge-active {
        background: rgba(72, 187, 120, 0.2);
        color: #48bb78;
    }
    .badge-breeding {
        background: rgba(66, 153, 225, 0.2);
        color: #4299e1;
    }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="animaux-container">
            <div class="animaux-header">
                <h1>Gestion des Animaux</h1>
                <p>Suivez votre bétail, volailles et autres animaux d'élevage.</p>
            </div>

            <div class="animaux-list">
                <div class="animal-card">
                    <h3>🐄 Bovins</h3>
                    <p>Nombre total: 0 têtes</p>
                    <p>Pâturage: N/A</p>
                    <span class="animal-badge badge-active">Actif</span>
                </div>
                <div class="animal-card">
                    <h3>🐑 Ovins</h3>
                    <p>Nombre total: 0 têtes</p>
                    <p>État du troupeau: N/A</p>
                    <span class="animal-badge badge-active">Actif</span>
                </div>
                <div class="animal-card">
                    <h3>🐔 Volailles</h3>
                    <p>Nombre total: 0 têtes</p>
                    <p>Production: N/A</p>
                    <span class="animal-badge badge-breeding">Reproduction</span>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.querySelector('.main');
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
    });
    const saved = localStorage.getItem('agri-theme') || 'dark';
    document.documentElement.setAttribute('data-theme', saved);
    document.getElementById('themeToggle')?.addEventListener('click', function() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
