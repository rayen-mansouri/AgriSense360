{% extends 'base.html.twig' %}

{% set activePage = 'animaux' %}
{% set activeSection = 'main' %}

{% block title %}Animaux — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }

    /* Grid Layout */
    .animaux-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; }

    .animal-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; padding: 30px; box-shadow: var(--sh-lg); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; gap: 15px; }
    .animal-card:hover { transform: translateY(-8px); border-color: var(--g); box-shadow: 0 15px 35px rgba(0,0,0,0.3); }

    .animal-header { display: flex; align-items: center; gap: 15px; margin-bottom: 5px; }
    .animal-icon { width: 60px; height: 60px; border-radius: 18px; background: rgba(90,181,90,0.1); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--g); }
    .animal-name { font-size: 1.4rem; font-weight: 800; color: var(--ch3); margin: 0; }

    .animal-stats { display: flex; flex-direction: column; gap: 10px; }
    .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--cbr); }
    .stat-row:last-child { border-bottom: none; }
    .stat-label { font-size: 0.85rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-value { font-size: 1rem; font-weight: 800; color: var(--ch3); }

    .animal-badge { align-self: flex-start; padding: 6px 16px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-top: 10px; }
    .badge-active { background: rgba(76,175,80,0.1); color: #4CAF50; border: 1px solid rgba(76,175,80,0.2); }
    .badge-breeding { background: rgba(33,150,243,0.1); color: #2196F3; border: 1px solid rgba(33,150,243,0.2); }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">🐾 Gestion des Animaux</h1>
        <p class="page-subtitle">Suivez votre bétail, volailles et autres animaux d'élevage.</p>
    </div>
</div>

<div class="animaux-grid">
    <div class="animal-card">
        <div class="animal-header">
            <div class="animal-icon">🐄</div>
            <h3 class="animal-name">Bovins</h3>
        </div>
        <div class="animal-stats">
            <div class="stat-row">
                <span class="stat-label">Nombre total</span>
                <span class="stat-value">0 têtes</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Pâturage</span>
                <span class="stat-value">N/A</span>
            </div>
        </div>
        <span class="animal-badge badge-active">🟢 Actif</span>
    </div>

    <div class="animal-card">
        <div class="animal-header">
            <div class="animal-icon">🐑</div>
            <h3 class="animal-name">Ovins</h3>
        </div>
        <div class="animal-stats">
            <div class="stat-row">
                <span class="stat-label">Nombre total</span>
                <span class="stat-value">0 têtes</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">État du troupeau</span>
                <span class="stat-value">N/A</span>
            </div>
        </div>
        <span class="animal-badge badge-active">🟢 Actif</span>
    </div>

    <div class="animal-card">
        <div class="animal-header">
            <div class="animal-icon">🐔</div>
            <h3 class="animal-name">Volailles</h3>
        </div>
        <div class="animal-stats">
            <div class="stat-row">
                <span class="stat-label">Nombre total</span>
                <span class="stat-value">0 têtes</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Production</span>
                <span class="stat-value">N/A</span>
            </div>
        </div>
        <span class="animal-badge badge-breeding">🔵 Reproduction</span>
    </div>
</div>

    </div>
</main>

<script>
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
</script>
{% endblock %}
