{% extends 'base.html.twig' %}

{% set activePage = 'equipements' %}
{% set activeSection = 'main' %}

{% block title %}Équipements — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }

    /* Grid Layout */
    .equipements-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; }

    .equipement-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; padding: 30px; box-shadow: var(--sh-lg); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; gap: 15px; }
    .equipement-card:hover { transform: translateY(-8px); border-color: var(--g); box-shadow: 0 15px 35px rgba(0,0,0,0.3); }

    .equipement-header { display: flex; align-items: center; gap: 15px; margin-bottom: 5px; }
    .equipement-icon { width: 60px; height: 60px; border-radius: 18px; background: rgba(90,181,90,0.1); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: var(--g); }
    .equipement-name { font-size: 1.4rem; font-weight: 800; color: var(--ch3); margin: 0; letter-spacing: -0.5px; }

    .equipement-details { display: flex; flex-direction: column; gap: 10px; }
    .detail-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--cbr); }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-size: 0.85rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: 0.5px; }
    .detail-value { font-size: 1rem; font-weight: 800; color: var(--ch3); }

    .status-badge { align-self: flex-start; padding: 6px 16px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; margin-top: 10px; }
    .status-operational { background: rgba(76,175,80,0.1); color: #4CAF50; border: 1px solid rgba(76,175,80,0.2); }
    .status-maintenance { background: rgba(255,152,0,0.1); color: #FF9800; border: 1px solid rgba(255,152,0,0.2); }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">🚜 Gestion des Équipements</h1>
        <p class="page-subtitle">Suivez l'état et l'entretien de vos équipements agricoles.</p>
    </div>
</div>

<div class="equipements-grid">
    <div class="equipement-card">
        <div class="equipement-header">
            <div class="equipement-icon"><i class="fa-solid fa-tractor"></i></div>
            <h3 class="equipement-name">Tracteur Principal</h3>
        </div>
        <div class="equipement-details">
            <div class="detail-row"><span class="detail-label">Marque & Modèle</span><span class="detail-value">N/A</span></div>
            <div class="detail-row"><span class="detail-label">Heures d'utilisation</span><span class="detail-value">0 h</span></div>
        </div>
        <span class="status-badge status-operational">🟢 Opérationnel</span>
    </div>

    <div class="equipement-card">
        <div class="equipement-header">
            <div class="equipement-icon"><i class="fa-solid fa-shredder"></i></div>
            <h3 class="equipement-name">Charrue</h3>
        </div>
        <div class="equipement-details">
            <div class="detail-row"><span class="detail-label">État</span><span class="detail-value">N/A</span></div>
            <div class="detail-row"><span class="detail-label">Dernière maintenance</span><span class="detail-value">N/A</span></div>
        </div>
        <span class="status-badge status-maintenance">🟠 En maintenance</span>
    </div>

    <div class="equipement-card">
        <div class="equipement-header">
            <div class="equipement-icon"><i class="fa-solid fa-seedling"></i></div>
            <h3 class="equipement-name">Semoir</h3>
        </div>
        <div class="equipement-details">
            <div class="detail-row"><span class="detail-label">État</span><span class="detail-value">N/A</span></div>
            <div class="detail-row"><span class="detail-label">Dernière utilisation</span><span class="detail-value">N/A</span></div>
        </div>
        <span class="status-badge status-operational">🟢 Opérationnel</span>
    </div>
</div>

    </div>
</main>

<script>
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
</script>
{% endblock %}
