{% extends 'base.html.twig' %}
{% set activePage = 'equipements' %}
{% set activeSection = 'main' %}

{% block title %}Équipements — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .equipements-container {
        padding: 2rem;
    }
    .equipements-header {
        margin-bottom: 2rem;
    }
    .equipements-header h1 {
        color: var(--ch3);
        font-size: 1.875rem;
        margin-bottom: 0.5rem;
    }
    .equipements-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }
    .equipement-card {
        background: var(--cb);
        border: 1px solid var(--cbr);
        border-radius: 8px;
        padding: 1.5rem;
        color: var(--pc);
    }
    .equipement-card h3 {
        color: var(--ch3);
        margin-bottom: 1rem;
    }
    .equipement-status {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        font-size: 0.875rem;
        margin-top: 1rem;
    }
    .status-operational {
        background: rgba(72, 187, 120, 0.2);
        color: #48bb78;
    }
    .status-maintenance {
        background: rgba(237, 137, 54, 0.2);
        color: #ed8936;
    }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="equipements-container">
            <div class="equipements-header">
                <h1>Gestion des Équipements</h1>
                <p>Suivez l'état et l'entretien de vos équipements agricoles.</p>
            </div>

            <div class="equipements-list">
                <div class="equipement-card">
                    <h3>Tracteur Principal</h3>
                    <p>Marque & Modèle: N/A</p>
                    <p>Heures d'utilisation: 0 h</p>
                    <span class="equipement-status status-operational">Opérationnel</span>
                </div>
                <div class="equipement-card">
                    <h3>Charrue</h3>
                    <p>État: N/A</p>
                    <p>Dernière maintenance: N/A</p>
                    <span class="equipement-status status-maintenance">En maintenance</span>
                </div>
                <div class="equipement-card">
                    <h3>Semoir</h3>
                    <p>État: N/A</p>
                    <p>Dernière utilisation: N/A</p>
                    <span class="equipement-status status-operational">Opérationnel</span>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.querySelector('.main');
    document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
    });
    const saved = localStorage.getItem('agri-theme') || 'dark';
    document.documentElement.setAttribute('data-theme', saved);
    document.getElementById('themeToggle')?.addEventListener('click', function() {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
