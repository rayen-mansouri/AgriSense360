{% extends 'base.html.twig' %}

{% block title %}{{ user.name }} — Détails ouvrier{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
    :root {
        --pg: #0a0f0a; --pc: #e8f5e4;
        --s1: #0d1a0d; --s2: #0a0f0a;
        --cb: rgba(255,255,255,.04); --cbr: rgba(255,255,255,.08);
        --ch3: #fff; --cp: rgba(232,245,228,.55);
        --g: #5ab55a; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #060a06;
        --sidebar-border: rgba(255,255,255,.05);
        --danger: #f87171; --danger-bg: rgba(248,113,113,.1);
        --indigo: #818cf8; --indigo-bg: rgba(129,140,248,.1);
    }
    [data-theme="light"] {
        --pg: #f0f7ee; --pc: #1a3a1a;
        --s1: #e8f5e4; --s2: #f0f7ee;
        --cb: rgba(255,255,255,.85); --cbr: rgba(0,0,0,.07);
        --ch3: #1a3a1a; --cp: #4a6741;
        --g: #3e8e3e; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #ffffff;
        --sidebar-border: rgba(0,0,0,.08);
        --danger: #dc2626; --danger-bg: rgba(220,38,38,.1);
        --indigo: #4338ca; --indigo-bg: rgba(67,56,202,.1);
    }

    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* Sidebar */
    .sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); display: flex; flex-direction: column; transition: transform .3s ease, width .3s ease; position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; }
    .sidebar.collapsed { transform: translateX(-100%); }
    .sidebar-header { padding: 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--sidebar-border); }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ch3); font-weight: 800; font-size: 1.1rem; }
    .sidebar-brand img { width: 32px; height: 32px; object-fit: contain; }
    .sidebar-nav { padding: 20px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .sidebar-link { padding: 12px 16px; display: flex; align-items: center; gap: 12px; color: var(--cp); text-decoration: none; font-weight: 600; font-size: .95rem; border-radius: 10px; transition: all .2s; }
    .sidebar-link:hover, .sidebar-link.active { background: rgba(90,181,90,.1); color: var(--g); }
    .sidebar-footer { padding: 20px; border-top: 1px solid var(--sidebar-border); }

    .theme-toggle { background: none; border: none; color: var(--cp); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 8px; border-radius: 8px; transition: all .2s; }
    .theme-toggle:hover { background: rgba(255,255,255,.05); color: var(--ch3); }
    [data-theme="light"] .theme-toggle:hover { background: rgba(0,0,0,.05); }
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="light"] .icon-sun { display: none; }

    /* Main Content */
    .main-content { flex: 1; margin-left: 260px; transition: margin-left .3s ease; display: flex; flex-direction: column; min-height: 100vh; }
    .main-content.expanded { margin-left: 0; }

    .topbar { height: 70px; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(var(--sidebar-bg), .8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--sidebar-border); position: sticky; top: 0; z-index: 90; }
    .sidebar-toggle { background: none; border: none; color: var(--ch3); cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 8px; }
    .sidebar-toggle span { display: block; width: 24px; height: 2px; background: currentColor; border-radius: 2px; }

    .content-wrapper { padding: 32px; max-width: 1200px; margin: 0 auto; width: 100%; }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; overflow: hidden; }
    .card-head { padding: 24px 32px; border-bottom: 1px solid var(--cbr); display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,.02); }
    [data-theme="light"] .card-head { background: rgba(0,0,0,.01); }
    .card-title { font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--ch3); display: flex; align-items: center; gap: 12px; }
    .card-body { padding: 32px; }

    .btn-pale { color: var(--cp); text-decoration: none; font-size: .9rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 50px; border: 1px solid var(--cbr); transition: all .2s; }
    .btn-pale:hover { background: var(--cbr); color: var(--ch3); }
    
    .btn-red { background: var(--danger-bg); color: var(--danger); font-size: .9rem; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 50px; border: none; transition: all .2s; cursor: pointer; }
    .btn-red:hover { opacity: .8; }

    .badge-orange { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 700; background: rgba(245,158,11,.1); color: #f59e0b; padding: 4px 10px; border-radius: 50px; }

    @media (max-width: 768px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .main-content { margin-left: 0; }
    }
</style>
{% endblock %}

{% block body %}
<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('app_index') }}" class="sidebar-brand">
            <img src="{{ asset('images/logo.png') }}" alt="Logo">
            AgriSense 360
        </a>
    </div>
    <div class="sidebar-nav">
        <a href="{{ path('gerant_home') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Tableau de bord
        </a>
        <a href="{{ path('gerant_ouvriers') }}" class="sidebar-link active">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Ouvriers
        </a>
    </div>
    <div class="sidebar-footer">
        <a href="{{ path('profile_show') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Mon Profil
        </a>
        <a href="{{ path('app_logout') }}" class="sidebar-link" style="color: var(--danger);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Déconnexion
        </a>
    </div>
</div>

<main class="main-content" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>

    <div class="content-wrapper">
        <div style="display:flex; align-items:center; gap:8px; font-size:.8rem; color:var(--cp); margin-bottom:20px;">
            <a href="{{ path('gerant_ouvriers') }}" style="color:var(--g); text-decoration:none; font-weight:600;">👷 Ouvriers</a>
            <span>›</span><span>{{ user.name }}</span>
        </div>

        <div style="display:grid;grid-template-columns:280px 1fr;gap:24px;align-items:start;">
            <!-- Left -->
            <div class="card">
                <div style="padding:32px 24px;text-align:center;">
                    <div style="width:90px;height:90px;border-radius:50%;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;font-weight:800;color:#fff;background:linear-gradient(135deg,var(--gd),var(--g));overflow:hidden;">
                        {% if user.profilePicture %}
                            <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" alt="Photo" style="width:100%;height:100%;object-fit:cover;">
                        {% else %}
                            {{ user.name|first|upper }}
                        {% endif %}
                    </div>
                    <div style="font-size:1.2rem;font-weight:800;margin-bottom:4px;color:var(--ch3);">{{ user.name }}</div>
                    <div style="font-size:.85rem;color:var(--cp);margin-bottom:14px;">{{ user.email }}</div>
                    <span class="badge-orange">Ouvrier</span>

                    <hr style="border:none;border-top:1px solid var(--cbr);margin:20px 0;">

                    <div style="display:flex;justify-content:space-between;font-size:.85rem;color:var(--cp);margin-bottom:10px;">
                        <span>Statut</span>
                        <strong style="{{ user.status == 'active' ? 'color:var(--g)' : 'color:var(--danger)' }}">
                            {{ user.status == 'active' ? '✓ Actif' : '✗ Bloqué' }}
                        </strong>
                    </div>
                    {% if user.phone %}
                    <div style="display:flex;justify-content:space-between;font-size:.85rem;color:var(--cp);margin-bottom:10px;">
                        <span>📞 Téléphone</span><strong style="color:var(--ch3);">{{ user.phone }}</strong>
                    </div>
                    {% endif %}
                    <div style="display:flex;justify-content:space-between;font-size:.85rem;color:var(--cp);margin-bottom:10px;">
                        <span>Membre depuis</span>
                        <strong style="color:var(--ch3);">{{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}</strong>
                    </div>
                </div>
            </div>

            <!-- Right -->
            <div class="card">
                <div class="card-head">
                    <span class="card-title">📋 Informations de l'ouvrier</span>
                    <span class="badge-orange">Lecture seule</span>
                </div>
                <div class="card-body">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
                        <div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cp);margin-bottom:6px;">Nom complet</div>
                            <div style="padding:12px 16px;border:1px solid var(--cbr);border-radius:12px;font-size:.9rem;color:var(--ch3);background:var(--cb);">{{ user.name }}</div>
                        </div>
                        <div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cp);margin-bottom:6px;">Adresse email</div>
                            <div style="padding:12px 16px;border:1px solid var(--cbr);border-radius:12px;font-size:.9rem;color:var(--ch3);background:var(--cb);">{{ user.email }}</div>
                        </div>
                        <div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cp);margin-bottom:6px;">Téléphone</div>
                            <div style="padding:12px 16px;border:1px solid var(--cbr);border-radius:12px;font-size:.9rem;color:var(--ch3);background:var(--cb);">{{ user.phone ?? '—' }}</div>
                        </div>
                        <div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cp);margin-bottom:6px;">Statut</div>
                            <div style="padding:12px 16px;border:1px solid var(--cbr);border-radius:12px;font-size:.9rem;color:var(--ch3);background:var(--cb);">
                                {{ user.status == 'active' ? '✓ Actif' : '✗ Bloqué' }}
                            </div>
                        </div>
                    </div>

                    {% if user.profilePicture %}
                    <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--cbr);">
                        <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cp);margin-bottom:12px;">Photo de profil</div>
                        <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" alt="Photo de profil"
                             style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--cbr);">
                    </div>
                    {% endif %}
                </div>

                <div style="display:flex;gap:12px;padding:20px 32px;border-top:1px solid var(--cbr);background:rgba(0,0,0,.01);">
                    <a href="{{ path('gerant_ouvriers') }}" class="btn-pale">← Retour à la liste</a>
                    <form method="post" action="{{ path('gerant_ouvrier_delete', {id: user.id}) }}"
                          onsubmit="return confirm('Supprimer définitivement cet ouvrier ?');"
                          style="margin-left:auto;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn-red">🗑 Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('open');
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        }
    });

    // Theme toggle — persist preference
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);

    document.getElementById('themeToggle').addEventListener('click', function () {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
