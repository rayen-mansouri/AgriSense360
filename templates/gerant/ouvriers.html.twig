{% extends 'base.html.twig' %}

{% block title %}Gestion des Ouvriers — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700&display=swap" rel="stylesheet">
<style>
    :root {
        --pg: #0a0f0a; --pc: #e8f5e4;
        --s1: #0d1a0d; --s2: #0a0f0a;
        --cb: rgba(255,255,255,.04); --cbr: rgba(255,255,255,.08);
        --ch3: #fff; --cp: rgba(232,245,228,.55);
        --g: #5ab55a; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #060a06;
        --sidebar-border: rgba(255,255,255,.05);
        --danger: #f87171; --danger-bg: rgba(248,113,113,.1);
        --indigo: #818cf8; --indigo-bg: rgba(129,140,248,.1);
    }
    [data-theme="light"] {
        --pg: #f0f7ee; --pc: #1a3a1a;
        --s1: #e8f5e4; --s2: #f0f7ee;
        --cb: rgba(255,255,255,.85); --cbr: rgba(0,0,0,.07);
        --ch3: #1a3a1a; --cp: #4a6741;
        --g: #3e8e3e; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #ffffff;
        --sidebar-border: rgba(0,0,0,.08);
        --danger: #dc2626; --danger-bg: rgba(220,38,38,.1);
        --indigo: #4338ca; --indigo-bg: rgba(67,56,202,.1);
    }

    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* Sidebar */
    .sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); display: flex; flex-direction: column; transition: transform .3s ease, width .3s ease; position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; }
    .sidebar.collapsed { transform: translateX(-100%); }
    .sidebar-header { padding: 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--sidebar-border); }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ch3); font-weight: 800; font-size: 1.1rem; }
    .sidebar-brand img { width: 32px; height: 32px; object-fit: contain; }
    .sidebar-nav { padding: 20px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .sidebar-link { padding: 12px 16px; display: flex; align-items: center; gap: 12px; color: var(--cp); text-decoration: none; font-weight: 600; font-size: .95rem; border-radius: 10px; transition: all .2s; }
    .sidebar-link:hover, .sidebar-link.active { background: rgba(90,181,90,.1); color: var(--g); }
    .sidebar-footer { padding: 20px; border-top: 1px solid var(--sidebar-border); }

    .theme-toggle { background: none; border: none; color: var(--cp); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 8px; border-radius: 8px; transition: all .2s; }
    .theme-toggle:hover { background: rgba(255,255,255,.05); color: var(--ch3); }
    [data-theme="light"] .theme-toggle:hover { background: rgba(0,0,0,.05); }
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="light"] .icon-sun { display: none; }

    /* Main Content */
    .main-content { flex: 1; margin-left: 260px; transition: margin-left .3s ease; display: flex; flex-direction: column; min-height: 100vh; }
    .main-content.expanded { margin-left: 0; }

    .topbar { height: 70px; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(var(--sidebar-bg), .8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--sidebar-border); position: sticky; top: 0; z-index: 90; }
    .sidebar-toggle { background: none; border: none; color: var(--ch3); cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 8px; }
    .sidebar-toggle span { display: block; width: 24px; height: 2px; background: currentColor; border-radius: 2px; }

    .content-wrapper { padding: 32px; max-width: 1200px; margin: 0 auto; width: 100%; }

    /* Page Header */
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px; }
    .page-header h1 { font-family: 'Fraunces', serif; font-size: 2rem; color: var(--ch3); margin: 0 0 8px 0; }
    .page-header p { color: var(--cp); margin: 0; font-size: 1.05rem; }
    
    .stats-badge { background: rgba(90,181,90,.15); border: 1px solid rgba(90,181,90,.3); padding: 8px 16px; border-radius: 50px; display: flex; align-items: center; gap: 8px; color: var(--g); font-weight: 700; }
    .stats-badge span { font-size: 1.2rem; }

    /* Filters */
    .filters-bar { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; background: var(--cb); padding: 16px; border-radius: 16px; border: 1px solid var(--cbr); }
    .search-input-wrap { position: relative; flex: 1; min-width: 250px; }
    .search-input-wrap svg { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--cp); width: 18px; height: 18px; }
    .search-input-wrap input { width: 100%; padding: 12px 16px 12px 40px; border-radius: 50px; border: 1px solid var(--cbr); background: var(--pg); color: var(--ch3); font-family: inherit; font-size: .95rem; }
    .search-input-wrap input:focus { outline: none; border-color: var(--g); }
    .filter-select { padding: 12px 16px; border-radius: 50px; border: 1px solid var(--cbr); background: var(--pg); color: var(--ch3); font-family: inherit; font-size: .95rem; cursor: pointer; }
    .filter-select:focus { outline: none; border-color: var(--g); }
    .btn-reset { padding: 12px 20px; border-radius: 50px; background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(248,113,113,.2); font-weight: 600; cursor: pointer; transition: all .2s; }
    .btn-reset:hover { background: rgba(248,113,113,.2); }

    /* List */
    .ouvrier-list { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); }
    .ouvrier-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 20px; padding: 24px; transition: transform .2s, border-color .2s; display: flex; flex-direction: column; gap: 16px; }
    .ouvrier-card:hover { transform: translateY(-4px); border-color: rgba(90,181,90,.3); }
    .ouvrier-header { display: flex; gap: 16px; align-items: center; }
    .ouvrier-avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; font-size: 1.5rem; font-weight: 800; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .ouvrier-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .ouvrier-info { flex: 1; min-width: 0; }
    .ouvrier-name { font-size: 1.1rem; font-weight: 700; color: var(--ch3); margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .role-badge { display: inline-block; padding: 4px 10px; border-radius: 50px; background: rgba(90,181,90,.15); color: var(--g); font-size: .75rem; font-weight: 700; }
    
    .ouvrier-contact { font-size: .85rem; color: var(--cp); display: flex; flex-direction: column; gap: 6px; }
    .contact-item { display: flex; align-items: center; gap: 8px; }
    
    .ouvrier-actions { display: flex; gap: 12px; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--cbr); }
    .btn-action { flex: 1; padding: 10px; border-radius: 12px; font-weight: 600; font-size: .9rem; cursor: pointer; text-align: center; text-decoration: none; display: inline-flex; justify-content: center; align-items: center; gap: 6px; transition: all .2s; }
    .btn-view { background: var(--indigo-bg); color: var(--indigo); border: 1px solid rgba(129,140,248,.2); }
    .btn-view:hover { background: rgba(129,140,248,.2); }
    .btn-delete { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(248,113,113,.2); }
    .btn-delete:hover { background: rgba(248,113,113,.2); }

    .empty-state { grid-column: 1 / -1; text-align: center; padding: 60px 20px; border: 1px dashed var(--cbr); border-radius: 20px; color: var(--cp); }
    .empty-state svg { width: 48px; height: 48px; stroke: currentColor; margin-bottom: 16px; opacity: .5; }

    @media (max-width: 768px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .main-content { margin-left: 0; }
    }
</style>
{% endblock %}

{% block body %}

<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('gerant_home') }}" class="sidebar-brand">
            <img src="{{ asset('images/logo.png') }}" alt="Logo">
            AgriSense 360
        </a>
    </div>
    <div class="sidebar-nav">
        <a href="{{ path('gerant_home') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Accueil
        </a>
        <a href="{{ path('gerant_ouvriers') }}" class="sidebar-link active">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Travailleurs
        </a>
        <a href="#" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            Cultures
        </a>
        <a href="#" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
            Stockés
        </a>
        <a href="#" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
            Équipements
        </a>
        <a href="#" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Affectations
        </a>
        <a href="#" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2.2a3 3 0 0 1 4 4l-9 9-4 1 1-4 9-9z"></path></svg>
            Animaux
        </a>
    </div>
    <div class="sidebar-footer">
        <a href="{{ path('profile_show') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Mon Profil
        </a>
        <a href="{{ path('app_logout') }}" class="sidebar-link" style="color: var(--danger);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Déconnexion
        </a>
    </div>
</div>

<main class="main-content" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>

    <div class="content-wrapper">
        
        {# Flash Messages #}
        {% for msg in app.flashes('success') %}
            <div style="background: rgba(90,181,90,.1); border: 1px solid rgba(90,181,90,.3); color: var(--g); padding: 16px; border-radius: 12px; margin-bottom: 24px; font-weight: 500;">
                ✓ {{ msg }}
            </div>
        {% endfor %}

        <div class="page-header">
            <div>
                <h1>Ouvriers</h1>
                <p>Gérez la liste des ouvriers travaillant dans votre exploitation.</p>
            </div>
            <div class="stats-badge">
                <span id="ouvriersCount">{{ ouvriers|length }}</span> Ouvriers
            </div>
        </div>

        <div class="filters-bar">
            <div class="search-input-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="searchInput" placeholder="Rechercher par nom, email..." oninput="filterList()">
            </div>
            <select id="statusFilter" class="filter-select" onchange="filterList()">
                <option value="">Tous les statuts</option>
                <option value="active">Actif</option>
                <option value="blocked">Bloqué</option>
            </select>
            <button class="btn-reset" onclick="resetFilters()">✕ Réinitialiser</button>
        </div>

        <div class="ouvrier-list" id="ouvriersList">
            {% for ouvrier in ouvriers %}
                <div class="ouvrier-card" data-name="{{ ouvrier.name|lower }}" data-email="{{ ouvrier.email|lower }}" data-status="{{ ouvrier.status }}">
                    <div class="ouvrier-header">
                        <div class="ouvrier-avatar">
                            {% if ouvrier.profilePicture %}
                                <img src="{{ asset('uploads/profiles/' ~ ouvrier.profilePicture) }}" alt="{{ ouvrier.name }}">
                            {% else %}
                                {{ ouvrier.name|first|upper }}
                            {% endif %}
                        </div>
                        <div class="ouvrier-info">
                            <div class="ouvrier-name">{{ ouvrier.name }}</div>
                            <span class="role-badge">Ouvrier</span>
                        </div>
                    </div>
                    
                    <div class="ouvrier-contact">
                        <div class="contact-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            {{ ouvrier.email }}
                        </div>
                        {% if ouvrier.phone %}
                        <div class="contact-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                            {{ ouvrier.phone }}
                        </div>
                        {% endif %}
                        <div class="contact-item" style="margin-top:4px;">
                            <span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:{{ ouvrier.status == 'active' ? '#10b981' : '#ef4444' }};"></span>
                            {{ ouvrier.status == 'active' ? 'Actif' : 'Bloqué' }}
                        </div>
                    </div>

                    <div class="ouvrier-actions">
                        <a href="{{ path('gerant_ouvrier_show', {id: ouvrier.id}) }}" class="btn-action btn-view">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                            Voir Profil
                        </a>
                        <form method="post" action="{{ path('gerant_ouvrier_delete', {id: ouvrier.id}) }}" onsubmit="return confirm('Supprimer cet ouvrier ? Cette action est irréversible.');" style="margin:0; flex:1; display:flex;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ouvrier.id) }}">
                            <button type="submit" class="btn-action btn-delete" style="width:100%;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                Retirer
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    <h3>Aucun ouvrier</h3>
                    <p>Votre exploitation ne compte aucun ouvrier pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</main>

<script>
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('open');
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        }
    });

    // Theme toggle
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);

    document.getElementById('themeToggle').addEventListener('click', function () {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });

    // Filtering logic
    function filterList() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const cards = document.querySelectorAll('.ouvrier-card');
        let count = 0;

        cards.forEach(card => {
            const matchName = card.dataset.name.includes(query);
            const matchEmail = card.dataset.email.includes(query);
            const matchStatus = status === '' || card.dataset.status === status;

            if ((matchName || matchEmail) && matchStatus) {
                card.style.display = 'flex';
                count++;
            } else {
                card.style.display = 'none';
            }
        });

        document.getElementById('ouvriersCount').textContent = count;
    }

    function resetFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = '';
        filterList();
    }
</script>
{% endblock %}
