{% extends 'base.html.twig' %}

{% block title %}Ouvriers — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }

    .stats-badge { background: rgba(90,181,90,0.1); border: 1px solid rgba(90,181,90,0.2); padding: 10px 20px; border-radius: 50px; color: var(--g); font-weight: 800; display: flex; align-items: center; gap: 10px; }

    /* Filters bar */
    .filters-bar { background: var(--cb); border: 1px solid var(--cbr); border-radius: 20px; padding: 20px; margin-bottom: 30px; display: flex; gap: 15px; flex-wrap: wrap; align-items: center; }
    .search-input-wrap { position: relative; flex: 1; min-width: 300px; }
    .search-input-wrap i { position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: var(--cp); }
    .search-input { width: 100%; padding: 12px 20px 12px 45px; border-radius: 50px; border: 1px solid var(--cbr); background: rgba(0,0,0,0.1); color: var(--ch3); font-weight: 500; }
    .search-input:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 4px rgba(90,181,90,0.1); }

    .filter-select { padding: 12px 25px; border-radius: 50px; border: 1px solid var(--cbr); background: rgba(0,0,0,0.1); color: var(--ch3); font-weight: 600; cursor: pointer; }

    .btn-reset { padding: 12px 25px; border-radius: 50px; background: rgba(248,113,113,0.1); color: #f87171; border: 1px solid rgba(248,113,113,0.2); font-weight: 700; cursor: pointer; }

    /* Cards Grid */
    .ouvrier-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 25px; }

    .ouvrier-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; padding: 30px; box-shadow: var(--sh-lg); transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; gap: 20px; }
    .ouvrier-card:hover { transform: translateY(-8px); border-color: var(--g); box-shadow: 0 15px 35px rgba(0,0,0,0.3); }

    .ouvrier-header { display: flex; align-items: center; gap: 20px; }
    .ouvrier-avatar { width: 65px; height: 65px; border-radius: 50%; background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; font-size: 1.8rem; font-weight: 900; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 3px solid var(--cbr); }
    .ouvrier-avatar img { width: 100%; height: 100%; object-fit: cover; }

    .ouvrier-name { font-size: 1.25rem; font-weight: 800; color: var(--ch3); margin: 0; }
    .role-badge { display: inline-block; padding: 4px 12px; border-radius: 50px; background: rgba(90,181,90,0.1); color: var(--g); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-top: 5px; }

    .ouvrier-contact { display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem; color: var(--cp); font-weight: 600; }
    .contact-item { display: flex; align-items: center; gap: 10px; }

    .ouvrier-actions { display: flex; gap: 12px; margin-top: auto; padding-top: 20px; border-top: 1px solid var(--cbr); }
    .btn-action { flex: 1; padding: 12px; border-radius: 14px; font-weight: 700; font-size: 0.9rem; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s; }
    .btn-view { background: rgba(129,140,248,0.1); color: #818cf8; border: 1px solid rgba(129,140,248,0.2); }
    .btn-view:hover { background: #818cf8; color: #fff; }
    .btn-delete { background: rgba(248,113,113,0.1); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }
    .btn-delete:hover { background: #f87171; color: #fff; }

    .empty-state { grid-column: 1 / -1; text-align: center; padding: 100px 40px; background: var(--cb); border-radius: 30px; border: 2px dashed var(--cbr); }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">👨‍🌾 Gestion des Ouvriers</h1>
        <p class="page-subtitle">Gérez la liste des ouvriers travaillant dans votre exploitation.</p>
    </div>
    <div class="stats-badge">
        <span id="ouvriersCount">{{ ouvriers|length }}</span> 👤 Actifs
    </div>
</div>

<div class="filters-bar">
    <div class="search-input-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="searchInput" class="search-input" placeholder="Rechercher par nom, email..." oninput="filterList()">
    </div>
    <select id="statusFilter" class="filter-select" onchange="filterList()">
        <option value="">Tous les statuts</option>
        <option value="active">Actif</option>
        <option value="blocked">Bloqué</option>
    </select>
    <button class="btn-reset" onclick="resetFilters()">✕ Réinitialiser</button>
</div>

<div class="ouvrier-list" id="ouvriersList">
    {% for ouvrier in ouvriers %}
        <div class="ouvrier-card" data-name="{{ ouvrier.name|lower }}" data-email="{{ ouvrier.email|lower }}" data-status="{{ ouvrier.status }}">
            <div class="ouvrier-header">
                <div class="ouvrier-avatar">
                    {% if ouvrier.profilePicture %}
                        <img src="{{ asset('uploads/profiles/' ~ ouvrier.profilePicture) }}" alt="{{ ouvrier.name }}">
                    {% else %}
                        {{ ouvrier.name|first|upper }}
                    {% endif %}
                </div>
                <div class="ouvrier-info">
                    <div class="ouvrier-name">{{ ouvrier.name }}</div>
                    <span class="role-badge">Ouvrier Agricole</span>
                </div>
            </div>
            
            <div class="ouvrier-contact">
                <div class="contact-item"><i class="fa-solid fa-envelope"></i> {{ ouvrier.email }}</div>
                {% if ouvrier.phone %}
                    <div class="contact-item"><i class="fa-solid fa-phone"></i> {{ ouvrier.phone }}</div>
                {% endif %}
                <div class="contact-item" style="margin-top:5px;">
                    <span style="display:inline-block; width:10px; height:10px; border-radius:50%; background:{{ ouvrier.status == 'active' ? '#10b981' : '#ef4444' }}; box-shadow: 0 0 10px {{ ouvrier.status == 'active' ? 'rgba(16,185,129,0.4)' : 'rgba(239,68,68,0.4)' }};"></span>
                    <span style="font-weight:800; color:{{ ouvrier.status == 'active' ? '#10b981' : '#ef4444' }};">{{ ouvrier.status == 'active' ? 'Opérationnel' : 'Bloqué' }}</span>
                </div>
            </div>

            <div class="ouvrier-actions">
                <a href="{{ path('gerant_ouvrier_show', {id: ouvrier.id}) }}" class="btn-action btn-view">
                    <i class="fa-solid fa-user-gear"></i> Voir Profil
                </a>
                <form method="post" action="{{ path('gerant_ouvrier_delete', {id: ouvrier.id}) }}" onsubmit="return confirm('Supprimer cet ouvrier ?');" style="margin:0; flex:1;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ouvrier.id) }}">
                    <button type="submit" class="btn-action btn-delete" style="width:100%;">
                        <i class="fa-solid fa-user-minus"></i> Retirer
                    </button>
                </form>
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <div style="font-size:4rem; opacity:0.3; margin-bottom:20px;">🚜</div>
            <h3 style="color:var(--ch3); font-weight:800;">Aucun ouvrier</h3>
            <p style="color:var(--cp);">Votre exploitation ne compte aucun ouvrier pour le moment.</p>
        </div>
    {% endfor %}
</div>

    </div>
</main>

<script>
    // Theme toggle
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const dropdown = document.getElementById('gerant-dropdown-nav');
            if (dropdown && dropdown.classList.contains('show')) dropdown.classList.remove('show');
        }
    }

    // Filtering logic
    function filterList() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const status = document.getElementById('statusFilter').value;
        const cards = document.querySelectorAll('.ouvrier-card');
        let count = 0;

        cards.forEach(card => {
            const matchName = card.dataset.name.includes(query);
            const matchEmail = card.dataset.email.includes(query);
            const matchStatus = status === '' || card.dataset.status === status;

            if ((matchName || matchEmail) && matchStatus) {
                card.style.display = 'flex';
                count++;
            } else {
                card.style.display = 'none';
            }
        });
        document.getElementById('ouvriersCount').textContent = count;
    }

    function resetFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = '';
        filterList();
    }
</script>
{% endblock %}
