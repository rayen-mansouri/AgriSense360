<script>
const nav = document.getElementById('homeNav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
});
const burger = document.getElementById('navBurger');
const links = document.querySelector('.home-nav__links');
burger.addEventListener('click', () => links.classList.toggle('open'));
document.querySelectorAll('.home-nav__links a').forEach(a => {
  a.addEventListener('click', () => links.classList.remove('open'));
});
document.getElementById('themeToggleNav').addEventListener('click', function(){
  var h=document.documentElement,c=h.getAttribute('data-theme'),n=c==='dark'?'light':'dark';
  h.setAttribute('data-theme',n);localStorage.setItem('agri-theme',n);
});
</script>
