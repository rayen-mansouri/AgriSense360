{% extends 'base.html.twig' %}

{% block title %}AgriSense 360{% endblock %}

{% block styles %}
<style>

/* HERO SECTION */
.hero {
    position: relative;
    width: 100%;
    height: calc(100vh - 100px); /* adjusted for header */
    overflow: hidden;
}

/* VIDEO */
.hero video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
}

/* OVERLAY */
.hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 2;
}

/* CONTENT */
.hero-content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
    padding: 0 20px;
}

.hero h1 {
    font-size: 3rem;
    margin-bottom: 20px;
}

.hero p {
    font-size: 1.2rem;
    margin-bottom: 25px;
}

/* BUTTON */
.btn-main {
    padding: 14px 30px;
    background: var(--green-mid);
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
}

.btn-main:hover {
    background: var(--green-dark);
}

/* SECTION */
.section {
    padding: 80px 20px;
    text-align: center;
}

/* FEATURES GRID */
.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
    gap: 20px;
    margin-top: 40px;
}

/* CARD */
.card {
    background: white;
    padding: 25px;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
}

</style>
{% endblock %}

{% block body %}

<!-- HERO VIDEO -->
<div class="hero">

    <!-- VIDEO -->
    <video autoplay muted loop playsinline poster="{{ asset('images/farm.jpg') }}">
        <source src="{{ asset('videos/farm.mp4') }}" type="video/mp4">
    </video>

    <!-- DARK OVERLAY -->
    <div class="hero-overlay"></div>

    <!-- TEXT -->
    <div class="hero-content">
        <h1>Gérez votre exploitation intelligemment</h1>
        <p>Une seule plateforme pour tout contrôler</p>

        <a href="{{ path('app_register') }}" class="btn-main">
            Commencer maintenant
        </a>
    </div>
</div>

<!-- FEATURES -->
<div class="section">
    <h2>Pourquoi AgriSense 360 ?</h2>

    <div class="features">
        <div class="card">
            <h3>🌱 Suivi intelligent</h3>
            <p>Analyse des cultures en temps réel</p>
        </div>

        <div class="card">
            <h3>💧 Optimisation</h3>
            <p>Gestion de l’eau et fertilisation</p>
        </div>

        <div class="card">
            <h3>📊 Rapports</h3>
            <p>Suivi complet de votre production</p>
        </div>
    </div>
</div>

<!-- TECHNO SECTION -->
<div class="section">
    <h2>Technologie agricole intelligente</h2>
    <p>Améliorez votre rendement avec nos outils IA</p>
</div>

<!-- CTA -->
<div class="section" style="background: var(--green-pale);">
    <h2>Prêt à digitaliser votre ferme ?</h2>
    <a href="{{ path('app_login') }}" class="btn-main">
        Se connecter
    </a>
</div>

{% endblock %}