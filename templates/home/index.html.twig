{% extends 'base.html.twig' %}

{% block title %}Dashboard Administrateur{% endblock %}

{% block content %}

<style>
.dash-section { margin-bottom: 48px; }
.dash-section-title {
    font-size: 1.15rem; font-weight: 700; color: var(--text-dark);
    margin-bottom: 20px; display: flex; align-items: center; gap: 10px;
    padding-bottom: 10px; border-bottom: 2px solid var(--green-200);
}
.dash-section-title .badge {
    background: var(--green-100); color: var(--green-700);
    font-size: 0.75rem; padding: 3px 10px; border-radius: 20px; font-weight: 600;
    margin-left: auto;
}
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 18px; margin-bottom: 48px;
}
.kpi-card {
    background: var(--bg-card); border-radius: 16px; padding: 22px 20px;
    box-shadow: var(--shadow-sm); border: 1.5px solid var(--border);
    position: relative; overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    opacity: 0; transform: translateY(28px);
}
.kpi-card.visible { opacity: 1; transform: translateY(0); transition: opacity 0.5s ease, transform 0.5s ease; }
.kpi-card::before {
    content: ''; position: absolute; top: -30px; right: -30px;
    width: 90px; height: 90px; border-radius: 50%; opacity: 0.12;
}
.kpi-card.c-green::before  { background: #4caf50; }
.kpi-card.c-blue::before   { background: #2196f3; }
.kpi-card.c-amber::before  { background: #ff9800; }
.kpi-card.c-red::before    { background: #f44336; }
.kpi-card.c-teal::before   { background: #009688; }
.kpi-card.c-purple::before { background: #9c27b0; }
.kpi-card:hover { transform: translateY(-4px) !important; box-shadow: var(--shadow-md); }
.kpi-icon  { font-size: 2rem; margin-bottom: 10px; display: block; }
.kpi-value { font-size: 2rem; font-weight: 800; color: var(--text-dark); line-height: 1; margin-bottom: 6px; font-family: var(--font-display); }
.kpi-label { font-size: 0.78rem; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; }
.kpi-bar   { margin-top: 12px; height: 4px; background: var(--border); border-radius: 4px; overflow: hidden; }
.kpi-bar-fill { height: 100%; border-radius: 4px; transition: width 1.2s ease; width: 0; }
.kpi-card.c-green .kpi-bar-fill   { background: #4caf50; }
.kpi-card.c-blue .kpi-bar-fill    { background: #2196f3; }
.kpi-card.c-amber .kpi-bar-fill   { background: #ff9800; }
.kpi-card.c-red .kpi-bar-fill     { background: #f44336; }
.kpi-card.c-teal .kpi-bar-fill    { background: #009688; }
.kpi-card.c-purple .kpi-bar-fill  { background: #9c27b0; }
.kpi-sub { font-size: 0.72rem; color: var(--text-muted); margin-top: 4px; }

.charts-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-bottom: 48px;
}
@media(max-width:860px){ .charts-grid { grid-template-columns: 1fr; } }
.chart-card {
    background: var(--bg-card); border-radius: 16px; padding: 24px;
    box-shadow: var(--shadow-sm); border: 1.5px solid var(--border);
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}
.chart-card.visible { opacity: 1; transform: translateY(0); }
.chart-card-title { font-size: 0.88rem; font-weight: 700; color: var(--text-dark); margin-bottom: 18px; text-transform: uppercase; letter-spacing: 0.04em; }
.chart-wrap { position: relative; height: 260px; }

.top-scroll {
    display: flex; gap: 16px; overflow-x: auto; padding-bottom: 12px;
    scroll-snap-type: x mandatory;
}
.top-scroll::-webkit-scrollbar { height: 5px; }
.top-scroll::-webkit-scrollbar-track { background: var(--green-50); border-radius: 4px; }
.top-scroll::-webkit-scrollbar-thumb { background: var(--green-400); border-radius: 4px; }

.top-p-card {
    min-width: 230px; max-width: 230px;
    background: var(--bg-card); border-radius: 14px; padding: 18px;
    border: 1.5px solid var(--border); box-shadow: var(--shadow-sm);
    scroll-snap-align: start; flex-shrink: 0;
    opacity: 0; transform: translateX(30px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}
.top-p-card.visible { opacity: 1; transform: translateX(0); }
.top-p-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.rank-badge {
    width: 30px; height: 30px; border-radius: 50%; display: inline-flex;
    align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.82rem; margin-bottom: 10px;
}
.rank-1 { background: #FFD700; color: #7a5a00; }
.rank-2 { background: #C0C0C0; color: #444; }
.rank-3 { background: #CD7F32; color: #5a2a00; }
.rank-n { background: var(--green-100); color: var(--green-700); }
.p-name { font-weight: 700; font-size: 1rem; color: var(--text-dark); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
.p-meta { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 10px; }
.p-row  { display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 3px; }
.p-prog { height: 6px; background: var(--border); border-radius: 6px; margin-top: 10px; overflow: hidden; }
.p-prog-fill { height: 100%; background: linear-gradient(90deg, #81c784, #2e7d32); border-radius: 6px; transition: width 1.2s ease; width: 0; }

.harvest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 18px; }
.h-card {
    background: var(--bg-card); border-radius: 14px; overflow: hidden;
    box-shadow: var(--shadow-sm); border: 1.5px solid var(--border);
    display: flex; flex-direction: column;
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}
.h-card.visible { opacity: 1; transform: translateY(0); }
.h-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.h-card-img {
    height: 130px; background: var(--green-50);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
}
.h-card-img img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
.retard-ribbon {
    position: absolute; top: 12px; right: -18px;
    background: #f44336; color: white; font-size: 0.62rem; font-weight: 800;
    padding: 3px 28px; transform: rotate(35deg); letter-spacing: 0.06em;
}
.h-card-body { padding: 14px; flex: 1; }
.h-type { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 3px; }
.h-name { font-size: 1rem; font-weight: 700; color: var(--text-dark); margin-bottom: 8px; }
.h-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
.h-chip {
    font-size: 0.7rem; padding: 3px 8px; border-radius: 20px;
    background: var(--green-50); color: var(--green-700);
    border: 1px solid var(--green-200); font-weight: 500;
}
.anim-in { opacity: 0; transform: translateY(20px); }
.anim-in.visible { opacity: 1; transform: translateY(0); transition: opacity 0.5s ease, transform 0.5s ease; }
.donut-layout { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
.surf-legend { display: flex; flex-direction: column; gap: 12px; }
.s-row { display: flex; align-items: center; gap: 9px; font-size: 0.85rem; }
.s-dot { width: 13px; height: 13px; border-radius: 50%; flex-shrink: 0; }
.s-val { font-weight: 700; color: var(--text-dark); margin-left: auto; padding-left: 10px; }
.empty-box {
    text-align: center; padding: 50px 20px; color: var(--text-muted);
    background: var(--green-50); border-radius: 14px; border: 2px dashed var(--green-200);
}

{# ── IA Harvested section styles ── #}
.ia-harvest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 18px; }
.ia-h-card {
    background: var(--bg-card); border-radius: 14px; overflow: hidden;
    box-shadow: var(--shadow-sm); border: 1.5px solid #86efac;
    display: flex; flex-direction: column;
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.5s ease, transform 0.5s ease;
}
.ia-h-card.visible { opacity: 1; transform: translateY(0); }
.ia-h-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.ia-h-header {
    background: linear-gradient(135deg, #1e3c2c, #2a5a3a);
    padding: 14px 16px;
    display: flex; align-items: center; justify-content: space-between;
}
.ia-h-nom { font-size: 1rem; font-weight: 700; color: #fff; }
.ia-h-type { font-size: 0.7rem; color: rgba(255,255,255,0.7); margin-top: 2px; }
.ia-h-qty {
    font-size: 1.4rem; font-weight: 800; color: #86efac;
    text-align: right; white-space: nowrap;
}
.ia-h-qty-label { font-size: 0.62rem; color: rgba(255,255,255,0.6); text-align: right; }
.ia-h-body { padding: 14px; }
.ia-score-bar-wrap { margin-bottom: 10px; }
.ia-score-bar-label {
    display: flex; justify-content: space-between;
    font-size: 0.72rem; color: var(--text-muted); margin-bottom: 4px;
}
.ia-score-bar {
    height: 6px; border-radius: 6px; background: var(--border); overflow: hidden;
}
.ia-score-bar-fill {
    height: 100%; border-radius: 6px;
    transition: width 1.2s ease; width: 0;
}
.ia-h-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
.ia-h-chip {
    font-size: 0.68rem; padding: 2px 8px; border-radius: 20px;
    background: #f0fdf4; color: #1e3c2c;
    border: 1px solid #86efac; font-weight: 500;
}
</style>

{# ── HEADER ── #}
<div class="page-header anim-in" style="margin-bottom:32px;">
    <div class="page-header-left">
        <p class="page-breadcrumb">🏠 Accueil / Dashboard</p>
        <h1 class="page-title">📊 Dashboard Administrateur</h1>
        <p class="page-subtitle">Vue d'ensemble de l'exploitation — lecture seule</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">🗺️ Parcelles</a>
        <a href="{{ path('culture_index') }}"  class="btn btn-primary">🌱 Cultures</a>
    </div>
</div>

{# ── KPI CARDS ── #}
<div class="dash-section">
    <div class="dash-section-title anim-in">📈 Indicateurs clés <span class="badge">En temps réel</span></div>
    <div class="kpi-grid">

        <div class="kpi-card c-green" data-bar="100">
            <span class="kpi-icon">🗺️</span>
            <div class="kpi-value" data-count="{{ totalParcelles }}">0</div>
            <div class="kpi-label">Parcelles totales</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        <div class="kpi-card c-teal" data-bar="100">
            <span class="kpi-icon">🌱</span>
            <div class="kpi-value" data-count="{{ totalCultures }}">0</div>
            <div class="kpi-label">Cultures en cours</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        <div class="kpi-card c-blue" data-bar="{{ tauxOccupation }}">
            <span class="kpi-icon">📐</span>
            <div class="kpi-value" data-count="{{ surfaceTotal|round }}" data-suffix=" m²">0</div>
            <div class="kpi-label">Surface totale</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        <div class="kpi-card c-amber" data-bar="{{ tauxOccupation }}">
            <span class="kpi-icon">📊</span>
            <div class="kpi-value" data-count="{{ tauxOccupation }}" data-suffix="%">0</div>
            <div class="kpi-label">Taux d'occupation</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        <div class="kpi-card c-green" data-bar="{{ totalCultures > 0 ? ((culturesPretes / totalCultures) * 100)|round : 0 }}">
            <span class="kpi-icon">🌾</span>
            <div class="kpi-value" data-count="{{ culturesPretes }}">0</div>
            <div class="kpi-label">Prêtes à récolter</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        <div class="kpi-card c-red" data-bar="{{ totalCultures > 0 ? ((culturesRetard / totalCultures) * 100)|round : 0 }}">
            <span class="kpi-icon">⚠️</span>
            <div class="kpi-value" data-count="{{ culturesRetard }}">0</div>
            <div class="kpi-label">En retard de récolte</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

        {# ── NEW: IA Récoltes KPI ── #}
        <div class="kpi-card c-purple" data-bar="100">
            <span class="kpi-icon">🤖</span>
            <div class="kpi-value" data-count="{{ totalRecoltes }}">0</div>
            <div class="kpi-label">Récoltes IA effectuées</div>
            <div class="kpi-sub">{{ totalKgRecolte|number_format(1) }} kg au total</div>
            <div class="kpi-bar"><div class="kpi-bar-fill"></div></div>
        </div>

    </div>
</div>

{# ── CHARTS ── #}
<div class="dash-section">
    <div class="dash-section-title anim-in">📉 Visualisations graphiques <span class="badge">Charts</span></div>
    <div class="charts-grid">

        <div class="chart-card">
            <div class="chart-card-title">🟡 Répartition par état</div>
            <div class="chart-wrap"><canvas id="chartEtat"></canvas></div>
        </div>

        <div class="chart-card">
            <div class="chart-card-title">📊 Cultures par type</div>
            <div class="chart-wrap"><canvas id="chartType"></canvas></div>
        </div>

        <div class="chart-card">
            <div class="chart-card-title">📐 Occupation des surfaces</div>
            <div class="donut-layout">
                <div style="position:relative;width:210px;height:210px;flex-shrink:0;">
                    <canvas id="chartSurface"></canvas>
                    <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;">
                        <div style="font-size:1.6rem;font-weight:800;color:var(--text-dark);">{{ tauxOccupation }}%</div>
                        <div style="font-size:0.72rem;color:var(--text-muted);">occupé</div>
                    </div>
                </div>
                <div class="surf-legend">
                    <div class="s-row"><div class="s-dot" style="background:#4caf50;"></div><span>Utilisée</span><span class="s-val">{{ surfaceUtilisee|number_format(0,',',' ') }} m²</span></div>
                    <div class="s-row"><div class="s-dot" style="background:#e0e0e0;"></div><span>Disponible</span><span class="s-val">{{ surfaceRestante|number_format(0,',',' ') }} m²</span></div>
                    <div class="s-row"><div class="s-dot" style="background:#2196f3;"></div><span>Totale</span><span class="s-val">{{ surfaceTotal|number_format(0,',',' ') }} m²</span></div>
                </div>
            </div>
        </div>

        <div class="chart-card">
            <div class="chart-card-title">🏆 Top parcelles (nb cultures)</div>
            <div class="chart-wrap"><canvas id="chartTop"></canvas></div>
        </div>

    </div>
</div>

{# ── TOP PARCELLES SCROLL ── #}
<div class="dash-section">
    <div class="dash-section-title anim-in">🏅 Top parcelles <span class="badge">{{ topParcelles|length }} parcelle(s)</span></div>
    {% if topParcelles is empty %}
        <div class="empty-box"><div style="font-size:2.5rem;">🗺️</div><p>Aucune parcelle enregistrée</p></div>
    {% else %}
    <div class="top-scroll">
        {% for p in topParcelles %}
        <div class="top-p-card" style="transition-delay:{{ loop.index0 * 0.08 }}s;">
            <div class="rank-badge rank-{{ loop.index <= 3 ? loop.index : 'n' }}">{{ loop.index }}</div>
            <div class="p-name" title="{{ p.nom }}">{{ p.nom }}</div>
            <div class="p-meta">{{ p.statut == 'Libre' ? '🟢 Libre' : '🟠 Occupée' }}</div>
            <div class="p-row"><span style="color:var(--text-muted);">🌱 Cultures</span><strong>{{ p.cultures }}</strong></div>
            <div class="p-row"><span style="color:var(--text-muted);">📐 Surface</span><strong>{{ p.surface|number_format(0,',',' ') }} m²</strong></div>
            <div class="p-row"><span style="color:var(--text-muted);">📏 Restant</span><strong>{{ p.surfaceRestant|number_format(0,',',' ') }} m²</strong></div>
            <div class="p-prog"><div class="p-prog-fill" data-width="{{ p.taux }}"></div></div>
            <div style="text-align:right;margin-top:5px;font-size:0.71rem;color:var(--text-muted);">{{ p.taux }}% occupé</div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

{# ── CULTURES À RÉCOLTER ── #}
<div class="dash-section">
    <div class="dash-section-title anim-in">🌾 Cultures à récolter <span class="badge">{{ culturesRecolte|length }} culture(s)</span></div>
    {% if culturesRecolte is empty %}
        <div class="empty-box">
            <div style="font-size:3rem;margin-bottom:10px;">🌿</div>
            <p style="font-weight:600;">Aucune culture prête ou en retard de récolte</p>
            <p style="font-size:0.82rem;margin-top:4px;">Les cultures arrivant à maturité apparaîtront ici</p>
        </div>
    {% else %}
    <div class="harvest-grid">
        {% for culture in culturesRecolte %}
        <div class="h-card" style="transition-delay:{{ loop.index0 * 0.07 }}s;
            {% if culture.etat == 'Récolte en Retard' %}border-color:#f44336;
            {% elseif culture.etat == 'Récolte Prévue' %}border-color:#ff9800;
            {% else %}border-color:#4caf50;{% endif %}">

            <div class="h-card-img"
                 style="{% if culture.etat == 'Récolte en Retard' %}background:#ffebee;
                        {% elseif culture.etat == 'Récolte Prévue' %}background:#fff8e1;
                        {% else %}background:#e8f5e9;{% endif %}">
                {% if culture.img %}
                    <img src="{{ asset('images/cultures/' ~ culture.img) }}" alt="{{ culture.nom }}"
                         onerror="this.parentElement.innerHTML='<div style=\'font-size:3.5rem\'>🌱</div>'">
                {% else %}
                    <div style="font-size:3.5rem;">🌱</div>
                {% endif %}
                {% if culture.etat == 'Récolte en Retard' %}
                    <div class="retard-ribbon">RETARD</div>
                {% endif %}
            </div>

            <div class="h-card-body">
                <div class="h-type">{{ culture.typeCulture }}</div>
                <div class="h-name">{{ culture.nom }}</div>
                {% set ec = culture.etat == 'Récolte en Retard' ? 'etat-recolte-en-retard'
                           : (culture.etat == 'Récolte Prévue' ? 'etat-recolte-prevue' : 'etat-maturite') %}
                <span class="etat-badge {{ ec }}">{{ culture.etat }}</span>
                <div class="h-chips">
                    <span class="h-chip">📐 {{ culture.surface }} m²</span>
                    <span class="h-chip">🗺️ {{ parcelleMap[culture.parcelle.id] ?? 'N/A' }}</span>
                    {% if culture.dateRecolte %}
                        <span class="h-chip">🌾 {{ culture.dateRecolte|date('d/m/Y') }}</span>
                    {% endif %}
                    {% if culture.datePlantation %}
                        <span class="h-chip">🌱 {{ culture.datePlantation|date('d/m/Y') }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

{# ══════════════════════════════════════════════════════
   NEW — RÉCOLTES IA SECTION
   Shows the last 12 harvests from parcelle_historique
   ══════════════════════════════════════════════════════ #}
<div class="dash-section">
    <div class="dash-section-title anim-in">
        🤖 Récoltes IA — Historique
        <span class="badge">{{ recentRecoltes|length }} récente(s)</span>
        <a href="{{ path('culture_analytics') }}"
           style="margin-left:auto;font-size:0.78rem;font-weight:600;color:var(--green-600);text-decoration:none;">
            Voir tout →
        </a>
    </div>

    {% if recentRecoltes is empty %}
        <div class="empty-box">
            <div style="font-size:3rem;margin-bottom:10px;">🤖</div>
            <p style="font-weight:600;">Aucune récolte IA enregistrée</p>
            <p style="font-size:0.82rem;margin-top:4px;">
                Utilisez le bouton 🌾 Récolter sur les cartes culture pour commencer
            </p>
            <a href="{{ path('culture_index') }}" class="btn btn-primary" style="margin-top:16px;">
                → Aller aux cultures
            </a>
        </div>
    {% else %}
    <div class="ia-harvest-grid">
        {% for h in recentRecoltes %}
        {% set iaScoreNum = h.description|split('Score qualité : ')|last|split('%')|first|trim|default('0') %}
        <div class="ia-h-card" style="transition-delay:{{ loop.index0 * 0.06 }}s;">

            {# Dark green header with name + quantity #}
            <div class="ia-h-header">
                <div>
                    <div class="ia-h-nom">{{ h.cultureNom ?? 'Culture' }}</div>
                    <div class="ia-h-type">{{ h.typeCulture ?? '' }}</div>
                </div>
                <div>
                    <div class="ia-h-qty">
                        {{ h.quantiteRecolte is not null ? h.quantiteRecolte|number_format(1) ~ ' kg' : '— kg' }}
                    </div>
                    <div class="ia-h-qty-label">quantité IA</div>
                </div>
            </div>

            {# Body: score bar + chips #}
            <div class="ia-h-body">

                {# IA Score bar (extracted from description string) #}
                {% set scoreVal = 0 %}
                {% if h.description %}
                    {% set parts = h.description|split('Score qualité : ') %}
                    {% if parts|length > 1 %}
                        {% set scoreVal = parts[1]|split('%')|first|trim|number_format(0) %}
                    {% endif %}
                {% endif %}

                <div class="ia-score-bar-wrap">
                    <div class="ia-score-bar-label">
                        <span>Score qualité IA</span>
                        <span style="font-weight:700;color:{% if scoreVal >= 75 %}#16a34a{% elseif scoreVal >= 50 %}#d97706{% else %}#dc2626{% endif %};">
                            {{ scoreVal }}%
                        </span>
                    </div>
                    <div class="ia-score-bar">
                        <div class="ia-score-bar-fill"
                             data-width="{{ scoreVal }}"
                             style="background:{% if scoreVal >= 75 %}#16a34a{% elseif scoreVal >= 50 %}#d97706{% else %}#dc2626{% endif %};">
                        </div>
                    </div>
                </div>

                <div class="ia-h-chips">
                    {% if h.surface %}
                        <span class="ia-h-chip">📐 {{ h.surface|number_format(1) }} m²</span>
                    {% endif %}
                    {% if h.surface and h.quantiteRecolte %}
                        <span class="ia-h-chip">⚡ {{ (h.quantiteRecolte / h.surface)|number_format(2) }} kg/m²</span>
                    {% endif %}
                    <span class="ia-h-chip">📅 {{ h.dateAction|date('d/m/Y') }}</span>
                    {# Show ML vs PHP source #}
                    {% if h.description and 'ML Python' in h.description %}
                        <span class="ia-h-chip" style="background:#f5f3ff;color:#7c3aed;border-color:#c4b5fd;">🤖 ML</span>
                    {% else %}
                        <span class="ia-h-chip" style="background:#f0fdf4;color:#1e3c2c;border-color:#86efac;">🧮 PHP</span>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>

{% endblock %}

{% block javascripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const ETAT_DATA = {{ etatCounts|json_encode|raw }};
const TYPE_DATA = {{ typeCounts|json_encode|raw }};
const TOP_DATA  = {{ topParcelles|json_encode|raw }};
const SURF_USED = {{ surfaceUtilisee }};
const SURF_REST = {{ surfaceRestante }};

Chart.defaults.font.family = "'Inter','Segoe UI',sans-serif";
Chart.defaults.color = '#666';

/* ── Doughnut: États ── */
new Chart(document.getElementById('chartEtat'), {
    type: 'doughnut',
    data: {
        labels: Object.keys(ETAT_DATA),
        datasets: [{
            data: Object.values(ETAT_DATA),
            backgroundColor: ['#a5d6a7','#64b5f6','#ffcc80','#81c784','#ef9a9a'],
            borderColor:     ['#4caf50','#2196f3','#ff9800','#388e3c','#f44336'],
            borderWidth: 2, hoverOffset: 14,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false, cutout: '58%',
        plugins: {
            legend: { position: 'right', labels: { padding: 14, boxWidth: 13, font: { size: 11 } } },
            tooltip: { callbacks: { label: c => ` ${c.label}: ${c.raw} culture(s)` } }
        },
        animation: { duration: 1200, easing: 'easeInOutQuart' }
    }
});

/* ── Bar: Types ── */
const typeLabels = Object.keys(TYPE_DATA);
const typeColors = ['#a5d6a7','#90caf9','#ffcc80','#ce93d8','#80cbc4','#f48fb1'];
new Chart(document.getElementById('chartType'), {
    type: 'bar',
    data: {
        labels: typeLabels,
        datasets: [{
            label: 'Cultures',
            data: Object.values(TYPE_DATA),
            backgroundColor: typeColors.slice(0, typeLabels.length),
            borderColor:     typeColors.slice(0, typeLabels.length).map(c => c.replace(/a7|9a/, '50')),
            borderWidth: 2, borderRadius: 8, borderSkipped: false,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ` ${c.raw} culture(s)` } } },
        scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
            x: { grid: { display: false } }
        },
        animation: { duration: 1100, easing: 'easeOutBounce' }
    }
});

/* ── Donut: Surface ── */
new Chart(document.getElementById('chartSurface'), {
    type: 'doughnut',
    data: {
        labels: ['Utilisée','Disponible'],
        datasets: [{
            data: [SURF_USED || 0, SURF_REST || 0.01],
            backgroundColor: ['#4caf50','#e0e0e0'],
            borderColor: ['#388e3c','#bdbdbd'],
            borderWidth: 2, hoverOffset: 8,
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false, cutout: '72%',
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ` ${c.label}: ${(c.raw||0).toLocaleString('fr-FR')} m²` } } },
        animation: { duration: 1400, easing: 'easeInOutCubic' }
    }
});

/* ── Horizontal bar: Top parcelles ── */
const ctxTop = document.getElementById('chartTop').getContext('2d');
const grad = ctxTop.createLinearGradient(0, 0, 400, 0);
grad.addColorStop(0,'#a5d6a7'); grad.addColorStop(1,'#2e7d32');
new Chart(ctxTop, {
    type: 'bar',
    data: {
        labels: TOP_DATA.map(p => p.nom.length > 14 ? p.nom.slice(0,13)+'…' : p.nom),
        datasets: [{
            label: 'Cultures',
            data: TOP_DATA.map(p => p.cultures),
            backgroundColor: grad, borderColor: '#388e3c',
            borderWidth: 1.5, borderRadius: 6,
        }]
    },
    options: {
        indexAxis: 'y', responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ` ${c.raw} culture(s)` } } },
        scales: {
            x: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
            y: { grid: { display: false } }
        },
        animation: { duration: 1000, easing: 'easeOutQuart' }
    }
});

/* ── Counter animation ── */
function animCounter(el) {
    const target = parseFloat(el.dataset.count) || 0;
    const suffix = el.dataset.suffix || '';
    const steps = 50; const dur = 1200;
    let cur = 0; let t = 0;
    const iv = setInterval(() => {
        t++; cur = Math.min(cur + target / steps, target);
        el.textContent = (target % 1 === 0 ? Math.round(cur) : cur.toFixed(1)).toLocaleString('fr-FR') + suffix;
        if (t >= steps) { el.textContent = target.toLocaleString('fr-FR') + suffix; clearInterval(iv); }
    }, dur / steps);
}

/* ── Intersection Observer ── */
const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target;
        el.classList.add('visible');
        if (el.classList.contains('kpi-card')) {
            const v = el.querySelector('.kpi-value[data-count]');
            if (v) animCounter(v);
            const b = el.querySelector('.kpi-bar-fill');
            if (b) setTimeout(() => b.style.width = (el.dataset.bar||0) + '%', 100);
        }
        if (el.classList.contains('top-p-card')) {
            const f = el.querySelector('.p-prog-fill');
            if (f) setTimeout(() => f.style.width = (f.dataset.width||0) + '%', 100);
        }
        // Animate IA score bars
        if (el.classList.contains('ia-h-card')) {
            el.querySelectorAll('.ia-score-bar-fill[data-width]').forEach(b => {
                setTimeout(() => b.style.width = (b.dataset.width||0) + '%', 200);
            });
        }
        io.unobserve(el);
    });
}, { threshold: 0.1 });

document.querySelectorAll('.kpi-card,.chart-card,.top-p-card,.h-card,.ia-h-card,.anim-in').forEach(el => io.observe(el));
</script>
{% endblock %}
