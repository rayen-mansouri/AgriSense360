<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Management{% endblock %} | AgriSense 360</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('assets/styles/management.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/styles/menu.css') }}">
    <style>
        :root {
            --bg: #f4efe6;
            --surface: #ffffff;
            --surface-soft: #fdfaf4;
            --ink: #1f2a1f;
            --muted: #5f6b5d;
            --accent: #2f7b5a;
            --accent-strong: #1d6144;
            --accent-warm: #d49a3a;
            --stroke: #ddd2c3;
            --sidebar: #18251a;
            --sidebar-edge: rgba(255, 255, 255, 0.08);
            --sidebar-text: #e6efe1;
            --sidebar-muted: rgba(230, 239, 225, 0.7);
            --shadow: 0 24px 48px rgba(18, 24, 15, 0.12);
            --radius-lg: 24px;
            --radius-md: 16px;
            --radius-sm: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at top, #ffffff 0%, #f4efe6 35%, #e7dcc8 100%);
            color: var(--ink);
            min-height: 100vh;
        }

        .page {
            display: grid;
            grid-template-columns: minmax(240px, 300px) 1fr;
            min-height: 100vh;
            transition: grid-template-columns 0.3s ease;
        }

        .sidebar {
            background: linear-gradient(180deg, rgba(32, 61, 28, 0.98) 0%, rgba(24, 44, 20, 0.98) 100%);
            color: var(--sidebar-text);
            padding: 36px 28px;
            display: flex;
            flex-direction: column;
            gap: 32px;
            position: sticky;
            top: 0;
            height: 100vh;
            border-right: 1px solid var(--sidebar-edge);
            transition: width 0.3s ease, padding 0.3s ease;
            overflow-y: auto;
        }

        .brand {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .brand-logo {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.08);
            padding: 6px;
        }

        .brand-name {
            font-family: 'Fraunces', 'Georgia', serif;
            font-size: 20px;
            letter-spacing: 0.4px;
            font-weight: 700;
        }

        .brand-tagline {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--sidebar-muted);
        }

        .managements {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .nav-title {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--sidebar-muted);
        }

        .managements ul {
            list-style: none;
            display: grid;
            gap: 12px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: var(--sidebar-muted);
            text-decoration: none;
            border-radius: var(--radius-sm);
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.08);
            color: var(--sidebar-text);
        }

        .managements li.active .nav-link {
            background: var(--accent);
            color: white;
        }

        .nav-icon {
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-icon svg {
            width: 100%;
            height: 100%;
        }

        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .topbar {
            background: var(--surface);
            padding: 24px 36px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--stroke);
        }

        .topbar-title h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 5px;
            color: var(--ink);
        }

        .eyebrow {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            margin-bottom: 5px;
        }

        .subhead {
            font-size: 14px;
            color: var(--muted);
        }

        .topbar-actions {
            display: flex;
            gap: 12px;
        }

        .topbar-actions .primary {
            background: var(--accent);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .topbar-actions .primary:hover {
            background: var(--accent-strong);
        }

        .topbar-actions .ghost {
            background: transparent;
            border: 1px solid var(--stroke);
            color: var(--ink);
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.2s ease;
        }

        .topbar-actions .ghost:hover {
            background: var(--surface-soft);
        }

        .worker-tabs {
            display: flex;
            gap: 0;
            background: var(--surface);
            border-bottom: 2px solid var(--stroke);
            padding: 0 36px;
        }

        .tab-btn {
            padding: 16px 24px;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            cursor: pointer;
            font-weight: 500;
            color: var(--muted);
            transition: all 0.2s ease;
            text-decoration: none;
            font-size: 14px;
        }

        .tab-btn:hover {
            color: var(--accent);
        }

        .tab-btn.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

        body[data-collapsed="true"] .page {
            grid-template-columns: 80px 1fr;
        }

        body[data-collapsed="true"] .sidebar {
            padding: 20px 12px;
        }

        body[data-collapsed="true"] .nav-label {
            display: none;
        }

        body[data-collapsed="true"] .topbar {
            padding: 20px 24px;
        }

        body[data-collapsed="true"] .topbar-title h1 {
            font-size: 22px;
        }
    </style>
</head>
<body data-collapsed="false">
    <div class="page">
        <aside class="sidebar">
            <div class="brand">
                <div>
                    <div class="brand-name">AgriSense 360</div>
                    <div class="brand-tagline">Smart AI Companion for Farms</div>
                </div>
            </div>
            <nav class="managements">
                <p class="nav-title">Managements</p>
                <ul>
                    <li class="{% if active_tab|default('') == 'home' %}active{% endif %}">
                        <a class="nav-link" href="{{ path('home') }}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M4 11l8-7 8 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M6 10v8h12v-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            <span class="nav-label">Home</span>
                        </a>
                    </li>
                    <li class="{% if active_tab == 'affectation' %}active{% endif %}">
                        <a class="nav-link" href="{{ path('affectation_travail_index') }}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M7 8h10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    <path d="M6 12h12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    <path d="M8 16h8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                            </span>
                            <span class="nav-label">Affectation</span>
                        </a>
                    </li>
                    <li class="{% if active_tab == 'evaluation' %}active{% endif %}">
                        <a class="nav-link" href="{{ path('evaluation_performance_index') }}">
                            <span class="nav-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 2v20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    <path d="M4 8h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    <path d="M4 16h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                            </span>
                            <span class="nav-label">Evaluation</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </aside>

        <main class="content">
            <header class="topbar">
                <div class="topbar-title">
                    <p class="eyebrow">{% block eyebrow %}Gestion d'Ouvrier{% endblock %}</p>
                    <h1>{% block heading %}{% endblock %}</h1>
                    <p class="subhead">{% block subhead %}{% endblock %}</p>
                </div>
                <div class="topbar-actions">
                    {% block topbar_actions %}{% endblock %}
                </div>
            </header>

            <!-- Navigation Tabs -->
            {% block tabs %}
            <div class="worker-tabs">
                <a href="{{ path('affectation_travail_index') }}" class="tab-btn {% if active_tab == 'affectation' %}active{% endif %}">
                    <span class="tab-icon">📋</span> Affectations
                </a>
                <a href="{{ path('evaluation_performance_index') }}" class="tab-btn {% if active_tab == 'evaluation' %}active{% endif %}">
                    <span class="tab-icon">⭐</span> Evaluations
                </a>
                <a href="#" class="tab-btn">
                    <span class="tab-icon">📊</span> Dashboard
                </a>
                <a href="#" class="tab-btn">
                    <span class="tab-icon">📅</span> Calendrier
                </a>
            </div>
            {% endblock %}

            {% block management_content %}{% endblock %}
        </main>
    </div>

    <script>
        const sidebarToggleBtn = document.querySelector('.sidebar-toggle');
        if (sidebarToggleBtn) {
            sidebarToggleBtn.addEventListener('click', () => {
                const body = document.body;
                const isCollapsed = body.getAttribute('data-collapsed') === 'true';
                body.setAttribute('data-collapsed', String(!isCollapsed));
                localStorage.setItem('sidebarCollapsed', String(!isCollapsed));
            });
        }

        // Restore sidebar state
        const savedState = localStorage.getItem('sidebarCollapsed');
        if (savedState === 'true') {
            document.body.setAttribute('data-collapsed', 'true');
        }
    </script>
</body>
</html>
