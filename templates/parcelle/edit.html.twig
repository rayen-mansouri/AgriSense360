{% extends 'base.html.twig' %}
{% block title %}Modifier Parcelle{% endblock %}

{% block content %}

<div style="max-width:680px; margin:40px auto; padding:0 20px;">

    <a href="{{ path('parcelle_index') }}" style="color:#5a9814; text-decoration:none; font-size:14px;">
        ← Retour aux parcelles
    </a>

    <div class="popup-content" style="margin-top:20px;">
        <h2 class="popup-title">✏️ Modifier : {{ parcelle.nom }}</h2>

        {% if errors is defined and errors|length > 0 %}
        <div style="background:#ffeaea; border:1px solid #f44336; border-radius:10px; padding:14px; margin-bottom:20px;">
            {% for error in errors %}
                <p style="color:#d32f2f; margin:4px 0; font-size:14px;">⚠️ {{ error }}</p>
            {% endfor %}
        </div>
        {% endif %}

        <form method="POST" action="{{ path('parcelle_edit', {id: parcelle.id}) }}"
              style="display:flex; flex-direction:column; gap:18px;">

            <div>
                <label class="form-label" for="nom">Nom *</label>
                <input type="text" name="nom" id="nom" class="form-field"
                       value="{{ parcelle.nom }}"
                       style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px;" required>
            </div>

            <div>
                <label class="form-label" for="surface">Surface (m²) *</label>
                <input type="number" name="surface" id="surface" class="form-field"
                       value="{{ parcelle.surface }}" min="1" step="0.01"
                       style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px;" required>
                <small style="color:#888; font-size:12px;">
                    Surface restante actuelle : {{ parcelle.surfaceRestant|number_format(2) }} m²
                </small>
            </div>

            <div>
                <label class="form-label" for="localisation">Localisation</label>
                <select name="localisation" id="localisation" class="form-field"
                        style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px; background:white;">
                    <option value="">-- Choisir --</option>
                    {% for gov in ['Ariana','Béja','Ben Arous','Bizerte','Gabès','Gafsa','Jendouba',
                                   'Kairouan','Kasserine','Kébili','Le Kef','Mahdia','Manouba',
                                   'Médenine','Monastir','Nabeul','Sfax','Sidi Bouzid','Siliana',
                                   'Sousse','Tataouine','Tozeur','Tunis','Zaghouan'] %}
                        <option value="{{ gov }}" {% if parcelle.localisation == gov %}selected{% endif %}>
                            {{ gov }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="form-label" for="type_sol">Type de sol</label>
                <select name="type_sol" id="type_sol" class="form-field"
                        style="width:100%; border:1px solid #ddd; border-radius:8px; padding:10px 14px; background:white;">
                    <option value="">-- Choisir --</option>
                    {% for sol in ['Argileux','Sableux','Limoneux','Calcaire','Humifère','Tourbeux'] %}
                        <option value="{{ sol }}" {% if parcelle.typeSol == sol %}selected{% endif %}>
                            {{ sol }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div style="display:flex; gap:12px; justify-content:flex-end; margin-top:8px;">
                <a href="{{ path('parcelle_index') }}"
                   style="padding:12px 24px; border:1px solid #ccc; border-radius:25px; text-decoration:none; color:#555;">
                    Annuler
                </a>
                <button type="submit" class="add-button">💾 Sauvegarder</button>
            </div>

        </form>
    </div>
</div>

{% endblock %}
