{% extends 'base.html.twig' %}

{% set activePage = 'parcelles' %}
{% set activeSection = 'main' %}

{% block title %}Gestion des Parcelles — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
<style>
    body { 
        font-family: 'Inter', sans-serif; 
        background: var(--pg); 
        color: var(--pc); 
        transition: background .3s, color .3s; 
        margin: 0; 
        min-height: 100vh; 
        overflow-x: hidden; 
    }

    /* Main wrapper to use full width and match front layout */
    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    .page-header-left { display: flex; flex-direction: column; gap: 4px; }
    .page-title { font-size: 1.75rem; font-weight: 800; color: var(--ch3); margin-bottom: 4px; }
    .page-subtitle { color: var(--cp); font-size: 0.9rem; }
    .page-breadcrumb { color: var(--cp); font-size: 0.85rem; }
    .page-breadcrumb a { color: var(--g); text-decoration: none; }
    .page-breadcrumb a:hover { text-decoration: underline; }

    /* Toolbar */
    .toolbar { background: var(--cb); padding: 16px; border-radius: 12px; margin-bottom: 24px; border: 1px solid var(--cbr); display: flex; gap: 10px; flex-wrap: wrap; }
    .search-wrap { position: relative; flex: 1; min-width: 200px; }
    .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--cp); pointer-events: none; }
    .search-input { width: 100%; padding: 10px 14px 10px 36px; border: 1px solid var(--cbr); border-radius: 8px; background: var(--fi); color: var(--ch3); font-size: 0.9rem; }
    .search-input::placeholder { color: var(--cp); }
    .search-input:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 2px rgba(90,181,90,0.15); }

    /* Sort group */
    .sort-group { display: flex; gap: 8px; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border-radius: 12px; border: 1px solid transparent; font-family: inherit; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; border: none; box-shadow: 0 4px 12px rgba(62,142,62,0.2); }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(62,142,62,0.3); }
    .btn-secondary { background: var(--cb); color: var(--ch3); border: 1px solid var(--cbr); }
    .btn-secondary:hover { background: rgba(90,181,90,0.1); border-color: var(--g); color: var(--g); }
    .btn-secondary.active { background: rgba(90,181,90,0.15); border-color: var(--g); color: var(--g); }
    .btn-sm { padding: 6px 12px; font-size: 0.82rem; }
    .btn-danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
    .btn-danger:hover { background: #ef4444; color: #fff; }

    /* Card grid */
    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }

    /* Parcelle card styling */
    .parcelle-card { 
        background: var(--cb); 
        border: 1px solid var(--cbr); 
        border-radius: 20px; 
        padding: 24px; 
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        display: flex;
        flex-direction: column;
    }
    .parcelle-card:hover { 
        transform: translateY(-8px); 
        box-shadow: 0 15px 35px rgba(0,0,0,0.3); 
        border-color: var(--g);
    }
    .parcelle-card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; margin-bottom: 20px; }
    .parcelle-card-name { font-size: 1.15rem; font-weight: 700; color: var(--ch3); }
    
    .statut-badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 700; }
    .statut-libre { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
    .statut-occupee { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

    /* Info grid */
    .parcelle-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; margin: 15px 0; }
    .parcelle-info-item { display: flex; flex-direction: column; gap: 2px; }
    .parcelle-info-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--cp); }
    .parcelle-info-value { font-size: 0.95rem; font-weight: 600; color: var(--ch3); }

    /* Occupation bar */
    .occupation-wrap { margin-top: 15px; }
    .occupation-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .occupation-label { font-size: 0.7rem; font-weight: 700; color: var(--cp); text-transform: uppercase; }
    .occupation-value { font-size: 0.85rem; font-weight: 800; }
    .progress-track { height: 8px; background: var(--fi); border-radius: 10px; overflow: hidden; border: 1px solid var(--cbr); }
    .progress-fill { height: 100%; border-radius: 10px; transition: width 1s ease-out; }

    /* Card footer */
    .parcelle-card-footer {
        display: flex;
        gap: 10px;
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid var(--cbr);
    }
    .parcelle-card-footer form { margin: 0; }

    /* Empty state */
    .empty-state { grid-column: 1 / -1; text-align: center; padding: 80px 20px; }
    .empty-icon { font-size: 4rem; margin-bottom: 20px; opacity: 0.5; }
    .empty-title { font-size: 1.5rem; font-weight: 700; color: var(--ch3); margin-bottom: 10px; }
    .empty-subtitle { color: var(--cp); font-size: 1rem; }

    /* Modals */
    .modal-backdrop { 
        position: fixed; top: 0; left: 0; right: 0; bottom: 0; 
        background: rgba(0,0,0,0.8); 
        backdrop-filter: blur(8px);
        z-index: 10000 !important; 
        display: none; 
        align-items: center; justify-content: center; 
        padding: 20px; 
    }
    .modal { 
        background: var(--cb); 
        backdrop-filter: blur(15px);
        box-shadow: 0 30px 70px rgba(0,0,0,0.6); 
        border-radius: 28px; 
        width: 100%; max-width: 560px; 
        max-height: 90vh; 
        overflow-y: auto; 
        border: 1px solid var(--cbr);
        position: relative;
        display: none;
        flex-direction: column;
        animation: modalScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes modalScale {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal-backdrop.active { display: flex !important; }
    .modal-backdrop.active .modal { display: flex !important; }
    .modal-header { 
        padding: 24px 32px; 
        display: flex; align-items: center; justify-content: space-between; 
        border-bottom: 1px solid var(--cbr); 
        background: linear-gradient(135deg, var(--gd), var(--g));
        color: #fff;
    }
    .modal-title { color: #fff; font-weight: 800; font-size: 1.5rem; }
    .modal-close { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.8rem; cursor: pointer; transition: all 0.2s; }
    .modal-close:hover { color: #fff; transform: rotate(90deg); }
    .modal-body { padding: 32px; }
    .modal-footer { padding: 20px 32px; background: var(--fi); border-top: 1px solid var(--cbr); display: flex; justify-content: flex-end; gap: 12px; }

    /* Form */
    .form-group { margin-bottom: 20px; }
    .form-group label { font-size: 0.9rem; font-weight: 700; color: var(--ch3); margin-bottom: 8px; display: block; }
    .form-control { 
        width: 100%; background: var(--fi); border: 1.5px solid var(--cbr); 
        border-radius: 12px; padding: 12px 16px; color: var(--ch3); font-weight: 500; transition: all 0.2s;
    }
    .form-control:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1); }
    
    .btn-submit { 
        background: #ff8c00; color: #fff; border: none; padding: 12px 28px; border-radius: 50px; 
        font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(255,140,0,0.3);
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,140,0,0.4); }

    /* Detail Modal Styles */
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 25px; }
    .detail-item { display: flex; flex-direction: column; gap: 4px; }
    .detail-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--cp); }
    .detail-value { font-size: 1.1rem; font-weight: 700; color: var(--ch3); }
    .cultures-list { margin-top: 20px; }
    .culture-mini-card { background: rgba(255,255,255,0.05); border: 1px solid var(--cbr); border-radius: 12px; padding: 12px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
</style>
{% endblock %}

{% block body %}
{% if is_granted('ROLE_ADMIN') %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}
    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>
        <div class="content-wrapper" style="padding-top:20px !important;">
{% else %}
    {% include 'partials/home_nav.html.twig' %}
    <main class="front-main">
        <div class="front-main-container">
{% endif %}

        {# ── Page header ── #}
        <div class="page-header">
            <div class="page-header-left">
                <p class="page-breadcrumb">
                    <a href="{{ path('app_home') }}">🏠 Accueil</a> / Parcelles
                </p>
                <h1 class="page-title">🗺️ Gestion des Parcelles</h1>
                <p class="page-subtitle">{{ parcelles|length }} parcelle(s) enregistrée(s) dans votre exploitation</p>
            </div>
            <div style="display:flex;gap:10px;align-items:center;">
                <a href="{{ path('culture_index') }}" class="btn btn-secondary">🌱 Voir les cultures</a>
                <button class="btn btn-primary" onclick="openModal('modal-add')">➕ Nouvelle parcelle</button>
            </div>
        </div>

        {# ── Flash messages ── #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding:15px 20px; margin-bottom:24px; border-radius:12px; font-weight:600; 
                    background: {{ type == 'success' ? 'rgba(34, 197, 94, 0.1)' : 'rgba(239, 68, 68, 0.1)' }};
                    border: 1px solid {{ type == 'success' ? 'rgba(34, 197, 94, 0.2)' : 'rgba(239, 68, 68, 0.2)' }};
                    color: {{ type == 'success' ? '#22c55e' : '#ef4444' }};">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# ── Toolbar ── #}
        <div class="toolbar">
            <form method="get" action="{{ path('parcelle_index') }}" style="flex:1;display:flex;gap:12px;flex-wrap:wrap;">
                <div class="search-wrap">
                    <span class="search-icon">🔍</span>
                    <input type="text" name="search" value="{{ search }}" class="search-input"
                           placeholder="Rechercher par nom ou gouvernorat…" autocomplete="off">
                </div>
                <div class="sort-group">
                    <button type="submit" name="sort" value="statut"
                            class="btn btn-secondary {% if sort == 'statut' %}active{% endif %}">🔵 Statut</button>
                    <button type="submit" name="sort" value="surface"
                            class="btn btn-secondary {% if sort == 'surface' %}active{% endif %}">📐 Surface</button>
                    {% if sort or search %}
                        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">↺ Reset</a>
                    {% endif %}
                </div>
            </form>
        </div>

        {# ── Card grid ── #}
        <div class="card-grid">
            {% if parcelles is empty %}
                <div class="empty-state">
                    <div class="empty-icon">🗺️</div>
                    <div class="empty-title">Aucune parcelle trouvée</div>
                    <div class="empty-subtitle">Commencez par ajouter votre première parcelle de terrain.</div>
                </div>
            {% endif %}

            {% for parcelle in parcelles %}
                <div class="parcelle-card" ondblclick="openDetailModal({{ parcelle.id }})" style="cursor: pointer;" title="Double-cliquez pour plus de détails">
                    <div class="parcelle-card-header">
                        <div class="parcelle-card-name">{{ parcelle.nom }}</div>
                        <span class="statut-badge {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}">
                            {{ parcelle.statut == 'Libre' ? '🟢 Libre' : '🟠 Occupée' }}
                        </span>
                    </div>

                    <div class="parcelle-info-grid">
                        <div class="parcelle-info-item">
                            <span class="parcelle-info-label">📐 Surface Totale</span>
                            <span class="parcelle-info-value">{{ parcelle.surface|number_format(0, ',', ' ') }} m²</span>
                        </div>
                        <div class="parcelle-info-item">
                            <span class="parcelle-info-label">📍 Gouvernorat</span>
                            <span class="parcelle-info-value">{{ parcelle.localisation }}</span>
                        </div>
                        <div class="parcelle-info-item">
                            <span class="parcelle-info-label">🌍 Type de Sol</span>
                            <span class="parcelle-info-value">{{ parcelle.typeSol }}</span>
                        </div>
                        <div class="parcelle-info-item">
                            <span class="parcelle-info-label">🌱 Cultures</span>
                            <span class="parcelle-info-value">{{ parcelle.cultures|length }} active(s)</span>
                        </div>
                    </div>

                    {% set taux = parcelle.tauxOccupation %}
                    <div class="occupation-wrap">
                        <div class="occupation-header">
                            <span class="occupation-label">📊 Taux d'occupation</span>
                            <span class="occupation-value" style="color: {{ taux >= 90 ? '#ef4444' : (taux >= 60 ? '#f59e0b' : '#22c55e') }}">
                                {{ taux }}%
                            </span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: {{ taux }}%; background: {{ taux >= 90 ? '#ef4444' : (taux >= 60 ? '#f59e0b' : '#22c55e') }}"></div>
                        </div>
                    </div>

                    <div class="parcelle-card-footer">
                        <a href="{{ path('parcelle_show', {id: parcelle.id}) }}" class="btn btn-secondary btn-sm" style="flex:1; justify-content: center;">🔍 Détails</a>
                        <button class="btn btn-secondary btn-sm" onclick="openEditModal({{ parcelle.id }}, '{{ parcelle.nom|e('js') }}', {{ parcelle.surface }}, '{{ parcelle.localisation|e('js') }}', '{{ parcelle.typeSol|e('js') }}')">✏️ Modifier</button>
                        <form method="post" action="{{ path('parcelle_delete', {id: parcelle.id}) }}" onsubmit="return confirm('Supprimer cette parcelle ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('del-parcelle-' ~ parcelle.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>

    </div>
</main>

{# ── Modal: Add Parcelle ── #}
<div id="modal-add" class="modal-backdrop">
    <div class="modal">
        <div class="modal-header">
            <h2 class="modal-title">+ Nouvelle Parcelle</h2>
            <button class="modal-close" onclick="closeModal('modal-add')">✕</button>
        </div>
        <form method="post" action="{{ path('parcelle_new') }}">
            <div class="modal-body">
                <div class="form-group">
                    <label>Nom de la parcelle *</label>
                    <input type="text" name="nom" class="form-control" placeholder="Ex: Parcelle Nord" required>
                </div>
                <div class="form-group">
                    <label>Surface totale (m²) *</label>
                    <input type="number" name="surface" class="form-control" placeholder="Ex: 5000" step="0.01" required>
                </div>
                <div class="form-group">
                    <label>Gouvernorat *</label>
                    <select name="localisation" class="form-control" required>
                        <option value="">-- Sélectionner --</option>
                        {% for g in gouvernorats %}
                            <option value="{{ g }}">{{ g }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label>Type de sol *</label>
                    <select name="type_sol" class="form-control" required>
                        <option value="">-- Sélectionner --</option>
                        {% for t in typesSol %}
                            <option value="{{ t }}">{{ t }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-add')">Annuler</button>
                <button type="submit" class="btn-submit">✓ Enregistrer</button>
            </div>
        </form>
    </div>
</div>

{# ── Modal: Edit Parcelle ── #}
<div id="modal-edit" class="modal-backdrop">
    <div class="modal">
        <div class="modal-header">
            <h2 class="modal-title">✏️ Modifier la Parcelle</h2>
            <button class="modal-close" onclick="closeModal('modal-edit')">✕</button>
        </div>
        <form id="edit-form" method="post" action="">
            <div class="modal-body">
                <div class="form-group">
                    <label>Nom *</label>
                    <input type="text" name="nom" id="edit-nom" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Surface totale (m²) *</label>
                    <input type="number" name="surface" id="edit-surface" class="form-control" step="0.01" required>
                </div>
                <div class="form-group">
                    <label>Gouvernorat *</label>
                    <select name="localisation" id="edit-localisation" class="form-control" required>
                        {% for g in gouvernorats %}
                            <option value="{{ g }}">{{ g }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-group">
                    <label>Type de sol *</label>
                    <select name="type_sol" id="edit-type-sol" class="form-control" required>
                        {% for t in typesSol %}
                            <option value="{{ t }}">{{ t }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit')">Annuler</button>
                <button type="submit" class="btn-submit">✓ Enregistrer</button>
            </div>
        </form>
    </div>
</div>

{# ── Modal: Quick Details ── #}
<div id="modal-detail" class="modal-backdrop">
    <div class="modal" style="max-width: 650px;">
        <div class="modal-header">
            <h2 class="modal-title" id="detail-title">Détails de la Parcelle</h2>
            <button class="modal-close" onclick="closeModal('modal-detail')">✕</button>
        </div>
        <div class="modal-body">
            <div class="detail-grid">
                <div class="detail-item"><span class="detail-label">📍 Localisation</span><span class="detail-value" id="detail-loc">—</span></div>
                <div class="detail-item"><span class="detail-label">🌍 Type de Sol</span><span class="detail-value" id="detail-sol">—</span></div>
                <div class="detail-item"><span class="detail-label">📐 Surface Totale</span><span class="detail-value" id="detail-surf">—</span></div>
                <div class="detail-item"><span class="detail-label">📏 Surface Restante</span><span class="detail-value" id="detail-rest">—</span></div>
            </div>
            
            <div class="cultures-list">
                <h3 style="font-size: 1rem; color: var(--ch3); margin-bottom: 15px; border-bottom: 1px solid var(--cbr); padding-bottom: 8px;">🌱 Cultures en cours</h3>
                <div id="detail-cultures-container">
                    {# Dynamic #}
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('modal-detail')">Fermer</button>
            <a href="#" id="detail-full-btn" class="btn btn-primary">Voir Fiche Complète</a>
        </div>
    </div>
</div>

<script>
    // JS Data
    const PARCELLES = [
        {% for p in parcelles %}
        {
            id: {{ p.id }},
            nom: "{{ p.nom|e('js') }}",
            surface: {{ p.surface }},
            restant: {{ p.surfaceRestant }},
            loc: "{{ p.localisation|e('js') }}",
            sol: "{{ p.typeSol|e('js') }}",
            cultures: [
                {% for c in p.cultures %}
                { nom: "{{ c.nom|e('js') }}", surface: {{ c.surface }} }{% if not loop.last %},{% endif %}
                {% endfor %}
            ]
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    function openModal(id) { document.getElementById(id).classList.add('active'); }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }

    function openEditModal(id, nom, surface, loc, sol) {
        const form = document.getElementById('edit-form');
        form.action = "/parcelle/" + id + "/edit";
        document.getElementById('edit-nom').value = nom;
        document.getElementById('edit-surface').value = surface;
        document.getElementById('edit-localisation').value = loc;
        document.getElementById('edit-type-sol').value = sol;
        openModal('modal-edit');
    }

    function openDetailModal(id) {
        const p = PARCELLES.find(x => x.id === id);
        if (!p) return;

        document.getElementById('detail-title').innerText = "🗺️ " + p.nom;
        document.getElementById('detail-loc').innerText = p.loc;
        document.getElementById('detail-sol').innerText = p.sol;
        document.getElementById('detail-surf').innerText = p.surface + " m²";
        document.getElementById('detail-rest').innerText = p.restant.toFixed(2) + " m²";
        document.getElementById('detail-full-btn').href = "/parcelle/" + p.id;

        const container = document.getElementById('detail-cultures-container');
        container.innerHTML = '';
        if (p.cultures.length === 0) {
            container.innerHTML = '<p style="color: var(--cp); font-style: italic;">Aucune culture sur cette parcelle.</p>';
        } else {
            p.cultures.forEach(c => {
                container.innerHTML += `
                    <div class="culture-mini-card">
                        <span style="font-weight: 700; color: var(--ch3);">${c.nom}</span>
                        <span style="font-size: 0.85rem; color: var(--g); font-weight: 700;">${c.surface} m²</span>
                    </div>
                `;
            });
        }
        openModal('modal-detail');
    }

    // Theme toggle matching home_nav
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
</script>

{% if is_granted('ROLE_ADMIN') %}
        </div>
    </main>
</div>
{% else %}
    </div>
</main>
{% endif %}

<script>
    /* ── SIDEBAR & THEME TOGGLES (Admin) ── */
    const sidebarToggle = document.getElementById('sidebarToggle');
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle('open');
            } else {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');
            }
        });
    }
    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const html = document.documentElement;
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endblock %}
