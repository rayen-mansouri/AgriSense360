{% extends 'base.html.twig' %}

{% block title %}Parcelles{% endblock %}

{% block content %}
<style>
/* ── Card footer ─────────────────────────────── */
.parcelle-card-footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
}

/* Full-width rows */
.parcelle-card-footer .btn-full  { grid-column: 1 / -1; }
.parcelle-card-footer .btn-icon  { grid-column: auto; }

.parcelle-card-footer .btn {
    text-align: center;
    font-size: 0.78rem;
    padding: 7px 6px;
    border-radius: 8px;
    white-space: nowrap;
    transition: transform .15s, opacity .15s;
}
.parcelle-card-footer .btn:hover { transform: translateY(-1px); }

/* Historique button — teal */
.btn-historique {
    background: linear-gradient(135deg, #1ABC9C, #16A085) !important;
    color: #fff !important;
    border: none !important;
    font-weight: 600;
}
.btn-historique:hover { opacity: .9; }

/* Delete button */
.btn-danger {
    background: linear-gradient(135deg, #E74C3C, #c0392b) !important;
    color: #fff !important;
    border: none !important;
}
.btn-danger:hover { opacity: .9; }

/* ── Validation styles ───────────────────────── */
.field-error {
    display: none;
    color: #e53935;
    font-size: 0.78rem;
    margin-top: 5px;
    padding: 4px 8px;
    background: #ffebee;
    border-left: 3px solid #e53935;
    border-radius: 0 4px 4px 0;
    font-weight: 500;
}
.field-error.visible {
    display: block;
}
.input-invalid {
    border-color: #e53935 !important;
    background: #fff8f8 !important;
}
.input-valid {
    border-color: #43a047 !important;
}
</style>

{# ── Page header ───────────────────────────────────────────────────────── #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('home') }}">🏠 Accueil</a> / Parcelles
        </p>
        <h1 class="page-title">🗺️ Parcelles</h1>
        <p class="page-subtitle">{{ parcelles|length }} parcelle(s) enregistrée(s)</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="{{ path('culture_index') }}" class="btn btn-secondary">🌱 Voir les cultures</a>
        <button class="btn btn-secondary" onclick="openCarteModal()">🗺️ Visualiser carte</button>
        <button class="btn btn-primary" onclick="openModal('modal-add')">➕ Nouvelle parcelle</button>
    </div>
</div>

{# ── Flash messages ────────────────────────────────────────────────────── #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:12px 18px;margin-bottom:12px;border-radius:8px;
             background:{{ type == 'success' ? '#e8f5e9' : '#ffebee' }};
             border-left:4px solid {{ type == 'success' ? '#4CAF50' : '#f44336' }};
             color:{{ type == 'success' ? '#2e7d32' : '#c62828' }};font-weight:500;">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ── Toolbar ───────────────────────────────────────────────────────────── #}
<div class="toolbar">
    <form method="get" action="{{ path('parcelle_index') }}" style="flex:1;display:flex;gap:10px;flex-wrap:wrap;">
        <div class="search-wrap" style="flex:1;min-width:200px;">
            <span class="search-icon">🔍</span>
            <input type="text" name="search" value="{{ search }}" class="search-input"
                   placeholder="Rechercher par nom ou gouvernorat…" autocomplete="off">
        </div>
        <div class="sort-group">
            <button type="submit" name="sort" value="statut"
                    class="btn btn-secondary {% if sort == 'statut' %}active{% endif %}">🔵 Statut</button>
            <button type="submit" name="sort" value="surface"
                    class="btn btn-secondary {% if sort == 'surface' %}active{% endif %}">📐 Surface</button>
            {% if sort or search %}
                <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">↺ Reset</a>
            {% endif %}
        </div>
    </form>
</div>

{% if parcelles|length > 0 %}
<div style="margin-bottom:10px;color:#888;font-size:0.82rem;text-align:center;">
    💡 Double-cliquez sur une carte pour voir les détails et les cultures
</div>
{% endif %}

{# ── JS data ───────────────────────────────────────────────────────────── #}
<script>
const PARCELLES_DATA = [
    {% for p in parcelles %}
    {
        id: {{ p.id }},
        nom: {{ p.nom|json_encode|raw }},
        surface: {{ p.surface }},
        surfaceRestant: {{ p.surfaceRestant }},
        taux: {{ p.tauxOccupation }},
        localisation: {{ p.localisation|json_encode|raw }},
        typeSol: {{ p.typeSol|json_encode|raw }},
        statut: {{ p.statut|json_encode|raw }},
        cultures: {{ p.cultures|json_encode|raw }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
];
</script>

{# ── Card grid ─────────────────────────────────────────────────────────── #}
<div class="card-grid">

    {% if parcelles is empty %}
        <div class="empty-state">
            <div class="empty-icon">🗺️</div>
            <div class="empty-title">Aucune parcelle trouvée</div>
            <div class="empty-subtitle">Ajoutez votre première parcelle pour commencer</div>
        </div>
    {% endif %}

    {% for parcelle in parcelles %}
    <div class="parcelle-card"
         style="cursor:pointer;"
         title="Double-cliquez pour voir les détails"
         ondblclick="openDetailModal({{ parcelle.id }})">

        <div class="parcelle-card-header">
            <div class="parcelle-card-name">{{ parcelle.nom }}</div>
            <span class="parcelle-statut {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}">
                {{ parcelle.statut == 'Libre' ? '🟢' : '🟠' }} {{ parcelle.statut }}
            </span>
        </div>

        <div class="parcelle-info-grid">
            <div class="parcelle-info-item">
                <span class="meta-label">📐 Surface totale</span>
                <span class="meta-value">{{ parcelle.surface|number_format(0,',') }} m²</span>
            </div>
            <div class="parcelle-info-item">
                <span class="meta-label">📏 Restante</span>
                <span class="meta-value">{{ parcelle.surfaceRestant|number_format(2,',') }} m²</span>
            </div>
            <div class="parcelle-info-item">
                <span class="meta-label">📍 Localisation</span>
                <span class="meta-value">{{ parcelle.localisation }}</span>
            </div>
            <div class="parcelle-info-item">
                <span class="meta-label">🌍 Type de sol</span>
                {% set solClass = parcelle.typeSol == 'Sol Limoneux' ? 'sol-limoneux'
                               : (parcelle.typeSol == 'Sol Argileux' ? 'sol-argileux' : 'sol-sablonneux') %}
                <span class="type-sol-badge {{ solClass }}">{{ parcelle.typeSol }}</span>
            </div>
        </div>

        {% set taux = parcelle.tauxOccupation %}
        <div class="progress-wrap">
            <div class="progress-label">
                <span>📊 Occupation</span>
                <span>{{ taux }}%</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width:{{ taux }}%;
                    {% if taux >= 90 %}background:var(--red-600){% elseif taux >= 60 %}background:var(--amber){% endif %}">
                </div>
            </div>
        </div>

        {% set culturesCount = parcelle.cultures|length %}

        {# ── Footer: 2×2 grid of buttons ─────────────────────────────── #}
        <div class="parcelle-card-footer" onclick="event.stopPropagation();">

            {# Row 1: Détails + Modifier #}
            <a href="{{ path('parcelle_show', {id: parcelle.id}) }}"
               class="btn btn-secondary btn-sm">
                🔍 Détails
            </a>

            <button class="btn btn-secondary btn-sm"
                    onclick="openEditModal({{ parcelle.id }},
                        '{{ parcelle.nom|e('js') }}',
                        {{ parcelle.surface }},
                        '{{ parcelle.localisation|e('js') }}',
                        '{{ parcelle.typeSol|e('js') }}',
                        '{{ parcelle.statut|e('js') }}',
                        {{ parcelle.surfaceRestant }},
                        {{ culturesCount }})">
                ✏️ Modifier
            </button>

            {# Row 2: Historique (full width) #}
            <a href="{{ path('parcelle_historique', {id: parcelle.id}) }}"
               class="btn btn-historique btn-sm btn-full">
                📋 Historique
            </a>

            {# Row 3: Delete (full width) #}
            <form method="post" action="{{ path('parcelle_delete', {id: parcelle.id}) }}"
                  onsubmit="return confirmDelete('{{ parcelle.nom|e('js') }}', {{ culturesCount }})"
                  style="margin:0; grid-column: 1 / -1;">
                <input type="hidden" name="_token" value="{{ csrf_token('del-parcelle-' ~ parcelle.id) }}">
                <button type="submit" class="btn btn-danger btn-sm" style="width:100%;">
                    🗑️ Supprimer
                </button>
            </form>

        </div>
    </div>
    {% endfor %}

</div>{# end .card-grid #}


{# ════════════════════════════════════════════════════════════
   MODAL — Ajouter une parcelle
   ════════════════════════════════════════════════════════════ #}
<div id="modal-add" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;overflow-y:auto;">
    <div style="background:#fff;border-radius:16px;width:95%;max-width:560px;margin:auto;box-shadow:0 8px 40px rgba(0,0,0,.18);overflow:hidden;">
        <div style="padding:20px 24px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center;">
            <h2 style="margin:0;font-size:1.15rem;">➕ Nouvelle Parcelle</h2>
            <button onclick="closeModal('modal-add')" style="background:none;border:none;font-size:1.3rem;cursor:pointer;line-height:1;">✕</button>
        </div>
        <form method="post" action="{{ path('parcelle_new') }}" id="form-add" novalidate>
            <div style="padding:24px;display:flex;flex-direction:column;gap:16px;">

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Nom de la parcelle *</label>
                    <input type="text" name="nom" id="add-nom" placeholder="Ex: Parcelle Nord"
                           style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;transition:border-color .2s;">
                    <div class="field-error" id="add-nom-error">⚠️ Le nom doit contenir au moins 3 caractères.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Surface totale (m²) *</label>
                    <input type="number" name="surface" id="add-surface" placeholder="Ex: 5000" step="0.01"
                           style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;transition:border-color .2s;">
                    <div class="field-error" id="add-surface-error">⚠️ Veuillez entrer un nombre positif supérieur à 0.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Gouvernorat *</label>
                    <select name="localisation" id="add-localisation"
                            style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;background:#fff;transition:border-color .2s;">
                        <option value="">-- Sélectionner --</option>
                        {% for g in gouvernorats %}
                            <option value="{{ g }}">{{ g }}</option>
                        {% endfor %}
                    </select>
                    <div class="field-error" id="add-localisation-error">⚠️ Veuillez sélectionner un gouvernorat.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Type de sol *</label>
                    <select name="type_sol" id="add-typesol"
                            style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;background:#fff;transition:border-color .2s;">
                        <option value="">-- Sélectionner --</option>
                        {% for t in typesSol %}
                            <option value="{{ t }}">{{ t }}</option>
                        {% endfor %}
                    </select>
                    <div class="field-error" id="add-typesol-error">⚠️ Veuillez sélectionner un type de sol.</div>
                </div>

            </div>
            <div style="padding:16px 24px;border-top:1px solid #eee;display:flex;justify-content:flex-end;gap:10px;">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-add')">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="validateAndSubmitAdd()">✅ Ajouter</button>
            </div>
        </form>
    </div>
</div>

{# ════════════════════════════════════════════════════════════
   MODAL — Modifier une parcelle
   ════════════════════════════════════════════════════════════ #}
<div id="modal-edit" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;overflow-y:auto;">
    <div style="background:#fff;border-radius:16px;width:95%;max-width:560px;margin:auto;box-shadow:0 8px 40px rgba(0,0,0,.18);overflow:hidden;">
        <div style="padding:20px 24px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center;">
            <h2 style="margin:0;font-size:1.15rem;">✏️ Modifier la Parcelle</h2>
            <button onclick="closeModal('modal-edit')" style="background:none;border:none;font-size:1.3rem;cursor:pointer;line-height:1;">✕</button>
        </div>
        <form method="post" id="edit-form" action="" novalidate>
            <div style="padding:24px;display:flex;flex-direction:column;gap:16px;">

                <div id="cultures-warning" style="display:none;background:#fff3e0;border:1px solid #FFB74D;border-radius:8px;padding:10px 14px;font-size:0.85rem;color:#e65100;">
                    ⚠️ Cette parcelle contient <strong id="cultures-warning-count">0</strong> culture(s). La surface ne peut pas être modifiée.
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Nom *</label>
                    <input type="text" name="nom" id="edit-nom"
                           style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;transition:border-color .2s;">
                    <div class="field-error" id="edit-nom-error">⚠️ Le nom doit contenir au moins 3 caractères.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Surface (m²) *</label>
                    {# Visible input for display/edit — value is mirrored to hidden input for form submission #}
                    <input type="number" id="edit-surface-display" step="0.01"
                           style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;transition:border-color .2s;">
                    <input type="hidden" name="surface" id="edit-surface">
                    <div class="field-error" id="edit-surface-error">⚠️ Veuillez entrer un nombre positif supérieur à 0.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Gouvernorat *</label>
                    <select name="localisation" id="edit-localisation"
                            style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;background:#fff;transition:border-color .2s;">
                        <option value="">-- Sélectionner --</option>
                        {% for g in gouvernorats %}
                            <option value="{{ g }}">{{ g }}</option>
                        {% endfor %}
                    </select>
                    <div class="field-error" id="edit-localisation-error">⚠️ Veuillez sélectionner un gouvernorat.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Type de sol *</label>
                    <select name="type_sol" id="edit-type-sol"
                            style="width:100%;box-sizing:border-box;border:1.5px solid #ddd;border-radius:8px;padding:10px 14px;font-size:.95rem;background:#fff;transition:border-color .2s;">
                        <option value="">-- Sélectionner --</option>
                        {% for t in typesSol %}
                            <option value="{{ t }}">{{ t }}</option>
                        {% endfor %}
                    </select>
                    <div class="field-error" id="edit-type-sol-error">⚠️ Veuillez sélectionner un type de sol.</div>
                </div>

                <div>
                    <label style="display:block;font-weight:600;margin-bottom:6px;font-size:.9rem;">Statut</label>
                    <div id="edit-statut-display" style="padding:10px 14px;border-radius:8px;border:1.5px solid #ccc;display:flex;align-items:center;gap:8px;font-weight:600;">
                        <span id="edit-statut-icon">🟢</span>
                        <span id="edit-statut-text">Libre</span>
                    </div>
                    <input type="hidden" name="statut" id="edit-statut" value="Libre">
                </div>

            </div>
            <div style="padding:16px 24px;border-top:1px solid #eee;display:flex;justify-content:flex-end;gap:10px;">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modal-edit')">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="validateAndSubmitEdit()">💾 Enregistrer</button>
            </div>
        </form>
    </div>
</div>

{# ════════════════════════════════════════════════════════════
   MODAL — Détails (double-clic)
   ════════════════════════════════════════════════════════════ #}
<div id="modal-detail" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;overflow-y:auto;">
    <div style="background:#fff;border-radius:16px;width:95%;max-width:700px;margin:auto;box-shadow:0 8px 40px rgba(0,0,0,.18);overflow:hidden;">
        <div style="padding:20px 24px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center;">
            <h2 style="margin:0;font-size:1.15rem;" id="detail-nom">—</h2>
            <button onclick="closeModal('modal-detail')" style="background:none;border:none;font-size:1.3rem;cursor:pointer;line-height:1;">✕</button>
        </div>
        <div style="padding:24px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                <div><span style="color:#888;font-size:.8rem;">📍 Localisation</span><br><strong id="detail-localisation">—</strong></div>
                <div><span style="color:#888;font-size:.8rem;">🌍 Type de sol</span><br><strong id="detail-type-sol">—</strong></div>
                <div><span style="color:#888;font-size:.8rem;">📐 Surface totale</span><br><strong id="detail-surface">—</strong></div>
                <div><span style="color:#888;font-size:.8rem;">📏 Restante</span><br><strong id="detail-surface-restant">—</strong></div>
                <div><span style="color:#888;font-size:.8rem;">🌱 Cultures</span><br><strong id="detail-cultures-count">—</strong></div>
                <div><span style="color:#888;font-size:.8rem;">📊 Occupation</span><br>
                    <strong id="detail-taux">—</strong>
                    <span id="detail-statut-badge" style="margin-left:8px;padding:2px 8px;border-radius:12px;font-size:.75rem;border:1px solid;">—</span>
                </div>
            </div>
            <div class="progress-bar" style="margin-bottom:16px;">
                <div id="detail-progress-fill" class="progress-fill" style="width:0%;transition:width .4s;"></div>
            </div>
            <div id="detail-cultures-container"></div>
        </div>
        <div style="padding:16px 24px;border-top:1px solid #eee;display:flex;justify-content:flex-end;gap:10px;">
            <button type="button" class="btn btn-secondary" onclick="closeModal('modal-detail')">Fermer</button>
            <button type="button" id="detail-edit-btn" class="btn btn-primary">✏️ Modifier</button>
        </div>
    </div>
</div>

{# ════════════════════════════════════════════════════════════
   MODAL — Carte
   ════════════════════════════════════════════════════════════ #}
<div id="modal-carte" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:16px;width:95%;max-width:1000px;height:80vh;display:flex;flex-direction:column;overflow:hidden;">
        <div style="padding:16px 20px;border-bottom:1px solid #eee;display:flex;justify-content:space-between;align-items:center;">
            <strong>🗺️ Carte des parcelles</strong>
            <button onclick="closeCarteModal()" style="background:none;border:none;font-size:1.3rem;cursor:pointer;">✕</button>
        </div>
        <iframe id="carte-iframe" style="flex:1;border:none;" src=""></iframe>
    </div>
</div>

{# ════════════════════════════════════════════════════════════
   JAVASCRIPT
   ════════════════════════════════════════════════════════════ #}
<script>
/* ── Generic modal helpers ─────────────────────────────────── */
function openModal(id) {
    document.getElementById(id).style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeModal(id) {
    document.getElementById(id).style.display = 'none';
    document.body.style.overflow = '';
}

/* ══════════════════════════════════════════════════════════════
   VALIDATION HELPERS
   ══════════════════════════════════════════════════════════════ */
function setFieldError(inputEl, errorEl, hasError) {
    if (hasError) {
        inputEl.classList.add('input-invalid');
        inputEl.classList.remove('input-valid');
        errorEl.classList.add('visible');
    } else {
        inputEl.classList.remove('input-invalid');
        inputEl.classList.add('input-valid');
        errorEl.classList.remove('visible');
    }
}

/* ══════════════════════════════════════════════════════════════
   AJOUTER — validate & submit
   ══════════════════════════════════════════════════════════════ */
function validateAndSubmitAdd() {
    var nom      = document.getElementById('add-nom');
    var surface  = document.getElementById('add-surface');
    var localisa = document.getElementById('add-localisation');
    var typesol  = document.getElementById('add-typesol');

    var nomErr  = document.getElementById('add-nom-error');
    var surfErr = document.getElementById('add-surface-error');
    var locErr  = document.getElementById('add-localisation-error');
    var solErr  = document.getElementById('add-typesol-error');

    var valid = true;

    // Nom: min 3 chars
    if (nom.value.trim().length < 3) {
        setFieldError(nom, nomErr, true);
        valid = false;
    } else {
        setFieldError(nom, nomErr, false);
    }

    // Surface: positive number
    var surfVal = parseFloat(surface.value);
    if (!surface.value || isNaN(surfVal) || surfVal <= 0) {
        setFieldError(surface, surfErr, true);
        valid = false;
    } else {
        setFieldError(surface, surfErr, false);
    }

    // Gouvernorat: must be chosen
    if (!localisa.value) {
        setFieldError(localisa, locErr, true);
        valid = false;
    } else {
        setFieldError(localisa, locErr, false);
    }

    // Type de sol: must be chosen
    if (!typesol.value) {
        setFieldError(typesol, solErr, true);
        valid = false;
    } else {
        setFieldError(typesol, solErr, false);
    }

    if (valid) {
        document.getElementById('form-add').submit();
    }
}

/* ══════════════════════════════════════════════════════════════
   MODIFIER — validate & submit
   ══════════════════════════════════════════════════════════════ */
function validateAndSubmitEdit() {
    var nom        = document.getElementById('edit-nom');
    var surfDisp   = document.getElementById('edit-surface-display');
    var surfHidden = document.getElementById('edit-surface');
    var localisa   = document.getElementById('edit-localisation');
    var typesol    = document.getElementById('edit-type-sol');

    var nomErr  = document.getElementById('edit-nom-error');
    var surfErr = document.getElementById('edit-surface-error');
    var locErr  = document.getElementById('edit-localisation-error');
    var solErr  = document.getElementById('edit-type-sol-error');

    var valid = true;

    // Nom: min 3 chars
    if (nom.value.trim().length < 3) {
        setFieldError(nom, nomErr, true);
        valid = false;
    } else {
        setFieldError(nom, nomErr, false);
    }

    // Surface — always sync hidden from display first, then validate hidden value
    if (!surfDisp.readOnly) {
        surfHidden.value = surfDisp.value;
    }
    var surfVal = parseFloat(surfHidden.value);
    if (!surfHidden.value || isNaN(surfVal) || surfVal <= 0) {
        setFieldError(surfDisp, surfErr, true);
        valid = false;
    } else {
        setFieldError(surfDisp, surfErr, false);
    }

    // Gouvernorat
    if (!localisa.value) {
        setFieldError(localisa, locErr, true);
        valid = false;
    } else {
        setFieldError(localisa, locErr, false);
    }

    // Type de sol
    if (!typesol.value) {
        setFieldError(typesol, solErr, true);
        valid = false;
    } else {
        setFieldError(typesol, solErr, false);
    }

    if (valid) {
        document.getElementById('edit-form').submit();
    }
}

/* ── Live validation — clear error as user corrects field ───── */
document.addEventListener('DOMContentLoaded', function() {

    /* ADD form live */
    document.getElementById('add-nom').addEventListener('input', function() {
        if (this.value.trim().length >= 3)
            setFieldError(this, document.getElementById('add-nom-error'), false);
    });
    document.getElementById('add-surface').addEventListener('input', function() {
        var v = parseFloat(this.value);
        if (this.value && !isNaN(v) && v > 0)
            setFieldError(this, document.getElementById('add-surface-error'), false);
    });
    document.getElementById('add-localisation').addEventListener('change', function() {
        if (this.value)
            setFieldError(this, document.getElementById('add-localisation-error'), false);
    });
    document.getElementById('add-typesol').addEventListener('change', function() {
        if (this.value)
            setFieldError(this, document.getElementById('add-typesol-error'), false);
    });

    /* EDIT form live */
    document.getElementById('edit-nom').addEventListener('input', function() {
        if (this.value.trim().length >= 3)
            setFieldError(this, document.getElementById('edit-nom-error'), false);
    });
    document.getElementById('edit-surface-display').addEventListener('input', function() {
        var v = parseFloat(this.value);
        if (this.value && !isNaN(v) && v > 0) {
            document.getElementById('edit-surface').value = this.value; // keep hidden in sync
            setFieldError(this, document.getElementById('edit-surface-error'), false);
        }
    });
    document.getElementById('edit-localisation').addEventListener('change', function() {
        if (this.value)
            setFieldError(this, document.getElementById('edit-localisation-error'), false);
    });
    document.getElementById('edit-type-sol').addEventListener('change', function() {
        if (this.value)
            setFieldError(this, document.getElementById('edit-type-sol-error'), false);
    });
});

/* ── Edit modal open ───────────────────────────────────────── */
function openEditModal(id, nom, surface, localisation, typeSol, statut, surfaceRestant, culturesCount) {
    var hasCultures = culturesCount > 0;

    // Clear all previous errors & highlights
    ['edit-nom', 'edit-surface-display', 'edit-localisation', 'edit-type-sol'].forEach(function(eid) {
        var el = document.getElementById(eid);
        if (el) { el.classList.remove('input-invalid', 'input-valid'); }
    });
    ['edit-nom-error', 'edit-surface-error', 'edit-localisation-error', 'edit-type-sol-error'].forEach(function(eid) {
        var el = document.getElementById(eid);
        if (el) el.classList.remove('visible');
    });

    document.getElementById('edit-form').action = '/parcelle/' + id + '/edit';
    document.getElementById('edit-nom').value = nom;

    // Surface: display + hidden (always both populated so validation always passes for existing data)
    var surfDisplay = document.getElementById('edit-surface-display');
    var surfHidden  = document.getElementById('edit-surface');
    surfDisplay.value = surface;
    surfHidden.value  = surface;

    var statusDisplay = document.getElementById('edit-statut-display');
    var warningDiv    = document.getElementById('cultures-warning');
    var warningCount  = document.getElementById('cultures-warning-count');

    if (hasCultures) {
        surfDisplay.readOnly = true;
        surfDisplay.style.opacity  = '0.6';
        surfDisplay.style.background = '#f5f5f5';
        surfDisplay.style.cursor   = 'not-allowed';
        statusDisplay.style.opacity = '0.6';
        warningDiv.style.display   = 'block';
        warningCount.textContent   = culturesCount;
    } else {
        surfDisplay.readOnly = false;
        surfDisplay.style.opacity  = '1';
        surfDisplay.style.background = '';
        surfDisplay.style.cursor   = '';
        statusDisplay.style.opacity = '1';
        warningDiv.style.display   = 'none';
    }

    setTimeout(function() {
        document.getElementById('edit-localisation').value = localisation;
        document.getElementById('edit-type-sol').value = typeSol;
        updateParcelleStatus(surfaceRestant);
    }, 10);

    openModal('modal-edit');
}

function updateParcelleStatus(surfaceRestant) {
    var statusInput   = document.getElementById('edit-statut');
    var statusDisplay = document.getElementById('edit-statut-display');
    var statusIcon    = document.getElementById('edit-statut-icon');
    var statusText    = document.getElementById('edit-statut-text');
    var isLibre       = surfaceRestant > 0.01;

    if (isLibre) {
        statusDisplay.style.background  = '#e8f5e9';
        statusDisplay.style.borderColor = '#4CAF50';
        statusInput.value               = 'Libre';
        statusIcon.textContent          = '🟢';
        statusText.textContent          = 'Libre';
        statusText.style.color          = '#2e7d32';
    } else {
        statusDisplay.style.background  = '#ffebee';
        statusDisplay.style.borderColor = '#f44336';
        statusInput.value               = 'Occupée';
        statusIcon.textContent          = '🟠';
        statusText.textContent          = 'Occupée';
        statusText.style.color          = '#c62828';
    }
}

/* ── Confirm delete ────────────────────────────────────────── */
function confirmDelete(nom, culturesCount) {
    if (culturesCount > 0) {
        return confirm('⚠️ La parcelle "' + nom + '" contient ' + culturesCount + ' culture(s).\nToutes les cultures seront supprimées. Continuer ?');
    }
    return confirm('Supprimer la parcelle "' + nom + '" ?');
}

/* ── Detail modal (double-clic) ────────────────────────────── */
function openDetailModal(parcelleId) {
    var p = PARCELLES_DATA.find(function(x) { return x.id === parcelleId; });
    if (!p) return;

    document.getElementById('detail-nom').textContent             = p.nom;
    document.getElementById('detail-localisation').textContent    = p.localisation;
    document.getElementById('detail-surface').textContent         = p.surface.toLocaleString('fr-FR') + ' m²';
    document.getElementById('detail-surface-restant').textContent = p.surfaceRestant.toFixed(2) + ' m²';
    document.getElementById('detail-type-sol').textContent        = p.typeSol;
    document.getElementById('detail-cultures-count').textContent  = (p.cultures || []).length;

    var tauxEl = document.getElementById('detail-taux');
    var fillEl = document.getElementById('detail-progress-fill');
    tauxEl.textContent      = p.taux + '%';
    tauxEl.style.color      = p.taux >= 90 ? '#e74c3c' : (p.taux >= 60 ? '#f39c12' : '#27ae60');
    fillEl.style.width      = p.taux + '%';
    fillEl.style.background = p.taux >= 90 ? '#e74c3c' : (p.taux >= 60 ? '#f39c12' : '#27ae60');

    var badge = document.getElementById('detail-statut-badge');
    if (p.statut === 'Libre') {
        badge.textContent = '🟢 Libre'; badge.style.background = '#e8f5e9';
        badge.style.color = '#2e7d32'; badge.style.borderColor = '#4CAF50';
    } else {
        badge.textContent = '🟠 Occupée'; badge.style.background = '#fff3e0';
        badge.style.color = '#e65100'; badge.style.borderColor = '#FF9800';
    }

    document.getElementById('detail-edit-btn').onclick = function() {
        closeModal('modal-detail');
        openEditModal(p.id, p.nom, p.surface, p.localisation, p.typeSol, p.statut, p.surfaceRestant, (p.cultures || []).length);
    };

    var container = document.getElementById('detail-cultures-container');
    container.innerHTML = '';
    if (!p.cultures || p.cultures.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:40px;color:#888;"><div style="font-size:2.5rem;">🌾</div><div>Aucune culture</div></div>';
    } else {
        var grid = document.createElement('div');
        grid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;';
        p.cultures.forEach(function(c) {
            var card = document.createElement('div');
            card.style.cssText = 'border:1px solid #ddd;border-radius:10px;padding:12px;background:#fff;';
            card.innerHTML = '<div style="font-weight:600;margin-bottom:6px;">' + c.nom + '</div>'
                + '<div style="font-size:.8rem;color:#666;">📂 ' + (c.typeCulture || 'N/A') + '</div>'
                + '<div style="background:#f5f5f5;border-radius:6px;padding:6px;text-align:center;margin-top:8px;font-size:.85rem;">'
                + '📐 ' + (c.surface || 0) + ' m²</div>';
            grid.appendChild(card);
        });
        container.appendChild(grid);
    }
    openModal('modal-detail');
}

/* ── Carte modal ───────────────────────────────────────────── */
function openCarteModal() {
    var modal  = document.getElementById('modal-carte');
    var iframe = document.getElementById('carte-iframe');
    if (!iframe.getAttribute('data-loaded')) {
        iframe.src = '{{ path('carte_parcelles') }}';
        iframe.setAttribute('data-loaded', '1');
    }
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}
function closeCarteModal() {
    document.getElementById('modal-carte').style.display = 'none';
    document.body.style.overflow = '';
}

/* ── Auto-open edit modal if ?edit_id= in URL ──────────────── */
{% if app.request.query.get('edit_id') %}
window.addEventListener('DOMContentLoaded', function() {
    {% for parcelle in parcelles %}
        {% if parcelle.id == app.request.query.get('edit_id') %}
        openEditModal(
            {{ parcelle.id }},
            '{{ parcelle.nom|e('js') }}',
            {{ parcelle.surface }},
            '{{ parcelle.localisation|e('js') }}',
            '{{ parcelle.typeSol|e('js') }}',
            '{{ parcelle.statut|e('js') }}',
            {{ parcelle.surfaceRestant }},
            {{ parcelle.cultures|length }}
        );
        {% endif %}
    {% endfor %}
});
{% endif %}
</script>

{% endblock %}
