{% extends 'base.html.twig' %}

{% block title %}{{ parcelle.nom }} — Détails{% endblock %}

{% block content %}

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('home') }}">🏠 Accueil</a> /
            <a href="{{ path('parcelle_index') }}">Parcelles</a> /
            {{ parcelle.nom }}
        </p>
        <h1 class="page-title">🗺️ {{ parcelle.nom }}</h1>
        <p class="page-subtitle">{{ cultures|length }} culture(s) sur cette parcelle</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">← Retour aux parcelles</a>
        <a href="{{ path('culture_index') }}" class="btn btn-primary">🌱 Gérer les cultures</a>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   FLASH MESSAGES
   ═══════════════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:12px 18px;margin-bottom:12px;border-radius:8px;
             background:{{ type == 'success' ? '#e8f5e9' : '#ffebee' }};
             border-left:4px solid {{ type == 'success' ? '#4CAF50' : '#f44336' }};
             color:{{ type == 'success' ? '#2e7d32' : '#c62828' }};font-weight:500;">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ═══════════════════════════════════════════════════
   PARCELLE INFO CARD
   ═══════════════════════════════════════════════════ #}
<div style="background:linear-gradient(135deg,var(--green-50) 0%,var(--green-100) 100%);
            border-radius:16px;padding:24px;margin-bottom:28px;
            border-left:5px solid var(--green-600);box-shadow:var(--shadow-sm);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
        <h2 style="margin:0;font-size:1.4rem;font-weight:700;color:var(--text-dark);">
            📋 Informations de la parcelle
        </h2>
        <span class="parcelle-statut {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}"
              style="font-size:0.95rem;padding:6px 14px;">
            {{ parcelle.statut == 'Libre' ? '🟢' : '🟠' }} {{ parcelle.statut }}
        </span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:20px;">
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📐 Surface totale</div>
            <div style="font-size:1.2rem;font-weight:700;color:var(--text-dark);">{{ parcelle.surface|number_format(0,',',' ') }} m²</div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📏 Surface restante</div>
            <div style="font-size:1.2rem;font-weight:700;color:{{ parcelle.surfaceRestant <= 0.01 ? 'var(--red-600)' : 'var(--green-700)' }};">
                {{ parcelle.surfaceRestant|number_format(2,',',' ') }} m²
            </div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📍 Gouvernorat</div>
            <div style="font-size:1rem;font-weight:600;color:var(--text-dark);">{{ parcelle.localisation }}</div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">🌍 Type de sol</div>
            {% set solClass = parcelle.typeSol == 'Sol Limoneux' ? 'sol-limoneux'
                           : (parcelle.typeSol == 'Sol Argileux' ? 'sol-argileux' : 'sol-sablonneux') %}
            <span class="type-sol-badge {{ solClass }}">{{ parcelle.typeSol }}</span>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">🌱 Cultures</div>
            <div style="font-size:1.2rem;font-weight:700;color:var(--text-dark);">{{ cultures|length }}</div>
        </div>
    </div>

    {# Progress bar #}
    {% set taux = parcelle.tauxOccupation %}
    <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="font-size:0.85rem;font-weight:600;color:var(--text-muted);">📊 Taux d'occupation</span>
            <span style="font-weight:700;
                color:{{ taux >= 90 ? 'var(--red-600)' : (taux >= 60 ? 'var(--amber)' : 'var(--green-600)') }};">
                {{ taux }}%
            </span>
        </div>
        <div class="progress-bar">
            <div class="progress-fill" style="width:{{ taux }}%;
                {% if taux >= 90 %}background:var(--red-600){% elseif taux >= 60 %}background:var(--amber){% endif %}">
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   CULTURES LIST
   ═══════════════════════════════════════════════════ #}
<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-dark);margin-bottom:18px;">
    🌱 Cultures sur cette parcelle
</h2>

{% if cultures is empty %}
    <div class="empty-state">
        <div class="empty-icon">🌾</div>
        <div class="empty-title">Aucune culture sur cette parcelle</div>
        <div class="empty-subtitle">
            <a href="{{ path('culture_index') }}" style="color:var(--green-600);text-decoration:none;font-weight:600;">
                ➕ Ajouter une culture
            </a>
        </div>
    </div>
{% else %}
    <div class="card-grid">
        {% for culture in cultures %}
        <div class="culture-card">

            <div class="culture-card-image">
                {% if culture.img %}
                    <img src="{{ asset('images/cultures/' ~ culture.img) }}"
                         alt="{{ culture.nom }}"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <div class="img-fallback" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">
                        🌱
                    </div>
                {% else %}
                    <div class="img-fallback" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">
                        🌱
                    </div>
                {% endif %}
            </div>

            <div class="culture-card-body">
                <span class="culture-card-type">{{ culture.typeCulture }}</span>
                <div class="culture-card-name">{{ culture.nom }}</div>
                {% set etatClass = etatToCssClass(culture.etat) %}
                <span class="etat-badge {{ etatClass }}">{{ culture.etat }}</span>

                <div class="culture-card-meta">
                    <div class="meta-item">
                        <span class="meta-label">📐 Surface</span>
                        <span class="meta-value">{{ culture.surface }} m²</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌱 Plantation</span>
                        <span class="meta-value">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌾 Récolte prévue</span>
                        <span class="meta-value">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
            </div>

            <div class="culture-card-footer">
                {# Harvest action if ready #}
                {% if culture.etat in ['Maturité', 'Récolte Prévue', 'Récolte en Retard'] %}
                <form method="post" action="{{ path('culture_harvest', {id: culture.id}) }}"
                      onsubmit="return confirm('Marquer « {{ culture.nom|e('js') }} » comme récoltée ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('harvest-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-primary btn-sm">🌾 Récolter</button>
                </form>
                {% endif %}

                <form method="post" action="{{ path('culture_delete', {id: culture.id}) }}"
                      onsubmit="return confirm('Supprimer « {{ culture.nom|e('js') }} » ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('del-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
