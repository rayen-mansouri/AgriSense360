{% extends 'base.html.twig' %}

{% block title %}{{ parcelle.nom }} — Détails — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    /* Main wrapper to use full width and match front layout */
    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    /* Page header refinement */
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 20px; }
    .page-header-left { display: flex; flex-direction: column; gap: 8px; }
    .page-title { font-size: 2.2rem; font-weight: 900; color: var(--ch3); margin: 0; letter-spacing: -1px; }
    .page-subtitle { color: var(--cp); font-size: 1rem; font-weight: 500; }
    .page-breadcrumb { color: var(--cp); font-size: 0.9rem; margin-bottom: 5px; font-weight: 600; }
    .page-breadcrumb a { color: var(--g); text-decoration: none; }
    .page-breadcrumb a:hover { text-decoration: underline; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 12px; border: 1px solid transparent; font-family: inherit; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; border: none; box-shadow: 0 4px 15px rgba(90,181,90,0.3); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(90,181,90,0.4); }
    .btn-secondary { background: var(--cb); color: var(--ch3); border: 1px solid var(--cbr); }
    .btn-secondary:hover { background: rgba(90,181,90,0.05); border-color: var(--g); color: var(--g); }
    .btn-danger { background: rgba(231,76,60,0.1) !important; color: #E74C3C !important; border: 1px solid rgba(231,76,60,0.2) !important; }
    .btn-danger:hover { background: #E74C3C !important; color: #fff !important; }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 28px; box-shadow: var(--sh-lg); overflow: hidden; }

    /* Weather refinement */
    .weather-stat-item { background: transparent !important; }
    [data-theme="light"] .weather-hero { background: linear-gradient(135deg, #dcfce7, #bbf7d0); color: #166534; }
    [data-theme="light"] .weather-temp-big { color: #166534; }
    [data-theme="light"] .weather-desc { color: #166534; }
    [data-theme="light"] .weather-stat-value { color: #166534; }
</style>
{% endblock %}

{% block body %}
{% if is_granted('ROLE_ADMIN') %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}
    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>
        <div class="content-wrapper" style="padding-top:20px !important;">
{% else %}
    {% include 'partials/home_nav.html.twig' %}
    <main class="front-main">
        <div class="front-main-container">
{% endif %}

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('app_home') }}">🏠 Accueil</a> /
            <a href="{{ path('parcelle_index') }}">Parcelles</a> /
            {{ parcelle.nom }}
        </p>
        <h1 class="page-title">🗺️ {{ parcelle.nom }}</h1>
        <p class="page-subtitle">{{ cultures|length }} culture(s) sur cette parcelle</p>
    </div>
    <div style="display:flex;gap:15px;align-items:center;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a>
        <a href="{{ path('culture_index') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Gérer les cultures</a>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   FLASH MESSAGES
   ═══════════════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:15px 25px;margin-bottom:25px;border-radius:15px;
             background:{{ type == 'success' ? 'rgba(76,175,80,0.1)' : 'rgba(244,67,54,0.1)' }};
             border:1px solid {{ type == 'success' ? 'rgba(76,175,80,0.2)' : 'rgba(244,67,54,0.2)' }};
             color:{{ type == 'success' ? 'var(--success-c)' : 'var(--danger-c)' }};font-weight:700;display:flex;align-items:center;gap:12px;">
            <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-check-circle' }}"></i>
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ═══════════════════════════════════════════════════
   PARCELLE INFO CARD
   ═══════════════════════════════════════════════════ #}
<div class="card" style="padding: 30px; margin-bottom: 35px;">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;flex-wrap:wrap;gap:15px;">
        <h2 style="margin:0;font-size:1.6rem;font-weight:900;color:var(--ch3); display: flex; align-items: center; gap: 15px; letter-spacing: -0.5px;">
            <span style="background: rgba(90,181,90,0.1); padding: 12px; border-radius: 16px; color: var(--g);">📋</span>
            Informations de la parcelle
        </h2>
        <span class="parcelle-statut {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}"
              style="font-size:0.85rem; padding:8px 22px; border-radius: 50px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; border: 1px solid rgba(0,0,0,0.1);">
            {{ parcelle.statut == 'Libre' ? '🟢 Libre' : '🟠 Occupée' }}
        </span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:25px;margin-bottom:35px;">
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:20px; padding:25px;">
            <div style="font-size:0.75rem; font-weight:800; text-transform:uppercase; color:var(--cp); margin-bottom:12px; letter-spacing: 1px;">📐 Surface totale</div>
            <div style="font-size:1.6rem; font-weight:900; color:var(--ch3);">{{ parcelle.surface|number_format(0,',',' ') }} <span style="font-size: 1rem; opacity: 0.6;">m²</span></div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:20px; padding:25px;">
            <div style="font-size:0.75rem; font-weight:800; text-transform:uppercase; color:var(--cp); margin-bottom:12px; letter-spacing: 1px;">📏 Surface disponible</div>
            <div style="font-size:1.6rem; font-weight:900; color:{{ parcelle.surfaceRestant <= 0.01 ? '#ff4757' : 'var(--g)' }};">
                {{ parcelle.surfaceRestant|number_format(1,',',' ') }} <span style="font-size: 1rem; opacity: 0.6;">m²</span>
            </div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:20px; padding:25px;">
            <div style="font-size:0.75rem; font-weight:800; text-transform:uppercase; color:var(--cp); margin-bottom:12px; letter-spacing: 1px;">📍 Gouvernorat</div>
            <div style="font-size:1.3rem; font-weight:900; color:var(--ch3);">{{ parcelle.localisation }}</div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:20px; padding:25px;">
            <div style="font-size:0.75rem; font-weight:800; text-transform:uppercase; color:var(--cp); margin-bottom:12px; letter-spacing: 1px;">🌍 Type de sol</div>
            <div style="font-size:1.2rem; font-weight:800; color:var(--g);">{{ parcelle.typeSol }}</div>
        </div>
    </div>

    {# Premium Progress bar #}
    {% set taux = parcelle.tauxOccupation %}
    <div style="background: var(--fi); border: 1px solid var(--cbr); border-radius:24px; padding:30px;">
        <div style="display:flex; justify-content:space-between; align-items: center; margin-bottom:18px;">
            <span style="font-size:0.95rem; font-weight:800; color:var(--ch3); display: flex; align-items: center; gap: 10px;">
                <i class="fa-solid fa-chart-bar" style="color:var(--g)"></i> Taux d'occupation de la parcelle
            </span>
            <span style="font-size: 1.4rem; font-weight:900; color:{{ taux >= 90 ? '#ff4757' : (taux >= 60 ? '#ffa502' : 'var(--g)') }};">
                {{ taux }}%
            </span>
        </div>
        <div style="height: 16px; background: rgba(255,255,255,0.05); border-radius: 50px; overflow: hidden; position: relative; border: 1px solid var(--cbr);">
            <div style="height: 100%; width: {{ taux }}%; 
                background: linear-gradient(90deg, var(--g) 0%, {{ taux >= 90 ? '#ff4757' : (taux >= 60 ? '#ffa502' : 'var(--gm)') }} 100%);
                border-radius: 50px; transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 15px rgba(90,181,90,0.2);">
            </div>
        </div>
        <div style="margin-top: 15px; font-size: 0.85rem; color: var(--cp); text-align: right; font-weight: 600;">
            {{ (parcelle.surface - parcelle.surfaceRestant)|number_format(0) }} m² exploités sur {{ parcelle.surface|number_format(0) }} m² au total
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   WEATHER SECTION
   ═══════════════════════════════════════════════════ #}
{% if weather %}
<style>
.weather-wrap { margin-bottom: 35px; }
.weather-header-label { font-size: 1.4rem; font-weight: 900; color: var(--ch3); margin-bottom: 20px; display: flex; align-items: center; gap: 12px; letter-spacing: -0.5px; }
.weather-main-card { border-radius: 28px; padding: 0; overflow: hidden; box-shadow: var(--sh-lg); margin-bottom: 30px; border: 1px solid var(--cbr); background: var(--cb); }
.weather-hero { background: linear-gradient(135deg, #1e3a2a 0%, #2d5a42 100%); padding: 40px; color: white; position: relative; overflow: hidden; }
.weather-hero::after { content: ''; position: absolute; top: -50px; right: -50px; width: 250px; height: 250px; background: rgba(255,255,255,.05); border-radius: 50%; }
.weather-location-row { display: flex; align-items: center; gap: 8px; font-size: 1rem; opacity: .9; margin-bottom: 20px; font-weight: 600; }
.weather-temp-row { display: flex; align-items: center; gap: 30px; position: relative; z-index: 1; }
.weather-temp-big { font-size: 6rem; font-weight: 900; line-height: 1; letter-spacing: -4px; }
.weather-temp-details { flex: 1; }
.weather-desc { font-size: 1.4rem; font-weight: 800; margin-bottom: 6px; text-transform: capitalize; }
.weather-feels { font-size: 0.95rem; opacity: .8; font-weight: 600; }
.weather-emoji-big { font-size: 5.5rem; line-height: 1; }
.weather-updated { font-size: 0.8rem; opacity: .7; margin-top: 25px; font-weight: 500; }
.weather-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0; border-top: 1px solid var(--cbr); }
.weather-stat-item { padding: 20px; border-right: 1px solid var(--cbr); text-align: center; }
.weather-stat-item:last-child { border-right: none; }
.weather-stat-icon { font-size: 1.8rem; margin-bottom: 10px; }
.weather-stat-value { font-size: 1.2rem; font-weight: 900; color: var(--ch3); margin-bottom: 4px; }
.weather-stat-label { font-size: 0.75rem; text-transform: uppercase; color: var(--cp); font-weight: 800; letter-spacing: 0.5px; }

.forecast-strip { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 20px; margin-bottom: 30px; }
.forecast-day-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 22px; padding: 20px 15px; text-align: center; transition: all .3s; }
.forecast-day-card:hover { transform: translateY(-8px); border-color: var(--g); box-shadow: var(--sh-lg); }
.forecast-day-card.today { background: rgba(90,181,90,0.05); border: 2px solid var(--g); }
.forecast-label { font-size: 0.8rem; font-weight: 900; text-transform: uppercase; color: var(--cp); margin-bottom: 12px; }
.forecast-label.today { color: var(--g); }
.forecast-icon-img { width: 60px; height: 60px; margin: 0 auto 10px; }
.forecast-temps { display: flex; justify-content: center; gap: 10px; font-size: 1rem; margin-bottom: 8px; }
.forecast-max { font-weight: 900; color: #ffa502; }
.forecast-min { color: #5352ed; font-weight: 700; }
.forecast-desc { font-size: 0.75rem; color: var(--cp); font-weight: 600; text-transform: capitalize; }

.agri-advice-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; padding: 30px; margin-bottom: 30px; box-shadow: var(--sh-lg); }
.agri-advice-title { font-size: 1.15rem; font-weight: 900; color: var(--ch3); margin-bottom: 20px; display: flex; align-items: center; gap: 12px; }
.agri-advice-item { display: flex; align-items: flex-start; gap: 15px; padding: 12px 18px; border-radius: 14px; margin-bottom: 10px; font-size: 0.95rem; font-weight: 600; line-height: 1.5; }
.agri-advice-item.success { background: rgba(76,175,80,0.1); color: #4CAF50; border: 1px solid rgba(76,175,80,0.1); }
.agri-advice-item.warning { background: rgba(255,152,0,0.1); color: #FF9800; border: 1px solid rgba(255,152,0,0.1); }
.agri-advice-item.danger  { background: rgba(244,67,54,0.1); color: #F44336; border: 1px solid rgba(244,67,54,0.1); }
.agri-advice-item.info    { background: rgba(33,150,243,0.1); color: #2196F3; border: 1px solid rgba(33,150,243,0.1); }
</style>

<div class="weather-wrap">
    <h2 class="weather-header-label"><i class="fa-solid fa-cloud-sun" style="color:var(--g)"></i> Bulletin Météo — {{ weather.location }}</h2>
    <div class="weather-main-card">
        <div class="weather-hero">
            <div class="weather-location-row"><i class="fa-solid fa-location-dot"></i> {{ weather.location }}, Tunisie</div>
            <div class="weather-temp-row">
                <div class="weather-temp-big">{{ weather.temp }}°</div>
                <div class="weather-temp-details">
                    <div class="weather-desc">{{ weather.description }}</div>
                    <div class="weather-feels">Ressenti {{ weather.feels_like }}° · ↑ {{ weather.temp_max }}° ↓ {{ weather.temp_min }}°</div>
                </div>
                <div class="weather-emoji-big">{{ weather.emoji }}</div>
            </div>
            <div class="weather-updated">Dernière mise à jour : {{ weather.updated_at }}</div>
        </div>
        <div class="weather-stats">
            <div class="weather-stat-item"><div class="weather-stat-icon">💧</div><div class="weather-stat-value">{{ weather.humidity }}%</div><div class="weather-stat-label">Humidité</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">💨</div><div class="weather-stat-value">{{ weather.wind_speed }} km/h</div><div class="weather-stat-label">Vent</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌡️</div><div class="weather-stat-value">{{ weather.pressure }} hPa</div><div class="weather-stat-label">Pression</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">☁️</div><div class="weather-stat-value">{{ weather.clouds }}%</div><div class="weather-stat-label">Nuages</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌅</div><div class="weather-stat-value">{{ weather.sunrise }}</div><div class="weather-stat-label">Lever</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌇</div><div class="weather-stat-value">{{ weather.sunset }}</div><div class="weather-stat-label">Coucher</div></div>
        </div>
    </div>
    {% if weather.daily %}
    <div class="forecast-strip">
        {% for day in weather.daily %}
        <div class="forecast-day-card {{ loop.first ? 'today' : '' }}">
            <div class="forecast-label {{ loop.first ? 'today' : '' }}">{{ day.label }}</div>
            <img class="forecast-icon-img" src="https://openweathermap.org/img/wn/{{ day.icon }}@2x.png" alt="{{ day.description }}">
            <div class="forecast-temps"><span class="forecast-max">{{ day.temp_max }}°</span><span class="forecast-min">{{ day.temp_min }}°</span></div>
            <div class="forecast-desc">{{ day.description }}</div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
    <div class="agri-advice-card">
        <div class="agri-advice-title"><i class="fa-solid fa-seedling" style="color:var(--g)"></i> Recommandations agronomiques</div>
        {% for tip in weather.agri_advice %}
        <div class="agri-advice-item {{ tip.type }}"><span style="font-size:1.3rem;">{{ tip.icon }}</span><span>{{ tip.text }}</span></div>
        {% endfor %}
    </div>
</div>

{% else %}
<div class="card" style="padding:25px 30px;margin-bottom:35px;display:flex;align-items:center;gap:20px;border-style:dashed;background:rgba(0,0,0,0.05);">
    <span style="font-size:2.5rem;opacity:0.5;">🌥️</span>
    <div>
        <strong style="color:var(--ch3);font-size:1.1rem;display:block;margin-bottom:5px;">Bulletin météo indisponible</strong>
        <span style="color:var(--cp);font-weight:600;">Les données climatiques en temps réel pour « {{ parcelle.localisation }} » n'ont pas pu être chargées.</span>
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════
   CULTURES LIST
   ═══════════════════════════════════════════════════ #}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:25px;">
    <h2 style="font-size:1.5rem;font-weight:900;color:var(--ch3);margin:0;letter-spacing:-0.5px;">🌱 Cultures actives sur la parcelle</h2>
    <span class="badge" style="background:var(--g);color:#fff;padding:6px 15px;border-radius:50px;font-weight:800;font-size:0.85rem;">{{ cultures|length }} culture(s)</span>
</div>

{% if cultures is empty %}
    <div style="text-align:center;padding:80px 40px;background:var(--cb);border:1px dashed var(--cbr);border-radius:30px;">
        <div style="font-size:3.5rem;margin-bottom:20px;opacity:0.4;">🌾</div>
        <h3 style="color:var(--ch3);font-weight:800;margin-bottom:10px;">Parcelle inoccupée</h3>
        <p style="color:var(--cp);margin-bottom:25px;">Aucune culture n'est actuellement plantée sur cette parcelle.</p>
        <a href="{{ path('culture_index') }}" class="btn btn-primary">➕ Lancer une culture</a>
    </div>
{% else %}
    <style>
        .culture-card-p { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s; box-shadow: var(--sh-lg); }
        .culture-card-p:hover { transform: translateY(-8px); border-color: var(--g); box-shadow: 0 15px 35px rgba(0,0,0,0.3); }
        .culture-img-box { height: 180px; position: relative; background: #000; }
        .culture-img-box img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }
        .culture-badge-float { position: absolute; top: 15px; right: 15px; padding: 6px 14px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .culture-body-p { padding: 25px; flex: 1; }
        .culture-type-p { font-size: 0.75rem; font-weight: 800; color: var(--g); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; display: block; }
        .culture-name-p { font-size: 1.2rem; font-weight: 900; color: var(--ch3); margin-bottom: 15px; display: block; letter-spacing: -0.5px; }
        .culture-meta-p { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .meta-p-item { display: flex; flex-direction: column; gap: 3px; }
        .meta-p-label { font-size: 0.7rem; font-weight: 800; color: var(--cp); text-transform: uppercase; }
        .meta-p-value { font-size: 0.9rem; font-weight: 700; color: var(--ch3); }
        .culture-footer-p { padding: 20px 25px; border-top: 1px solid var(--cbr); background: rgba(0,0,0,0.05); display: flex; justify-content: space-between; align-items: center; }
    </style>
    <div class="card-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:25px;">
        {% for culture in cultures %}
        <div class="culture-card-p">
            <div class="culture-img-box">
                {% if culture.img %}
                    <img src="{{ asset('images/cultures/' ~ culture.img) }}" alt="{{ culture.nom }}">
                {% else %}
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--gd);font-size:3.5rem;">🌱</div>
                {% endif %}
                <span class="culture-badge-float {{ etatToCssClass(culture.etat) }}" style="background: {{ culture.etat == 'Maturité' ? '#2ecc71' : (culture.etat == 'Récolte Prévue' ? '#f1c40f' : '#3498db') }};">
                    {{ culture.etat }}
                </span>
            </div>

            <div class="culture-body-p">
                <span class="culture-type-p">{{ culture.typeCulture }}</span>
                <span class="culture-name-p">{{ culture.nom }}</span>

                <div class="culture-meta-p">
                    <div class="meta-p-item">
                        <span class="meta-p-label">📐 Surface</span>
                        <span class="meta-p-value">{{ culture.surface|number_format(0) }} m²</span>
                    </div>
                    <div class="meta-p-item">
                        <span class="meta-p-label">🌱 Plantation</span>
                        <span class="meta-p-value">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</span>
                    </div>
                    <div class="meta-p-item" style="grid-column: span 2;">
                        <span class="meta-p-label">🌾 Récolte prévue</span>
                        <span class="meta-p-value">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
            </div>

            <div class="culture-footer-p">
                {% if culture.etat in ['Maturité', 'Récolte Prévue', 'Récolte en Retard'] %}
                <form method="post" action="{{ path('culture_harvest', {id: culture.id}) }}" class="harvest-form"
                      data-culture-id="{{ culture.id }}" data-culture-nom="{{ culture.nom|e('html_attr') }}" data-rapport-url="{{ path('culture_harvest_rapport', {id: culture.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('harvest-culture-' ~ culture.id) }}">
                    <button type="button" class="btn btn-primary btn-sm" onclick="handleRecolte(this)"><i class="fa-solid fa-wheat-awn"></i> Récolter</button>
                </form>
                {% else %}
                    <span style="color:var(--cp);font-size:0.8rem;font-weight:700;"><i class="fa-solid fa-hourglass-start"></i> En croissance</span>
                {% endif %}

                <form method="post" action="{{ path('culture_delete', {id: culture.id}) }}" onsubmit="return confirm('Supprimer « {{ culture.nom|e('js') }} » ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('del-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm" style="padding:8px 12px;"><i class="fa-solid fa-trash-can"></i></button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

    </div>
</main>

{# ── Modal IA Rapport ── #}
<div id="rapportModal" class="rapport-overlay" style="display:none;">
    <div class="rapport-box" style="border-radius:30px;overflow:hidden;box-shadow:var(--sh-lg);border:1px solid var(--cbr);">
        <div class="rapport-header" style="background:linear-gradient(135deg, #1a6b3c, #2d5a42);padding:30px;border:none;">
            <div class="rapport-header-left">
                <span style="font-size:3rem;">🌾</span>
                <div>
                    <div style="font-size:0.8rem;text-transform:uppercase;font-weight:800;opacity:0.8;letter-spacing:1px;margin-bottom:5px;">Rapport de récolte assisté par IA</div>
                    <div id="rapportCultureName" style="font-size:1.5rem;font-weight:900;"></div>
                </div>
            </div>
            <div id="rapportScoreBadge" style="text-align:center;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);border-radius:20px;padding:12px 20px;">
                <div id="rapportScore" style="font-size:2rem;font-weight:900;">—</div>
                <div style="font-size:0.65rem;text-transform:uppercase;font-weight:800;opacity:0.8;">Score IA</div>
            </div>
        </div>

        <div style="display:flex;gap:20px;padding:30px;background:rgba(0,0,0,0.05);border-bottom:1px solid var(--cbr);">
            <div style="flex:1;">
                <div style="font-size:0.75rem;font-weight:800;color:var(--g);text-transform:uppercase;margin-bottom:8px;">Quantité estimée</div>
                <div id="rapportQty" style="font-size:2.5rem;font-weight:900;color:var(--ch3);">—</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:10px;">
                <div style="display:flex;align-items:center;gap:12px;background:var(--cb);padding:10px 18px;border-radius:15px;border:1px solid var(--cbr);">
                    <span style="font-size:1.2rem;">⏰</span>
                    <div><div style="font-size:0.65rem;font-weight:800;color:var(--cp);text-transform:uppercase;">Timing</div><div id="rapportLateness" style="font-weight:800;color:var(--ch3);">—</div></div>
                </div>
                <div style="display:flex;align-items:center;gap:12px;background:var(--cb);padding:10px 18px;border-radius:15px;border:1px solid var(--cbr);">
                    <span style="font-size:1.2rem;">🌤️</span>
                    <div><div style="font-size:0.65rem;font-weight:800;color:var(--cp);text-transform:uppercase;">Climat</div><div id="rapportWeather" style="font-weight:800;color:var(--ch3);">—</div></div>
                </div>
            </div>
        </div>

        <div style="padding:30px;">
            <div style="font-size:0.75rem;font-weight:800;color:var(--cp);text-transform:uppercase;margin-bottom:12px;letter-spacing:1px;">📋 Analyse détaillée de l'IA</div>
            <div id="rapportText" style="padding:20px;background:rgba(255,255,255,0.02);border:1px solid var(--cbr);border-left:5px solid var(--g);border-radius:15px;line-height:1.7;color:var(--ch3);font-size:1rem;font-weight:500;">Chargement en cours...</div>
        </div>

        <div style="padding:25px 30px;background:rgba(0,0,0,0.05);border-top:1px solid var(--cbr);display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.8rem;color:var(--cp);font-weight:600;max-width:200px;">AgriSense AI v2.4 - Analyse basée sur l'historique météo.</span>
            <div style="display:flex;gap:12px;">
                <button class="btn btn-secondary" onclick="cancelRecolte()">Annuler</button>
                <button class="btn btn-primary" id="btnConfirmRecolte" onclick="confirmRecolte()">✓ Confirmer la récolte</button>
            </div>
        </div>
    </div>
</div>

<script>
    var _pendingForm = null;
    function handleRecolte(btn) {
        var form = btn.closest('form'), url = form.dataset.rapportUrl, nom = form.dataset.cultureNom;
        _pendingForm = form;
        document.getElementById('rapportCultureName').innerText = nom;
        document.getElementById('rapportText').innerText = 'Analyse des données climatiques et phénologiques en cours...';
        document.getElementById('btnConfirmRecolte').disabled = true;
        document.getElementById('rapportModal').style.display = 'flex';

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(d => {
                document.getElementById('rapportScore').innerText = (d.iaScore || 0) + '%';
                document.getElementById('rapportQty').innerText = d.quantite ? parseFloat(d.quantite).toLocaleString('fr-FR') + ' kg' : '—';
                document.getElementById('rapportLateness').innerText = d.latenessScore ? d.latenessScore + '%' : '—';
                document.getElementById('rapportWeather').innerText = d.weatherScore ? d.weatherScore + '%' : '—';
                document.getElementById('rapportText').innerText = d.rapport || 'Aucun rapport disponible.';
                document.getElementById('btnConfirmRecolte').disabled = false;
            })
            .catch(() => {
                document.getElementById('rapportText').innerText = 'Erreur lors du chargement de l\'analyse IA. Vous pouvez toutefois continuer.';
                document.getElementById('btnConfirmRecolte').disabled = false;
            });
    }
    function confirmRecolte() {
        document.getElementById('rapportModal').style.display = 'none';
        if (_pendingForm) _pendingForm.submit();
    }
    function cancelRecolte() {
        document.getElementById('rapportModal').style.display = 'none';
        _pendingForm = null;
    }

    // Theme and dropdown
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
{% if is_granted('ROLE_ADMIN') %}
        </div>
    </main>
</div>
{% else %}
    </div>
</main>
{% endif %}

<script>
    /* ── SIDEBAR & THEME TOGGLES ── */
    const sidebarToggle = document.getElementById('sidebarToggle');
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle('open');
            } else {
                sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded');
            }
        });
    }

    function toggleTheme() {
        const html = document.documentElement;
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    }

    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) themeToggle.addEventListener('click', toggleTheme);

    const themeToggleNav = document.getElementById('themeToggleNav');
    if (themeToggleNav) themeToggleNav.addEventListener('click', toggleTheme);

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const d = document.getElementById('gerant-dropdown-nav');
            if (d && d.classList.contains('show')) d.classList.remove('show');
        }
    }
</script>
{% endblock %}
