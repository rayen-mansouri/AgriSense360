{% set activePage = 'parcelles' %}
{% set activeSection = 'main' %}

{% block title %}{{ parcelle.nom }} — Détails{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div style="padding: 30px;">


{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('app_home') }}">🏠 Accueil</a> /
            <a href="{{ path('parcelle_index') }}">Parcelles</a> /
            {{ parcelle.nom }}
        </p>
        <h1 class="page-title">🗺️ {{ parcelle.nom }}</h1>
        <p class="page-subtitle">{{ cultures|length }} culture(s) sur cette parcelle</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">← Retour aux parcelles</a>
        <a href="{{ path('culture_index') }}" class="btn btn-primary">🌱 Gérer les cultures</a>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   FLASH MESSAGES
   ═══════════════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:12px 18px;margin-bottom:12px;border-radius:8px;
             background:{{ type == 'success' ? '#e8f5e9' : '#ffebee' }};
             border-left:4px solid {{ type == 'success' ? '#4CAF50' : '#f44336' }};
             color:{{ type == 'success' ? '#2e7d32' : '#c62828' }};font-weight:500;">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ═══════════════════════════════════════════════════
   PARCELLE INFO CARD
   ═══════════════════════════════════════════════════ #}
<div style="background: var(--cb); border: 1px solid var(--cbr);
            border-radius: 24px; padding: 28px; margin-bottom: 32px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:15px;">
        <h2 style="margin:0;font-size:1.6rem;font-weight:800;color:var(--ch3); display: flex; align-items: center; gap: 12px;">
            <span style="background: var(--green-pale); padding: 10px; border-radius: 12px;">📋</span>
            Informations de la parcelle
        </h2>
        <span class="parcelle-statut {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}"
              style="font-size:0.9rem; padding:8px 20px; border-radius: 50px; font-weight: 700;">
            {{ parcelle.statut == 'Libre' ? '🟢 Libre' : '🟠 Occupée' }}
        </span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px;margin-bottom:32px;">
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:18px; padding:20px; transition: transform 0.2s;">
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--cp); margin-bottom:10px; letter-spacing: 0.5px;">📐 Surface totale</div>
            <div style="font-size:1.4rem; font-weight:800; color:var(--ch3);">{{ parcelle.surface|number_format(0,',',' ') }} <span style="font-size: 0.9rem; opacity: 0.7;">m²</span></div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:18px; padding:20px;">
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--cp); margin-bottom:10px; letter-spacing: 0.5px;">📏 Surface restante</div>
            <div style="font-size:1.4rem; font-weight:800; color:{{ parcelle.surfaceRestant <= 0.01 ? 'var(--danger)' : 'var(--g)' }};">
                {{ parcelle.surfaceRestant|number_format(2,',',' ') }} <span style="font-size: 0.9rem; opacity: 0.7;">m²</span>
            </div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:18px; padding:20px;">
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--cp); margin-bottom:10px; letter-spacing: 0.5px;">📍 Gouvernorat</div>
            <div style="font-size:1.2rem; font-weight:700; color:var(--ch3);">{{ parcelle.localisation }}</div>
        </div>
        <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:18px; padding:20px;">
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--cp); margin-bottom:10px; letter-spacing: 0.5px;">🌍 Type de sol</div>
            {% set solClass = parcelle.typeSol == 'Sol Limoneux' ? 'sol-limoneux'
                           : (parcelle.typeSol == 'Sol Argileux' ? 'sol-argileux' : 'sol-sablonneux') %}
            <span class="type-sol-badge {{ solClass }}" style="display: inline-block; margin-top: 5px;">{{ parcelle.typeSol }}</span>
        </div>
    </div>

    {# Premium Progress bar #}
    {% set taux = parcelle.tauxOccupation %}
    <div style="background: var(--surface2); border: 1px solid var(--cbr); border-radius:20px; padding:24px;">
        <div style="display:flex; justify-content:space-between; align-items: center; margin-bottom:15px;">
            <span style="font-size:0.9rem; font-weight:700; color:var(--ch3); display: flex; align-items: center; gap: 8px;">
                📊 Taux d'occupation
            </span>
            <span style="font-size: 1.2rem; font-weight:900; color:{{ taux >= 90 ? 'var(--danger)' : (taux >= 60 ? '#f59e0b' : 'var(--g)') }};">
                {{ taux }}%
            </span>
        </div>
        <div style="height: 14px; background: rgba(0,0,0,0.1); border-radius: 50px; overflow: hidden; position: relative; border: 1px solid var(--cbr);">
            <div style="height: 100%; width: {{ taux }}%; 
                background: linear-gradient(90deg, var(--g) 0%, {{ taux >= 90 ? 'var(--danger)' : (taux >= 60 ? '#f59e0b' : 'var(--gm)') }} 100%);
                border-radius: 50px; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 0 10px rgba(90,181,90,0.2);">
            </div>
        </div>
        <div style="margin-top: 10px; font-size: 0.8rem; color: var(--cp); text-align: right;">
            {{ (parcelle.surface - parcelle.surfaceRestant)|number_format(0) }} m² occupés sur {{ parcelle.surface|number_format(0) }} m²
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   WEATHER SECTION
   ═══════════════════════════════════════════════════ #}
{% if weather %}
<style>
.weather-wrap { margin-bottom: 32px; }
.weather-header-label { font-size: 1.25rem; font-weight: 700; color: var(--text-dark); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.weather-main-card { border-radius: 20px; padding: 0; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,.13); margin-bottom: 24px; border: 1px solid var(--cbr); }
.weather-hero { background: linear-gradient(135deg, #1a6b3c 0%, #2d9d5e 45%, #1e7a4a 100%); padding: 32px; color: white; position: relative; overflow: hidden; }
.weather-hero::before { content: ''; position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; background: rgba(255,255,255,.06); border-radius: 50%; }
.weather-hero::after  { content: ''; position: absolute; bottom: -60px; left: -20px; width: 250px; height: 250px; background: rgba(255,255,255,.04); border-radius: 50%; }
.weather-location-row { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; opacity: .85; margin-bottom: 16px; position: relative; z-index: 1; }
.weather-temp-row { display: flex; align-items: flex-end; gap: 24px; position: relative; z-index: 1; flex-wrap: wrap; }
.weather-temp-big { font-size: 5.5rem; font-weight: 800; line-height: 1; letter-spacing: -3px; }
.weather-temp-details { padding-bottom: 10px; }
.weather-desc { font-size: 1.2rem; font-weight: 700; margin-bottom: 4px; }
.weather-feels { font-size: 0.85rem; opacity: .8; }
.weather-emoji-big { font-size: 4.5rem; line-height: 1; margin-left: auto; position: relative; z-index: 1; }
.weather-updated { font-size: 0.75rem; opacity: .65; margin-top: 16px; position: relative; z-index: 1; }
.weather-stats { background: var(--cb); display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0; border-top: 1px solid var(--cbr); }
.weather-stat-item { padding: 16px 20px; border-right: 1px solid var(--cbr); text-align: center; }
.weather-stat-item:last-child { border-right: none; }
.weather-stat-icon { font-size: 1.5rem; margin-bottom: 6px; }
.weather-stat-value { font-size: 1.1rem; font-weight: 800; color: var(--ch3); }
.weather-stat-label { font-size: 0.7rem; text-transform: uppercase; color: var(--cp); font-weight: 700; letter-spacing: .5px; }
.forecast-strip { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 16px; margin-bottom: 24px; }
.forecast-day-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 18px; padding: 16px 12px; text-align: center; transition: all .2s; }
.forecast-day-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.2); border-color: var(--g); }
.forecast-day-card.today { background: linear-gradient(135deg, rgba(90,181,90,0.1), rgba(90,181,90,0.2)); border: 2px solid var(--g); }
.forecast-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--cp); margin-bottom: 8px; }
.forecast-label.today { color: var(--g); }
.forecast-icon-img { width: 50px; height: 50px; margin: 0 auto 6px; }
.forecast-temps { display: flex; justify-content: center; gap: 8px; font-size: 0.9rem; }
.forecast-max { font-weight: 800; color: #ff9800; }
.forecast-min { color: #60a5fa; font-weight: 700; }
.forecast-desc { font-size: 0.7rem; color: var(--cp); margin-top: 6px; line-height: 1.4; font-weight: 500; }
.agri-advice-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 20px; padding: 24px; margin-bottom: 24px; }
.agri-advice-title { font-size: 1rem; font-weight: 800; color: var(--ch3); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
.agri-advice-item { display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; border-radius: 8px; margin-bottom: 6px; font-size: 0.85rem; font-weight: 500; }
.agri-advice-item:last-child { margin-bottom: 0; }
.agri-advice-item.success { background: rgba(76,175,80,0.1); color: #4CAF50; }
.agri-advice-item.warning { background: rgba(255,152,0,0.1); color: #FF9800; }
.agri-advice-item.danger  { background: rgba(244,67,54,0.1); color: #F44336; }
.agri-advice-item.info    { background: rgba(33,150,243,0.1); color: #2196F3; }
.agri-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }
@media (max-width: 600px) {
    .weather-temp-big { font-size: 3.5rem; }
    .weather-emoji-big { font-size: 2.8rem; }
    .weather-stats { grid-template-columns: repeat(3, 1fr); }
    .forecast-strip { grid-template-columns: repeat(3, 1fr); }
}
</style>

<div class="weather-wrap">
    <div class="weather-header-label">🌤️ Météo actuelle — {{ weather.location }}</div>
    <div class="weather-main-card">
        <div class="weather-hero">
            <div class="weather-location-row">📍 {{ weather.location }}, Tunisie</div>
            <div class="weather-temp-row">
                <div class="weather-temp-big">{{ weather.temp }}°</div>
                <div class="weather-temp-details">
                    <div class="weather-desc">{{ weather.description }}</div>
                    <div class="weather-feels">Ressenti {{ weather.feels_like }}° · ↑ {{ weather.temp_max }}° ↓ {{ weather.temp_min }}°</div>
                </div>
                <div class="weather-emoji-big">{{ weather.emoji }}</div>
            </div>
            <div class="weather-updated">Mis à jour à {{ weather.updated_at }}</div>
        </div>
        <div class="weather-stats">
            <div class="weather-stat-item"><div class="weather-stat-icon">💧</div><div class="weather-stat-value">{{ weather.humidity }}%</div><div class="weather-stat-label">Humidité</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">💨</div><div class="weather-stat-value">{{ weather.wind_speed }} km/h</div><div class="weather-stat-label">Vent</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌡️</div><div class="weather-stat-value">{{ weather.pressure }} hPa</div><div class="weather-stat-label">Pression</div></div>
            {% if weather.visibility %}<div class="weather-stat-item"><div class="weather-stat-icon">👁️</div><div class="weather-stat-value">{{ weather.visibility }} km</div><div class="weather-stat-label">Visibilité</div></div>{% endif %}
            <div class="weather-stat-item"><div class="weather-stat-icon">☁️</div><div class="weather-stat-value">{{ weather.clouds }}%</div><div class="weather-stat-label">Nuages</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌅</div><div class="weather-stat-value">{{ weather.sunrise }}</div><div class="weather-stat-label">Lever</div></div>
            <div class="weather-stat-item"><div class="weather-stat-icon">🌇</div><div class="weather-stat-value">{{ weather.sunset }}</div><div class="weather-stat-label">Coucher</div></div>
        </div>
    </div>
    {% if weather.daily %}
    <div class="forecast-strip">
        {% for day in weather.daily %}
        <div class="forecast-day-card {{ loop.first ? 'today' : '' }}">
            <div class="forecast-label {{ loop.first ? 'today' : '' }}">{{ day.label }}</div>
            <img class="forecast-icon-img" src="https://openweathermap.org/img/wn/{{ day.icon }}@2x.png" alt="{{ day.description }}" loading="lazy">
            <div class="forecast-temps"><span class="forecast-max">{{ day.temp_max }}°</span><span class="forecast-min">{{ day.temp_min }}°</span></div>
            <div class="forecast-desc">{{ day.description }}</div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
    <div class="agri-advice-card">
        <div class="agri-advice-title">🌾 Conseils agricoles du jour</div>
        {% for tip in weather.agri_advice %}
        <div class="agri-advice-item {{ tip.type }}"><span class="agri-icon">{{ tip.icon }}</span><span>{{ tip.text }}</span></div>
        {% endfor %}
    </div>
</div>

{% else %}
<div style="background:#f9f9f9;border:1.5px dashed #ddd;border-radius:14px;
            padding:20px 24px;margin-bottom:28px;color:#888;font-size:0.9rem;
            display:flex;align-items:center;gap:12px;">
    <span style="font-size:1.6rem;">🌥️</span>
    <div>
        <strong style="color:#555;">Météo indisponible</strong><br>
        Impossible de récupérer la météo pour « {{ parcelle.localisation }} » — vérifiez votre clé API OpenWeather.
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════
   CULTURES LIST
   ═══════════════════════════════════════════════════ #}
<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-dark);margin-bottom:18px;">
    🌱 Cultures sur cette parcelle
</h2>

{% if cultures is empty %}
    <div class="empty-state">
        <div class="empty-icon">🌾</div>
        <div class="empty-title">Aucune culture sur cette parcelle</div>
        <div class="empty-subtitle">
            <a href="{{ path('culture_index') }}" style="color:var(--green-600);text-decoration:none;font-weight:600;">
                ➕ Ajouter une culture
            </a>
        </div>
    </div>
{% else %}
    <div class="card-grid">
        {% for culture in cultures %}
        <div class="culture-card">

            <div class="culture-card-image">
                {% if culture.img %}
                    <img src="{{ asset('images/cultures/' ~ culture.img) }}"
                         alt="{{ culture.nom }}"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <div class="img-fallback" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">🌱</div>
                {% else %}
                    <div class="img-fallback" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">🌱</div>
                {% endif %}
            </div>

            <div class="culture-card-body">
                <span class="culture-card-type">{{ culture.typeCulture }}</span>
                <div class="culture-card-name">{{ culture.nom }}</div>
                {% set etatClass = etatToCssClass(culture.etat) %}
                <span class="etat-badge {{ etatClass }}">{{ culture.etat }}</span>

                <div class="culture-card-meta">
                    <div class="meta-item">
                        <span class="meta-label">📐 Surface</span>
                        <span class="meta-value">{{ culture.surface }} m²</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌱 Plantation</span>
                        <span class="meta-value">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌾 Récolte prévue</span>
                        <span class="meta-value">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
            </div>

            <div class="culture-card-footer">
                {# ── Harvest button — intercepts click, shows IA rapport first ── #}
                {% if culture.etat in ['Maturité', 'Récolte Prévue', 'Récolte en Retard'] %}
                <form method="post"
                      action="{{ path('culture_harvest', {id: culture.id}) }}"
                      class="harvest-form"
                      data-culture-id="{{ culture.id }}"
                      data-culture-nom="{{ culture.nom|e('html_attr') }}"
                      data-rapport-url="{{ path('culture_harvest_rapport', {id: culture.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('harvest-culture-' ~ culture.id) }}">
                    <button type="button"
                            class="btn btn-primary btn-sm btn-recolter"
                            onclick="handleRecolte(this)">
                        🌾 Récolter
                    </button>
                </form>
                {% endif %}

                <form method="post" action="{{ path('culture_delete', {id: culture.id}) }}"
                      onsubmit="return confirm('Supprimer « {{ culture.nom|e('js') }} » ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('del-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}


{# ═══════════════════════════════════════════════════
   IA RAPPORT MODAL
   ═══════════════════════════════════════════════════ #}
<div id="rapportModal" class="rapport-overlay" style="display:none;">
    <div class="rapport-box">

        {# Header #}
        <div class="rapport-header">
            <div class="rapport-header-left">
                <span class="rapport-big-icon">🌾</span>
                <div>
                    <div class="rapport-title">Rapport de récolte — IA</div>
                    <div class="rapport-culture-name" id="rapportCultureName"></div>
                </div>
            </div>
            <div class="rapport-score-badge" id="rapportScoreBadge">
                <div class="rapport-score-value" id="rapportScore">—</div>
                <div class="rapport-score-label">Score IA</div>
            </div>
        </div>

        {# Quantity hero #}
        <div class="rapport-qty-row">
            <div class="rapport-qty-block">
                <div class="rapport-qty-label">Quantité estimée</div>
                <div class="rapport-qty-value" id="rapportQty">—</div>
            </div>
            <div class="rapport-factors">
                <div class="rapport-factor" id="rapportLatenessBlock">
                    <div class="rapport-factor-icon">⏰</div>
                    <div>
                        <div class="rapport-factor-label">Ponctualité</div>
                        <div class="rapport-factor-value" id="rapportLateness">—</div>
                    </div>
                </div>
                <div class="rapport-factor" id="rapportWeatherBlock">
                    <div class="rapport-factor-icon">🌤️</div>
                    <div>
                        <div class="rapport-factor-label">Météo</div>
                        <div class="rapport-factor-value" id="rapportWeather">—</div>
                    </div>
                </div>
            </div>
        </div>

        {# Rapport text #}
        <div class="rapport-section-label">📋 Explication</div>
        <div class="rapport-text" id="rapportText">Chargement en cours…</div>

        {# Footer buttons #}
        <div class="rapport-footer">
            <span class="rapport-footer-note">
                💡 Ce rapport est généré automatiquement par l'IA.
            </span>
            <div style="display:flex;gap:10px;">
                <button class="btn-rapport-cancel" onclick="cancelRecolte()">Annuler</button>
                <button class="btn-rapport-ok" id="btnConfirmRecolte" onclick="confirmRecolte()">
                    ✅ Confirmer la récolte
                </button>
            </div>
        </div>

    </div>
</div>


{# ═══════════════════════════════════════════════════
   CSS
   ═══════════════════════════════════════════════════ #}
<style>
/* ── Rapport Modal Overlay ──────────────────────────── */
.rapport-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.50);
    z-index: 9999;
    display: flex !important;
    align-items: center;
    justify-content: center;
    padding: 16px;
    backdrop-filter: blur(4px);
}
.rapport-overlay[style*="display:none"] { display: none !important; }

.rapport-box {
    background: #fff;
    border-radius: 20px;
    width: 100%;
    max-width: 540px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
    overflow: hidden;
    animation: rapportPop 0.28s cubic-bezier(.34,1.56,.64,1);
}
@keyframes rapportPop {
    from { transform: scale(0.88) translateY(20px); opacity: 0; }
    to   { transform: scale(1)    translateY(0);    opacity: 1; }
}

/* Header */
.rapport-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 22px 16px;
    background: linear-gradient(135deg, #1a6b3c 0%, #2d9d5e 100%);
    color: white;
}
.rapport-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
}
.rapport-big-icon { font-size: 2.4rem; line-height: 1; }
.rapport-title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
