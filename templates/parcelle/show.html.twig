.btn-rapport-ok:hover { opacity: 0.88; transform: translateY(-1px); }
.btn-rapport-ok:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
</style>


{# ═══════════════════════════════════════════════════
   JS — Harvest intercept + rapport modal
   ═══════════════════════════════════════════════════ #}
<script>
var _pendingForm = null;   // the harvest form waiting to be submitted

/**
 * Called when user clicks "🌾 Récolter".
 * 1. Fetches the IA rapport from the server (no side effects)
 * 2. Displays the modal with the rapport
 * 3. User clicks "Confirmer" → the real form submits
 */
function handleRecolte(btn) {
    var form       = btn.closest('form');
    var rapportUrl = form.dataset.rapportUrl;
    var nom        = form.dataset.cultureNom;

    _pendingForm = form;

    // Show modal in loading state
    document.getElementById('rapportCultureName').textContent = nom;
    document.getElementById('rapportScore').textContent       = '…';
    document.getElementById('rapportQty').textContent         = '…';
    document.getElementById('rapportLateness').textContent    = '…';
    document.getElementById('rapportWeather').textContent     = '…';
    document.getElementById('rapportText').textContent        = 'Analyse en cours…';
    document.getElementById('btnConfirmRecolte').disabled     = true;
    document.getElementById('rapportModal').style.display     = '';

    // Fetch rapport from server (read-only, no DB write)
    fetch(rapportUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            // Score
            var score = d.iaScore || 0;
            document.getElementById('rapportScore').textContent = score + '%';

            // Colour the score badge
            var badge = document.getElementById('rapportScoreBadge');
            badge.style.background = score >= 80
                ? 'rgba(34,197,94,0.25)'
                : (score >= 55 ? 'rgba(251,191,36,0.25)' : 'rgba(239,68,68,0.20)');

            // Quantity
            var qty = d.quantite !== undefined ? d.quantite : '—';
            document.getElementById('rapportQty').textContent =
                qty !== '—'
                ? parseFloat(qty).toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' kg'
                : '—';

            // Factors
            document.getElementById('rapportLateness').textContent =
                d.latenessScore !== undefined ? d.latenessScore + '%' : '—';
            document.getElementById('rapportWeather').textContent =
                d.weatherScore !== undefined ? d.weatherScore + '%' : '—';

            // Rapport text
            document.getElementById('rapportText').textContent =
                d.rapport || 'Aucun rapport disponible.';

            document.getElementById('btnConfirmRecolte').disabled = false;
        })
        .catch(function() {
            // If fetch fails just show a message and let user confirm anyway
            document.getElementById('rapportText').textContent =
                'Impossible de charger le rapport IA. Vous pouvez tout de même confirmer la récolte.';
            document.getElementById('rapportScore').textContent = '—';
            document.getElementById('rapportQty').textContent   = '—';
            document.getElementById('btnConfirmRecolte').disabled = false;
        });
}

/** User clicks "Confirmer la récolte" → submit the real form */
function confirmRecolte() {
    document.getElementById('rapportModal').style.display = 'none';
    if (_pendingForm) {
        _pendingForm.submit();
        _pendingForm = null;
    }
}

/** User clicks "Annuler" → close modal, do nothing */
function cancelRecolte() {
    document.getElementById('rapportModal').style.display = 'none';
    _pendingForm = null;
}

/** Close on Escape key */
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') cancelRecolte();
});
</script>

    </div>{# end .content-wrapper #}
    </main>
</div>{# end .layout #}
