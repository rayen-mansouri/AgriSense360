{% extends 'base.html.twig' %}

{% block title %}{{ parcelle.nom }} — Détails{% endblock %}

{% block content %}

{# ═══════════════════════════════════════════════════
   PAGE HEADER
   ═══════════════════════════════════════════════════ #}
<div class="page-header">
    <div class="page-header-left">
        <p class="page-breadcrumb">
            <a href="{{ path('home') }}">🏠 Accueil</a> /
            <a href="{{ path('parcelle_index') }}">Parcelles</a> /
            {{ parcelle.nom }}
        </p>
        <h1 class="page-title">🗺️ {{ parcelle.nom }}</h1>
        <p class="page-subtitle">{{ cultures|length }} culture(s) sur cette parcelle</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="{{ path('parcelle_index') }}" class="btn btn-secondary">← Retour aux parcelles</a>
        <a href="{{ path('culture_index') }}" class="btn btn-primary">🌱 Gérer les cultures</a>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   FLASH MESSAGES
   ═══════════════════════════════════════════════════ #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding:12px 18px;margin-bottom:12px;border-radius:8px;
             background:{{ type == 'success' ? '#e8f5e9' : '#ffebee' }};
             border-left:4px solid {{ type == 'success' ? '#4CAF50' : '#f44336' }};
             color:{{ type == 'success' ? '#2e7d32' : '#c62828' }};font-weight:500;">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ═══════════════════════════════════════════════════
   PARCELLE INFO CARD
   ═══════════════════════════════════════════════════ #}
<div style="background:linear-gradient(135deg,var(--green-50) 0%,var(--green-100) 100%);
            border-radius:16px;padding:24px;margin-bottom:28px;
            border-left:5px solid var(--green-600);box-shadow:var(--shadow-sm);">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
        <h2 style="margin:0;font-size:1.4rem;font-weight:700;color:var(--text-dark);">
            📋 Informations de la parcelle
        </h2>
        <span class="parcelle-statut {{ parcelle.statut == 'Libre' ? 'statut-libre' : 'statut-occupee' }}"
              style="font-size:0.95rem;padding:6px 14px;">
            {{ parcelle.statut == 'Libre' ? '🟢' : '🟠' }} {{ parcelle.statut }}
        </span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:20px;">
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📐 Surface totale</div>
            <div style="font-size:1.2rem;font-weight:700;color:var(--text-dark);">{{ parcelle.surface|number_format(0,',',' ') }} m²</div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📏 Surface restante</div>
            <div style="font-size:1.2rem;font-weight:700;color:{{ parcelle.surfaceRestant <= 0.01 ? 'var(--red-600)' : 'var(--green-700)' }};">
                {{ parcelle.surfaceRestant|number_format(2,',',' ') }} m²
            </div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">📍 Gouvernorat</div>
            <div style="font-size:1rem;font-weight:600;color:var(--text-dark);">{{ parcelle.localisation }}</div>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">🌍 Type de sol</div>
            {% set solClass = parcelle.typeSol == 'Sol Limoneux' ? 'sol-limoneux'
                           : (parcelle.typeSol == 'Sol Argileux' ? 'sol-argileux' : 'sol-sablonneux') %}
            <span class="type-sol-badge {{ solClass }}">{{ parcelle.typeSol }}</span>
        </div>
        <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;color:var(--text-light);margin-bottom:6px;">🌱 Cultures</div>
            <div style="font-size:1.2rem;font-weight:700;color:var(--text-dark);">{{ cultures|length }}</div>
        </div>
    </div>

    {# Progress bar #}
    {% set taux = parcelle.tauxOccupation %}
    <div style="background:white;border-radius:10px;padding:14px;box-shadow:var(--shadow-sm);">
        <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
            <span style="font-size:0.85rem;font-weight:600;color:var(--text-muted);">📊 Taux d'occupation</span>
            <span style="font-weight:700;
                color:{{ taux >= 90 ? 'var(--red-600)' : (taux >= 60 ? 'var(--amber)' : 'var(--green-600)') }};">
                {{ taux }}%
            </span>
        </div>
        <div class="progress-bar">
            <div class="progress-fill" style="width:{{ taux }}%;
                {% if taux >= 90 %}background:var(--red-600){% elseif taux >= 60 %}background:var(--amber){% endif %}">
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════
   WEATHER SECTION
   ═══════════════════════════════════════════════════ #}
{% if weather %}
<style>
/* ── Weather card ── */
.weather-wrap {
    margin-bottom: 32px;
}
.weather-header-label {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.weather-main-card {
    border-radius: 20px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,.13);
    margin-bottom: 16px;
}
.weather-hero {
    background: linear-gradient(135deg, #1a6b3c 0%, #2d9d5e 45%, #1e7a4a 100%);
    padding: 28px 28px 22px;
    color: white;
    position: relative;
    overflow: hidden;
}
.weather-hero::before {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    background: rgba(255,255,255,.06);
    border-radius: 50%;
}
.weather-hero::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -20px;
    width: 250px; height: 250px;
    background: rgba(255,255,255,.04);
    border-radius: 50%;
}
.weather-location-row {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    opacity: .85;
    margin-bottom: 16px;
    position: relative; z-index: 1;
}
.weather-temp-row {
    display: flex;
    align-items: flex-end;
    gap: 20px;
    position: relative; z-index: 1;
    flex-wrap: wrap;
}
.weather-temp-big {
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -3px;
}
.weather-temp-details {
    padding-bottom: 8px;
}
.weather-desc {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 4px;
}
.weather-feels {
    font-size: 0.82rem;
    opacity: .8;
}
.weather-emoji-big {
    font-size: 4rem;
    line-height: 1;
    margin-left: auto;
    position: relative; z-index: 1;
}
.weather-updated {
    font-size: 0.72rem;
    opacity: .65;
    margin-top: 14px;
    position: relative; z-index: 1;
}

/* Stats strip */
.weather-stats {
    background: white;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 0;
    border-top: 1px solid #f0f0f0;
}
.weather-stat-item {
    padding: 14px 16px;
    border-right: 1px solid #f0f0f0;
    text-align: center;
}
.weather-stat-item:last-child { border-right: none; }
.weather-stat-icon { font-size: 1.3rem; margin-bottom: 4px; }
.weather-stat-value {
    font-size: 1rem;
    font-weight: 700;
    color: #1a3d2b;
}
.weather-stat-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    color: #888;
    font-weight: 600;
    letter-spacing: .3px;
}

/* Forecast strip */
.forecast-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 12px;
    margin-bottom: 16px;
}
.forecast-day-card {
    background: white;
    border-radius: 14px;
    padding: 14px 10px;
    text-align: center;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
    transition: transform .15s, box-shadow .15s;
}
.forecast-day-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,.11);
}
.forecast-day-card.today {
    background: linear-gradient(135deg, #e8f5ee, #d0ede0);
    border: 2px solid #2d9d5e;
}
.forecast-label {
    font-size: 0.73rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 6px;
}
.forecast-label.today { color: #1a6b3c; }
.forecast-icon-img { width: 44px; height: 44px; margin: 0 auto 4px; }
.forecast-temps {
    display: flex;
    justify-content: center;
    gap: 6px;
    font-size: 0.85rem;
}
.forecast-max { font-weight: 700; color: #d35400; }
.forecast-min { color: #5d9cec; font-weight: 600; }
.forecast-desc {
    font-size: 0.68rem;
    color: #888;
    margin-top: 4px;
    line-height: 1.3;
}

/* Agri advice */
.agri-advice-card {
    background: white;
    border-radius: 14px;
    padding: 16px 20px;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
    margin-bottom: 16px;
}
.agri-advice-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a3d2b;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.agri-advice-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 8px;
    margin-bottom: 6px;
    font-size: 0.85rem;
    font-weight: 500;
}
.agri-advice-item:last-child { margin-bottom: 0; }
.agri-advice-item.success { background: #e8f5e9; color: #2e7d32; }
.agri-advice-item.warning { background: #fff8e1; color: #f57f17; }
.agri-advice-item.danger  { background: #ffebee; color: #c62828; }
.agri-advice-item.info    { background: #e3f2fd; color: #1565c0; }
.agri-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }

@media (max-width: 600px) {
    .weather-temp-big { font-size: 3.5rem; }
    .weather-emoji-big { font-size: 2.8rem; }
    .weather-stats { grid-template-columns: repeat(3, 1fr); }
    .forecast-strip { grid-template-columns: repeat(3, 1fr); }
}
</style>

<div class="weather-wrap">
    <div class="weather-header-label">
        🌤️ Météo actuelle — {{ weather.location }}
    </div>

    {# ── Main weather card ── #}
    <div class="weather-main-card">
        <div class="weather-hero">
            <div class="weather-location-row">
                📍 {{ weather.location }}, Tunisie
            </div>
            <div class="weather-temp-row">
                <div class="weather-temp-big">{{ weather.temp }}°</div>
                <div class="weather-temp-details">
                    <div class="weather-desc">{{ weather.description }}</div>
                    <div class="weather-feels">Ressenti {{ weather.feels_like }}° · ↑ {{ weather.temp_max }}° ↓ {{ weather.temp_min }}°</div>
                </div>
                <div class="weather-emoji-big">{{ weather.emoji }}</div>
            </div>
            <div class="weather-updated">Mis à jour à {{ weather.updated_at }}</div>
        </div>

        {# Stats strip #}
        <div class="weather-stats">
            <div class="weather-stat-item">
                <div class="weather-stat-icon">💧</div>
                <div class="weather-stat-value">{{ weather.humidity }}%</div>
                <div class="weather-stat-label">Humidité</div>
            </div>
            <div class="weather-stat-item">
                <div class="weather-stat-icon">💨</div>
                <div class="weather-stat-value">{{ weather.wind_speed }} km/h</div>
                <div class="weather-stat-label">Vent</div>
            </div>
            <div class="weather-stat-item">
                <div class="weather-stat-icon">🌡️</div>
                <div class="weather-stat-value">{{ weather.pressure }} hPa</div>
                <div class="weather-stat-label">Pression</div>
            </div>
            {% if weather.visibility %}
            <div class="weather-stat-item">
                <div class="weather-stat-icon">👁️</div>
                <div class="weather-stat-value">{{ weather.visibility }} km</div>
                <div class="weather-stat-label">Visibilité</div>
            </div>
            {% endif %}
            <div class="weather-stat-item">
                <div class="weather-stat-icon">☁️</div>
                <div class="weather-stat-value">{{ weather.clouds }}%</div>
                <div class="weather-stat-label">Nuages</div>
            </div>
            <div class="weather-stat-item">
                <div class="weather-stat-icon">🌅</div>
                <div class="weather-stat-value">{{ weather.sunrise }}</div>
                <div class="weather-stat-label">Lever</div>
            </div>
            <div class="weather-stat-item">
                <div class="weather-stat-icon">🌇</div>
                <div class="weather-stat-value">{{ weather.sunset }}</div>
                <div class="weather-stat-label">Coucher</div>
            </div>
        </div>
    </div>

    {# ── 5-Day Forecast ── #}
    {% if weather.daily %}
    <div class="forecast-strip">
        {% for day in weather.daily %}
        <div class="forecast-day-card {{ loop.first ? 'today' : '' }}">
            <div class="forecast-label {{ loop.first ? 'today' : '' }}">{{ day.label }}</div>
            <img class="forecast-icon-img"
                 src="https://openweathermap.org/img/wn/{{ day.icon }}@2x.png"
                 alt="{{ day.description }}" loading="lazy">
            <div class="forecast-temps">
                <span class="forecast-max">{{ day.temp_max }}°</span>
                <span class="forecast-min">{{ day.temp_min }}°</span>
            </div>
            <div class="forecast-desc">{{ day.description }}</div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Agricultural advice ── #}
    <div class="agri-advice-card">
        <div class="agri-advice-title">🌾 Conseils agricoles du jour</div>
        {% for tip in weather.agri_advice %}
        <div class="agri-advice-item {{ tip.type }}">
            <span class="agri-icon">{{ tip.icon }}</span>
            <span>{{ tip.text }}</span>
        </div>
        {% endfor %}
    </div>
</div>

{% else %}
{# Weather unavailable fallback #}
<div style="background:#f9f9f9;border:1.5px dashed #ddd;border-radius:14px;
            padding:20px 24px;margin-bottom:28px;color:#888;font-size:0.9rem;
            display:flex;align-items:center;gap:12px;">
    <span style="font-size:1.6rem;">🌥️</span>
    <div>
        <strong style="color:#555;">Météo indisponible</strong><br>
        Impossible de récupérer la météo pour « {{ parcelle.localisation }} » — vérifiez votre clé API OpenWeather.
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════
   CULTURES LIST
   ═══════════════════════════════════════════════════ #}
<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-dark);margin-bottom:18px;">
    🌱 Cultures sur cette parcelle
</h2>

{% if cultures is empty %}
    <div class="empty-state">
        <div class="empty-icon">🌾</div>
        <div class="empty-title">Aucune culture sur cette parcelle</div>
        <div class="empty-subtitle">
            <a href="{{ path('culture_index') }}" style="color:var(--green-600);text-decoration:none;font-weight:600;">
                ➕ Ajouter une culture
            </a>
        </div>
    </div>
{% else %}
    <div class="card-grid">
        {% for culture in cultures %}
        <div class="culture-card">

            <div class="culture-card-image">
                {% if culture.img %}
                    <img src="{{ asset('images/cultures/' ~ culture.img) }}"
                         alt="{{ culture.nom }}"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <div class="img-fallback" style="display:none;width:100%;height:100%;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">
                        🌱
                    </div>
                {% else %}
                    <div class="img-fallback" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--green-100);font-size:2.5rem;">
                        🌱
                    </div>
                {% endif %}
            </div>

            <div class="culture-card-body">
                <span class="culture-card-type">{{ culture.typeCulture }}</span>
                <div class="culture-card-name">{{ culture.nom }}</div>
                {% set etatClass = etatToCssClass(culture.etat) %}
                <span class="etat-badge {{ etatClass }}">{{ culture.etat }}</span>

                <div class="culture-card-meta">
                    <div class="meta-item">
                        <span class="meta-label">📐 Surface</span>
                        <span class="meta-value">{{ culture.surface }} m²</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌱 Plantation</span>
                        <span class="meta-value">{{ culture.datePlantation ? culture.datePlantation|date('d/m/Y') : '—' }}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">🌾 Récolte prévue</span>
                        <span class="meta-value">{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
            </div>

            <div class="culture-card-footer">
                {% if culture.etat in ['Maturité', 'Récolte Prévue', 'Récolte en Retard'] %}
                <form method="post" action="{{ path('culture_harvest', {id: culture.id}) }}"
                      onsubmit="return confirm('Marquer « {{ culture.nom|e('js') }} » comme récoltée ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('harvest-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-primary btn-sm">🌾 Récolter</button>
                </form>
                {% endif %}

                <form method="post" action="{{ path('culture_delete', {id: culture.id}) }}"
                      onsubmit="return confirm('Supprimer « {{ culture.nom|e('js') }} » ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('del-culture-' ~ culture.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
