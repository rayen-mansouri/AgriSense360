{% set roles = app.user ? app.user.getRoles() : [] %}
{% set isAdmin   = 'ROLE_ADMIN'   in roles %}
{% set isGerant  = 'ROLE_GERANT'  in roles %}
{% set activeSection = activeSection ?? 'main' %}
{% set activePage    = activePage    ?? '' %}

<aside class="sidebar" id="sidebar">

    <!-- Brand -->
    <div class="brand">
        <div class="brand-icon">🌱</div>
        <div class="brand-text">
            <span class="brand-name">AgriSense 360</span>
            <span class="brand-tagline">Smart AI Companion for Farms</span>
        </div>
    </div>

    <!-- Profile mini — always visible -->
    {% if app.user %}
    <a href="{{ path('profile_show') }}" class="profile-mini {{ activeSection == 'profile' ? 'active' : '' }}">
        <div class="profile-avatar">
            {% if app.user.profilePicture %}
                <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" alt="Photo">
            {% else %}
                {{ app.user.name|first|upper }}
            {% endif %}
        </div>
        <div style="overflow:hidden; min-width:0;">
            <div class="profile-name">{{ app.user.name }}</div>
            <div class="profile-role">
                {% if isAdmin %}Administrateur{% elseif isGerant %}Gérant{% else %}Ouvrier{% endif %}
            </div>
        </div>
        <span class="profile-arrow">›</span>
    </a>
    {% endif %}

    <hr class="sidebar-divider">

    <!-- Navigation -->
    <nav class="managements">

        {% if activeSection == 'profile' %}
            <p class="nav-title">Mon compte</p>
            <ul>
                <li>
                    <a class="nav-link {{ activePage == 'account' ? 'active' : '' }}" href="{{ path('profile_show') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="8" r="4"/><path d="M6 20c0-4 2.7-6 6-6s6 2 6 6"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gérer mon compte</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'notifications' ? 'active' : '' }}" href="{{ path('profile_notifications') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                            </svg>
                        </span>
                        <span class="nav-label">Notifications</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'rapports' ? 'active' : '' }}" href="{{ path('profile_rapports') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </span>
                        <span class="nav-label">Mes rapports</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'help' ? 'active' : '' }}" href="{{ path('profile_help') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                        </span>
                        <span class="nav-label">Centre d'aide</span>
                    </a>
                </li>
            </ul>
            <hr class="sidebar-divider" style="margin: 10px 0;">
            <ul>
                <li>
                    <a class="nav-link" href="{% if isAdmin %}{{ path('admin_home') }}{% elseif isGerant %}{{ path('gerant_home') }}{% else %}{{ path('ouvrier_home') }}{% endif %}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                            </svg>
                        </span>
                        <span class="nav-label">Retour au tableau de bord</span>
                    </a>
                </li>
            </ul>

        {% elseif isAdmin %}
            <p class="nav-title">Gestions</p>
            <ul>
                <li>
                    <a class="nav-link {{ activePage == 'accueil' ? 'active' : '' }}" href="{{ path('admin_home') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                            </svg>
                        </span>
                        <span class="nav-label">Accueil</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'users' ? 'active' : '' }}" href="{{ path('admin_dashboard') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="8" r="3"/><path d="M6 20c1.5-3 10.5-3 12 0"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion utilisateurs</span>
                    </a>
                </li>
            </ul>

        {% elseif isGerant %}
            <p class="nav-title">Gestions</p>
            <ul>
                <li>
                    <a class="nav-link {{ activePage == 'dashboard' ? 'active' : '' }}" href="{{ path('gerant_home') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                            </svg>
                        </span>
                        <span class="nav-label">Tableau de bord</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'animaux' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 15c0 2 3 4 7 4s7-2 7-4"/><path d="M9 11c0-2 1.5-3 3-3s3 1 3 3"/><path d="M8 7c0-1.6 1.8-3 4-3s4 1.4 4 3"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion animaux</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'equipements' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 15h16l-2-6H6l-2 6z"/><circle cx="8" cy="17" r="2"/><circle cx="16" cy="17" r="2"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion équipements</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'stock' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 4h12v6H6z"/><path d="M5 10h14v8H5z"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion stock</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'cultures' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 18c4-3 12-3 16 0"/><path d="M7 10c2-2 8-2 10 0"/><path d="M9 6c1.5-1 4.5-1 6 0"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion cultures</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'ouvriers' ? 'active' : '' }}" href="{{ path('gerant_ouvriers') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M7 8h10"/><path d="M6 12h12"/><path d="M8 16h8"/>
                            </svg>
                        </span>
                        <span class="nav-label">Gestion ouvriers</span>
                    </a>
                </li>
            </ul>

        {% else %}
            <p class="nav-title">Navigation</p>
            <ul>
                <li>
                    <a class="nav-link {{ activePage == 'dashboard' ? 'active' : '' }}" href="{{ path('ouvrier_home') }}">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                            </svg>
                        </span>
                        <span class="nav-label">Mon espace</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'taches' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                            </svg>
                        </span>
                        <span class="nav-label">Mes tâches</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'planning' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                        </span>
                        <span class="nav-label">Planning</span>
                    </a>
                </li>
                <li>
                    <a class="nav-link {{ activePage == 'meteo' ? 'active' : '' }}" href="#">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            </svg>
                        </span>
                        <span class="nav-label">Météo</span>
                    </a>
                </li>
            </ul>
        {% endif %}

    </nav>

    <!-- Déconnexion -->
    <a href="{{ path('app_logout') }}" class="logout-link">
        <span class="nav-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </span>
        <span class="nav-label">Déconnexion</span>
    </a>

    <div class="sidebar-foot">
        <span class="pulse-dot"></span>
        <span>Connecté aux données en temps réel</span>
    </div>

</aside>

<script>
(function() {
    const key = 'gerant_sidebar_collapsed';
    if (localStorage.getItem(key) !== '0') {
        document.body.classList.add('sidebar-collapsed');
    }
    window._sbToggle = function() {
        const collapsed = document.body.classList.toggle('sidebar-collapsed');
        localStorage.setItem(key, collapsed ? '1' : '0');
    };
})();
</script>
