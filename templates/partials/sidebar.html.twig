{% set roles = app.user ? app.user.getRoles() : [] %}
{% set isAdmin   = 'ROLE_ADMIN'   in roles %}
{% set isGerant  = 'ROLE_GERANT'  in roles %}
{% set isOwner   = 'ROLE_OWNER'   in roles %}
{% set activeSection = activeSection ?? 'main' %}
{% set activePage    = activePage    ?? '' %}

<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('app_index') }}" class="sidebar-brand">
            <img src="{{ asset('images/logo.png') }}" alt="Logo">
            AgriSense 360
        </a>
    </div>

    <div class="sidebar-nav">
        {% if activeSection == 'profile' %}
            <div style="font-size: .75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: .1em; padding: 10px 16px;">Mon compte</div>
            <a href="{{ path('profile_show') }}" class="sidebar-link {{ activePage == 'account' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M6 20c0-4 2.7-6 6-6s6 2 6 6"/></svg>
                Gérer mon compte
            </a>
            <a href="{{ path('profile_notifications') }}" class="sidebar-link {{ activePage == 'notifications' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                Notifications
            </a>
            <a href="{{ path('profile_rapports') }}" class="sidebar-link {{ activePage == 'rapports' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                Mes rapports
            </a>
            <a href="{{ path('profile_help') }}" class="sidebar-link {{ activePage == 'help' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Centre d'aide
            </a>
            <div style="margin: 10px 16px; border-top: 1px solid var(--sidebar-border);"></div>
            <a href="{% if isAdmin %}{{ path('admin_home') }}{% elseif isOwner %}{{ path('farm_dashboard') }}{% elseif isGerant %}{{ path('gerant_home') }}{% else %}{{ path('ouvrier_home') }}{% endif %}" class="sidebar-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Retour au tableau de bord
            </a>

        {% elseif isAdmin %}
            <div style="font-size: .75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: .1em; padding: 10px 16px;">Administration</div>
            <a href="{{ path('admin_home') }}" class="sidebar-link {{ activePage == 'accueil' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                Accueil
            </a>
            <a href="{{ path('admin_dashboard') }}" class="sidebar-link {{ activePage == 'users' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3"/><path d="M6 20c1.5-3 10.5-3 12 0"/></svg>
                Utilisateurs
            </a>
            <a href="{{ path('admin_culture_dashboard') }}" class="sidebar-link {{ activePage == 'cultures_admin' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                Cultures
            </a>

        {% elseif isGerant %}
            <div style="font-size: .75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: .1em; padding: 10px 16px;">Gestions</div>
            <a href="{{ path('app_home') }}" class="sidebar-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Vue d'ensemble
            </a>
            <a href="{{ path('gerant_home') }}" class="sidebar-link {{ activePage == 'dashboard' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                Tableau de bord
            </a>
            <a href="{{ path('gerant_ouvriers') }}" class="sidebar-link {{ activePage == 'ouvriers' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                Ouvriers
            </a>
            <a href="{{ path('gerant_cultures') }}" class="sidebar-link {{ activePage == 'cultures' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                Cultures
            </a>
            <a href="{{ path('gerant_stockes') }}" class="sidebar-link {{ activePage == 'stockes' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                Stockés
            </a>
            <a href="{{ path('gerant_equipements') }}" class="sidebar-link {{ activePage == 'equipements' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle></svg>
                Équipements
            </a>
            <a href="{{ path('gerant_affectations') }}" class="sidebar-link {{ activePage == 'affectations' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                Affectations
            </a>
            <a href="{{ path('gerant_animaux') }}" class="sidebar-link {{ activePage == 'animaux' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="16" rx="8" ry="5"></ellipse><path d="M12 11v5M7 7.5C7.5 5.5 9 4 12 4s4.5 1.5 5 3.5M16 7.5c.5 2 2 3.5 4 4.5"></path></svg>
                Animaux
            </a>

        {% elseif isOwner %}
            <div style="font-size: .75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: .1em; padding: 10px 16px;">Fermes</div>
            <a href="{{ path('farm_dashboard') }}" class="sidebar-link {{ activePage == 'dashboard' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                Tableau de bord
            </a>
            <a href="{{ path('farm_create') }}" class="sidebar-link {{ activePage == 'farm_create' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>
                Nouvelle Ferme
            </a>

        {% else %}
            <div style="font-size: .75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: .1em; padding: 10px 16px;">Navigation</div>
            <a href="{{ path('ouvrier_home') }}" class="sidebar-link {{ activePage == 'dashboard' ? 'active' : '' }}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                Mon espace
            </a>
        {% endif %}
    </div>

    <div class="sidebar-footer">
        <a href="{{ path('profile_show') }}" class="sidebar-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            Mon Profil
        </a>
        <a href="{{ path('app_logout') }}" class="sidebar-link" style="color: var(--danger);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Déconnexion
        </a>
    </div>
</div>
