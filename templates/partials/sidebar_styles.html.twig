<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
    :root {
        --pg: #0a0f0a; --pc: #e8f5e4;
        --s1: #0d1a0d; --s2: #0a0f0a;
        --cb: rgba(255,255,255,.04); --cbr: rgba(255,255,255,.08);
        --ch3: #fff; --cp: rgba(232,245,228,.55);
        --g: #5ab55a; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #060a06;
        --sidebar-border: rgba(255,255,255,.05);
        --danger: #f87171; --danger-bg: rgba(248,113,113,.1);
        --indigo: #818cf8; --indigo-bg: rgba(129,140,248,.1);
        
        /* Map old profile variables */
        --card-bg: var(--cb);
        --card-b: var(--cbr);
        --border: var(--cbr);
        --surface-b: var(--cbr);
        --surface2: rgba(255,255,255,.02);
        --h: var(--ch3);
        --muted: var(--cp);
        --badge-g: rgba(90,181,90,.1);
        --text-mid: var(--cp);
        --text-light: var(--cp);
        --text-mute: var(--cp);
        --text-dark: var(--ch3);
        --radius: 24px;
        --radius-sm: 12px;
        --green-pale: rgba(90,181,90,.1);
        --green-mid: var(--g);
        --green-dark: var(--gd);
        --sh: none;
        --sh-lg: none;
    }
    [data-theme="light"] {
        --pg: #f5f7f5; --pc: #1a3a1a;
        --s1: #e8f5e4; --s2: #f0f7ee;
        --cb: #ffffff; --cbr: rgba(0,0,0,.08);
        --ch3: #0c1a0c; --cp: #4a6741;
        --g: #2d6a2d; --gm: #3e8e3e; --gd: #2d6a2d;
        --sidebar-bg: #ffffff;
        --sidebar-border: rgba(0,0,0,.1);
        --danger: #dc2626; --danger-bg: rgba(220,38,38,.1);
        --indigo: #4338ca; --indigo-bg: rgba(67,56,202,.1);
        --surface2: rgba(0,0,0,.04);
        --text-dark: #0c1a0c;
        --sh: 0 4px 12px rgba(0,0,0,.05);
        --sh-lg: 0 10px 30px rgba(0,0,0,.08);
    }

    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; display: flex; min-height: 100vh; overflow-x: hidden; }

    /* Sidebar */
    .sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); display: flex; flex-direction: column; transition: transform .3s ease, width .3s ease; position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; }
    .sidebar.collapsed { transform: translateX(-100%); }
    .sidebar-header { padding: 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--sidebar-border); }
    .sidebar-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--ch3); font-weight: 800; font-size: 1.1rem; }
    .sidebar-brand img { width: 32px; height: 32px; object-fit: contain; }
    .sidebar-nav { padding: 20px 10px; flex: 1; display: flex; flex-direction: column; gap: 8px; overflow-y: auto; }
    .sidebar-link { padding: 12px 16px; display: flex; align-items: center; gap: 12px; color: var(--cp); text-decoration: none; font-weight: 600; font-size: .95rem; border-radius: 10px; transition: all .2s; }
    .sidebar-link:hover, .sidebar-link.active { background: rgba(90,181,90,.1); color: var(--g); }
    .sidebar-footer { padding: 20px; border-top: 1px solid var(--sidebar-border); display:flex; flex-direction:column; gap:8px; }

    /* Main Content */
    .layout { display: flex; min-height: 100vh; width: 100%; }
    .main { flex: 1; margin-left: 260px; transition: margin-left .3s ease; display: flex; flex-direction: column; min-height: 100vh; }
    .main.expanded { margin-left: 0; }

    .topbar { height: 70px; padding: 0 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(var(--sidebar-bg), .8); backdrop-filter: blur(10px); border-bottom: 1px solid var(--sidebar-border); position: sticky; top: 0; z-index: 90; }
    .sidebar-toggle { background: none; border: none; color: var(--ch3); cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 8px; }
    .sidebar-toggle span { display: block; width: 24px; height: 2px; background: currentColor; border-radius: 2px; }

    .theme-toggle { background: none; border: none; color: var(--cp); cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 8px; border-radius: 8px; transition: all .2s; }
    .theme-toggle:hover { background: rgba(255,255,255,.05); color: var(--ch3); }
    [data-theme="light"] .theme-toggle:hover { background: rgba(0,0,0,.05); }
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="light"] .icon-sun { display: none; }

    .content-wrapper { padding: 32px; width: 100%; box-sizing: border-box; }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; overflow: hidden; margin-bottom: 20px; box-shadow: var(--sh); }
    .card-head { padding: 24px 32px; border-bottom: 1px solid var(--cbr); display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,.03); }
    [data-theme="light"] .card-head { background: rgba(0,0,0,.02); }
    .card-title { font-family: 'Inter', sans-serif; font-size: 1.2rem; font-weight: 800; color: var(--ch3); display: flex; align-items: center; gap: 12px; }
    .card-body { padding: 32px; }

    .badge-orange { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 700; background: rgba(245,158,11,.1); color: #f59e0b; padding: 4px 10px; border-radius: 50px; }
    .badge-blue { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 700; background: rgba(59,130,246,.1); color: #3b82f6; padding: 4px 10px; border-radius: 50px; }
    .badge-green { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 700; background: rgba(16,185,129,.1); color: #10b981; padding: 4px 10px; border-radius: 50px; }

    .breadcrumb { display:flex; align-items:center; gap:8px; font-size:.8rem; color:var(--cp); margin-bottom:20px; padding: 0 32px; margin-top: 32px; }
    .breadcrumb span:last-child { color: var(--ch3); }

    .form-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--cp); margin-bottom: 6px; }
    .form-input, .form-input[readonly] { width: 100%; box-sizing: border-box; padding: 12px 16px; border: 1px solid var(--cbr); border-radius: 12px; font-size: .9rem; color: var(--ch3); background: rgba(0,0,0,.1); outline: none; transition: border-color .2s; font-family: 'Inter', sans-serif; }
    [data-theme="light"] .form-input { background: #fafafa; }
    [data-theme="light"] .form-input[readonly] { background: #f0f0f0; }
    .form-input:focus { border-color: var(--g); }

    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 16px; border-radius: 50px; font-family: 'Inter', sans-serif; font-size: .9rem; font-weight: 600; cursor: pointer; text-decoration: none; border: 1px solid transparent; transition: all .2s; }
    .btn-save { background: linear-gradient(135deg, var(--gd), var(--g)); color: #fff; }
    .btn-save:hover { opacity: .9; }
    .btn-danger { background: var(--danger-bg); color: var(--danger); }
    .btn-danger:hover { opacity: .8; }
    .btn-pale { color: var(--cp); border-color: var(--cbr); background: transparent; }
    .btn-pale:hover { background: var(--cbr); color: var(--ch3); }

    .flash-success { background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.2); color: #10b981; padding: 16px; border-radius: 12px; margin: 0 32px 20px; }
    .flash-error { background: var(--danger-bg); border: 1px solid rgba(220,38,38,.2); color: var(--danger); padding: 16px; border-radius: 12px; margin: 0 32px 20px; }

    @media (max-width: 768px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.open { transform: translateX(0); }
        .main { margin-left: 0; }
    }
</style>
