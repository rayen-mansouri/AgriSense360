{% extends 'base.html.twig' %}
{% set activePage = 'stockes' %}
{% set activeSection = 'main' %}

{% block title %}Modifier {{ produit.nom }} — Agrisens 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    /* ── CUSTOM OVERRIDES ── */
    .form-container { max-width: 1000px; margin: 0 auto; }
    .form-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; padding: 32px; margin-bottom: 32px; }
    .form-card-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--cbr); }
    .form-card-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .form-card-title { font-size: 1.1rem; font-weight: 800; color: var(--ch3); margin: 0; }
    .form-card-subtitle { font-size: 0.85rem; color: var(--cp); margin: 4px 0 0; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .form-full { grid-column: span 2; }
    @media (max-width: 768px) { .form-grid { grid-template-columns: 1fr; } .form-full { grid-column: span 1; } }

    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-label { font-size: 0.75rem; font-weight: 700; color: var(--cp); text-transform: uppercase; letter-spacing: 0.05em; }
    .input-field { background: rgba(0,0,0,0.2); border: 1px solid var(--cbr); border-radius: 12px; padding: 12px 16px; color: var(--ch3); font-family: inherit; font-size: 0.95rem; outline: none; transition: all 0.2s; }
    .input-field:focus { border-color: var(--g); background: rgba(0,0,0,0.3); }

    .current-img-preview { margin-bottom: 20px; text-align: center; }
    .current-img-preview img { max-width: 180px; max-height: 180px; border-radius: 16px; border: 2px solid var(--g); padding: 4px; background: white; object-fit: cover; }

    .upload-zone { border: 2px dashed var(--cbr); border-radius: 16px; padding: 32px; text-align: center; cursor: pointer; transition: all 0.2s; background: rgba(255,255,255,0.02); }
    .upload-zone:hover { border-color: var(--g); background: rgba(90,181,90,0.05); }
    .upload-zone i { font-size: 2rem; color: var(--cp); margin-bottom: 12px; }
    .upload-zone p { font-size: 0.85rem; color: var(--cp); margin: 0; }

    .preview-zone { margin-top: 16px; text-align: center; }
    .preview-img { max-width: 180px; max-height: 180px; border-radius: 12px; border: 2px solid var(--indigo); padding: 4px; background: white; }

    .error-msg { background: rgba(239,68,68,0.1); color: #ef4444; padding: 8px 12px; border-radius: 8px; font-size: 0.8rem; margin-top: 4px; border-left: 3px solid #ef4444; }

    /* Fix spacing */
    .content-wrapper { padding-top: 20px !important; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <a href="{{ path('homestock') }}" class="btn btn-pale btn-sm" style="border-radius: 50px; padding: 6px 16px;"><i class="fa-solid fa-arrow-left"></i> Retour</a>
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>

        <div class="content-wrapper">
            <div class="form-container">
                <div style="margin-bottom: 32px;">
                    <h1 style="font-size: 2rem; font-weight: 900; color: var(--ch3); margin: 0;">✏️ Modifier le Produit</h1>
                    <p style="color: var(--cp); font-size: 1rem; margin: 4px 0 0;">Produit : <strong>{{ produit.nom }}</strong></p>
                </div>

                <form method="post" id="produitForm" enctype="multipart/form-data" novalidate>
                    {{ form_widget(form._token) }}

                    <!-- Section Produit -->
                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon" style="background: rgba(90,181,90,0.1); color: var(--g);"><i class="fa-solid fa-box"></i></div>
                            <div>
                                <h2 class="form-card-title">📦 Informations Produit</h2>
                                <p class="form-card-subtitle">Mettre à jour les détails de l'article</p>
                            </div>
                        </div>

                        <div class="form-grid">
                            <div class="input-group">
                                <label class="input-label">Catégorie *</label>
                                {{ form_widget(form.produit.categorie, {'attr': {'class': 'input-field field-categorie'}}) }}
                                <div class="error-categorie"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Nom du produit *</label>
                                {{ form_widget(form.produit.nom, {'attr': {'class': 'input-field field-nom'}}) }}
                                <div class="error-nom"></div>
                            </div>
                            <div class="input-group form-full">
                                <label class="input-label">Description</label>
                                {{ form_widget(form.produit.description, {'attr': {'class': 'input-field field-description', 'rows': 3}}) }}
                                <div class="error-description"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Prix unitaire (DT) *</label>
                                {{ form_widget(form.produit.prixUnitaire, {'attr': {'class': 'input-field field-prix'}}) }}
                                <div class="error-prix"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Photo du produit</label>
                                
                                {% if produit.photoUrl %}
                                    <div class="current-img-preview">
                                        <img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}">
                                        <p style="font-size: 0.7rem; color: var(--cp); margin-top: 4px;">Image actuelle</p>
                                    </div>
                                {% endif %}

                                <div id="uploadZone" class="upload-zone">
                                    <i class="fa-solid fa-cloud-arrow-up"></i>
                                    <p>{{ produit.photoUrl ? 'Changer l\'image' : 'Choisir une image' }}</p>
                                </div>
                                <div style="display:none;">{{ form_widget(form.produit.photoFile, {'attr': {'class': 'field-photo'}}) }}</div>
                                <div id="previewZone" class="preview-zone" style="display:none;">
                                    <img id="previewImage" src="" class="preview-img">
                                    <br>
                                    <button type="button" id="btnSupprimer" class="btn btn-danger btn-sm" style="margin-top:12px; border-radius:50px;">✖ Annuler</button>
                                </div>
                                <div class="error-photo"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Section Stock -->
                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon" style="background: rgba(129,140,248,0.1); color: var(--indigo);"><i class="fa-solid fa-warehouse"></i></div>
                            <div>
                                <h2 class="form-card-title">📊 État du Stock</h2>
                                <p class="form-card-subtitle">
                                    {% if produit.stockActuel %}<span class="badge-green">Stock existant</span>{% else %}Configuration optionnelle{% endif %}
                                </p>
                            </div>
                        </div>

                        <div class="form-grid">
                            <div class="input-group">
                                <label class="input-label">Quantité actuelle</label>
                                {{ form_widget(form.stock.quantiteActuelle, {'attr': {'class': 'input-field field-quantite'}}) }}
                                <div class="error-quantite"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Seuil d'alerte</label>
                                {{ form_widget(form.stock.seuilAlerte, {'attr': {'class': 'input-field field-seuil'}}) }}
                                <div class="error-seuil"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Unité de mesure</label>
                                {{ form_widget(form.stock.uniteMesure, {'attr': {'class': 'input-field field-unite'}}) }}
                                <div class="error-unite"></div>
                            </div>
                            <div class="input-group">
                                <label class="input-label">Emplacement</label>
                                {{ form_widget(form.stock.emplacement, {'attr': {'class': 'input-field field-emplacement'}}) }}
                            </div>
                            <div class="input-group">
                                <label class="input-label">Date de réception</label>
                                {{ form_widget(form.stock.dateReception, {'attr': {'class': 'input-field field-dateReception'}}) }}
                            </div>
                            <div class="input-group">
                                <label class="input-label">Date d'expiration</label>
                                {{ form_widget(form.stock.dateExpiration, {'attr': {'class': 'input-field field-dateExpiration'}}) }}
                                <div class="error-dateExpiration"></div>
                            </div>
                        </div>
                    </div>

                    <div style="display: flex; justify-content: flex-end; gap: 16px; margin-bottom: 60px;">
                        <a href="{{ path('homestock') }}" class="btn btn-pale" style="padding: 12px 32px; border-radius: 14px;">Annuler</a>
                        <button type="submit" class="btn btn-save" style="padding: 12px 32px; border-radius: 14px; font-weight: 800;">✓ Enregistrer les Modifications</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<script>
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('open');
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        }
    });

    // Theme toggle
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);

    document.getElementById('themeToggle').addEventListener('click', function () {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });

    // ── FORM LOGIC (JS) ──
    (function() {
        var form = document.getElementById('produitForm');
        var uploadZone = document.getElementById('uploadZone');
        var previewZone = document.getElementById('previewZone');
        var previewImage = document.getElementById('previewImage');
        var btnSupprimer = document.getElementById('btnSupprimer');
        var fileInput = document.querySelector('.field-photo');
        var imageSelectionnee = false;

        function findErr(c) { return document.querySelector('.error-' + c); }
        function findFld(c) { return document.querySelector('.field-' + c); }

        function showErr(c, msg) {
            var d = findErr(c);
            if (d) d.innerHTML = '<div class="error-msg">⚠️ ' + msg + '</div>';
            var f = findFld(c);
            if (f) f.style.borderColor = '#ef4444';
        }

        function hideErr(c) {
            var d = findErr(c);
            if (d) d.innerHTML = '';
            var f = findFld(c);
            if (f) f.style.borderColor = '';
        }

        if (uploadZone && fileInput) {
            uploadZone.onclick = function() { fileInput.click(); };
            fileInput.onchange = function() {
                if (this.files && this.files.length > 0) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        previewImage.src = e.target.result;
                        previewZone.style.display = 'block';
                        uploadZone.style.display = 'none';
                        imageSelectionnee = true;
                    };
                    reader.readAsDataURL(this.files[0]);
                }
            };
        }

        if (btnSupprimer) {
            btnSupprimer.onclick = function() {
                fileInput.value = '';
                previewZone.style.display = 'none';
                uploadZone.style.display = 'block';
                imageSelectionnee = false;
            };
        }

        form.onsubmit = function(e) {
            var ok = true;
            ['categorie', 'nom', 'prix'].forEach(hideErr);

            if (!findFld('categorie').value) { showErr('categorie', 'Requis'); ok = false; }
            if (!findFld('nom').value) { showErr('nom', 'Requis'); ok = false; }
            if (!findFld('prix').value) { showErr('prix', 'Requis'); ok = false; }

            if (!ok) e.preventDefault();
            return ok;
        };
    })();
</script>
{% endblock %}