{% extends 'base.html.twig' %}
{% set activePage = 'stockes' %}
{% set activeSection = 'main' %}

{% block title %}{{ produit.nom }} — Agrisens 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    /* ── CUSTOM OVERRIDES ── */
    .show-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; flex-wrap: wrap; gap: 15px; }
    .show-title-group h1 { font-size: 1.75rem; font-weight: 800; color: var(--ch3); margin-bottom: 4px; }
    .show-title-group p { color: var(--cp); font-size: 0.9rem; }

    .show-container { display: grid; grid-template-columns: 1fr 2fr; gap: 32px; margin-bottom: 40px; }
    @media (max-width: 992px) { .show-container { grid-template-columns: 1fr; } }

    .product-image-card { 
        background: var(--cb); 
        border: 1px solid var(--cbr); 
        border-radius: 24px; 
        padding: 32px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        position: sticky; 
        top: 100px;
        min-height: 300px;
    }
    .product-image-card img { max-width: 100%; max-height: 400px; border-radius: 16px; object-fit: contain; }

    .details-card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; padding: 32px; display: flex; flex-direction: column; gap: 24px; }
    
    .info-section-title { font-size: 0.8rem; font-weight: 800; color: var(--cp); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    
    .stock-box { background: rgba(255,255,255,0.02); border: 1px solid var(--cbr); border-radius: 20px; padding: 24px; }
    .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; }
    .meta-item { display: flex; flex-direction: column; gap: 4px; }
    .meta-label { font-size: 0.7rem; font-weight: 700; color: var(--cp); text-transform: uppercase; }
    .meta-value { font-size: 1rem; font-weight: 700; color: var(--ch3); }

    .progress-bar-wrap { height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; margin-top: 12px; }
    .progress-bar-fill { height: 100%; border-radius: 4px; transition: width 0.3s ease; }
    
    .barcode-section { background: white; border-radius: 16px; padding: 24px; display: flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 24px; }
    .barcode-section p { color: #000; font-weight: 700; margin: 0; }

    /* Recommendations */
    .reco-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 24px; }
    .reco-card { 
        background: var(--cb); 
        border: 1px solid var(--cbr); 
        border-radius: 16px; 
        padding: 16px; 
        text-decoration: none; 
        transition: all 0.2s; 
        display: flex; 
        flex-direction: column; 
        gap: 12px; 
    }
    .reco-card:hover { transform: translateY(-4px); border-color: var(--g); background: rgba(255,255,255,0.02); }
    .reco-img { height: 120px; background: rgba(255,255,255,0.05); border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .reco-img img { width: 100%; height: 100%; object-fit: cover; }
    .reco-name { font-weight: 700; color: var(--ch3); font-size: 0.95rem; }
    .reco-reason { font-size: 0.75rem; color: var(--cp); background: rgba(0,0,0,0.1); padding: 8px; border-radius: 8px; font-style: italic; }

    /* Fix spacing */
    .content-wrapper { padding-top: 20px !important; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main" id="mainContent">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle">
                <span></span><span></span><span></span>
            </button>
            <div style="display: flex; gap: 16px; align-items: center;">
                <a href="{{ path('homestock') }}" class="btn btn-pale btn-sm" style="border-radius: 50px; padding: 6px 16px;"><i class="fa-solid fa-arrow-left"></i> Retour</a>
                <button class="theme-toggle" id="themeToggle">
                    <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                    <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
                </button>
            </div>
        </header>

        <div class="content-wrapper">
            
            <div class="show-header">
                <div class="show-title-group">
                    <h1>Détails du Produit</h1>
                    <p>{{ produit.nom }} — Identifiant #{{ produit.id }}</p>
                </div>
                <div style="display: flex; gap: 12px;">
                    <a href="{{ path('produit_edit', {id: produit.id}) }}" class="btn btn-save" style="padding: 8px 20px; border-radius: 12px;"><i class="fa-solid fa-pen"></i> Modifier</a>
                    <form method="POST" action="{{ path('produit_delete', {id: produit.id}) }}" onsubmit="return confirm('⚠️ Supprimer ce produit ?')" style="display:inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
                        <button type="submit" class="btn btn-danger" style="padding: 8px 20px; border-radius: 12px;"><i class="fa-solid fa-trash"></i> Supprimer</button>
                    </form>
                </div>
            </div>

            <div class="show-container">
                <!-- Col Image -->
                <div class="product-image-card">
                    {% if produit.photoUrl %}
                        <img src="{{ asset(produit.photoUrl) }}" alt="{{ produit.nom }}">
                    {% else %}
                        <i class="fa-solid fa-seedling" style="font-size: 80px; color: var(--cbr);"></i>
                    {% endif %}
                </div>

                <!-- Col Info -->
                <div class="details-card">
                    <div>
                        <div class="info-section-title"><i class="fa-solid fa-info-circle"></i> Informations Générales</div>
                        <span class="badge-green" style="margin-bottom: 12px;">{{ produit.categorie ?: 'Autre' }}</span>
                        <h2 style="font-size: 2rem; font-weight: 900; color: var(--ch3); margin: 8px 0;">{{ produit.nom }}</h2>
                        <p style="color: var(--cp); font-size: 1rem; line-height: 1.6; margin-bottom: 20px;">{{ produit.description ?: 'Aucune description disponible.' }}</p>
                        <div style="font-size: 1.75rem; font-weight: 900; color: var(--g);">{{ produit.prixUnitaire }} DT <span style="font-size: 0.9rem; font-weight: 600; color: var(--cp);">/ unité</span></div>
                    </div>

                    <!-- Stock Info -->
                    <div class="stock-box">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                            <div class="info-section-title" style="margin-bottom: 0;"><i class="fa-solid fa-warehouse"></i> État des Stocks</div>
                            {% if stock %}
                                <span class="statut-badge statut-{{ stock.statut|lower }}">{{ stock.statut }}</span>
                            {% else %}
                                <span class="statut-badge" style="background: rgba(255,255,255,0.05); color: var(--cp);">Aucun Stock</span>
                            {% endif %}
                        </div>

                        {% if stock %}
                            <div class="meta-grid">
                                <div class="meta-item">
                                    <span class="meta-label">Quantité Actuelle</span>
                                    <span class="meta-value" style="font-size: 1.5rem; color: {{ stock.isEnAlerte ? 'var(--danger)' : 'var(--g)' }};">{{ stock.quantiteActuelle }} {{ stock.uniteMesure }}</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">Seuil d'Alerte</span>
                                    <span class="meta-value">{{ stock.seuilAlerte ?: '—' }} {{ stock.uniteMesure }}</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">Emplacement</span>
                                    <span class="meta-value">{{ stock.emplacement ?: '—' }}</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">Dernière Réception</span>
                                    <span class="meta-value">{{ stock.dateReception ? stock.dateReception|date('d/m/Y') : '—' }}</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-label">Expiration</span>
                                    <span class="meta-value" style="{{ stock.dateExpiration and date(stock.dateExpiration) < date('+30 days') ? 'color: var(--danger);' : '' }}">
                                        {{ stock.dateExpiration ? stock.dateExpiration|date('d/m/Y') : '—' }}
                                    </span>
                                </div>
                            </div>

                            {% if stock.seuilAlerte and stock.seuilAlerte > 0 %}
                                {% set pct = (stock.quantiteActuelle / stock.seuilAlerte * 100)|round(0) %}
                                {% set pct = pct > 100 ? 100 : pct %}
                                <div style="margin-top: 24px;">
                                    <div style="display:flex; justify-content:space-between; margin-bottom: 8px;">
                                        <span style="font-size: 0.75rem; font-weight: 700; color: var(--cp);">CAPACITÉ CRITIQUE</span>
                                        <span style="font-size: 0.75rem; font-weight: 700; color: {{ pct < 50 ? 'var(--danger)' : 'var(--g)' }};">{{ pct }}%</span>
                                    </div>
                                    <div class="progress-bar-wrap">
                                        <div class="progress-bar-fill {{ pct < 50 ? 'fill-danger' : (pct < 100 ? 'fill-warning' : 'fill-ok') }}" style="width: {{ pct }}%"></div>
                                    </div>
                                </div>
                            {% endif %}

                            <div style="margin-top: 24px; display: flex; gap: 12px;">
                                <a href="{{ path('stock_edit', {id: stock.id}) }}" class="btn btn-pale btn-sm" style="flex: 1;"><i class="fa-solid fa-pen"></i> Modifier le stock</a>
                            </div>
                        {% else %}
                            <div style="text-align: center; padding: 20px; border: 1px dashed var(--cbr); border-radius: 12px;">
                                <p style="color: var(--cp); font-size: 0.9rem; margin-bottom: 16px;">Aucun stock n'est enregistré pour ce produit.</p>
                                <a href="{{ path('stock_new') }}" class="btn btn-save btn-sm"><i class="fa-solid fa-plus"></i> Créer un stock</a>
                            </div>
                        {% endif %}
                    </div>

                    <!-- Identifiants -->
                    <div class="stock-box">
                        <div class="info-section-title"><i class="fa-solid fa-barcode"></i> Traçabilité & Codes</div>
                        <div style="display: flex; gap: 24px; align-items: center; flex-wrap: wrap;">
                            {% if produit.barcodeUrl %}
                                <div class="barcode-section">
                                    <img src="{{ produit.barcodeUrl }}" alt="Barcode" style="height: 60px;">
                                    <p>SKU: {{ produit.sku }}</p>
                                    <a href="{{ produit.barcodeUrl }}" download="barcode-{{ produit.sku }}.png" class="btn btn-pale btn-sm" style="background: rgba(0,0,0,0.05);"><i class="fa-solid fa-download"></i></a>
                                </div>
                            {% else %}
                                <p style="color: var(--cp); font-size: 0.85rem;">Aucun code-barres généré.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recommendations -->
            {% if recommendations is not empty %}
                <div class="action-section-title"><i class="fa-solid fa-wand-magic-sparkles"></i> Produits Similaires</div>
                <div class="reco-grid">
                    {% for item in recommendations %}
                        {% set p = item.produit %}
                        <a href="{{ path('produit_show', {id: p.id}) }}" class="reco-card">
                            <div class="reco-img">
                                {% if p.photoUrl %}
                                    <img src="{{ asset(p.photoUrl) }}" alt="{{ p.nom }}">
                                {% else %}
                                    <i class="fa-solid fa-seedling" style="font-size: 40px; color: var(--cbr);"></i>
                                {% endif %}
                            </div>
                            <div class="reco-name">{{ p.nom }}</div>
                            <div class="reco-reason">{{ item.reason }}</div>
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                                <span style="font-weight: 800; color: var(--g);">{{ p.prixUnitaire }} DT</span>
                                <span class="badge-green" style="font-size: 0.7rem;">{{ p.categorie }}</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </main>
</div>

<script>
    // Sidebar toggle
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('open');
        } else {
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        }
    });

    // Theme toggle
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);

    document.getElementById('themeToggle').addEventListener('click', function () {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('agri-theme', next);
    });
</script>
{% endblock %}
