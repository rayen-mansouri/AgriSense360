{% extends 'base.html.twig' %}
{% set activePage = 'help' %}
{% set activeSection = 'profile' %}
{% block title %}Centre d'aide — AgriSense 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    /* Main wrapper to use full width and match front layout */
    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    .help-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .help-card { 
        background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; box-shadow: var(--sh-lg); padding: 30px; 
        text-align: center; cursor: pointer; transition: all 0.2s; border: 2px solid transparent; 
    }
    .help-card:hover { transform: translateY(-5px); border-color: var(--g); box-shadow: 0 15px 30px rgba(0,0,0,0.3); }
    .help-card-icon { font-size: 2.5rem; margin-bottom: 15px; }
    .help-card-title { font-size: 1.1rem; font-weight: 800; color: var(--ch3); margin-bottom: 8px; }
    .help-card-desc  { font-size: 0.9rem; color: var(--cp); }

    .faq-item { border-bottom: 1px solid var(--cbr); }
    .faq-item:last-child { border-bottom: none; }
    .faq-question { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; cursor: pointer; font-size: 1rem; font-weight: 700; color: var(--ch3); }
    .faq-arrow { transition: transform 0.2s; color: var(--cp); font-size: 1.2rem; }
    .faq-answer  { font-size: 0.95rem; color: var(--cp); line-height: 1.6; padding-bottom: 20px; display: none; }
    .faq-item.open .faq-arrow { transform: rotate(90deg); color: var(--g); }
    .faq-item.open .faq-answer { display: block; }

    .contact-form { display: grid; gap: 20px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 0.85rem; font-weight: 700; color: var(--ch3); }
    .form-input, textarea { 
        padding: 12px 16px; border-radius: 12px; border: 1px solid var(--cbr); 
        background: rgba(255,255,255,0.02); color: var(--ch3); font-family: inherit; font-size: 0.95rem;
        transition: all 0.2s;
    }
    .form-input:focus, textarea:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 4px rgba(90,181,90,0.1); }
    textarea { resize: vertical; min-height: 120px; }
    
    .btn-send { 
        padding: 12px 24px; background: linear-gradient(135deg,var(--gd),var(--g)); color: #fff; 
        border: none; border-radius: 50px; font-family: inherit; font-size: 1rem; font-weight: 700; 
        cursor: pointer; display: inline-flex; align-items: center; gap: 10px; transition: all 0.2s;
    }
    .btn-send:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(90,181,90,0.3); }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; box-shadow: var(--sh-lg); overflow: hidden; margin-bottom: 30px; }
    .card-head { padding: 24px 30px; border-bottom: 1px solid var(--cbr); }
    .card-title { font-size: 1.25rem; font-weight: 800; color: var(--ch3); display: flex; align-items: center; gap: 12px; }
    .card-body { padding: 30px; }
    .page-title { font-size: 1.8rem; font-weight: 900; color: var(--ch3); margin-bottom: 30px; }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">
        <h1 class="page-title"><i class="fa-solid fa-circle-question" style="color:var(--g)"></i> Centre d'aide AgriSense 360</h1>

        <div class="help-grid">
            <div class="help-card"><div class="help-card-icon">📖</div><div class="help-card-title">Documentation</div><div class="help-card-desc">Consultez les guides et tutoriels complets</div></div>
            <div class="help-card"><div class="help-card-icon">🎥</div><div class="help-card-title">Tutoriels vidéo</div><div class="help-card-desc">Apprenez à utiliser AgriSense en vidéo</div></div>
            <div class="help-card"><div class="help-card-icon">💬</div><div class="help-card-title">Chat en direct</div><div class="help-card-desc">Parlez à notre équipe support en temps réel</div></div>
            <div class="help-card"><div class="help-card-icon">🐛</div><div class="help-card-title">Signaler un bug</div><div class="help-card-desc">Aidez-nous à améliorer la plateforme</div></div>
        </div>

        <div class="card">
            <div class="card-head"><span class="card-title">❓ Questions fréquentes</span></div>
            <div class="card-body">
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment modifier mon mot de passe ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Allez dans <strong>Mon compte → Gérer mon compte</strong>, remplissez les champs "Nouveau mot de passe" et "Confirmer", puis cliquez sur Enregistrer.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment télécharger un rapport ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Rendez-vous dans <strong>Mon compte → Mes rapports</strong>. Cliquez sur le bouton "Télécharger" à côté du rapport souhaité.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Ma session expire après combien de temps ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Par mesure de sécurité, votre session expire automatiquement après <strong>15 minutes d'inactivité</strong>. Vous serez redirigé vers la page de connexion.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment contacter un administrateur ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Utilisez le formulaire de contact ci-dessous pour envoyer un message directement à l'équipe d'administration.</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-head"><span class="card-title">✉️ Contacter le support</span></div>
            <div class="card-body">
                <div class="contact-form">
                    <div class="form-group"><label class="form-label">Sujet</label><input type="text" class="form-input" placeholder="Ex: Problème de connexion"></div>
                    <div class="form-group"><label class="form-label">Message</label><textarea placeholder="Décrivez votre problème en détail..."></textarea></div>
                    <div><button class="btn-send"><i class="fa-solid fa-paper-plane"></i> Envoyer le message</button></div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const dropdown = document.getElementById('gerant-dropdown-nav');
            if (dropdown && dropdown.classList.contains('show')) {
                dropdown.classList.remove('show');
            }
        }
    }

    function toggleFaq(el) {
        const item = el.parentElement;
        item.classList.toggle('open');
    }
</script>
{% endblock %}

