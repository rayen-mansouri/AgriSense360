{% extends 'base.html.twig' %}
{% set activePage = 'help' %}
{% set activeSection = 'profile' %}
{% block title %}Centre d'aide — AgriSense 360{% endblock %}
{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .help-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
    .help-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow-md); padding: 24px; text-align: center; cursor: pointer; transition: transform .2s, box-shadow .2s; border: 2px solid transparent; }
    .help-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.1); border-color: var(--green-light); }
    .help-card-icon { font-size: 2.2rem; margin-bottom: 10px; }
    .help-card-title { font-size: .95rem; font-weight: 800; margin-bottom: 5px; }
    .help-card-desc  { font-size: .78rem; color: var(--text-light); }

    .faq-item { border-bottom: 1px solid var(--border); }
    .faq-item:last-child { border-bottom: none; }
    .faq-question { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; cursor: pointer; font-size: .9rem; font-weight: 700; }
    .faq-arrow { transition: transform .2s; color: var(--text-light); }
    .faq-answer  { font-size: .84rem; color: var(--text-mid); line-height: 1.6; padding-bottom: 14px; display: none; }
    .faq-item.open .faq-arrow { transform: rotate(90deg); }
    .faq-item.open .faq-answer { display: block; }

    .contact-form { display: grid; gap: 14px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-light); }
    .form-input, textarea { padding: 10px 14px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: 'Plus Jakarta Sans',sans-serif; font-size: .88rem; color: var(--text-dark); background: #fafcf8; outline: none; transition: border-color .2s; width: 100%; }
    .form-input:focus, textarea:focus { border-color: var(--green-light); }
    textarea { resize: vertical; min-height: 100px; border-radius: var(--radius-sm); }
    .btn-send { padding: 11px 24px; background: var(--green-mid); color: #fff; border: none; border-radius: 50px; font-family: 'Plus Jakarta Sans',sans-serif; font-size: .88rem; font-weight: 700; cursor: pointer; }
    .btn-send:hover { background: var(--green-dark); }
    .page-title { font-size: 1.4rem; font-weight: 800; margin-bottom: 22px; }
</style>
{% endblock %}
{% block body %}
{% include 'partials/sidebar.html.twig' %}
<main class="main" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>
    <div class="breadcrumb"><span>Mon compte</span><span>›</span><span>Centre d'aide</span></div>
    <div class="content-wrapper">
        <p class="page-title" style="margin-top:0;">❓ Centre d'aide AgriSense 360</p>

        <div class="help-grid">
            <div class="help-card"><div class="help-card-icon">📖</div><div class="help-card-title">Documentation</div><div class="help-card-desc">Consultez les guides et tutoriels complets</div></div>
            <div class="help-card"><div class="help-card-icon">🎥</div><div class="help-card-title">Tutoriels vidéo</div><div class="help-card-desc">Apprenez à utiliser AgriSense en vidéo</div></div>
            <div class="help-card"><div class="help-card-icon">💬</div><div class="help-card-title">Chat en direct</div><div class="help-card-desc">Parlez à notre équipe support en temps réel</div></div>
            <div class="help-card"><div class="help-card-icon">🐛</div><div class="help-card-title">Signaler un bug</div><div class="help-card-desc">Aidez-nous à améliorer la plateforme</div></div>
        </div>

        <div class="card" style="margin-bottom:20px;">
            <div class="card-head"><span class="card-title">❓ Questions fréquentes</span></div>
            <div class="card-body">
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment modifier mon mot de passe ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Allez dans <strong>Mon compte → Gérer mon compte</strong>, remplissez les champs "Nouveau mot de passe" et "Confirmer", puis cliquez sur Enregistrer.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment télécharger un rapport ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Rendez-vous dans <strong>Mon compte → Mes rapports</strong>. Cliquez sur le bouton "Télécharger" à côté du rapport souhaité.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Ma session expire après combien de temps ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Par mesure de sécurité, votre session expire automatiquement après <strong>15 minutes d'inactivité</strong>. Vous serez redirigé vers la page de connexion.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleFaq(this)">Comment contacter un administrateur ? <span class="faq-arrow">›</span></div>
                    <div class="faq-answer">Utilisez le formulaire de contact ci-dessous pour envoyer un message directement à l'équipe d'administration.</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-head"><span class="card-title">✉️ Contacter le support</span></div>
            <div class="card-body">
                <div class="contact-form">
                    <div class="form-group"><label>Sujet</label><input type="text" class="form-input" placeholder="Ex: Problème de connexion"></div>
                    <div class="form-group"><label>Message</label><textarea placeholder="Décrivez votre problème en détail..."></textarea></div>
                    <div><button class="btn-send">📨 Envoyer le message</button></div>
                </div>
            </div>
        </div>
        </div>
    </div>
</main>
<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
            if (window.innerWidth <= 768) { sidebar.classList.toggle('open'); }
            else { sidebar.classList.toggle('collapsed'); mainContent.classList.toggle('expanded'); }
        });
    }
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);
    const themeBtn = document.getElementById('themeToggle');
    if (themeBtn) {
        themeBtn.addEventListener('click', function () {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endblock %}
{% block scripts %}
<script>
function toggleFaq(el) {
    const item = el.parentElement;
    item.classList.toggle('open');
}
</script>
{% endblock %}
