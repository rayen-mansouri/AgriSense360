{% extends 'base.html.twig' %}
{% set activePage = 'rapports' %}
{% set activeSection = 'profile' %}
{% block title %}Mes rapports — AgriSense 360{% endblock %}
{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    /* Main wrapper to use full width and match front layout */
    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    .rapport-item { display: flex; align-items: center; gap: 20px; padding: 20px 0; border-bottom: 1px solid var(--cbr); transition: all 0.2s; }
    .rapport-item:last-child { border-bottom: none; }
    .rapport-icon { width: 48px; height: 48px; border-radius: 14px; background: rgba(90,181,90,0.1); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
    .rapport-info { flex: 1; }
    .rapport-name { font-size: 1rem; font-weight: 800; color: var(--ch3); margin-bottom: 4px; }
    .rapport-meta { font-size: 0.85rem; color: var(--cp); }
    .btn-dl { 
        padding: 10px 20px; border-radius: 50px; background: rgba(90,181,90,0.1); color: var(--g); 
        border: 1px solid rgba(90,181,90,0.2); font-size: 0.85rem; font-weight: 700; cursor: pointer; 
        font-family: inherit; transition: all 0.2s; display: flex; align-items: center; gap: 8px;
    }
    .btn-dl:hover:not(:disabled) { background: var(--g); color: #fff; transform: translateY(-2px); }
    .btn-dl:disabled { opacity: 0.5; cursor: not-allowed; }

    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; box-shadow: var(--sh-lg); overflow: hidden; }
    .card-head { padding: 24px 30px; border-bottom: 1px solid var(--cbr); display: flex; justify-content: space-between; align-items: center; }
    .card-title { font-size: 1.25rem; font-weight: 800; color: var(--ch3); display: flex; align-items: center; gap: 12px; }
    .card-body { padding: 30px; }
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">
        <div class="card">
            <div class="card-head">
                <span class="card-title"><i class="fa-solid fa-chart-pie" style="color:var(--g)"></i> Mes rapports</span>
                <span class="badge badge-green">5 rapports disponibles</span>
            </div>
            <div class="card-body">
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Mars 2026</div><div class="rapport-meta">Généré le 01/04/2026 · PDF · 2.4 Mo</div></div>
                    <span class="badge badge-green" style="margin-right:15px">Complété</span>
                    <button class="btn-dl"><i class="fa-solid fa-download"></i> Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport hebdomadaire — Semaine 13</div><div class="rapport-meta">Généré le 28/03/2026 · PDF · 1.1 Mo</div></div>
                    <span class="badge badge-green" style="margin-right:15px">Complété</span>
                    <button class="btn-dl"><i class="fa-solid fa-download"></i> Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📊</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport stock — Q1 2026</div><div class="rapport-meta">Généré le 01/04/2026 · Excel · 850 Ko</div></div>
                    <span class="badge badge-orange" style="margin-right:15px">En cours</span>
                    <button class="btn-dl" disabled><i class="fa-solid fa-lock"></i> Indisponible</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Février 2026</div><div class="rapport-meta">Généré le 01/03/2026 · PDF · 2.1 Mo</div></div>
                    <span class="badge badge-green" style="margin-right:15px">Complété</span>
                    <button class="btn-dl"><i class="fa-solid fa-download"></i> Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Janvier 2026</div><div class="rapport-meta">Généré le 01/02/2026 · PDF · 1.9 Mo</div></div>
                    <span class="badge badge-green" style="margin-right:15px">Complété</span>
                    <button class="btn-dl"><i class="fa-solid fa-download"></i> Télécharger</button>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const dropdown = document.getElementById('gerant-dropdown-nav');
            if (dropdown && dropdown.classList.contains('show')) {
                dropdown.classList.remove('show');
            }
        }
    }
</script>
{% endblock %}
