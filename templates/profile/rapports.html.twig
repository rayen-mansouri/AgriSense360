{% extends 'base.html.twig' %}
{% set activePage = 'rapports' %}
{% set activeSection = 'profile' %}
{% block title %}Mes rapports — AgriSense 360{% endblock %}
{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .rapport-item { display: flex; align-items: center; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--border); }
    .rapport-item:last-child { border-bottom: none; }
    .rapport-icon { width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--green-pale); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
    .rapport-info { flex: 1; }
    .rapport-name { font-size: .9rem; font-weight: 700; margin-bottom: 3px; }
    .rapport-meta { font-size: .76rem; color: var(--text-light); }
    .btn-dl { padding: 7px 16px; border-radius: 50px; background: var(--green-pale); color: var(--green-dark); border: 1px solid #a5d6a7; font-size: .78rem; font-weight: 700; cursor: pointer; font-family: 'Plus Jakarta Sans',sans-serif; transition: background .2s; }
    .btn-dl:hover { background: #c8e6c9; }
    .rapport-status { padding: 3px 10px; border-radius: 50px; font-size: .72rem; font-weight: 700; }
</style>
{% endblock %}
{% block body %}
{% include 'partials/sidebar.html.twig' %}
<main class="main" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>
    <div class="breadcrumb"><span>Mon compte</span><span>›</span><span>Mes rapports</span></div>
    <div class="content-wrapper">
        <div class="card">
            <div class="card-head"><span class="card-title">📊 Mes rapports</span><span class="badge badge-green">5 rapports</span></div>
            <div class="card-body">
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Mars 2026</div><div class="rapport-meta">Généré le 01/04/2026 · PDF · 2.4 Mo</div></div>
                    <span class="rapport-status badge badge-green">Complété</span>
                    <button class="btn-dl">⬇ Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport hebdomadaire — Semaine 13</div><div class="rapport-meta">Généré le 28/03/2026 · PDF · 1.1 Mo</div></div>
                    <span class="rapport-status badge badge-green">Complété</span>
                    <button class="btn-dl">⬇ Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📊</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport stock — Q1 2026</div><div class="rapport-meta">Généré le 01/04/2026 · Excel · 850 Ko</div></div>
                    <span class="rapport-status badge badge-orange">En cours</span>
                    <button class="btn-dl" disabled style="opacity:.5;">⬇ Indisponible</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Février 2026</div><div class="rapport-meta">Généré le 01/03/2026 · PDF · 2.1 Mo</div></div>
                    <span class="rapport-status badge badge-green">Complété</span>
                    <button class="btn-dl">⬇ Télécharger</button>
                </div>
                <div class="rapport-item">
                    <div class="rapport-icon">📄</div>
                    <div class="rapport-info"><div class="rapport-name">Rapport mensuel — Janvier 2026</div><div class="rapport-meta">Généré le 01/02/2026 · PDF · 1.9 Mo</div></div>
                    <span class="rapport-status badge badge-green">Complété</span>
                    <button class="btn-dl">⬇ Télécharger</button>
                </div>
            </div>
        </div>
    </div>
</main>
<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
            if (window.innerWidth <= 768) { sidebar.classList.toggle('open'); }
            else { sidebar.classList.toggle('collapsed'); mainContent.classList.toggle('expanded'); }
        });
    }
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);
    const themeBtn = document.getElementById('themeToggle');
    if (themeBtn) {
        themeBtn.addEventListener('click', function () {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>
{% endblock %}
