{% extends 'base.html.twig' %}
{% set activePage = 'account' %}
{% set activeSection = 'profile' %}

{% block title %}Mon profil — AgriSense 360{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .profile-grid{display:grid;grid-template-columns:280px 1fr;gap:20px;align-items:start}
    .avatar-card{background:var(--card-bg);border:1px solid var(--card-b);border-radius:var(--radius);box-shadow:var(--sh);padding:26px 20px;text-align:center}
    .avatar-big{width:90px;height:90px;border-radius:50%;margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:800;color:#fff;background:linear-gradient(135deg,var(--gd),var(--g));overflow:hidden;position:relative;box-shadow:0 4px 16px rgba(46,125,50,.25)}
    .avatar-big img{width:100%;height:100%;object-fit:cover}
    .google-badge{position:absolute;bottom:0;right:0;width:24px;height:24px;border-radius:50%;background:#fff;border:2px solid #fff;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.2)}
    .google-badge svg{width:13px;height:13px}
    .avatar-edit-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 15px;border-radius:50px;background:var(--badge-g);color:var(--g);border:1px solid rgba(90,181,90,.2);font-size:.76rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;margin-bottom:14px;transition:filter .2s}
    .avatar-edit-btn:hover{filter:brightness(.9)}
    .avatar-edit-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
    .profile-name-big{font-size:1.1rem;font-weight:800;color:var(--h);margin-bottom:4px}
    .profile-badge-row{margin-bottom:14px}
    .profile-divider{border:none;border-top:1px solid var(--surface-b);margin:12px 0}
    .meta-row{display:flex;justify-content:space-between;font-size:.8rem;color:var(--muted);margin-bottom:7px}
    .meta-row strong{color:var(--h);font-weight:700}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .form-group{display:flex;flex-direction:column;gap:4px}
    .form-group.full{grid-column:1/-1}
    .action-bar{display:flex;gap:10px;padding:16px 20px;border-top:1px solid var(--surface-b);background:var(--surface2)}
    .btn-save{background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none}
    .btn-danger{background:rgba(220,50,50,.09);color:#f87171;border:1px solid rgba(220,50,50,.18)}
    .section-sep{font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:18px 0 10px;padding-top:14px;border-top:1px solid var(--surface-b)}
    .google-notice{display:flex;align-items:center;gap:10px;padding:9px 13px;background:rgba(26,115,232,.08);border:1px solid rgba(26,115,232,.18);border-radius:var(--radius-sm);font-size:.8rem;color:#60a5fa;margin-bottom:14px}
    .google-notice svg{width:16px;height:16px;flex-shrink:0}
    .photo-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000;align-items:center;justify-content:center}
    .photo-modal.open{display:flex}
    .photo-modal-card{background:var(--card-bg);border:1px solid var(--card-b);border-radius:var(--radius);padding:28px;width:470px;max-width:96vw;box-shadow:var(--sh-lg)}
    .photo-modal-title{font-size:1rem;font-weight:800;color:var(--h);margin-bottom:5px}
    .photo-modal-sub{font-size:.8rem;color:var(--muted);margin-bottom:18px}
    .modal-tabs{display:flex;border:1px solid var(--surface-b);border-radius:var(--radius-sm);overflow:hidden;margin-bottom:18px}
    .modal-tab{flex:1;padding:8px 0;text-align:center;font-size:.8rem;font-weight:700;cursor:pointer;color:var(--muted);background:var(--surface2);border:none;font-family:'Inter',sans-serif;transition:background .15s,color .15s}
    .modal-tab.active{background:linear-gradient(135deg,var(--gd),var(--g));color:#fff}
    .tab-panel{display:none}
    .tab-panel.active{display:block}
    .photo-drop{border:2px dashed var(--surface-b);border-radius:var(--radius-sm);padding:28px 18px;cursor:pointer;transition:border-color .2s,background .2s;margin-bottom:14px;text-align:center}
    .photo-drop:hover{border-color:var(--g);background:var(--badge-g)}
    .photo-drop-icon{margin-bottom:7px;opacity:.5}
    .photo-drop-icon svg{width:32px;height:32px;stroke:var(--muted);fill:none;stroke-width:1.5}
    .photo-drop-text{font-size:.82rem;color:var(--muted)}
    .preview-img{width:76px;height:76px;border-radius:50%;object-fit:cover;margin:0 auto 10px;display:none}
    .avatar-style-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
    .avatar-style-option{display:flex;flex-direction:column;align-items:center;gap:5px;padding:9px 5px;border-radius:var(--radius-sm);border:2px solid var(--surface-b);cursor:pointer;transition:border-color .2s,background .2s;background:var(--surface)}
    .avatar-style-option:hover{border-color:var(--g)}
    .avatar-style-option.selected{border-color:var(--g);background:var(--badge-g)}
    .avatar-style-option img{width:52px;height:52px;border-radius:50%}
    .avatar-style-label{font-size:.68rem;font-weight:700;color:var(--muted)}
    .modal-actions{display:flex;gap:9px;justify-content:flex-end;margin-top:4px}
    .btn-modal-save{padding:9px 20px;background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none;border-radius:50px;font-family:'Inter',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer}
    .btn-modal-save:disabled{opacity:.5;cursor:not-allowed}
    .btn-modal-cancel{padding:9px 20px;background:var(--surface2);color:var(--muted);border:1px solid var(--surface-b);border-radius:50px;font-family:'Inter',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer}
</style>
{% endblock %}

{% block body %}
{% include 'partials/sidebar.html.twig' %}

<main class="main" id="mainContent">
    <header class="topbar">
        <button class="sidebar-toggle" id="sidebarToggle">
            <span></span><span></span><span></span>
        </button>
        <div style="display: flex; gap: 16px; align-items: center;">
            <button class="theme-toggle" id="themeToggle" aria-label="Thème">
                <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
                <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
            </button>
        </div>
    </header>
    <div class="breadcrumb">
        <span>Mon compte</span><span>›</span><span>Gérer mon compte</span>
    </div>
    <div class="content-wrapper">

        {% for msg in app.flashes('success') %}<div class="flash-success">✓ {{ msg }}</div>{% endfor %}
        {% for msg in app.flashes('error') %}<div class="flash-error">⚠ {{ msg }}</div>{% endfor %}

        <div class="profile-grid">

            {# ── LEFT: avatar card ──────────────────────────────────────────── #}
            <div class="avatar-card">
                <div class="avatar-big" id="mainAvatarWrap">
                    {% set pic = app.user.profilePicture %}
                    {% if pic %}
                        {% if pic starts with 'http' %}
                            <img id="mainAvatarImg" src="{{ pic }}" alt="Photo de profil">
                        {% else %}
                            <img id="mainAvatarImg" src="{{ asset('uploads/profiles/' ~ pic) }}" alt="Photo de profil">
                        {% endif %}
                    {% else %}
                        {# DiceBear initials fallback #}
                        <img id="mainAvatarImg"
                             src="https://api.dicebear.com/9.x/initials/svg?seed={{ app.user.name|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                             alt="{{ app.user.name }}">
                    {% endif %}

                    {# Show Google badge if connected via Google #}
                    {% if app.user.authProvider == 'google' %}
                    <div class="google-badge" title="Compte Google">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                    </div>
                    {% endif %}
                </div>

            <button class="avatar-edit-btn" onclick="openAvatarModal()">
                    <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    Changer la photo
                </button>

                <div class="profile-name-big">{{ app.user.name }}</div>
                <div class="profile-badge-row">
                    {% set roles = app.user.getRoles() %}
                    {% if 'ROLE_ADMIN' in roles %}<span class="badge badge-blue">Administrateur</span>
                    {% elseif 'ROLE_GERANT' in roles %}<span class="badge badge-green">Gérant</span>
                    {% else %}<span class="badge badge-orange">Ouvrier</span>{% endif %}
                    {% if app.user.authProvider == 'google' %}
                        <span class="badge" style="background:#e8f0fe;color:#1a73e8;margin-left:4px;">Google</span>
                    {% endif %}
                </div>

                <hr class="profile-divider">
                <div class="meta-row"><span>Statut</span><strong style="color:#2e7d32;">✓ Actif</strong></div>
                {% if app.user.phone %}
                    <div class="meta-row"><span>Téléphone</span><strong>{{ app.user.phone }}</strong></div>
                {% endif %}
                <div class="meta-row">
                    <span>Membre depuis</span>
                    <strong>{{ app.user.createdAt ? app.user.createdAt|date('d/m/Y') : '—' }}</strong>
                </div>
                {% if app.user.updatedAt %}
                <div class="meta-row">
                    <span>Mis à jour</span>
                    <strong>{{ app.user.updatedAt|date('d/m/Y') }}</strong>
                </div>
                {% endif %}

                {# Remove avatar button #}
                <hr class="profile-divider">
                <form method="post" action="{{ path('profile_avatar_remove') }}"
                      onsubmit="return confirm('Supprimer la photo de profil ?')">
                    <button type="submit" class="btn btn-danger" style="width:100%;justify-content:center;font-size:.76rem;">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        Supprimer la photo
                    </button>
                </form>
            </div>

            {# ── RIGHT: edit form ───────────────────────────────────────────── #}
            <div class="card">
                <div class="card-head"><span class="card-title">Modifier mes informations</span></div>
                <form method="post" action="{{ path('profile_update') }}" enctype="multipart/form-data" id="profileForm">
                    <div class="card-body">

                        {# Google user notice #}
                        {% if app.user.authProvider == 'google' %}
                        <div class="google-notice">
                            <svg viewBox="0 0 24 24" fill="none">
                                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                            </svg>
                            Votre compte est lié à Google. Le mot de passe n'est pas disponible.
                        </div>
                        {% endif %}

                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nom complet</label>
                                <input type="text" name="name" class="form-input"
                                       value="{{ app.user.name }}" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Adresse email (non modifiable)</label>
                                <input type="email" class="form-input"
                                       value="{{ app.user.email }}" readonly>
                            </div>
                            <div class="form-group full">
                                <label class="form-label">Téléphone</label>
                                <input type="tel" name="phone" class="form-input"
                                       value="{{ app.user.phone }}"
                                       placeholder="Ex: 55 123 456">
                            </div>
                        </div>

                        {# Hide password section for Google users #}
                        {% if app.user.authProvider != 'google' %}
                        <p class="section-sep">Changer le mot de passe</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nouveau mot de passe</label>
                                <input type="password" name="password" class="form-input"
                                       placeholder="Laisser vide pour ne pas changer">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirmer le mot de passe</label>
                                <input type="password" name="confirm_password" class="form-input"
                                       placeholder="Répéter le mot de passe">
                            </div>
                        </div>
                        {% endif %}

                        {# Hidden file input — triggered by avatar modal #}
                        <input type="file" id="hiddenPhotoInput" name="profile_picture"
                               accept="image/*" style="display:none;">
                    </div>
                    <div class="action-bar">
                        <button type="submit" class="btn btn-save">
                            <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Enregistrer les modifications
                        </button>
                    </div>
                </form>
            </div>
        </div>
        </div>
    </div>
</main>

<script>
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    const toggleBtn = document.getElementById('sidebarToggle');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', () => {
            if (window.innerWidth <= 768) { sidebar.classList.toggle('open'); }
            else { sidebar.classList.toggle('collapsed'); mainContent.classList.toggle('expanded'); }
        });
    }
    const html = document.documentElement;
    const saved = localStorage.getItem('agri-theme') || 'dark';
    html.setAttribute('data-theme', saved);
    const themeBtn = document.getElementById('themeToggle');
    if (themeBtn) {
        themeBtn.addEventListener('click', function () {
            const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }
</script>

{# ── AVATAR MODAL ─────────────────────────────────────────────────────────── #}
<div class="photo-modal" id="photoModal">
    <div class="photo-modal-card">
        <div class="photo-modal-title">Changer la photo de profil</div>
        <div class="photo-modal-sub">Choisissez entre un avatar généré ou uploadez votre propre photo</div>

        <div class="modal-tabs">
            <button class="modal-tab active" onclick="switchTab('dicebear')">Avatar généré</button>
            <button class="modal-tab" onclick="switchTab('upload')">Uploader une photo</button>
        </div>

        {# Tab 1 — DiceBear style picker #}
        <div class="tab-panel active" id="tabDicebear">
            <div class="avatar-style-grid" id="styleGrid">
                {% for style, label in avatar_styles %}
                <div class="avatar-style-option {{ loop.first ? 'selected' : '' }}"
                     data-style="{{ style }}"
                     onclick="selectStyle(this)">
                    <img src="{{ dicebear_base }}{{ style }}/svg?seed={{ app.user.name|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                         alt="{{ label }}"
                         loading="lazy">
                    <span class="avatar-style-label">{{ label }}</span>
                </div>
                {% endfor %}
            </div>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeModal()">Annuler</button>
                <button class="btn-modal-save" id="dicebearSaveBtn" onclick="saveDicebear()">✓ Utiliser cet avatar</button>
            </div>
        </div>

        {# Tab 2 — File upload #}
        <div class="tab-panel" id="tabUpload">
            <img class="preview-img" id="modalPreview" alt="Aperçu">

            <label for="hiddenPhotoInput">
                <div class="photo-drop" id="photoDrop">
                    <div class="photo-drop-icon"><svg viewBox="0 0 24 24" style="width:32px;height:32px;stroke:var(--muted);fill:none;stroke-width:1.5;margin:0 auto;display:block"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
                    <div class="photo-drop-text">Cliquez pour choisir une image<br>ou glissez-déposez ici</div>
                </div>
            </label>

            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeModal()">Annuler</button>
                <button class="btn-modal-save" id="uploadSaveBtn"
                        onclick="submitWithPhoto()" style="display:none;">✓ Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    event.currentTarget.classList.add('active');
}

// ── Modal open / close ────────────────────────────────────────────────────────
function openAvatarModal() {
    document.getElementById('photoModal').classList.add('open');
}
function closeModal() {
    document.getElementById('photoModal').classList.remove('open');
}
// Close on backdrop click
document.getElementById('photoModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});

// ── DiceBear style selection ──────────────────────────────────────────────────
let selectedStyle = '{{ avatar_styles|keys|first }}';

function selectStyle(el) {
    document.querySelectorAll('.avatar-style-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    selectedStyle = el.dataset.style;
}

function saveDicebear() {
    const btn = document.getElementById('dicebearSaveBtn');
    btn.disabled = true;
    btn.textContent = 'Enregistrement…';

    fetch('{{ path("profile_avatar_choose") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'style=' + encodeURIComponent(selectedStyle),
    })
    .then(r => r.json())
    .then(data => {
        if (data.url) {
            // Update avatar immediately on the page
            document.getElementById('mainAvatarImg').src = data.url;
        }
        closeModal();
        btn.disabled = false;
        btn.textContent = '✓ Utiliser cet avatar';
    })
    .catch(() => {
        alert('Erreur lors de la sauvegarde. Réessayez.');
        btn.disabled = false;
        btn.textContent = '✓ Utiliser cet avatar';
    });
}

// ── Upload tab ────────────────────────────────────────────────────────────────
document.getElementById('hiddenPhotoInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
        const img = document.getElementById('modalPreview');
        img.src = ev.target.result;
        img.style.display = 'block';
        document.getElementById('photoDrop').style.display = 'none';
        document.getElementById('uploadSaveBtn').style.display = 'inline-flex';
    };
    reader.readAsDataURL(file);
});

function submitWithPhoto() {
    closeModal();
    document.getElementById('profileForm').submit();
}

// Drag-and-drop support
const dropZone = document.getElementById('photoDrop');
['dragenter','dragover'].forEach(ev => {
    dropZone.addEventListener(ev, e => {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--green-mid)';
    });
});
['dragleave','drop'].forEach(ev => {
    dropZone.addEventListener(ev, e => {
        e.preventDefault();
        dropZone.style.borderColor = '';
    });
});
dropZone.addEventListener('drop', e => {
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const input = document.getElementById('hiddenPhotoInput');
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
    }
});
</script>
{% endblock %}
