{% extends 'base.html.twig' %}
{% set activePage = 'account' %}
{% set activeSection = 'profile' %}

{% block title %}Mon profil — AgriSense 360{% endblock %}

{% block navbar %}{% endblock %}

{% block styles %}
{% include 'partials/home_nav_styles.html.twig' %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    body { font-family: 'Inter', sans-serif; background: var(--pg); color: var(--pc); transition: background .3s, color .3s; margin: 0; min-height: 100vh; overflow-x: hidden; }

    /* Main wrapper to use full width and match front layout */
    .front-main {
        padding-top: 70px;
        width: 100%;
    }
    .front-main-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 60px;
    }

    .profile-grid{display:grid;grid-template-columns:320px 1fr;gap:30px;align-items:start}
    .avatar-card{background:var(--cb);border:1px solid var(--cbr);border-radius:24px;box-shadow:var(--sh-lg);padding:40px 30px;text-align:center}
    .avatar-big{width:120px;height:120px;border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;font-size:3rem;font-weight:900;color:#fff;background:linear-gradient(135deg,var(--gd),var(--g));overflow:hidden;position:relative;box-shadow:0 10px 30px rgba(46,125,50,0.3)}
    .avatar-big img{width:100%;height:100%;object-fit:cover}
    .google-badge{position:absolute;bottom:5px;right:5px;width:32px;height:32px;border-radius:50%;background:#fff;border:2px solid #fff;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 10px rgba(0,0,0,0.2)}
    .google-badge svg{width:18px;height:18px}
    .avatar-edit-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;background:rgba(90,181,90,0.1);color:var(--g);border:1px solid rgba(90,181,90,0.2);font-size:0.85rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;margin-bottom:20px;transition:all 0.2s}
    .avatar-edit-btn:hover{background:var(--g);color:#fff;transform:translateY(-2px)}
    .avatar-edit-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
    .profile-name-big{font-size:1.4rem;font-weight:900;color:var(--ch3);margin-bottom:8px}
    .profile-badge-row{margin-bottom:20px}
    .profile-divider{border:none;border-top:1px solid var(--cbr);margin:20px 0}
    .meta-row{display:flex;justify-content:space-between;font-size:0.9rem;color:var(--cp);margin-bottom:10px}
    .meta-row strong{color:var(--ch3);font-weight:700}
    
    .card { background: var(--cb); border: 1px solid var(--cbr); border-radius: 24px; box-shadow: var(--sh-lg); overflow: hidden; }
    .card-head { padding: 24px 30px; border-bottom: 1px solid var(--cbr); }
    .card-title { font-size: 1.25rem; font-weight: 800; color: var(--ch3); }
    .card-body { padding: 30px; }

    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .form-group{display:flex;flex-direction:column;gap:8px}
    .form-group.full{grid-column:1/-1}
    .form-label { font-size: 0.85rem; font-weight: 700; color: var(--ch3); }
    .form-input { 
        width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid var(--cbr); 
        background: rgba(255,255,255,0.02); color: var(--ch3); font-family: inherit; font-size: 0.95rem;
        transition: all 0.2s;
    }
    .form-input:focus { outline: none; border-color: var(--g); box-shadow: 0 0 0 4px rgba(90,181,90,0.1); }
    .form-input[readonly] { background: rgba(0,0,0,0.05); color: var(--cp); cursor: not-allowed; }

    .action-bar{display:flex;gap:15px;padding:24px 30px;border-top:1px solid var(--cbr);background:rgba(0,0,0,0.02)}
    .btn-save{background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none; padding: 12px 24px; border-radius: 50px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: all 0.2s;}
    .btn-save:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(90,181,90,0.3); }
    
    .btn-danger{background:rgba(220,50,50,.1);color:#f87171;border:1px solid rgba(220,50,50,.2); padding: 8px 16px; border-radius: 50px; font-weight: 700; cursor: pointer; transition: all 0.2s;}
    .btn-danger:hover { background: #f87171; color: #fff; }

    .section-sep{font-size:.75rem;font-weight:900;text-transform:uppercase;letter-spacing:.1em;color:var(--g);margin:30px 0 15px;padding-top:20px;border-top:1px solid var(--cbr)}
    .google-notice{display:flex;align-items:center;gap:12px;padding:12px 16px;background:rgba(66,133,244,0.1);border:1px solid rgba(66,133,244,0.2);border-radius:12px;font-size:.9rem;color:#60a5fa;margin-bottom:20px}
    .google-notice svg{width:20px;height:20px;flex-shrink:0}

    /* Modal Styling */
    .photo-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:10000;align-items:center;justify-content:center; backdrop-filter: blur(8px);}
    .photo-modal.open{display:flex}
    .photo-modal-card{background:var(--cb);border:1px solid var(--cbr);border-radius:32px;padding:40px;width:500px;max-width:96vw;box-shadow:0 30px 60px rgba(0,0,0,0.5)}
    .photo-modal-title{font-size:1.5rem;font-weight:900;color:var(--ch3);margin-bottom:8px}
    .photo-modal-sub{font-size:.9rem;color:var(--cp);margin-bottom:24px}
    .modal-tabs{display:flex;border:1px solid var(--cbr);border-radius:14px;overflow:hidden;margin-bottom:24px}
    .modal-tab{flex:1;padding:12px 0;text-align:center;font-size:.85rem;font-weight:800;cursor:pointer;color:var(--cp);background:rgba(0,0,0,0.1);border:none;font-family:'Inter',sans-serif;transition:all 0.2s}
    .modal-tab.active{background:var(--g);color:#fff}
</style>
{% endblock %}

{% block body %}
{% include 'partials/home_nav.html.twig' %}

<main class="front-main">
    <div class="front-main-container">
        {% for msg in app.flashes('success') %}<div class="flash-success">✓ {{ msg }}</div>{% endfor %}
        {% for msg in app.flashes('error') %}<div class="flash-error">⚠ {{ msg }}</div>{% endfor %}

        <div class="profile-grid">
            {# ── LEFT: avatar card ──────────────────────────────────────────── #}
            <div class="avatar-card">
                <div class="avatar-big" id="mainAvatarWrap">
                    {% set pic = app.user.profilePicture %}
                    {% if pic %}
                        {% if pic starts with 'http' %}
                            <img id="mainAvatarImg" src="{{ pic }}" alt="Photo de profil">
                        {% else %}
                            <img id="mainAvatarImg" src="{{ asset('uploads/profiles/' ~ pic) }}" alt="Photo de profil">
                        {% endif %}
                    {% else %}
                        <img id="mainAvatarImg"
                             src="https://api.dicebear.com/9.x/initials/svg?seed={{ app.user.name|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                             alt="{{ app.user.name }}">
                    {% endif %}

                    {% if app.user.authProvider == 'google' %}
                    <div class="google-badge" title="Compte Google">
                        <svg viewBox="0 0 24 24" fill="none">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                    </div>
                    {% endif %}
                </div>

                <button class="avatar-edit-btn" onclick="openAvatarModal()">
                    <i class="fa-solid fa-camera" style="margin-right:8px;"></i> Modifier la photo
                </button>

                <div class="profile-name-big">{{ app.user.name }}</div>
                <div class="profile-badge-row">
                    {% set roles = app.user.getRoles() %}
                    {% if 'ROLE_ADMIN' in roles %}<span class="badge badge-blue">Administrateur</span>
                    {% elseif 'ROLE_GERANT' in roles %}<span class="badge badge-green">Gérant</span>
                    {% else %}<span class="badge badge-orange">Ouvrier</span>{% endif %}
                </div>

                <hr class="profile-divider">
                <div class="meta-row"><span>Statut</span><strong style="color:var(--g);">✓ Actif</strong></div>
                <div class="meta-row"><span>Membre depuis</span><strong>{{ app.user.createdAt ? app.user.createdAt|date('d/m/Y') : '—' }}</strong></div>

                <hr class="profile-divider">
                <form method="post" action="{{ path('profile_avatar_remove') }}" onsubmit="return confirm('Supprimer la photo de profil ?')">
                    <button type="submit" class="btn-danger" style="width:100%; font-size: 0.8rem;">
                        <i class="fa-solid fa-trash-can" style="margin-right:8px;"></i> Supprimer la photo
                    </button>
                </form>
            </div>

            {# ── RIGHT: edit form ───────────────────────────────────────────── #}
            <div class="card">
                <div class="card-head"><span class="card-title">Modifier mes informations</span></div>
                <form method="post" action="{{ path('profile_update') }}" enctype="multipart/form-data" id="profileForm">
                    <div class="card-body">
                        {% if app.user.authProvider == 'google' %}
                        <div class="google-notice">
                            <i class="fa-brands fa-google"></i>
                            <span>Votre compte est lié à Google. Le mot de passe n'est pas modifiable ici.</span>
                        </div>
                        {% endif %}

                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nom complet</label>
                                <input type="text" name="name" class="form-input" value="{{ app.user.name }}" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Adresse email</label>
                                <input type="email" class="form-input" value="{{ app.user.email }}" readonly>
                            </div>
                            <div class="form-group full">
                                <label class="form-label">Téléphone</label>
                                <input type="tel" name="phone" class="form-input" value="{{ app.user.phone }}" placeholder="Ex: 55 123 456">
                            </div>
                        </div>

                        {% if app.user.authProvider != 'google' %}
                        <p class="section-sep">Changer le mot de passe</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nouveau mot de passe</label>
                                <input type="password" name="password" class="form-input" placeholder="Laisser vide pour ne pas changer">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirmer le mot de passe</label>
                                <input type="password" name="confirm_password" class="form-input" placeholder="Répéter le mot de passe">
                            </div>
                        </div>
                        {% endif %}

                        <input type="file" id="hiddenPhotoInput" name="profile_picture" accept="image/*" style="display:none;">
                    </div>
                    <div class="action-bar">
                        <button type="submit" class="btn-save">
                            <i class="fa-solid fa-check"></i> Enregistrer les modifications
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>

{# ── AVATAR MODAL ─────────────────────────────────────────────────────────── #}
<div class="photo-modal" id="photoModal">
    <div class="photo-modal-card">
        <div class="photo-modal-title">Changer la photo de profil</div>
        <div class="photo-modal-sub">Choisissez entre un avatar généré ou uploadez votre propre photo</div>

        <div class="modal-tabs">
            <button class="modal-tab active" onclick="switchTab('dicebear')">Avatar généré</button>
            <button class="modal-tab" onclick="switchTab('upload')">Uploader une photo</button>
        </div>

        {# Tab 1 — DiceBear style picker #}
        <div class="tab-panel active" id="tabDicebear">
            <div class="avatar-style-grid" id="styleGrid">
                {% for style, label in avatar_styles %}
                <div class="avatar-style-option {{ loop.first ? 'selected' : '' }}"
                     data-style="{{ style }}"
                     onclick="selectStyle(this)">
                    <img src="{{ dicebear_base }}{{ style }}/svg?seed={{ app.user.name|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                         alt="{{ label }}"
                         loading="lazy">
                    <span class="avatar-style-label">{{ label }}</span>
                </div>
                {% endfor %}
            </div>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeModal()">Annuler</button>
                <button class="btn-modal-save" id="dicebearSaveBtn" onclick="saveDicebear()">✓ Utiliser cet avatar</button>
            </div>
        </div>

        {# Tab 2 — File upload #}
        <div class="tab-panel" id="tabUpload">
            <img class="preview-img" id="modalPreview" alt="Aperçu">

            <label for="hiddenPhotoInput">
                <div class="photo-drop" id="photoDrop">
                    <div class="photo-drop-icon">
                        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 2.5rem; color: var(--g);"></i>
                    </div>
                    <div class="photo-drop-text">Cliquez pour choisir une image<br>ou glissez-déposez ici</div>
                </div>
            </label>

            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeModal()">Annuler</button>
                <button class="btn-modal-save" id="uploadSaveBtn"
                        onclick="submitWithPhoto()" style="display:none;">✓ Enregistrer</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Theme toggle matching home_nav.html.twig
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeToggleNav');
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('agri-theme', next);
        });
    }

    // Dropdown profile
    window.onclick = function(event) {
        if (!event.target.closest('.gerant-profile')) {
            const dropdown = document.getElementById('gerant-dropdown-nav');
            if (dropdown && dropdown.classList.contains('show')) {
                dropdown.classList.remove('show');
            }
        }
    }

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(tab) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    event.currentTarget.classList.add('active');
}

// ── Modal open / close ────────────────────────────────────────────────────────
function openAvatarModal() {
    document.getElementById('photoModal').classList.add('open');
}
function closeModal() {
    document.getElementById('photoModal').classList.remove('open');
}
// Close on backdrop click
document.getElementById('photoModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});

// ── DiceBear style selection ──────────────────────────────────────────────────
let selectedStyle = '{{ avatar_styles|keys|first }}';

function selectStyle(el) {
    document.querySelectorAll('.avatar-style-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    selectedStyle = el.dataset.style;
}

function saveDicebear() {
    const btn = document.getElementById('dicebearSaveBtn');
    btn.disabled = true;
    btn.textContent = 'Enregistrement…';

    fetch('{{ path("profile_avatar_choose") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'style=' + encodeURIComponent(selectedStyle),
    })
    .then(r => r.json())
    .then(data => {
        if (data.url) {
            document.getElementById('mainAvatarImg').src = data.url;
        }
        closeModal();
        btn.disabled = false;
        btn.textContent = '✓ Utiliser cet avatar';
    })
    .catch(() => {
        alert('Erreur lors de la sauvegarde. Réessayez.');
        btn.disabled = false;
        btn.textContent = '✓ Utiliser cet avatar';
    });
}

// ── Upload tab ────────────────────────────────────────────────────────────────
document.getElementById('hiddenPhotoInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
        const img = document.getElementById('modalPreview');
        img.src = ev.target.result;
        img.style.display = 'block';
        document.getElementById('photoDrop').style.display = 'none';
        document.getElementById('uploadSaveBtn').style.display = 'inline-flex';
    };
    reader.readAsDataURL(file);
});

function submitWithPhoto() {
    closeModal();
    document.getElementById('profileForm').submit();
}

// Drag-and-drop support
const dropZone = document.getElementById('photoDrop');
['dragleave','drop'].forEach(ev => {
    dropZone.addEventListener(ev, e => {
        e.preventDefault();
        dropZone.style.borderColor = '';
    });
});
dropZone.addEventListener('drop', e => {
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const input = document.getElementById('hiddenPhotoInput');
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
    }
});
</script>
{% endblock %}
