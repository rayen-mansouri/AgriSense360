{% extends 'base.html.twig' %}
{% set activePage = 'account' %}
{% set activeSection = 'profile' %}

{% block title %}Mon profil — AgriSense 360{% endblock %}

{% block styles %}
{% include 'partials/sidebar_styles.html.twig' %}
<style>
    .profile-grid { display: grid; grid-template-columns: 280px 1fr; gap: 22px; align-items: start; }

    .avatar-card { background: var(--white); border-radius: var(--radius); box-shadow: var(--shadow-md); padding: 30px 22px; text-align: center; }

    .avatar-big {
        width: 90px; height: 90px; border-radius: 50%;
        margin: 0 auto 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; font-weight: 800; color: #fff;
        background: linear-gradient(135deg,#2e7d32,#4caf50);
        overflow: hidden; position: relative;
    }
    .avatar-big img { width: 100%; height: 100%; object-fit: cover; }

    .avatar-edit-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 16px; border-radius: 50px;
        background: var(--green-pale); color: var(--green-dark);
        border: 1px solid #a5d6a7; font-size: .78rem; font-weight: 700;
        cursor: pointer; font-family: 'Plus Jakarta Sans',sans-serif;
        margin-bottom: 16px; transition: background .2s;
    }
    .avatar-edit-btn:hover { background: #c8e6c9; }

    .profile-name-big { font-size: 1.15rem; font-weight: 800; margin-bottom: 4px; }
    .profile-badge-row { margin-bottom: 16px; }
    .profile-divider { border: none; border-top: 1px solid var(--border); margin: 14px 0; }
    .meta-row { display: flex; justify-content: space-between; font-size: .82rem; color: var(--text-mid); margin-bottom: 8px; }
    .meta-row strong { color: var(--text-dark); font-weight: 700; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group.full { grid-column: 1/-1; }
    .form-label { font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-light); }
    .form-input { padding: 10px 14px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-family: 'Plus Jakarta Sans',sans-serif; font-size: .88rem; color: var(--text-dark); background: #fafcf8; outline: none; transition: border-color .2s; width: 100%; }
    .form-input:focus { border-color: var(--green-light); }
    .form-input[readonly] { background: #f0f4f0; color: var(--text-light); cursor: not-allowed; }

    .action-bar { display: flex; gap: 12px; padding: 18px 22px; border-top: 1px solid var(--border); background: #fafcf8; }
    .btn { display: inline-flex; align-items: center; gap: 7px; padding: 10px 22px; border-radius: 50px; font-family: 'Plus Jakarta Sans',sans-serif; font-size: .85rem; font-weight: 700; cursor: pointer; border: none; text-decoration: none; transition: filter .2s, transform .1s; }
    .btn:hover { filter: brightness(.92); transform: translateY(-1px); }
    .btn-save { background: var(--green-mid); color: #fff; }

    .section-sep { font-size: .75rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--text-light); margin: 20px 0 12px; padding-top: 16px; border-top: 1px solid var(--border); }

    /* Photo upload modal */
    .photo-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 1000; align-items: center; justify-content: center; }
    .photo-modal.open { display: flex; }
    .photo-modal-card { background: var(--white); border-radius: var(--radius); padding: 32px; width: 400px; text-align: center; }
    .photo-modal-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 8px; }
    .photo-modal-sub { font-size: .82rem; color: var(--text-light); margin-bottom: 22px; }
    .photo-drop { border: 2px dashed var(--border); border-radius: var(--radius-sm); padding: 32px 20px; cursor: pointer; transition: border-color .2s, background .2s; margin-bottom: 16px; }
    .photo-drop:hover { border-color: var(--green-mid); background: var(--green-pale); }
    .photo-drop-icon { font-size: 2rem; margin-bottom: 8px; }
    .photo-drop-text { font-size: .85rem; color: var(--text-light); }
    .preview-img { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px; display: none; }
    .modal-actions { display: flex; gap: 10px; justify-content: center; }
    .btn-modal-save { padding: 10px 22px; background: var(--green-mid); color: #fff; border: none; border-radius: 50px; font-family: 'Plus Jakarta Sans',sans-serif; font-weight: 700; font-size: .88rem; cursor: pointer; }
    .btn-modal-cancel { padding: 10px 22px; background: var(--green-pale); color: var(--green-dark); border: 1px solid #a5d6a7; border-radius: 50px; font-family: 'Plus Jakarta Sans',sans-serif; font-weight: 700; font-size: .88rem; cursor: pointer; }
</style>
{% endblock %}

{% block body %}
<div class="layout">
    {% include 'partials/sidebar.html.twig' %}

    <main class="main">
        <div class="breadcrumb">
            <span>Mon compte</span><span>›</span><span>Gérer mon compte</span>
        </div>

        {% for msg in app.flashes('success') %}<div class="flash-success">✓ {{ msg }}</div>{% endfor %}
        {% for msg in app.flashes('error') %}<div class="flash-error">⚠ {{ msg }}</div>{% endfor %}

        <div class="profile-grid">
            <!-- Left: avatar card -->
            <div class="avatar-card">
                <div class="avatar-big">
                    {% if app.user.profilePicture %}
                        <img src="{{ asset('uploads/profiles/' ~ app.user.profilePicture) }}" alt="Photo de profil">
                    {% else %}
                        {{ app.user.name|first|upper }}
                    {% endif %}
                </div>

                <button class="avatar-edit-btn" onclick="document.getElementById('photoModal').classList.add('open')">
                    📷 Changer la photo
                </button>

                <div class="profile-name-big">{{ app.user.name }}</div>
                <div class="profile-badge-row">
                    {% set roles = app.user.getRoles() %}
                    {% if 'ROLE_ADMIN' in roles %}<span class="badge badge-blue">Administrateur</span>
                    {% elseif 'ROLE_GERANT' in roles %}<span class="badge badge-green">Gérant</span>
                    {% else %}<span class="badge badge-orange">Ouvrier</span>{% endif %}
                </div>

                <hr class="profile-divider">
                <div class="meta-row"><span>Statut</span><strong style="color:#2e7d32;">✓ Actif</strong></div>
                {% if app.user.phone %}<div class="meta-row"><span>📞</span><strong>{{ app.user.phone }}</strong></div>{% endif %}
                <div class="meta-row"><span>Membre depuis</span><strong>{{ app.user.createdAt ? app.user.createdAt|date('d/m/Y') : '—' }}</strong></div>
                {% if app.user.updatedAt %}
                <div class="meta-row"><span>Mis à jour</span><strong>{{ app.user.updatedAt|date('d/m/Y') }}</strong></div>
                {% endif %}
            </div>

            <!-- Right: edit form -->
            <div class="card">
                <div class="card-head"><span class="card-title">⚙️ Modifier mes informations</span></div>
                <form method="post" action="{{ path('profile_update') }}" enctype="multipart/form-data">
                    <div class="card-body">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nom complet</label>
                                <input type="text" name="name" class="form-input" value="{{ app.user.name }}" required>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Adresse email (non modifiable)</label>
                                <input type="email" class="form-input" value="{{ app.user.email }}" readonly>
                            </div>
                            <div class="form-group full">
                                <label class="form-label">Téléphone</label>
                                <input type="tel" name="phone" class="form-input" value="{{ app.user.phone }}" placeholder="Ex: 55 123 456">
                            </div>
                        </div>

                        <p class="section-sep">🔒 Changer le mot de passe</p>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Nouveau mot de passe</label>
                                <input type="password" name="password" class="form-input" placeholder="Laisser vide pour ne pas changer">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirmer le mot de passe</label>
                                <input type="password" name="confirm_password" class="form-input" placeholder="Répéter le mot de passe">
                            </div>
                        </div>

                        <!-- Hidden file input linked to photo modal -->
                        <input type="file" id="hiddenPhotoInput" name="profile_picture" accept="image/*" style="display:none;">
                    </div>
                    <div class="action-bar">
                        <button type="submit" class="btn btn-save">💾 Enregistrer les modifications</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<!-- Photo upload modal -->
<div class="photo-modal" id="photoModal">
    <div class="photo-modal-card">
        <div class="photo-modal-title">📷 Changer la photo de profil</div>
        <div class="photo-modal-sub">JPG, PNG ou WebP · max 3 Mo</div>

        <img class="preview-img" id="modalPreview" alt="Aperçu">

        <label for="hiddenPhotoInput">
            <div class="photo-drop" id="photoDrop">
                <div class="photo-drop-icon">🖼️</div>
                <div class="photo-drop-text">Cliquez pour choisir une image<br>ou glissez-déposez ici</div>
            </div>
        </label>

        <div class="modal-actions">
            <button class="btn-modal-save" id="modalSaveBtn" onclick="submitWithPhoto()" style="display:none;">✓ Enregistrer</button>
            <button class="btn-modal-cancel" onclick="document.getElementById('photoModal').classList.remove('open')">Annuler</button>
        </div>
    </div>
</div>

<script>
document.getElementById('hiddenPhotoInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(ev) {
        const img = document.getElementById('modalPreview');
        img.src = ev.target.result;
        img.style.display = 'block';
        document.getElementById('photoDrop').style.display = 'none';
        document.getElementById('modalSaveBtn').style.display = 'inline-flex';
    };
    reader.readAsDataURL(file);
});

function submitWithPhoto() {
    document.getElementById('photoModal').classList.remove('open');
    document.querySelector('form').submit();
}
</script>
{% endblock %}
