<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
    --g5: #3e8e3e;          /* main green */
    --g7: #2d6a2d;          /* dark green */

    --panel: #f4f9f1;       /* light background (instead of dark blue) */
    --panel-light: #ffffff; /* inputs */

    --border-inp: #dde8d8;  /* light border */

    --text: #1e3a1e;        /* dark green text */
    --muted: #6b8f6b;       /* soft green */
}
        html, body { height: 100%; overflow: hidden; font-family: 'Plus Jakarta Sans', sans-serif; }

        .split { display: flex; width: 100vw; height: 100vh; }

        /* ── Left dark panel ── */
        .left {
            width: 48%;
            background: var(--panel);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            position: relative;
        }

        .left::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(ellipse at 20% 80%, rgba(76,175,80,.07) 0%, transparent 60%),
                        radial-gradient(ellipse at 80% 10%, rgba(46,125,50,.05) 0%, transparent 50%);
            pointer-events: none;
        }

        /* Inner wrapper — takes full height, spaces brand at top, form in center, footer at bottom */
        .left-inner {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            min-height: 100%;
            padding: 40px 60px;
            align-items: center; 
        }

        /* ── Brand ── */
        .brand { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
        .brand-icon {
            width: 46px; height: 46px; border-radius: 12px;
            background: var(--g5);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .brand-icon svg { width: 26px; height: 26px; fill: #fff; }
        .brand-name { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 700; color: var(--text); line-height: 1.1; }
        .brand-sub  { font-size: .7rem; color: var(--muted); margin-top: 2px; }

        /* ── Form area — centered vertically ── */
        .form-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px 0;
            max-width: 360px;
            width: 100%;
        }

        h1 { font-family: 'Fraunces', serif; font-size: 2.2rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
        .sub { font-size: .88rem; color: var(--muted); margin-bottom: 36px; line-height: 1.5; }

        /* ── Fields ── */
        .field-group { margin-bottom: 20px; }
        .field-label { display: block; font-size: .76rem; font-weight: 600; color: var(--muted); margin-bottom: 8px; letter-spacing: .04em; }

        .inp-wrap { position: relative; }
        .inp-icon {
            position: absolute; left: 16px; top: 50%; transform: translateY(-50%);
            width: 16px; height: 16px; color: var(--muted);
            pointer-events: none;
        }
        .inp-icon svg { width: 100%; height: 100%; stroke: currentColor; fill: none; }

        .inp {
            width: 100%; padding: 14px 16px 14px 46px;
            background: var(--panel-light);
            border: 1px solid var(--border-inp);
            border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: .9rem; color: var(--text);
            outline: none;
            transition: border-color .18s, box-shadow .18s;
        }
        .inp::placeholder { color: #9bb79b; }        
        .inp:focus { border-color: var(--g5); box-shadow: 0 0 0 3px rgba(76,175,80,.15); }

        .row-mid { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .remember { display: flex; align-items: center; gap: 8px; font-size: .82rem; color: var(--muted); cursor: pointer; }
        .remember input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--g5); cursor: pointer; }
        .forgot { font-size: .82rem; color: var(--g5); font-weight: 600; text-decoration: none; }
        .forgot:hover { text-decoration: underline; }

        .btn-submit {
            width: 100%; padding: 15px;
            background: var(--g5); color: #fff;
            border: none; border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700; font-size: .95rem;
            cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: background .18s, transform .12s;
            margin-bottom: 28px;
        }
        .btn-submit:hover { background: var(--g7); transform: translateY(-1px); }

        .divider {
            display: flex; align-items: center; gap: 14px;
            font-size: .78rem; color: var(--muted);
            margin-bottom: 20px;
        }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,.1); }

        .social-btn {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            width: 100%; padding: 13px;
            border-radius: 10px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 600; font-size: .88rem;
            cursor: pointer; text-decoration: none;
            transition: opacity .18s; margin-bottom: 10px; border: none;
        }
        .social-btn:last-of-type { margin-bottom: 0; }
        .social-btn:hover { opacity: .88; }
        .social-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
        .btn-google   { background: #fff; color: #1a1a1a; }
        .btn-facebook { background: #1877f2; color: #fff; }
        .btn-apple    { background: #000; color: #fff; }

        /* ── Footer ── */
        .form-footer {
            flex-shrink: 0;
            text-align: center;
            font-size: .78rem;
            color: var(--muted);
            padding: 0 0 8px;
        }
        .form-footer a { color: var(--g5); text-decoration: none; font-weight: 600; }
        .form-footer a:hover { text-decoration: underline; }
        .copyright { font-size: .7rem; color: rgba(255,255,255,.2); margin-top: 8px; }

        /* Alerts */
        .alert-error   { background: rgba(220,38,38,.14); border: 1px solid rgba(220,38,38,.28); color: #fca5a5; padding: 11px 14px; border-radius: 8px; font-size: .84rem; margin-bottom: 20px; }
        .alert-blocked { background: rgba(251,146,60,.12); border: 1px solid rgba(251,146,60,.3); color: #fdba74; padding: 11px 14px; border-radius: 8px; font-size: .84rem; margin-bottom: 20px; }

        /* ── Right photo ── */
        .right { flex: 1; position: relative; overflow: hidden; }
        .right img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .right-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,20,15,.78) 0%, rgba(10,20,15,.1) 55%, transparent 100%);
        }
        .right-caption { position: absolute; bottom: 52px; left: 48px; right: 48px; }
        .right-caption h2 { font-family: 'Fraunces', serif; font-size: 2.4rem; font-weight: 700; color: #fff; margin-bottom: 14px; line-height: 1.2; }
        .right-caption p  { font-size: .95rem; color: rgba(255,255,255,.72); line-height: 1.6; max-width: 380px; }
        .help-bubble {
            position: absolute; bottom: 32px; right: 32px;
            width: 40px; height: 40px; border-radius: 50%;
            background: rgba(255,255,255,.18); backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.25);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer;
        }
    </style>
</head>
<body>
<div class="split">

    <div class="left">
        <div class="left-inner">

            <!-- Brand top -->
            <div class="brand">
                <div class="brand-icon">
                    <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg>
                </div>
                <div>
                    <div class="brand-name">AgriSense 360</div>
                    <div class="brand-sub">Agriculture Intelligente</div>
                </div>
            </div>

            <!-- Form centered -->
            <div class="form-area">
                <h1>Bienvenue</h1>
                <p class="sub">Connectez-vous à votre compte pour continuer</p>

                {% if error %}
                    {% if 'bloqué' in error.message or 'administrateur' in error.message %}
                        <div class="alert-blocked">🚫 {{ error.message }}</div>
                    {% else %}
                        <div class="alert-error">⚠ Email ou mot de passe incorrect.</div>
                    {% endif %}
                {% endif %}

                <form method="post" novalidate>
                    <div class="field-group">
                        <label class="field-label">Adresse email</label>
                        <div class="inp-wrap">
                            <span class="inp-icon"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                            <input type="email" name="email" class="inp" placeholder="votreemail@example.com"
                                   value="{{ last_username }}" autocomplete="email" required>
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Mot de passe</label>
                        <div class="inp-wrap">
                            <span class="inp-icon"><svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                            <input type="password" name="password" class="inp" placeholder="••••••••"
                                   autocomplete="current-password" required>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <div class="row-mid">
                        <label class="remember">
                            <input type="checkbox" name="_remember_me">
                            Se souvenir de moi
                        </label>
                        <a href="#" class="forgot">Mot de passe oublié?</a>
                    </div>

                    <button type="submit" class="btn-submit">Se connecter →</button>
                </form>

                <div class="divider">OU</div>

                <a href="#" class="social-btn btn-google">
                    <svg viewBox="0 0 24 24" fill="none"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    Continuer avec Google
                </a>
                <a href="#" class="social-btn btn-facebook">
                    <svg viewBox="0 0 24 24" fill="#fff"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                    Continuer avec Facebook
                </a>
                <a href="#" class="social-btn btn-apple">
                    <svg viewBox="0 0 24 24" fill="#fff"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09z"/><path d="M15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701z"/></svg>
                    Continuer avec Apple
                </a>
            </div>

            <!-- Footer bottom -->
            <div class="form-footer">
                <p>Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a></p>
                <p class="copyright">© 2024 AgriSense 360. Tous droits réservés.</p>
            </div>

        </div>
    </div>

    <!-- Right photo -->
    <div class="right">
        <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1400&q=85"
             alt="Champs agricoles au coucher du soleil">
        <div class="right-overlay"></div>
        <div class="right-caption">
            <h2>L'agriculture de demain</h2>
            <p>Optimisez votre exploitation agricole avec notre plateforme intelligente de gestion</p>
        </div>
        <div class="help-bubble">?</div>
    </div>

</div>
</body>
</html>
