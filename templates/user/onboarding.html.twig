<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bienvenue — AgriSense 360</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --g5: #3e8e3e; --g7: #2d6a2d;
            --panel: #f4f9f1; --panel-light: #ffffff;
            --border-inp: #dde8d8; --text: #1e3a1e; --muted: #6b8f6b;
        }
        html, body { min-height: 100%; font-family: 'Plus Jakarta Sans', sans-serif; background: var(--panel); }

        .page {
            min-height: 100vh; display: flex;
            align-items: center; justify-content: center; padding: 32px 16px;
        }
        .page::before {
            content: ''; position: fixed; inset: 0; pointer-events: none;
            background:
                radial-gradient(ellipse at 15% 85%, rgba(76,175,80,.1) 0%, transparent 55%),
                radial-gradient(ellipse at 85% 10%, rgba(46,125,50,.07) 0%, transparent 50%);
        }

        .card {
            background: var(--panel-light); border-radius: 20px;
            box-shadow: 0 8px 40px rgba(30,58,30,.10);
            width: 100%; max-width: 560px; overflow: hidden;
        }
        .card::before {
            content: ''; display: block; height: 4px;
            background: linear-gradient(90deg, var(--g7), var(--g5), #81c784);
        }
        .card-inner { padding: 36px 40px 40px; }

        /* Brand */
        .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
        .brand-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--g5); display: flex; align-items: center; justify-content: center; }
        .brand-icon svg { width: 22px; height: 22px; fill: #fff; }
        .brand-name { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; color: var(--text); }
        .brand-sub { font-size: .68rem; color: var(--muted); margin-top: 1px; }

        /* Steps */
        .steps-row { display: flex; align-items: center; gap: 6px; margin-bottom: 24px; }
        .step-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border-inp); transition: all .3s; }
        .step-dot.done { background: var(--g5); }
        .step-dot.active { background: var(--g5); width: 24px; border-radius: 4px; }
        .step-label { font-size: .72rem; color: var(--muted); margin-left: 6px; }

        /* Identity box (Google users only) */
        .identity-box {
            display: flex; align-items: center; gap: 14px;
            background: #f0f7ff; border: 1px solid #bfdbfe;
            border-radius: 14px; padding: 14px 16px; margin-bottom: 24px;
        }
        .identity-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid #fff; box-shadow: 0 2px 8px rgba(0,0,0,.12); }
        .identity-avatar-fallback { width: 48px; height: 48px; border-radius: 50%; background: var(--g5); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; font-weight: 800; color: #fff; }
        .identity-name { font-size: .9rem; font-weight: 700; color: #1e40af; }
        .identity-email { font-size: .75rem; color: #3b82f6; }
        .google-pill { display: inline-flex; align-items: center; gap: 4px; background: #fff; border: 1px solid #e2e8f0; border-radius: 50px; padding: 3px 9px; font-size: .68rem; font-weight: 700; color: #374151; flex-shrink: 0; margin-left: auto; }
        .google-pill svg { width: 12px; height: 12px; }

        h1 { font-family: 'Fraunces', serif; font-size: 1.55rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
        .subtitle { font-size: .86rem; color: var(--muted); line-height: 1.6; margin-bottom: 26px; }
        .optional-badge { display: inline-block; background: #dcfce7; color: #166534; font-size: .62rem; font-weight: 700; border-radius: 50px; padding: 2px 7px; margin-left: 5px; vertical-align: middle; }

        /* ── Avatar section ── */
        .avatar-section { margin-bottom: 24px; }
        .section-title { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--muted); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
        .section-title::after { content: ''; flex: 1; height: 1px; background: var(--border-inp); }

        /* Avatar source tabs */
        .avatar-tabs { display: flex; gap: 0; border: 1.5px solid var(--border-inp); border-radius: 10px; overflow: hidden; margin-bottom: 16px; }
        .avatar-tab { flex: 1; padding: 9px 0; text-align: center; font-size: .8rem; font-weight: 700; cursor: pointer; color: var(--muted); background: var(--panel); border: none; font-family: 'Plus Jakarta Sans', sans-serif; transition: background .15s, color .15s; }
        .avatar-tab.active { background: var(--g5); color: #fff; }

        /* DiceBear grid */
        .dicebear-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 12px; }
        .dicebear-opt {
            display: flex; flex-direction: column; align-items: center; gap: 6px;
            padding: 10px 6px; border-radius: 12px;
            border: 2px solid var(--border-inp); cursor: pointer;
            background: var(--panel); transition: border-color .18s, background .18s;
        }
        .dicebear-opt:hover { border-color: var(--g5); }
        .dicebear-opt.selected { border-color: var(--g5); background: rgba(62,142,62,.08); }
        .dicebear-opt img { width: 54px; height: 54px; border-radius: 50%; }
        .dicebear-opt span { font-size: .7rem; font-weight: 700; color: var(--muted); }
        .dicebear-opt.selected span { color: var(--g5); }

        /* Upload zone */
        .upload-zone {
            border: 2px dashed var(--border-inp); border-radius: 12px;
            padding: 24px 20px; cursor: pointer; text-align: center;
            transition: border-color .18s, background .18s;
            position: relative; overflow: hidden;
        }
        .upload-zone:hover { border-color: var(--g5); background: rgba(62,142,62,.04); }
        .upload-zone.has-file { border-style: solid; border-color: var(--g5); }
        .upload-zone-icon { font-size: 2rem; margin-bottom: 6px; }
        .upload-zone-text { font-size: .84rem; color: var(--muted); line-height: 1.5; }
        .upload-zone-text strong { color: var(--g5); }
        .upload-preview { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; margin: 0 auto 8px; display: none; }

        /* Tab panels */
        .avatar-panel { display: none; }
        .avatar-panel.active { display: block; }

        /* Large preview */
        .avatar-preview-wrap {
            display: flex; align-items: center; justify-content: center;
            gap: 16px; padding: 14px; background: var(--panel);
            border-radius: 12px; border: 1px solid var(--border-inp);
            margin-bottom: 16px;
        }
        .avatar-preview-big { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 3px solid var(--g5); }
        .avatar-preview-info { flex: 1; }
        .avatar-preview-name { font-size: .9rem; font-weight: 700; color: var(--text); }
        .avatar-preview-note { font-size: .75rem; color: var(--muted); margin-top: 2px; }

        /* ── Form fields ── */
        .field-group { margin-bottom: 16px; }
        .field-label { display: block; font-size: .72rem; font-weight: 700; color: var(--muted); margin-bottom: 8px; letter-spacing: .05em; text-transform: uppercase; }
        .inp-wrap { position: relative; }
        .inp-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--muted); pointer-events: none; }
        .inp-icon svg { width: 100%; height: 100%; stroke: currentColor; fill: none; }
        .inp {
            width: 100%; padding: 13px 14px 13px 44px;
            background: var(--panel); border: 1.5px solid var(--border-inp);
            border-radius: 11px; font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: .9rem; color: var(--text); outline: none;
            transition: border-color .18s, box-shadow .18s;
        }
        .inp::placeholder { color: #9bb79b; }
        .inp:focus { border-color: var(--g5); box-shadow: 0 0 0 3px rgba(76,175,80,.15); background: #fff; }
        .inp-hint { font-size: .7rem; color: #8fb08f; margin-top: 5px; display: block; }

        /* Role grid */
        .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .role-opt input { display: none; }
        .role-opt label { display: flex; align-items: center; gap: 10px; padding: 13px 14px; background: var(--panel); border: 1.5px solid var(--border-inp); border-radius: 12px; cursor: pointer; font-size: .86rem; font-weight: 600; color: var(--muted); transition: all .18s; }
        .role-opt label:hover { border-color: var(--g5); color: var(--text); background: #fff; }
        .role-opt input:checked + label { border-color: var(--g5); color: var(--g5); background: rgba(62,142,62,.08); }
        .role-icon-box { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(62,142,62,.12); flex-shrink: 0; }
        .role-icon-box svg { width: 17px; height: 17px; stroke: var(--g5); fill: none; }
        .role-opt input:checked + label .role-icon-box { background: var(--g5); }
        .role-opt input:checked + label .role-icon-box svg { stroke: #fff; }
        .role-text-wrap { display: flex; flex-direction: column; gap: 1px; }
        .role-title { font-size: .86rem; font-weight: 700; }
        .role-desc { font-size: .68rem; font-weight: 400; color: var(--muted); }

        /* Submit */
        .btn-submit {
            width: 100%; padding: 14px; background: var(--g5); color: #fff;
            border: none; border-radius: 11px;
            font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: .95rem;
            cursor: pointer; transition: background .18s, transform .12s; margin-top: 8px;
        }
        .btn-submit:hover { background: var(--g7); transform: translateY(-1px); }

        .skip-row { text-align: center; margin-top: 14px; font-size: .8rem; color: var(--muted); }
        .skip-row a { color: var(--g5); font-weight: 600; text-decoration: none; }
        .skip-row a:hover { text-decoration: underline; }

        .section-sep { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--muted); border-top: 1px solid var(--border-inp); padding-top: 16px; margin: 20px 0 14px; display: block; }
    </style>
</head>
<body>
<div class="page">
<div class="card">
<div class="card-inner">

    <!-- Brand -->
    <div class="brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.72L5.71 21l1-1.29A4.49 4.49 0 008 20c4 0 4-2 8-2s4 2 8 2v-2c-4 0-4-2-8-2-1.33 0-2.31.15-3.14.37C14 11.54 16 8.36 17 8z"/></svg>
        </div>
        <div>
            <div class="brand-name">AgriSense 360</div>
            <div class="brand-sub">Agriculture Intelligente</div>
        </div>
    </div>

    <!-- Step indicator -->
    <div class="steps-row">
        <div class="step-dot done"></div>
        <div class="step-dot active"></div>
        <div class="step-dot"></div>
        <span class="step-label">Étape 2 — Configuration du profil</span>
    </div>

    {# ── Google identity box (only for Google users) ── #}
    {% if is_google is defined and is_google %}
    <div class="identity-box">
        {% if google_pic %}
            <img class="identity-avatar" src="{{ google_pic }}" alt="{{ google_name }}">
        {% else %}
            <div class="identity-avatar-fallback">{{ google_name|first|upper }}</div>
        {% endif %}
        <div>
            <div class="identity-name">{{ google_name }}</div>
            <div class="identity-email">{{ google_email }}</div>
        </div>
        <div class="google-pill">
            <svg viewBox="0 0 24 24" fill="none">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google
        </div>
    </div>
    {% endif %}

    <h1>
        {% if is_google is defined and is_google %}
            Finalisez votre compte
        {% else %}
            Bienvenue, {{ app.user.name }} ! 🌱
        {% endif %}
    </h1>
    <p class="subtitle">
        {% if is_google is defined and is_google %}
            Choisissez votre rôle, un avatar et ajoutez votre téléphone si vous le souhaitez.
        {% else %}
            Personnalisez votre profil avant d'accéder à votre espace AgriSense.
        {% endif %}
        Tous les champs sont <strong>optionnels</strong> — vous pouvez ignorer et continuer.
    </p>

    <form method="post"
          action="{{ is_google is defined and is_google ? path('google_complete_profile_save') : path('profile_first_login_save') }}"
          enctype="multipart/form-data"
          id="onboardingForm">

        {# ── AVATAR SECTION ── #}
        <div class="avatar-section">
            <div class="section-title">Photo de profil <span class="optional-badge">optionnel</span></div>

            {# Live preview #}
            <div class="avatar-preview-wrap">
                <img id="previewBig"
                     class="avatar-preview-big"
                     src="https://api.dicebear.com/9.x/initials/svg?seed={{ (is_google is defined and is_google) ? google_name|url_encode : app.user.name|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                     alt="Preview">
                <div class="avatar-preview-info">
                    <div class="avatar-preview-name">
                        {{ (is_google is defined and is_google) ? google_name : app.user.name }}
                    </div>
                    <div class="avatar-preview-note" id="previewNote">Avatar généré automatiquement</div>
                </div>
            </div>

            {# Source tabs #}
            <div class="avatar-tabs">
                <button type="button" class="avatar-tab active" onclick="switchAvatarTab('dicebear', this)">🎨 Avatar généré</button>
                <button type="button" class="avatar-tab" onclick="switchAvatarTab('upload', this)">📁 Uploader une photo</button>
            </div>

            {# Tab: DiceBear styles #}
            <div class="avatar-panel active" id="panelDicebear">
                <div class="dicebear-grid" id="dicebearGrid">
                    {% set styles = {
                        'initials':   'Initiales',
                        'adventurer': 'Aventurier',
                        'bottts':     'Robot',
                        'pixel-art':  'Pixel Art',
                        'fun-emoji':  'Emoji',
                        'lorelei':    'Lorelei'
                    } %}
                    {% set userName = (is_google is defined and is_google) ? google_name : app.user.name %}
                    {% for style, label in styles %}
                    <div class="dicebear-opt {{ loop.first ? 'selected' : '' }}"
                         data-style="{{ style }}"
                         data-url="https://api.dicebear.com/9.x/{{ style }}/svg?seed={{ userName|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                         onclick="selectDicebear(this)">
                        <img src="https://api.dicebear.com/9.x/{{ style }}/svg?seed={{ userName|url_encode }}&backgroundColor=3e8e3e,2d6a2d"
                             alt="{{ label }}" loading="lazy">
                        <span>{{ label }}</span>
                    </div>
                    {% endfor %}
                </div>
                {# Hidden field stores the chosen DiceBear URL #}
                <input type="hidden" name="avatar_dicebear_url" id="dicebearUrl"
                       value="https://api.dicebear.com/9.x/initials/svg?seed={{ userName|url_encode }}&backgroundColor=3e8e3e,2d6a2d">
                <input type="hidden" name="avatar_source" id="avatarSource" value="dicebear">
            </div>

            {# Tab: Upload #}
            <div class="avatar-panel" id="panelUpload">
                <label for="photoInput">
                    <div class="upload-zone" id="uploadZone">
                        <img class="upload-preview" id="uploadPreview" alt="Aperçu">
                        <div id="uploadPlaceholder">
                            <div class="upload-zone-icon">🖼️</div>
                            <div class="upload-zone-text">
                                <strong>Cliquez pour choisir</strong> ou glissez-déposez<br>
                                JPG, PNG, WebP · max 3 Mo
                            </div>
                        </div>
                    </div>
                </label>
                <input type="file" id="photoInput" name="profile_picture" accept="image/*" style="display:none;">
            </div>
        </div>

        {# ── ROLE (only shown for Google users OR first-login if you want) ── #}
        {% if is_google is defined and is_google %}
        <span class="section-sep">Votre rôle <span class="optional-badge">optionnel</span></span>
        <div class="field-group">
            <div class="role-grid">
                <div class="role-opt">
                    <input type="radio" name="role" id="r_gerant" value="ROLE_GERANT" checked>
                    <label for="r_gerant">
                        <div class="role-icon-box">
                            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M6 20c1.5-3 10.5-3 12 0"/></svg>
                        </div>
                        <div class="role-text-wrap">
                            <span class="role-title">Gérant</span>
                            <span class="role-desc">Gérer l'exploitation</span>
                        </div>
                    </label>
                </div>
                <div class="role-opt">
                    <input type="radio" name="role" id="r_ouvrier" value="ROLE_OUVRIER">
                    <label for="r_ouvrier">
                        <div class="role-icon-box">
                            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><path d="M7 8h10"/><path d="M6 12h12"/><path d="M8 16h8"/></svg>
                        </div>
                        <div class="role-text-wrap">
                            <span class="role-title">Ouvrier</span>
                            <span class="role-desc">Exécuter les tâches</span>
                        </div>
                    </label>
                </div>
            </div>
        </div>
        {% endif %}

        <button type="submit" class="btn-submit">
            Accéder à mon tableau de bord →
        </button>
    </form>

    <div class="skip-row">
        <a href="#" onclick="skipAll(event)">Ignorer et continuer sans personnaliser →</a>
    </div>

</div>
</div>
</div>

<script>
// ── Avatar tab switching ───────────────────────────────────────────────────────
function switchAvatarTab(tab, btn) {
    document.querySelectorAll('.avatar-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.avatar-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    document.getElementById('avatarSource').value = tab;

    if (tab === 'dicebear') {
        // Restore selected dicebear preview
        const selected = document.querySelector('.dicebear-opt.selected');
        if (selected) updatePreview(selected.dataset.url, 'Avatar généré');
    }
}

// ── DiceBear style selection ──────────────────────────────────────────────────
function selectDicebear(el) {
    document.querySelectorAll('.dicebear-opt').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('dicebearUrl').value = el.dataset.url;
    updatePreview(el.dataset.url, 'Avatar "' + el.querySelector('span').textContent + '"');
}

// ── File upload ───────────────────────────────────────────────────────────────
document.getElementById('photoInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;

    // Show upload preview inside zone
    const reader = new FileReader();
    reader.onload = function(ev) {
        const zone = document.getElementById('uploadZone');
        const preview = document.getElementById('uploadPreview');
        const placeholder = document.getElementById('uploadPlaceholder');
        preview.src = ev.target.result;
        preview.style.display = 'block';
        placeholder.style.display = 'none';
        zone.classList.add('has-file');

        // Also update big preview
        updatePreview(ev.target.result, 'Photo uploadée — ' + file.name);
    };
    reader.readAsDataURL(file);
    document.getElementById('avatarSource').value = 'upload';
});

// Drag-and-drop
const uploadZone = document.getElementById('uploadZone');
['dragenter','dragover'].forEach(ev => uploadZone.addEventListener(ev, e => { e.preventDefault(); uploadZone.style.borderColor = 'var(--g5)'; }));
['dragleave','drop'].forEach(ev => uploadZone.addEventListener(ev, e => { e.preventDefault(); uploadZone.style.borderColor = ''; }));
uploadZone.addEventListener('drop', e => {
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        document.getElementById('photoInput').files = dt.files;
        document.getElementById('photoInput').dispatchEvent(new Event('change'));
    }
});

// ── Preview update ────────────────────────────────────────────────────────────
function updatePreview(src, note) {
    document.getElementById('previewBig').src = src;
    document.getElementById('previewNote').textContent = note;
}

// ── Skip everything ───────────────────────────────────────────────────────────
function skipAll(e) {
    e.preventDefault();
    // Clear file input so no photo is sent
    document.getElementById('photoInput').value = '';
    // Clear dicebear url to save nothing
    document.getElementById('dicebearUrl').value = '';
    document.getElementById('avatarSource').value = 'skip';
    document.getElementById('onboardingForm').submit();
}
</script>
</body>
</html>
