<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>S'inscrire — AgriSense 360</title>
    <script>(function(){var t=localStorage.getItem('agri-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
        --bg:#0a0f0a;--surface:rgba(255,255,255,.05);--surface-2:rgba(255,255,255,.08);
        --border:rgba(255,255,255,.09);--border-focus:rgba(90,181,90,.5);
        --text:#e8f5e4;--text-muted:rgba(232,245,228,.5);--text-dim:rgba(232,245,228,.25);
        --input-bg:rgba(255,255,255,.06);--input-focus-bg:rgba(90,181,90,.07);
        --card-shadow:0 32px 80px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.08);
        --blob-op:.32;--grid-c:rgba(90,181,90,.1);--topbar-bg:rgba(10,15,10,.6);
        --g:#5ab55a;--gm:#3e8e3e;--gd:#2d6a2d;
        --tab-inactive:rgba(255,255,255,.35);
        --divider:rgba(255,255,255,.08);--divider-text:rgba(255,255,255,.2);
        --social-bg:rgba(255,255,255,.05);--social-hover:rgba(255,255,255,.09);
        --role-bg:rgba(255,255,255,.04);--role-checked:rgba(90,181,90,.1);
        --note-bg:rgba(90,181,90,.07);--note-border:rgba(90,181,90,.18);--note-text:rgba(232,245,228,.7);
        --sep-text:rgba(255,255,255,.25);--sep-line:rgba(255,255,255,.07);
        --err-bg:rgba(220,38,38,.1);--err-border:rgba(220,38,38,.3);--err-text:#fca5a5;
    }
    [data-theme="light"]{
        --bg:#f0f7ee;--surface:rgba(255,255,255,.92);--surface-2:#fff;
        --border:rgba(0,0,0,.09);--border-focus:rgba(62,142,62,.5);
        --text:#1a3a1a;--text-muted:#4a6741;--text-dim:#9ab898;
        --input-bg:#f6faf4;--input-focus-bg:#edf7eb;
        --card-shadow:0 20px 60px rgba(0,0,0,.1),0 2px 8px rgba(0,0,0,.06);
        --blob-op:.12;--grid-c:rgba(62,142,62,.07);--topbar-bg:rgba(240,247,238,.82);
        --g:#3e8e3e;--gm:#3e8e3e;--gd:#2d6a2d;
        --tab-inactive:rgba(0,0,0,.35);
        --divider:rgba(0,0,0,.08);--divider-text:rgba(0,0,0,.25);
        --social-bg:rgba(0,0,0,.03);--social-hover:rgba(0,0,0,.06);
        --role-bg:rgba(0,0,0,.03);--role-checked:rgba(62,142,62,.08);
        --note-bg:rgba(62,142,62,.06);--note-border:rgba(62,142,62,.18);--note-text:#3a5e3a;
        --sep-text:rgba(0,0,0,.3);--sep-line:rgba(0,0,0,.07);
        --err-bg:rgba(220,38,38,.06);--err-border:rgba(220,38,38,.2);--err-text:#b91c1c;
    }
    html,body{font-family:'Inter',sans-serif}
    body{background:var(--bg);color:var(--text);display:flex;align-items:flex-start;justify-content:center;min-height:100vh;padding:90px 20px 40px;position:relative;overflow-x:hidden;transition:background .3s}
    .blob{position:fixed;border-radius:50%;filter:blur(90px);opacity:var(--blob-op);pointer-events:none;animation:drift 14s ease-in-out infinite alternate;z-index:0}
    .b1{width:500px;height:500px;background:radial-gradient(circle,#2d6a2d,transparent);top:-150px;left:-120px}
    .b2{width:380px;height:380px;background:radial-gradient(circle,#5ab55a,transparent);bottom:-100px;right:-80px;animation-delay:-5s}
    @keyframes drift{to{transform:translate(28px,18px) scale(1.06)}}
    body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(var(--grid-c) 1px,transparent 1px);background-size:30px 30px;pointer-events:none;z-index:0;transition:opacity .3s}

    /* TOPBAR */
    .topbar{position:fixed;top:0;left:0;width:100%;padding:16px 36px;display:flex;align-items:center;justify-content:space-between;background:var(--topbar-bg);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);z-index:100;transition:background .3s}
    .topbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--text);font-weight:700;font-size:1rem}
    .topbar-logo-img{height:30px;width:30px;object-fit:contain;border-radius:6px}
    .topbar-logo span{color:var(--g)}
    .topbar-right{display:flex;align-items:center;gap:16px}
    .topbar-back{font-size:.8rem;color:var(--text-muted);text-decoration:none;display:flex;align-items:center;gap:5px;transition:color .2s}
    .topbar-back:hover{color:var(--g)}
    .topbar-back svg{width:14px;height:14px;stroke:currentColor;fill:none}
    .theme-btn{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:7px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;color:var(--text-muted)}
    .theme-btn:hover{background:var(--surface-2);color:var(--text)}
    .theme-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
    [data-theme="dark"] .icon-moon{display:none}
    [data-theme="light"] .icon-sun{display:none}

    /* CARD */
    .card{position:relative;z-index:2;width:100%;max-width:460px;background:var(--surface);border:1px solid var(--border);border-radius:24px;backdrop-filter:blur(24px);box-shadow:var(--card-shadow);padding:40px 36px;animation:cardIn .55s cubic-bezier(.16,1,.3,1) both;transition:background .3s,border-color .3s}
    @keyframes cardIn{from{opacity:0;transform:translateY(24px) scale(.97)}to{opacity:1;transform:none}}
    .card.exit{animation:cardOut .3s cubic-bezier(.7,0,.3,1) forwards}
    @keyframes cardOut{to{opacity:0;transform:translateY(-20px) scale(.96)}}

    /* BRAND */
    .brand{display:flex;align-items:center;gap:12px;margin-bottom:28px}
    .brand-icon{width:48px;height:48px;border-radius:13px;overflow:hidden;flex-shrink:0;box-shadow:0 8px 22px rgba(62,142,62,.25);background:var(--surface-2);display:flex;align-items:center;justify-content:center}
    .brand-icon img{width:44px;height:44px;object-fit:contain;border-radius:10px}
    .brand-name{font-size:1rem;font-weight:800;color:var(--text)}
    .brand-name strong{color:var(--g)}
    .brand-sub{font-size:.68rem;color:var(--text-dim);margin-top:2px;letter-spacing:.04em}

    /* TABS */
    .tabs{display:grid;grid-template-columns:1fr 1fr;background:var(--input-bg);border-radius:10px;padding:3px;margin-bottom:26px;border:1px solid var(--border)}
    .tab{padding:8px 0;text-align:center;font-size:.82rem;font-weight:600;color:var(--tab-inactive);border-radius:8px;cursor:pointer;transition:all .25s;text-decoration:none}
    .tab.active{background:linear-gradient(135deg,var(--gd),var(--gm));color:#fff;box-shadow:0 4px 14px rgba(62,142,62,.3)}

    h1{font-size:1.5rem;font-weight:800;color:var(--text);margin-bottom:5px}
    .sub{font-size:.83rem;color:var(--text-muted);margin-bottom:24px;line-height:1.6}

    /* ROLE SELECTOR */
    .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
    .role-opt input{display:none}
    .role-opt label{display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 10px;background:var(--role-bg);border:1.5px solid var(--border);border-radius:14px;cursor:pointer;transition:all .25s;text-align:center}
    .role-opt label:hover{border-color:var(--border-focus);background:var(--role-checked)}
    .role-opt input:checked + label{border-color:var(--g);background:var(--role-checked);box-shadow:0 0 0 3px rgba(90,181,90,.1)}
    .role-icon{width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--gd),var(--gm));display:flex;align-items:center;justify-content:center}
    .role-icon svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
    .role-title{font-size:.82rem;font-weight:700;color:var(--text);transition:color .2s}
    .role-desc{font-size:.68rem;color:var(--text-dim);line-height:1.3}
    .role-opt input:checked + label .role-title{color:var(--g)}

    /* NOTE */
    .note{padding:11px 13px;border-radius:11px;margin-bottom:18px;font-size:.79rem;line-height:1.55;background:var(--note-bg);border:1px solid var(--note-border);color:var(--note-text);display:flex;align-items:flex-start;gap:9px;transition:all .3s}
    .note svg{width:15px;height:15px;stroke:var(--g);fill:none;stroke-width:2;flex-shrink:0;margin-top:1px;stroke-linecap:round;stroke-linejoin:round}

    /* SEP */
    .sep{display:flex;align-items:center;gap:11px;font-size:.67rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--sep-text);margin:18px 0 14px}
    .sep::before,.sep::after{content:'';flex:1;height:1px;background:var(--sep-line)}

    /* FIELDS */
    .field{margin-bottom:13px}
    .label{display:block;font-size:.7rem;font-weight:700;color:var(--text-muted);margin-bottom:6px;letter-spacing:.07em;text-transform:uppercase}
    .inp-wrap{position:relative}
    .inp-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--text-dim);pointer-events:none}
    .inp-icon svg{width:100%;height:100%;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
    .inp{width:100%;padding:11px 13px 11px 38px;background:var(--input-bg);border:1.5px solid var(--border);border-radius:11px;font-family:inherit;font-size:.88rem;color:var(--text);outline:none;transition:all .2s}
    .inp::placeholder{color:var(--text-dim)}
    .inp:focus{border-color:var(--border-focus);background:var(--input-focus-bg);box-shadow:0 0 0 3px rgba(90,181,90,.1)}

    .btn{width:100%;padding:13px;background:linear-gradient(135deg,var(--gd),var(--g));color:#fff;border:none;border-radius:12px;font-family:inherit;font-weight:700;font-size:.92rem;cursor:pointer;transition:all .25s;box-shadow:0 8px 26px rgba(62,142,62,.3);margin-top:8px;margin-bottom:18px}
    .btn:hover{transform:translateY(-2px);box-shadow:0 12px 34px rgba(62,142,62,.45)}
    .btn:disabled{opacity:.6;cursor:not-allowed;transform:none}

    .divider{display:flex;align-items:center;gap:11px;font-size:.7rem;font-weight:700;color:var(--divider-text);margin-bottom:16px}
    .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--divider)}

    .social-btn{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:11px;background:var(--social-bg);border:1.5px solid var(--border);border-radius:11px;font-weight:600;font-size:.84rem;cursor:pointer;text-decoration:none;color:var(--text);transition:all .2s}
    .social-btn:hover{background:var(--social-hover)}
    .social-btn svg{width:17px;height:17px;flex-shrink:0}

    .footer{text-align:center;font-size:.81rem;color:var(--text-muted);margin-top:20px}
    .footer a{color:var(--g);text-decoration:none;font-weight:600}
    .footer a:hover{text-decoration:underline}

    .alert{background:var(--err-bg);border:1px solid var(--err-border);color:var(--err-text);padding:11px 13px;border-radius:10px;font-size:.82rem;margin-bottom:16px;text-align:center}
    </style>
</head>
<body>
<div class="blob b1"></div>
<div class="blob b2"></div>

<nav class="topbar">
    <a href="{{ path('app_home') }}" class="topbar-logo">
        <img src="{{ asset('images/logo.png') }}" alt="Logo" class="topbar-logo-img">
        AgriSense <span>360</span>
    </a>
    <div class="topbar-right">
        <button class="theme-btn" id="themeBtn" aria-label="Changer le thème">
            <svg class="icon-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg class="icon-moon" viewBox="0 0 24 24"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>
        </button>
        <a href="{{ path('app_home') }}" class="topbar-back">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            Accueil
        </a>
    </div>
</nav>

<div class="card" id="card">
    <div class="brand">
        <div class="brand-icon">
            <img src="{{ asset('images/logo.png') }}" alt="Logo AgriSense">
        </div>
        <div>
            <div class="brand-name">AgriSense <strong>360</strong></div>
            <div class="brand-sub">Agriculture Intelligente</div>
        </div>
    </div>

    <div class="tabs">
        <a class="tab" href="{{ path('app_login') }}" onclick="navigate(event,this.href)">Se connecter</a>
        <a class="tab active" href="{{ path('app_register') }}">S'inscrire</a>
    </div>

    <h1>Créer un compte</h1>
    <p class="sub">Rejoignez AgriSense 360 et modernisez votre exploitation</p>

    {% if error %}<div class="alert">{{ error }}</div>{% endif %}

    <form method="post" id="regForm">
        <div class="role-grid">
            <div class="role-opt">
                <input type="radio" name="type" id="type-owner" value="owner">
                <label for="type-owner">
                    <div class="role-icon">
                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </div>
                    <span class="role-title">Propriétaire</span>
                    <span class="role-desc">Gérez votre ferme</span>
                </label>
            </div>
            <div class="role-opt">
                <input type="radio" name="type" id="type-worker" value="worker" checked>
                <label for="type-worker">
                    <div class="role-icon">
                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="2"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
                    </div>
                    <span class="role-title">Travailleur</span>
                    <span class="role-desc">Postulez aux offres</span>
                </label>
            </div>
        </div>

        <div class="note" id="regNote">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span id="noteText">Après inscription, vous pouvez parcourir les fermes disponibles et postuler en envoyant votre CV.</span>
        </div>

        <div class="sep">Informations personnelles</div>

        <div class="field">
            <label class="label" for="reg-name">Nom complet</label>
            <div class="inp-wrap">
                <span class="inp-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                <input id="reg-name" type="text" name="name" class="inp" placeholder="Votre nom complet" value="{{ app.request.request.get('name') }}" required>
            </div>
        </div>

        <div class="field">
            <label class="label" for="reg-email">Adresse email</label>
            <div class="inp-wrap">
                <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></span>
                <input id="reg-email" type="email" name="email" class="inp" placeholder="votre@email.com" value="{{ app.request.request.get('email') }}" required>
            </div>
        </div>

        <div class="sep">Mot de passe</div>

        <div class="field">
            <label class="label" for="reg-pwd">Mot de passe</label>
            <div class="inp-wrap">
                <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                <input id="reg-pwd" type="password" name="password" class="inp" placeholder="Minimum 6 caractères" required>
            </div>
        </div>

        <div class="field">
            <label class="label" for="reg-confirm">Confirmer le mot de passe</label>
            <div class="inp-wrap">
                <span class="inp-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                <input id="reg-confirm" type="password" name="confirm_password" class="inp" placeholder="Répéter le mot de passe" required>
            </div>
        </div>

        <button type="submit" class="btn" id="submitBtn">
            <span id="btnText">Créer mon compte</span>
        </button>
    </form>

    <div class="divider">ou continuer avec</div>

    <a href="{{ path('connect_google') }}" class="social-btn">
        <svg viewBox="0 0 24 24" fill="none"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Google
    </a>

    <div class="footer">
        Déjà un compte ? <a href="{{ path('app_login') }}" onclick="navigate(event,this.href)">Se connecter</a>
    </div>
</div>

<script>
(function(){var t=localStorage.getItem('agri-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();
document.getElementById('themeBtn').addEventListener('click',function(){
    var h=document.documentElement,c=h.getAttribute('data-theme'),n=c==='dark'?'light':'dark';
    h.setAttribute('data-theme',n);localStorage.setItem('agri-theme',n);
});
function navigate(e,url){e.preventDefault();var c=document.getElementById('card');c.classList.add('exit');setTimeout(function(){location.href=url;},300);}

var ownerR=document.getElementById('type-owner'),workerR=document.getElementById('type-worker');
var noteText=document.getElementById('noteText'),btnText=document.getElementById('btnText');
function updateUI(){
    var o=ownerR.checked;
    noteText.textContent=o?'Après inscription, vous configurerez votre ferme et commencerez à recevoir des candidatures.':'Après inscription, vous pouvez parcourir les fermes disponibles et postuler en envoyant votre CV.';
    btnText.textContent=o?'Créer mon compte propriétaire':'Créer mon compte travailleur';
}
ownerR.addEventListener('change',updateUI);workerR.addEventListener('change',updateUI);updateUI();
document.getElementById('regForm').addEventListener('submit',function(){
    document.getElementById('submitBtn').disabled=true;btnText.textContent='Création en cours…';
});
</script>
</body>
</html>
